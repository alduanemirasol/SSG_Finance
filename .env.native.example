# SSG Finance — Native (no Docker) Ubuntu deployment
# Copy this:  cp .env.native.example .env
# Then edit:  nano .env
# Then run:   sudo bash deploy-native.sh

# ---- Database (native MySQL on the same server) ----
DB_NAME=ssg_system
DB_USER=ssg
DB_PASSWORD=change_me_to_a_strong_password

# ---- Application ----
# Port users will reach in their browser: http://<server-ip>:APP_PORT
APP_PORT=8085
# Where the published app is installed on the server.
APP_DIR=/opt/ssg
# Linux user/group the service runs as (must be able to write wwwroot/uploads).
SERVICE_USER=www-data

# ---- SMTP / Gmail (optional) ----
# Leave SMTP_HOST blank to disable password-reset email (login still works).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
