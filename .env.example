# SSG Finance — Deployment Configuration
# Copy this:  cp .env.example .env
# Then edit:  nano .env
# Then run:   bash deploy.sh
#
# ── MySQL Manual Setup (run once before deploying) ──────────────
#    sudo mysql
#    CREATE USER 'ssg_finance'@'localhost' IDENTIFIED BY 'YourPassword!';
#    CREATE DATABASE ssg_system;
#    GRANT ALL PRIVILEGES ON ssg_system.* TO 'ssg_finance'@'localhost';
#    FLUSH PRIVILEGES;
#    EXIT;
# ─────────────────────────────────────────────────────────────────

# Required
GITHUB_TOKEN=
REPO_URL=
DB_PASSWORD=

# Optional (defaults shown)
BRANCH=main
DB_USER=ssg_finance
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ssg_system
DEPLOY_DIR=$HOME/ssg-finance
