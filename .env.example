# SSG Finance — Environment Variables
# Copy this to .env and fill in your values.
#
# For Docker deployment where MySQL runs on the host:
#   DB_HOST=host.docker.internal
#
# For native (no Docker) deployment:
#   DB_HOST=127.0.0.1

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

PORT=3000

DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=ssgfinance_db
DB_USERNAME=ssgfinance
DB_PASSWORD=#Fin@nce123
