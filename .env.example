# SSG Finance — Docker Deployment
# Copy this:  cp .env.example .env
# Then edit:  nano .env
# Then run:   bash deploy.sh

# MySQL (required)
DB_ROOT_PASSWORD=your_secure_password
MYSQL_DATABASE=ssg_system

# SMTP / Gmail (required for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
