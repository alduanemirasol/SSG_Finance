# SSG Finance — Ubuntu Deployment Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env

# --- Database ---
SSG_DB_PASSWORD=change_this_to_a_secure_password
SSG_DB_NAME=ssg_system
SSG_DB_USER=ssg_user
SSG_DB_HOST=127.0.0.1

# --- SMTP (Gmail) ---
SSG_SMTP_USER=ctuginatilanextensioncampus@gmail.com
SSG_SMTP_PASSWORD=jxbxcdkwavxthdan
SSG_SMTP_HOST=smtp.gmail.com
SSG_SMTP_PORT=587

# --- Domain (Nginx ServerName) ---
# Use your server's IP or domain name
SSG_DOMAIN=localhost

# --- Git repo (public, no auth needed) ---
SSG_REPO_URL=https://github.com/anomalyco/SSG_Finance.git
SSG_BRANCH=main

# --- Admin seed password (optional, default: admin123) ---
# SSG_ADMIN_PASSWORD=admin123
