@{
    ViewData["Title"] = "Professor Sign Up";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Professor Sign Up | SSG Finance</title>
  <link rel="icon" type="image/png" href="~/favicon.png" />
  <style>
    :root {
      color-scheme: dark;
      color: #eef2ff;
      background: #0b1410;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * { box-sizing: border-box; }
    body { margin: 0; min-height: 100vh; display: grid; place-items: center; background: radial-gradient(circle at top left, rgba(39,167,68,.18), transparent 28%), radial-gradient(circle at bottom right, rgba(64,116,242,.12), transparent 26%), #06100c; }
    a { color: #7de4a0; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .page-shell { width: min(1200px, calc(100vw - 32px)); display: grid; grid-template-columns: 1.05fr 1.3fr; gap: 32px; }
    .panel { border-radius: 24px; overflow: hidden; box-shadow: 0 30px 80px rgba(0,0,0,.35); }
    .panel.left { background: linear-gradient(180deg, rgba(13,31,18,.96), rgba(5,12,7,.99)); padding: 42px 36px; display: flex; flex-direction: column; justify-content: space-between; }
    .panel.right { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); padding: 34px; }

    .brand-logo { width: 68px; height: 68px; border-radius: 18px; background: linear-gradient(135deg, #1fa253, #28b460); display: grid; place-items: center; margin-bottom: 28px; }
    .brand-logo img { width: 42px; height: 42px; }
    .brand-title { font-size: clamp(2rem, 2.6vw, 3rem); line-height: 1.02; font-weight: 800; margin-bottom: 14px; }
    .brand-sub { max-width: 360px; color: rgba(238,242,255,.74); line-height: 1.7; margin-bottom: 28px; }
    .feature-list { display: grid; gap: 16px; }
    .feature-item { display: grid; gap: 8px; }
    .feature-item strong { display: block; color: #c5f1cf; font-size: 1rem; }
    .feature-item span { color: rgba(238,242,255,.72); line-height: 1.6; }
    .hint-box { border: 1px solid rgba(255,255,255,.08); background: rgba(255,255,255,.05); border-radius: 16px; padding: 18px 20px; color: #d2ffe9; font-size: .95rem; line-height: 1.65; }

    .form-card { display: flex; flex-direction: column; gap: 24px; }
    .form-card h1 { margin: 0; color: #f8fafc; font-size: clamp(1.9rem, 2.3vw, 2.7rem); }
    .form-card p { margin: 0; color: rgba(238,242,255,.72); line-height: 1.7; }
    .form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-group label { font-size: .88rem; color: rgba(238,242,255,.75); }
    .form-group input { width: 100%; border: 1px solid rgba(255,255,255,.12); border-radius: 14px; padding: 14px 16px; background: rgba(255,255,255,.05); color: #eef2ff; font-size: .98rem; }
    .form-group input::placeholder { color: rgba(238,242,255,.42); }
    .form-group .inline { display: inline-flex; gap: 14px; }
    .form-group .inline input { flex: 1; }
    .btn-submit { width: 100%; padding: 16px 18px; border: none; border-radius: 14px; font-size: 1rem; font-weight: 700; color: #081b0f; background: #7de4a0; cursor: pointer; transition: transform .2s ease, box-shadow .2s ease; }
    .btn-submit:hover { transform: translateY(-1px); box-shadow: 0 18px 50px rgba(125,228,160,.28); }
    .help-text { color: rgba(238,242,255,.72); font-size: .95rem; margin: 0; }
    .help-text a { font-weight: 700; }
    .status-message { min-height: 26px; color: #ffcd38; font-size: .95rem; }

    @@media (max-width: 960px) {
      .page-shell { grid-template-columns: 1fr; }
      .panel.left { order: 2; }
      .panel.right { order: 1; }
    }

    @@media (max-width: 640px) {
      body { background: #080f0a; }
      .panel.left { padding: 28px 24px; }
      .panel.right { padding: 28px 24px; }
      .form-grid { grid-template-columns: 1fr; }
      .brand-title { font-size: 2.3rem; }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <section class="panel left">
      <div>
        <div class="brand-logo">
          <img src="/images/logo.png" alt="SSG Finance" />
        </div>
        <div class="brand-title">Professor Sign Up</div>
        <div class="brand-sub">This hidden route is reserved for faculty account creation only. It does not collect any student academic profile details.</div>
        <div class="feature-list">
          <div class="feature-item">
            <strong>Secure hidden access</strong>
            <span>Only people with the exact link can reach this page.</span>
          </div>
          <div class="feature-item">
            <strong>User and account only</strong>
            <span>Only login credentials and basic profile fields are requested.</span>
          </div>
          <div class="feature-item">
            <strong>Admin approval</strong>
            <span>New professor accounts are created pending admin approval.</span>
          </div>
        </div>
      </div>
      <div class="hint-box">If you want, bookmark this URL: <strong>/proffessor_sign-up</strong>. Do not publish it publicly.</div>
    </section>

    <section class="panel right">
      <div class="form-card">
        <div>
          <h1>Register as Professor</h1>
          <p>Enter your basic account details to request a professor login.</p>
        </div>

        <div class="status-message" id="statusMessage"></div>

        <div class="form-grid">
          <div class="form-group">
            <label for="profSchoolId">School ID</label>
            <input id="profSchoolId" type="text" placeholder="Enter CTU ID" />
          </div>
          <div class="form-group">
            <label for="profEmail">Email</label>
            <input id="profEmail" type="email" placeholder="Enter email address" />
          </div>
          <div class="form-group">
            <label for="profFirstName">First Name</label>
            <input id="profFirstName" type="text" placeholder="Enter first name" />
          </div>
          <div class="form-group">
            <label for="profMiddleName">M.I.</label>
            <input id="profMiddleName" type="text" maxlength="1" placeholder="Optional" />
          </div>
          <div class="form-group">
            <label for="profLastName">Last Name</label>
            <input id="profLastName" type="text" placeholder="Enter last name" />
          </div>
          <div class="form-group">
            <label for="profPassword">Password</label>
            <input id="profPassword" type="password" placeholder="Create a password" />
          </div>
          <div class="form-group">
            <label for="profConfirmPassword">Confirm Password</label>
            <input id="profConfirmPassword" type="password" placeholder="Confirm password" />
          </div>
        </div>

        <button class="btn-submit" type="button" onclick="handleProfessorSignUp()">Create Professor Account</button>
        <p class="help-text">Already have an account? <a href="/Home/Login">Sign in</a></p>
      </div>
    </section>
  </div>

  <script>
    function showStatus(message, isError = false) {
      const status = document.getElementById('statusMessage');
      status.textContent = message || '';
      status.style.color = isError ? '#ffb3b3' : '#b9ffd5';
    }

    function validateEmail(email) {
      return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
    }

    async function handleProfessorSignUp() {
      const schoolId = document.getElementById('profSchoolId').value.trim();
      const email = document.getElementById('profEmail').value.trim();
      const firstName = document.getElementById('profFirstName').value.trim();
      const middleName = document.getElementById('profMiddleName').value.trim();
      const lastName = document.getElementById('profLastName').value.trim();
      const password = document.getElementById('profPassword').value;
      const confirmPassword = document.getElementById('profConfirmPassword').value;

      if (!schoolId || !email || !firstName || !lastName || !password || !confirmPassword) {
        showStatus('Please complete all required fields.', true);
        return;
      }
      if (!validateEmail(email)) {
        showStatus('Please enter a valid email address.', true);
        return;
      }
      if (password !== confirmPassword) {
        showStatus('Passwords do not match.', true);
        return;
      }
      if (password.length < 6) {
        showStatus('Password must be at least 6 characters.', true);
        return;
      }

      showStatus('Creating professor account, please wait...');

      try {
        const response = await fetch('/Home/Register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            schoolId,
            email,
            password,
            role: 'Professor',
            firstName,
            middleName,
            lastName
          })
        });

        const result = await response.json();
        if (result.success) {
          showStatus('Account request submitted. Please wait for admin approval.');
          document.querySelectorAll('input').forEach(i => i.value = '');
        } else {
          showStatus(result.message || 'Registration failed.', true);
        }
      } catch (error) {
        showStatus('An error occurred. Please try again.', true);
      }
    }
  </script>
</body>
</html>
