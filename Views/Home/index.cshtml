<!-- ═══════════════════════════════════════
     SCRIPTS
════════════════════════════════════════ -->
<script>
/* ── CLOCK ── */
function updateClock() {
  const now = new Date();
  let h = now.getHours();
  const m = String(now.getMinutes()).padStart(2,'0');
  const s = String(now.getSeconds()).padStart(2,'0');
  const ap = h >= 12 ? 'PM' : 'AM';
  h = h % 12 || 12;
  document.getElementById('clock').textContent = `${h}:${m}:${s} ${ap}`;
}
setInterval(updateClock, 1000);
updateClock();

/* ── AUTO-CAPITALIZE NAME FIELDS ── */
function capitalizeWords(input) {
  input.value = input.value.replace(/\b\w/g, char => char.toUpperCase());
}

document.addEventListener('DOMContentLoaded', function() {
  const nameFields = ['firstName', 'middleName', 'lastName'];
  nameFields.forEach(id => {
    const field = document.getElementById(id);
    if (field) {
      field.addEventListener('input', function() {
        capitalizeWords(this);
      });
    }
  });
});

/* ── LOGIN OPEN / CLOSE ── */
function openLogin() {
  document.body.classList.add('login-open');
  // Slight delay before fading landing so panels slide in simultaneously
  setTimeout(() => {
    document.getElementById('landingPage').classList.add('hidden');
  }, 80);
  showLeftScreen(0);
  showRightScreen('screenSignIn');
}

/**
 * When opening login on first paint (e.g. redirect from About/Contacts with ?login=1),
 * calling openLogin() in the same turn as DOMContentLoaded skips transforms because the
 * engine never composites an intermediate frame. Wait for layout + paint first.
 */
function openLoginAfterReadyForTransition(done) {
  const run = typeof done === 'function' ? done : openLogin;
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      const overlay = document.getElementById('loginOverlay');
      if (overlay) void overlay.offsetWidth;
      run();
    });
  });
}

function showLandingPage() {
  // Close login if open
  if (document.body.classList.contains('login-open')) {
    closeLogin();
  }
  // Show landing page content
  document.getElementById('landingPage').classList.remove('hidden');
}

function setActiveNav(clickedElement) {
  document.querySelectorAll('.nav-links a').forEach(link => {
    link.classList.remove('active');
  });
  clickedElement.classList.add('active');
}

function closeLogin() {
  document.getElementById('landingPage').classList.remove('hidden');
  document.body.classList.remove('login-open');
  // Reset active nav highlight back to Home
  const homeLink = document.querySelector('#mobileNav a:first-child');
  if (homeLink) setActiveNav(homeLink);
}

/* Close on Escape key */
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && document.body.classList.contains('login-open')) closeLogin();
});

/* ── LEFT PANEL SCREENS ── */
function showLeftScreen(idx) {
  document.querySelectorAll('.lp-screen').forEach((s,i) => {
    s.classList.toggle('active', i === idx);
  });
}

/* ── RIGHT PANEL SCREENS ── */
function showRightScreen(id) {
  document.querySelectorAll('.rp-screen').forEach(s => {
    s.classList.remove('active');
    s.style.display = 'none';
  });
  const el = document.getElementById(id);
  if (el) { el.style.display = 'flex'; requestAnimationFrame(() => el.classList.add('active')); }
}

/* ── NAV HELPERS ── */
function goToSignUp()         { showLeftScreen(1); showRightScreen('screenSignUp'); }
function goToSignIn()         { showLeftScreen(0); showRightScreen('screenSignIn'); }
function goToForgotPassword() { showLeftScreen(2); showRightScreen('screenForgot'); }

/* ── MOBILE NAV ── */
function toggleMobileNav() {
  const burger = document.querySelector('.burger-menu');
  const nav = document.getElementById('mobileNav');
  burger.classList.toggle('active');
  nav.classList.toggle('active');
}
function closeMobileNav() {
  const burger = document.querySelector('.burger-menu');
  const nav = document.getElementById('mobileNav');
  burger.classList.remove('active');
  nav.classList.remove('active');
}

function goToCodeVerification() {
  showLeftScreen(2);
  showRightScreen('screenCodeVerification');
}
function goToResetPassword() { showRightScreen('screenResetPassword'); }
function goToForgot()        { showRightScreen('screenForgot'); }

/* ── AUTH HANDLERS ── */
function handleSignIn() {
  const schoolId = document.querySelector('input[name="schoolId"]').value;
  const password = document.querySelector('input[name="password"]').value;

  if (!schoolId || !password) { alert('Please enter your CTU ID and password'); return; }

  const btn = event.target;
  const orig = btn.textContent;
  btn.textContent = 'Signing in...';
  btn.disabled = true;

  fetch('/Home/Login', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ schoolId, password })
  })
  .then(r => r.json())
  .then(data => {
    if (data && data.success) {
      localStorage.setItem('currentUser', JSON.stringify(data.user));
      // Redirect only when backend explicitly says success=true
      const target = data.redirectUrl || '/Home/Dashboard';
      window.location.href = target;
      return;
    }

    alert(`Login failed: ${data?.message || 'Unknown error'}`);
    btn.textContent = orig;
    btn.disabled = false;
  })
  .catch(() => { alert('An error occurred. Please try again.'); btn.textContent = orig; btn.disabled = false; });
}

// Stores the validated payload while waiting for OTP confirmation
window._pendingSignUpPayload = null;

/* ── SIGNUP FIELD HELPERS ── */
function setSignupFieldError(id, hasError) {
    const field = document.getElementById(id);
    if (!field) return;
    if (hasError) {
        field.style.borderColor = '#ef4444';
        field.style.background  = '#fef2f2';
    } else {
        field.style.borderColor = '';
        field.style.background  = '';
    }
}

function clearSignupErrors() {
    ['studentId','password','confirmPassword','firstName','lastName',
     'email','course','yearLevel','section','schoolYear','semesterEntered']
    .forEach(id => setSignupFieldError(id, false));
    const el = document.getElementById('signup-status');
    if (el) el.style.display = 'none';
}

function showSignupStatus(message, type) {
    const el = document.getElementById('signup-status');
    if (!el) return;
    el.textContent = message;
    el.style.display = 'block';
    if (type === 'fail') {
        el.style.background  = '#fef2f2';
        el.style.color       = '#991b1b';
        el.style.border      = '1px solid #fecaca';
    } else {
        el.style.background  = '#f0fdf4';
        el.style.color       = '#166534';
        el.style.border      = '1px solid #bbf7d0';
    }
    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function handleSignUp() {
    clearSignupErrors();

    const firstName       = document.getElementById('firstName')?.value.trim() || '';
    const lastName        = document.getElementById('lastName')?.value.trim() || '';
    const middleName      = document.getElementById('middleName')?.value.trim() || '';
    const email           = document.getElementById('email')?.value.trim() || '';
    const password        = document.getElementById('password')?.value || '';
    const confirmPassword = document.getElementById('confirmPassword')?.value || '';
    const course          = document.getElementById('course')?.value || '';
    const schoolYear      = document.getElementById('schoolYear')?.value || '';
    const semesterEntered = document.getElementById('semesterEntered')?.value || '';
    const section         = document.getElementById('section')?.value.trim() || '';
    const yearLevel       = document.getElementById('yearLevel')?.value || '';
    const studentId       = document.getElementById('studentId')?.value.trim() || '';
    const schoolId        = studentId || `STU-${Date.now()}`;

    let hasError = false;

    /* ── Required fields ── */
    if (!studentId)   { setSignupFieldError('studentId', true);   hasError = true; }
    if (!firstName)   { setSignupFieldError('firstName', true);   hasError = true; }
    if (!lastName)    { setSignupFieldError('lastName', true);    hasError = true; }

    if (!email) {
        setSignupFieldError('email', true);
        hasError = true;
    } else if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
        setSignupFieldError('email', true);
        showSignupStatus('Please enter a valid email address.', 'fail');
        return;
    }

    if (!password) {
        setSignupFieldError('password', true);
        hasError = true;
    } else if (
        password.length < 8 ||
        !/[A-Z]/.test(password) ||
        !/[a-z]/.test(password) ||
        !/[0-9]/.test(password) ||
        !/[^A-Za-z0-9]/.test(password) ||
        /\s/.test(password)
    ) {
        setSignupFieldError('password', true);
        showSignupStatus('Password must be at least 8 characters and include uppercase, lowercase, a number, and a special character.', 'fail');
        return;
    }

    if (!confirmPassword) {
        setSignupFieldError('confirmPassword', true);
        hasError = true;
    } else if (password !== confirmPassword) {
        setSignupFieldError('confirmPassword', true);
        showSignupStatus('Passwords do not match.', 'fail');
        return;
    }

    /* ── School information ── */
    if (!course)          { setSignupFieldError('course', true);          hasError = true; }
    if (!yearLevel)       { setSignupFieldError('yearLevel', true);       hasError = true; }
    if (!section)         { setSignupFieldError('section', true);         hasError = true; }
    if (!schoolYear)      { setSignupFieldError('schoolYear', true);      hasError = true; }
    if (!semesterEntered) { setSignupFieldError('semesterEntered', true); hasError = true; }

    if (hasError) {
        showSignupStatus('Please fill in all required fields.', 'fail');
        return;
    }

    /* ── Clear errors on input ── */
    ['studentId','password','confirmPassword','firstName','lastName',
     'email','course','yearLevel','section','schoolYear','semesterEntered']
    .forEach(id => {
        document.getElementById(id)?.addEventListener('input', () => {
            setSignupFieldError(id, false);
        }, { once: true });
    });

    /* ── Store payload and send OTP ── */
    window._pendingSignUpPayload = {
        schoolId, firstName, lastName, middleName, email,
        password, role: 'Student',
        courseCode: course,
        schoolYearId: schoolYear ? parseInt(schoolYear) : null,
        semesterEntered: semesterEntered || null,
        yearLevel: yearLevel ? parseInt(yearLevel) : null,
        section, studentId
    };

    sendSignupOTP(email);
}

function updatePasswordChecklist(pw) {
  const rules = {
    len:     pw.length >= 8 && !/\s/.test(pw),
    upper:   /[A-Z]/.test(pw),
    lower:   /[a-z]/.test(pw),
    digit:   /[0-9]/.test(pw),
    special: /[^A-Za-z0-9]/.test(pw)
  };
  const list = document.getElementById('password-checklist');
  if (!list) return;
  Object.keys(rules).forEach(key => {
  const li = list.querySelector(`[data-rule="${key}"]`);
  if (!li) return;
  const ok = rules[key];
  const text = li.textContent.replace(/^[•✓]\s*/, '');
  li.textContent = (ok ? '✓ ' : '• ') + text;
  li.style.color = ok ? '#27a744' : '#9aa';
  });
}


function sendSignupOTP(email) {
  const btn = document.querySelector('#screenSignUp .submit-btn');
  const orig = btn ? btn.textContent : '';
  if (btn) { btn.textContent = 'Sending Code…'; btn.disabled = true; }

  fetch('/Home/SendEmailOTP', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email })
  })
  .then(r => r.json())
  .then(data => {
    if (data.success) {
      document.getElementById('otpEmailDisplay').textContent = email;
      showLeftScreen(1);
      showRightScreen('screenEmailOTP');
      document.getElementById('signupOtpCode').value = '';
      document.getElementById('signupOtpCode').focus();
    } else {
      alert(`Could not send code: ${data.message}`);
    }
  })
  .catch(() => alert('An error occurred. Please try again.'))
  .finally(() => { if (btn) { btn.textContent = orig; btn.disabled = false; } });
}

function resendSignupOTP() {
  const payload = window._pendingSignUpPayload;
  if (!payload?.email) { goToSignUp(); return; }
  sendSignupOTP(payload.email);
}

function handleEmailOTPVerify() {
  const code    = document.getElementById('signupOtpCode').value.trim();
  const payload = window._pendingSignUpPayload;

  if (!payload) { alert('Session expired. Please fill the form again.'); goToSignUp(); return; }
  if (!code || code.length !== 6) { alert('Please enter the 6-digit code'); return; }

  const btn  = event.target;
  const orig = btn.textContent;
  btn.textContent = 'Verifying…'; btn.disabled = true;

  // Verify OTP first, then register
  fetch('/Home/VerifyEmailOTP', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: payload.email, code })
  })
  .then(r => r.json())
  .then(data => {
    if (!data.success) {
      alert(`Verification failed: ${data.message}`);
      btn.textContent = orig; btn.disabled = false;
      return;
    }
    // OTP confirmed — now register
    return fetch('/Home/Register', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(r => r.json())
    .then(regData => {
      if (regData.success) {
        alert(`Account created! ${regData.message}`);
        window._pendingSignUpPayload = null;
        document.querySelectorAll('.form-input').forEach(i => i.value = '');
        goToSignIn();
      } else {
        alert(`Registration failed: ${regData.message}`);
        btn.textContent = orig; btn.disabled = false;
      }
    });
  })
  .catch(() => { alert('An error occurred. Please try again.'); btn.textContent = orig; btn.disabled = false; });
}



function handleForgotPassword() {
  const studentId = document.getElementById('forgotStudentId').value;
  if (!studentId) { alert('Please enter your student ID'); return; }

  const btn = event.target; const orig = btn.textContent;
  btn.textContent = 'Sending...'; btn.disabled = true;

  fetch('/Home/ForgotPassword', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ studentId })
  })
  .then(r => r.json())
  .then(data => {
    if (data.success) {
      alert(data.message);
      window.forgotStudentId = data.studentId;
      document.getElementById('forgotStudentId').value = '';
      goToCodeVerification();
    } else {
      alert(`Failed: ${data.message}`);
      btn.textContent = orig; btn.disabled = false;
    }
  })
  .catch(() => { alert('An error occurred. Please try again.'); btn.textContent = orig; btn.disabled = false; });
}


function handleVerifyCode() {
  const code = document.getElementById('verificationCode').value;
  const studentId = window.forgotStudentId;

  if (!code) { alert('Please enter the verification code'); return; }
  if (code.length !== 6) { alert('Verification code must be 6 digits'); return; }

  const btn = event.target; const orig = btn.textContent;
  btn.textContent = 'Verifying...'; btn.disabled = true;

  fetch('/Home/VerifyResetCode', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ studentId, code })
  })
  .then(r => r.json())
  .then(data => {
    if (data.success) {
      alert(data.message);
      window.verifiedStudentId = studentId;
      goToResetPassword();
    } else {
      alert(`Failed: ${data.message}`);
      btn.textContent = orig; btn.disabled = false;
    }
  })
  .catch(() => { alert('An error occurred. Please try again.'); btn.textContent = orig; btn.disabled = false; });
}

function handleResetPassword() {
  const newPassword     = document.getElementById('newPassword')?.value;
  const confirmPassword = document.getElementById('confirmNewPassword')?.value;
  const studentId       = window.verifiedStudentId;

  if (!studentId) { alert('Session expired. Please start over.'); goToForgot(); return; }
  if (!newPassword) { alert('Please enter a new password'); return; }
  if (newPassword.length < 6) { alert('Password must be at least 6 characters'); return; }
  if (newPassword !== confirmPassword) { alert('Passwords do not match'); return; }

  const btn = event.target; const orig = btn.textContent;
  btn.textContent = 'Resetting...'; btn.disabled = true;

  fetch('/Home/ResetPassword', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ token:'verified', studentId, newPassword })
  })
  .then(r => r.json())
  .then(data => {
    if (data.success) {
      alert(data.message);
      document.getElementById('newPassword').value = '';
      document.getElementById('confirmNewPassword').value = '';
      goToSignIn();
    } else {
      alert(`Failed: ${data.message}`);
      btn.textContent = orig; btn.disabled = false;
    }
  })
  .catch(() => { alert('An error occurred. Please try again.'); btn.textContent = orig; btn.disabled = false; });
}

/* ── LOAD COURSES ── */
async function loadCourses() {
  try {
    const r = await fetch('/Home/GetCourses');
    const data = await r.json();
    if (data.success) {
      const sel = document.getElementById('course');
      sel.innerHTML = '<option value="">Select a course</option>';
      data.courses.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.courseCode;
        opt.textContent = c.courseName ? `${c.courseCode} - ${c.courseName}` : c.courseCode;
        sel.appendChild(opt);
      });
    }
  } catch(e) { console.error('Error loading courses:', e); }
}

async function loadSchoolYears() {
  try {
    const r = await fetch('/Home/GetSchoolYears');
    const data = await r.json();
    if (data.success) {
      const sel = document.getElementById('schoolYear');
      sel.innerHTML = '<option value="">Select school year</option>';
      data.schoolYears.forEach(sy => {
        const opt = document.createElement('option');
        opt.value = sy.schoolYearId ?? sy.SchoolYearId;
        const yearStart = sy.yearStart ?? sy.YearStart;
        const yearEnd = sy.yearEnd ?? sy.YearEnd;
        opt.textContent = `A.Y. ${yearStart}-${yearEnd}`;
        sel.appendChild(opt);
      });
    }
  } catch(e) { console.error('Error loading school years:', e); }
}

function togglePasswordVisibility(btn){
  if(!btn) return;
  const targetSel = btn.getAttribute('data-toggle-target');
  if(!targetSel) return;
  const input = targetSel.startsWith('input[')
    ? document.querySelector(targetSel)
    : document.querySelector(targetSel);

  if(!input) return;

  const isPassword = input.type === 'password';
  input.type = isPassword ? 'text' : 'password';

  const icon = btn.querySelector('ion-icon');
  if(icon){
    icon.setAttribute('name', isPassword ? 'eye-off' : 'eye');
  }

  btn.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
}

document.addEventListener('DOMContentLoaded', function() {
  loadCourses();
  loadSchoolYears();


  /* About/Contacts navbar uses /Home/Login, which redirects here with ?login=1 */
  (function openLoginFromDeepLink() {
    const params = new URLSearchParams(window.location.search);
    const loginParam = params.get('login');
    const wantsLogin =
      (loginParam != null && /^(1|true|yes)$/i.test(String(loginParam))) ||
      window.location.hash === '#login';
    if (!wantsLogin) return;
    openLoginAfterReadyForTransition(openLogin);
    const url = new URL(window.location.href);
    url.searchParams.delete('login');
    if (url.hash === '#login') url.hash = '';
    const q = url.searchParams.toString();
    window.history.replaceState({}, '', url.pathname + (q ? '?' + q : '') + url.hash);
  })();

  /**
   * LOGOUT HANDLER
   * Detects logout parameter and manages history to prevent back-button access to protected pages
   * - Cleans up history entries created during logout process
   * - Ensures back button from login page exits/closes the browser naturally
   */
  (function handleLogoutRedirect() {
    const params = new URLSearchParams(window.location.search);
    const isLogoutRedirect = params.get('logout') === '1' || params.get('auth') === 'required';
    
    if (!isLogoutRedirect) return;

    // Check if we came from the logout page's sessionStorage flag
    const logoutTimestamp = sessionStorage.getItem('ssg_logout_timestamp');
    const logoutActive = sessionStorage.getItem('ssg_logout_active');
    
    if (logoutActive === 'true' && logoutTimestamp) {
      // This is a confirmed logout redirect - clean up the sessionStorage
      sessionStorage.removeItem('ssg_logout_active');
      sessionStorage.removeItem('ssg_logout_timestamp');
      
      // Replace the current history entry to remove the logout parameter from URL
      // This makes the URL clean for the user, and prepares for natural back-button behavior
      const cleanUrl = window.location.pathname + (window.location.hash || '');
      try {
        // Try to replace the current entry with the clean URL
        window.history.replaceState({ logoutProcessed: true }, '', cleanUrl);
        
        // If this was the result of a back button navigation (detected via persisted state),
        // we might want to push an additional state to create a "dead end"
        if (window.history.state && window.history.state.logoutProcessed) {
          // Push a state that will prevent further back navigation to protected pages
          window.history.pushState({ loginEntry: true }, '', cleanUrl);
        }
      } catch (e) {
        // Fallback: just navigate to clean URL
        window.location.replace(cleanUrl);
      }
    } else {
      // Direct navigation with logout param (not from logout page) - just clean the URL
      const cleanUrl = window.location.pathname + (window.location.hash || '');
      window.history.replaceState({}, '', cleanUrl);
    }
    
    // Clear any remaining auth-related session storage
    sessionStorage.removeItem('ssg_last_auth_check');
    sessionStorage.removeItem('ssg_last_auth_result');
  })();

  // First nav `<a>` is Home — highlight when not opening login from deep link
  const mobileNavEl = document.getElementById('mobileNav');
  const homeNavLink = mobileNavEl?.querySelector('a');
  if (homeNavLink && !document.body.classList.contains('login-open')) {
    setActiveNav(homeNavLink);
  }

  // Close mobile nav when clicking outside
  document.addEventListener('click', function(e) {
    const nav = document.getElementById('mobileNav');
    const burger = document.querySelector('.burger-menu');
    if (nav && burger && nav.classList.contains('active')) {
      if (!nav.contains(e.target) && !burger.contains(e.target)) {
        closeMobileNav();
      }
    }
  });
});
</script>
