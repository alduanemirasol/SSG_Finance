// AUTO-REFRESH SYSTEM — Treasurer Dashboard (Clean Version)
// Only triggers on confirmed DB-write buttons
// ================================================================

const TREASURER_REFRESH_MAP = [
    { match: el => el.textContent.trim() === 'Save Payment',    pages: ['dashboard','history','income','students'] },
    { match: el => el.textContent.trim() === 'Save Fund',       pages: ['dashboard','history','income'] },
    { match: el => el.textContent.trim() === 'Save Expense',    pages: ['dashboard','history','expenses'] },
    { match: el => el.textContent.trim() === 'Save Changes',    pages: ['dashboard','history','income','students'] },
    { match: el => el.classList.contains('btn-danger'),         pages: ['dashboard','history','income','expenses','settings'] },
    { match: el => el.classList.contains('danger'),             pages: ['dashboard','history','income','expenses','settings'] },
    { match: el => el.textContent.trim() === 'Add School Year', pages: ['settings'] },
    { match: el => el.textContent.trim() === 'Add Course',      pages: ['settings'] },
    { match: el => el.textContent.trim() === 'Set Fee Amount',  pages: ['settings','income'] },
    { match: el => el.textContent.trim() === 'Save Signature',  pages: ['settings'] },
    { match: el => el.textContent.trim() === 'Edit Amount',     pages: ['settings'] },
    { match: el => el.textContent.trim().includes('Mark as') || el.textContent.trim().includes('Set as'), pages: ['settings'] },
];

async function refreshTreasurerPages(pages) {
    const activePage = document.querySelector('.page.active');
    const activePageId = activePage?.id?.replace('page-', '') ?? '';

    for (const page of pages) {
        if (page !== activePageId && page !== 'dashboard') continue;

        switch (page) {
            case 'dashboard':
                await Promise.all([
                    loadOrgFeePayments(),
                    loadOtherFunds(),
                    loadExpenses()
                ]);
                await renderDashboard();
                renderCharts();
                await loadStudentsPage();
                break;
            case 'history':
                await renderHistory();
                break;
            case 'students':
                await loadStudentsPage();
                break;
            case 'income':
                await renderIncome();
                break;
            case 'expenses':
                await renderExpenses();
                break;
            case 'settings':
                const activePanel = document.querySelector('.settings-panel.active');
                if (!activePanel) break;
                const panelId = activePanel.id.replace('settings-', '');
                if (panelId === 'sy')        await refreshSchoolYears();
                if (panelId === 'courses')   await refreshCourses();
                if (panelId === 'fees')      await refreshFees();
                if (panelId === 'signature') await refreshSignature();
                break;
        }
    }
}

document.addEventListener('click', async function(e) {
    const target = e.target.closest('button, .dropdown-item, .btn-danger');
    if (!target) return;

    const rule = TREASURER_REFRESH_MAP.find(r => r.match(target));
    if (!rule) return;

    setTimeout(async () => {
        await refreshTreasurerPages(rule.pages);
    }, 700);

}, true);

