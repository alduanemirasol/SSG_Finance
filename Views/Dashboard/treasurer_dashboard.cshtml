  <!-- STUDENTS -->
  <!-- INCOME -->
  <div class="page" id="page-income">
    <div class="page-hdr" style="justify-content:center;text-align:center">
      <div><div class="page-title">Record Payment</div><div class="page-sub">Record student fees and other receivable funds</div></div>
    </div>

    <!-- TYPE TABS -->
