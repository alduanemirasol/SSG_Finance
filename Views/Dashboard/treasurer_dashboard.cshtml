async function loadAvailableSemesters() {
    try {
        const res  = await fetch('/Home/GetAvailableSemesters');
        const data = await res.json();
        const sel  = document.getElementById('of-sem');

        if (!data.success || !data.fees.length) {
            sel.innerHTML = '<option value="">No semesters with fees set</option>';
            return;
        }

        sel.innerHTML = data.fees.map(f => {
            const semLabel    = f.semester === 'First' ? '1st' : '2nd';
            const statusColor = f.semesterStatus === 'Current' ? '#5fdd8e' : '#fbbf24';
            return `<option value="${f.semester}"
                            data-full-amount-id="${f.fullAmountId}"
                            data-year-start="${f.yearStart}"
                            data-year-end="${f.yearEnd}"
                            data-amount="${f.amount}"
                            data-status="${f.semesterStatus}">
                        ${f.yearStart}–${f.yearEnd} · ${semLabel} Semester · ${f.semesterStatus}
                    </option>`;
        }).join('');

        // ── AUTO-SELECT the Current semester ──
        const currentIndex = data.fees.findIndex(f => f.semesterStatus === 'Current');
        if (currentIndex !== -1) sel.selectedIndex = currentIndex;

        // Trigger status label update
        updateSemesterStatusLabel();
