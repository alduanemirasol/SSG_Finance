<script>
function resetDropdownPos(menu) {
  menu.style.position = '';
  menu.style.top = '';
  menu.style.left = '';
  menu.style.right = '';
  menu.style.bottom = '';
}
function closeAllDropdowns() {
  document.querySelectorAll('.dropdown-menu.open').forEach(m => { m.classList.remove('open'); resetDropdownPos(m); });
}
function toggleDropdown(btn) {
  const menu = btn.nextElementSibling;
  const willOpen = !menu.classList.contains('open');
  closeAllDropdowns();
  if (!willOpen) return;
  menu.classList.add('open');
  // Position as fixed so the menu can escape scrollable table containers
  const r = btn.getBoundingClientRect();
  menu.style.position = 'fixed';
  menu.style.left = 'auto';
  menu.style.right = (window.innerWidth - r.right) + 'px';
  const mh = menu.offsetHeight || 200;
  if (r.bottom + mh + 8 > window.innerHeight) {
    // not enough room below — open upward
    menu.style.top = 'auto';
    menu.style.bottom = (window.innerHeight - r.top + 4) + 'px';
  } else {
    menu.style.bottom = 'auto';
    menu.style.top = (r.bottom + 4) + 'px';
  }
}

// close dropdowns when clicking outside
document.addEventListener('click', e => {
  if (!e.target.closest('.dropdown-wrap')) closeAllDropdowns();
});
// close dropdowns on any scroll so the fixed menus don't detach from their row
document.addEventListener('scroll', closeAllDropdowns, true);

