async function downloadTreasurerReceiptPDF() {
  const receiptEl = document.getElementById('trReceiptPaper');
  const receiptNo = (document.getElementById('tr-rp-receipt-no')?.textContent || 'receipt')
    .replace(/[^\w-]+/g, '-')
    .replace(/^-+|-+$/g, '');

  showToast('Generating PDF...', 'ok');
  try {
    const canvas = await html2canvas(receiptEl, {
      scale: 2,
      useCORS: true,
      backgroundColor: '#f9f8f5',
      logging: false
    });

    const imgData = canvas.toDataURL('image/png');
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF({
      orientation: 'portrait',
      unit: 'mm',
      format: [216, 330]
    });

    const pageWidth = pdf.internal.pageSize.getWidth();
    const pageHeight = pdf.internal.pageSize.getHeight();
    const margin = 8;
    const imgWidth = pageWidth - margin * 2;
    const imgHeight = (canvas.height * imgWidth) / canvas.width;

    pdf.addImage(imgData, 'PNG', margin, margin, imgWidth, Math.min(imgHeight, pageHeight - margin * 2));
    pdf.save(`SSG-Receipt-${receiptNo}.pdf`);
    showToast('PDF downloaded successfully.', 'ok');
  } catch (err) {
    console.error('Failed to export receipt PDF:', err);
    showToast('Failed to generate PDF.', 'fail');
  }
}

function editIncome(type, id) {
  document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));

  if (type === 'OrgFee') {
    const fee = DB.orgFees.find(f => f.id === id);
    if (!fee) { showToast('Record not found.', 'fail'); return; }

    document.getElementById('edit-orgfee-id').value          = fee.id;
    document.getElementById('edit-orgfee-amount').value      = fee.amt;
    document.getElementById('edit-orgfee-receipt').value     = fee.receipt || '';
    document.getElementById('edit-orgfee-sub').textContent   = fee.name + ' — ' + fee.sem;

    document.getElementById('edit-orgfee-full-amount').value = REQ_FEE;

    checkEditPaymentStatus();
    openModal('modal-edit-orgfee');

  } else {
    // OtherFund — find record and open the fund modal pre-filled
    const fund = DB.funds.find(f => f.id === id);
    if (!fund) { showToast('Record not found.', 'fail'); return; }
    document.getElementById('fn-source').value = fund.source || '';
    document.getElementById('fn-desc').value   = fund.desc  || '';
    document.getElementById('fn-amount').value = fund.amt   || '';
    document.getElementById('fn-date').value   = fund.date  || today();
    openModal('modal-fund');
    document.querySelector('#modal-fund .btn-primary').setAttribute('data-edit-id', id);
    document.querySelector('#modal-fund .btn-primary').onclick = () => updateFund(id);
  }
}

function checkEditPaymentStatus() {
  const amt      = parseFloat(document.getElementById('edit-orgfee-amount').value) || 0;
  const required = parseFloat(document.getElementById('edit-orgfee-full-amount').value) || REQ_FEE;
  const el       = document.getElementById('edit-orgfee-status');

  if (!amt) {
    el.textContent = 'Enter amount to determine status';
    el.style.color = '#5fdd8e';
    el.style.background = 'rgba(39,167,68,.08)';
    el.style.borderColor = 'rgba(39,167,68,.15)';
    return;
  }
  if (amt >= required) {
    el.textContent = '✓ Full payment — Status: Paid';
    el.style.color = '#5fdd8e';
    el.style.background = 'rgba(39,167,68,.08)';
    el.style.borderColor = 'rgba(39,167,68,.15)';
  } else {
    el.textContent = '⚠ Partial — ₱' + amt.toFixed(2) + ' of ₱' + required.toFixed(2);
    el.style.color = '#fbbf24';
    el.style.background = 'rgba(251,191,36,.08)';
    el.style.borderColor = 'rgba(251,191,36,.15)';
  }
}

async function saveEditedOrgFee() {
  const id            = parseInt(document.getElementById('edit-orgfee-id').value);
  const amount        = parseFloat(document.getElementById('edit-orgfee-amount').value) || 0;
  const fullAmount    = parseFloat(document.getElementById('edit-orgfee-full-amount').value) || REQ_FEE;
  const receiptNumber = document.getElementById('edit-orgfee-receipt').value.trim();

  if (!amount) { showToast('Enter a valid amount.', 'fail'); return; }

  try {
    const res = await fetch('/Home/UpdateOrgFeePayment', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body: JSON.stringify({ id, amount, fullAmount, receiptNumber })
    });
    const data = await res.json();
    if (data.success) {
      closeModal('modal-edit-orgfee');
      await loadOrgFeePayments();
      await renderIncome();
      await renderHistory();
      await renderDashboard();
      showToast('Payment updated successfully.', 'ok');
      // If the edit was launched from the student org-fee modal, reopen it with fresh data.
      if (window._currentOrgFeeUserId) {
        openStudentOrgFeeModal(window._currentOrgFeeUserId);
      }
    } else {
      showToast(data.message || 'Failed to update.', 'fail');
    }
  } catch {
    showToast('Request failed.', 'fail');
  }
}

async function updateFund(id) {
  const source = document.getElementById('fn-source').value.trim();
  const desc   = document.getElementById('fn-desc').value.trim();
  const amt    = parseFloat(document.getElementById('fn-amount').value) || 0;
  const date   = document.getElementById('fn-date').value || today();
  if (!desc || !amt) { showToast('Description and amount are required.', 'fail'); return; }

  try {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const res = await fetch('/Home/UpdateOtherFund', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
      body: JSON.stringify({ id, source, description: desc, amount: amt, receivedDate: new Date(date).toISOString() })
    });
    const data = await res.json();
    if (data.success) {
      closeModal('modal-fund');
      // Reset modal button back to save mode
      document.querySelector('#modal-fund .btn-primary').onclick = saveFund;
      await renderIncome();
      await renderDashboard();
      showToast('Fund updated successfully.', 'ok');
    } else {
      showToast(data.message || 'Failed to update.', 'fail');
    }
  } catch {
    showToast('Request failed.', 'fail');
  }
}

function editTransaction(src, id) {
  document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));

  if (src === 'OrgFee') {
    showToast('To edit an org fee payment, delete and re-record it.', 'fail');

  } else if (src === 'OtherFund') {
    const fund = DB.funds.find(f => f.id === id);
    if (!fund) { showToast('Record not found.', 'fail'); return; }
    document.getElementById('fn-source').value = fund.source || '';
    document.getElementById('fn-desc').value   = fund.desc   || '';
    document.getElementById('fn-amount').value = fund.amt    || '';
    document.getElementById('fn-date').value   = fund.date   || today();
    openModal('modal-fund');
    document.querySelector('#modal-fund .btn-primary').onclick = () => updateFund(id);

  } else if (src === 'Expense') {
    const exp = DB.expenses.find(e => e.id === id);
    if (!exp) { showToast('Record not found.', 'fail'); return; }
    document.getElementById('ex-desc').value   = exp.desc || '';
    document.getElementById('ex-amount').value = exp.amt  || '';
    document.getElementById('ex-date').value   = exp.date || today();
    openModal('modal-expense');
    document.querySelector('#modal-expense .btn-primary').onclick = () => updateExpense(id);
  }
}

async function updateExpense(id) {
  const desc = document.getElementById('ex-desc').value.trim();
  const amt  = parseFloat(document.getElementById('ex-amount').value) || 0;
  const date = document.getElementById('ex-date').value || today();
  if (!desc || !amt) { showToast('Description and amount are required.', 'fail'); return; }

  try {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const res = await fetch('/Home/UpdateExpense', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
      body: JSON.stringify({ id, description: desc, amount: amt, expenseDate: new Date(date).toISOString() })
    });
    const data = await res.json();
    if (data.success) {
      closeModal('modal-expense');
      // Reset modal button back to save mode
      document.querySelector('#modal-expense .btn-primary').onclick = saveExpense;
      await renderHistory();
      await renderExpenses();
      await renderDashboard();
      showToast('Expense updated successfully.', 'ok');
    } else {
      showToast(data.message || 'Failed to update.', 'fail');
    }
  } catch {
    showToast('Request failed.', 'fail');
  }
}

function editSchoolYear(id, yearStart, yearEnd, firstStart, firstEnd, secondStart, secondEnd) {
  document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
  document.getElementById('edit-sy-id').value          = id;
  document.getElementById('edit-sy-yearStart').value   = yearStart;
  document.getElementById('edit-sy-yearEnd').value     = yearEnd;
  document.getElementById('edit-sy-sub').textContent   = `A.Y. ${yearStart}–${yearEnd}`;
  // Convert ISO date strings to yyyy-mm-dd for date inputs
  const toInput = d => d ? d.split('T')[0] : '';
  document.getElementById('edit-sy-first-start').value  = toInput(firstStart);
  document.getElementById('edit-sy-first-end').value    = toInput(firstEnd);
  document.getElementById('edit-sy-second-start').value = toInput(secondStart);
  document.getElementById('edit-sy-second-end').value   = toInput(secondEnd);
  openModal('modal-edit-sy');
}

async function saveEditedSchoolYear() {
  const id          = parseInt(document.getElementById('edit-sy-id').value);
  const firstStart  = document.getElementById('edit-sy-first-start').value  || null;
  const firstEnd    = document.getElementById('edit-sy-first-end').value    || null;
  const secondStart = document.getElementById('edit-sy-second-start').value || null;
  const secondEnd   = document.getElementById('edit-sy-second-end').value   || null;

  try {
    const res  = await fetch('/Home/UpdateSchoolYearDates', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body:    JSON.stringify({
        schoolYearId:   id,
        firstSemStart:  firstStart  ? new Date(firstStart).toISOString()  : null,
        firstSemEnd:    firstEnd    ? new Date(firstEnd).toISOString()    : null,
        secondSemStart: secondStart ? new Date(secondStart).toISOString() : null,
        secondSemEnd:   secondEnd   ? new Date(secondEnd).toISOString()   : null
      })
    });
    const data = await res.json();
    if (data.success) {
      closeModal('modal-edit-sy');
      showToast(data.message, 'ok');
      await refreshSchoolYears();
    } else {
      showToast(data.message, 'fail');
    }
  } catch { showToast('Request failed.', 'fail'); }
}

// ── INIT ─────────────────────────────────────────────────────────
async function init() {
  await loadCurrentSemesterInfo();
  await Promise.all([
    loadOrgFeePayments(),
    loadOtherFunds(),
    loadExpenses()
  ]);
  await renderDashboard();
  await loadStudents();
  await populateFeeSySemDropdown();
  await populateChartSchoolYears();
  setTimeout(renderCharts, 200);
  await refreshDashboardStats();
  await loadStudentsPage();
}

init();

// ================================================================
// AUTO-REFRESH SYSTEM — Treasurer Dashboard (Clean Version)
// Only triggers on confirmed DB-write buttons
// ================================================================

const TREASURER_REFRESH_MAP = [
    { match: el => el.textContent.trim() === 'Save Payment',    pages: ['dashboard','history','income','students'] },
    { match: el => el.textContent.trim() === 'Save Fund',       pages: ['dashboard','history','income'] },
    { match: el => el.textContent.trim() === 'Save Expense',    pages: ['dashboard','history','expenses'] },
    { match: el => el.textContent.trim() === 'Save Changes',    pages: ['dashboard','history','income','students'] },
    { match: el => el.classList.contains('btn-danger'),         pages: ['dashboard','history','income','expenses','settings'] },
    { match: el => el.classList.contains('danger'),             pages: ['dashboard','history','income','expenses','settings'] },
    { match: el => el.textContent.trim() === 'Add School Year', pages: ['settings'] },
    { match: el => el.textContent.trim() === 'Add Course',      pages: ['settings'] },
    { match: el => el.textContent.trim() === 'Set Fee Amount',  pages: ['settings','income'] },
    { match: el => el.textContent.trim() === 'Save Signature',  pages: ['settings'] },
    { match: el => el.textContent.trim() === 'Edit Amount',     pages: ['settings'] },
    { match: el => el.textContent.trim().includes('Mark as') || el.textContent.trim().includes('Set as'), pages: ['settings'] },
];

async function refreshTreasurerPages(pages) {
    const activePage = document.querySelector('.page.active');
    const activePageId = activePage?.id?.replace('page-', '') ?? '';

    for (const page of pages) {
        if (page !== activePageId && page !== 'dashboard') continue;

        switch (page) {
            case 'dashboard':
                await Promise.all([
                    loadOrgFeePayments(),
                    loadOtherFunds(),
                    loadExpenses()
                ]);
                await renderDashboard();
                renderCharts();
                await loadStudentsPage();
                break;
            case 'history':
                await renderHistory();
                break;
            case 'students':
                await loadStudentsPage();
                break;
            case 'income':
                await renderIncome();
                break;
            case 'expenses':
                await renderExpenses();
                break;
            case 'settings':
                const activePanel = document.querySelector('.settings-panel.active');
                if (!activePanel) break;
                const panelId = activePanel.id.replace('settings-', '');
                if (panelId === 'sy')        await refreshSchoolYears();
                if (panelId === 'courses')   await refreshCourses();
                if (panelId === 'fees')      await refreshFees();
                if (panelId === 'signature') await refreshSignature();
                break;
        }
    }
}

document.addEventListener('click', async function(e) {
    const target = e.target.closest('button, .dropdown-item, .btn-danger');
    if (!target) return;

    const rule = TREASURER_REFRESH_MAP.find(r => r.match(target));
    if (!rule) return;

    setTimeout(async () => {
        await refreshTreasurerPages(rule.pages);
    }, 700);

}, true);

// ── SESSION ──────
</script>
