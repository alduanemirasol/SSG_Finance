          <div style="font-size:26px;font-weight:800;color:#fca5a5;line-height:1;letter-spacing:-.03em" id="bd-unpaid">0</div>
        </div>
      </div>
    </div>

    <!-- STUDENTS LIST (moved from former Students page) -->
    <div class="content-card">
      <div class="cc-hdr"><div class="cc-title">Students</div></div>
      <div class="toolbar">
        <div class="search-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="8" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke-width="1.8" stroke-linecap="round"/></svg>
