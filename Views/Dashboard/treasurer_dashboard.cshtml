// SIGNATURE PAD
let sigCanvas, sigCtx, sigDrawing = false, sigHasContent = false, sigPadReady = false;

function initSignaturePad() {
  sigCanvas = document.getElementById('sig-canvas');
  if (!sigCanvas) return;

  sigCtx = sigCanvas.getContext('2d');
  setupSignatureCanvas();

  if (sigPadReady) return;
  sigPadReady = true;

  window.addEventListener('resize', setupSignatureCanvas);

  sigCanvas.addEventListener('pointerdown', startSignatureStroke);
  sigCanvas.addEventListener('pointermove', drawSignatureStroke);
  sigCanvas.addEventListener('pointerup', endSignatureStroke);
  sigCanvas.addEventListener('pointercancel', endSignatureStroke);
  sigCanvas.addEventListener('pointerleave', endSignatureStroke);
}

function setupSignatureCanvas() {
  if (!sigCanvas || !sigCtx) return;

  const rect = sigCanvas.getBoundingClientRect();
  const cssWidth = rect.width || 560;
  const cssHeight = rect.height || 160;
  const dpr = window.devicePixelRatio || 1;
  const previousImage = sigHasContent ? sigCanvas.toDataURL('image/png') : null;

  sigCanvas.width = Math.round(cssWidth * dpr);
  sigCanvas.height = Math.round(cssHeight * dpr);
  sigCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
  sigCtx.strokeStyle = '#111';
  sigCtx.lineWidth = 2;
  sigCtx.lineCap = 'round';
  sigCtx.lineJoin = 'round';

  if (previousImage) {
    const img = new Image();
    img.onload = () => sigCtx.drawImage(img, 0, 0, cssWidth, cssHeight);
    img.src = previousImage;
  }
}

function getSignaturePos(e) {
  const rect = sigCanvas.getBoundingClientRect();
  return { x: e.clientX - rect.left, y: e.clientY - rect.top };
}

function startSignatureStroke(e) {
  if (!sigCtx) return;
  e.preventDefault();
  sigDrawing = true;
  sigCanvas.setPointerCapture?.(e.pointerId);
  const pos = getSignaturePos(e);
  sigCtx.beginPath();
  sigCtx.moveTo(pos.x, pos.y);
}

function drawSignatureStroke(e) {
  if (!sigDrawing || !sigCtx) return;
  e.preventDefault();
  const pos = getSignaturePos(e);
  sigCtx.lineTo(pos.x, pos.y);
  sigCtx.stroke();
  sigHasContent = true;
  hideSignaturePlaceholder();
}

function endSignatureStroke(e) {
  sigDrawing = false;
  if (sigCanvas && e?.pointerId != null) {
    try { sigCanvas.releasePointerCapture?.(e.pointerId); } catch {}
  }
}

function hideSignaturePlaceholder() {
  const placeholder = document.getElementById('sig-placeholder');
  if (placeholder) placeholder.style.display = 'none';
}

function clearSignature() {
  if (!sigCanvas || !sigCtx) return;
  sigCtx.save();
  sigCtx.setTransform(1, 0, 0, 1, 0, 0);
  sigCtx.clearRect(0, 0, sigCanvas.width, sigCanvas.height);
  sigCtx.restore();
  setupSignatureCanvas();
  sigHasContent = false;

  const placeholder = document.getElementById('sig-placeholder');
  if (placeholder) placeholder.style.display = 'flex';
}

async function saveSignature() {
  if (!sigCanvas || !sigHasContent) {
    showToast('Please draw your signature first.', 'fail');
    return;
  }

  try {
    const res = await fetch('/Home/SaveTreasurerSignature', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body: JSON.stringify({ signatureData: sigCanvas.toDataURL('image/png') })
    });
    const data = await res.json();

    if (data.success) {
      showToast('Signature saved successfully.', 'ok');
      clearSignature();
      await refreshSignature();
    } else {
      showToast(data.message || 'Failed to save signature.', 'fail');
    }
  } catch {
    showToast('Request failed.', 'fail');
  }
}

async function refreshSignature() {
  try {
    const res = await fetch('/Home/GetMySignature');
    const data = await res.json();
    const badge = document.getElementById('sig-status-badge');
    const previewWrap = document.getElementById('sig-preview-wrap');
    const previewImg = document.getElementById('sig-preview-img');
    const previewDate = document.getElementById('sig-preview-date');

    if (data.success && data.signatureData) {
      if (previewWrap) previewWrap.style.display = 'block';
      if (previewImg) previewImg.src = data.signatureData;
      if (previewDate) {
        previewDate.textContent = 'Saved on ' + new Date(data.createdAt).toLocaleDateString('en-PH', {
          month: 'long',
          day: 'numeric',
          year: 'numeric'
        });
      }
      if (badge) {
        badge.textContent = 'Saved';
        badge.className = 'badge bg';
      }
    } else {
      if (previewWrap) previewWrap.style.display = 'none';
      if (previewImg) previewImg.src = '';
      if (previewDate) previewDate.textContent = '';
      if (badge) {
        badge.textContent = 'Not saved';
        badge.className = 'badge by';
      }
    }
  } catch {}

  try {
    const res = await fetch('/Home/GetAllTreasurerSignatures');
    const data = await res.json();
    const signatures = Array.isArray(data.signatures) ? data.signatures : [];
    const tbody = document.getElementById('sig-history-tbody');
    const count = document.getElementById('sig-history-count');

    if (!tbody) return;

    if (!data.success || signatures.length === 0) {
      tbody.innerHTML = '<tr class="empty-row"><td colspan="5">No signatures found.</td></tr>';
      if (count) count.textContent = '0 records';
      return;
    }

    if (count) count.textContent = signatures.length + ' record' + (signatures.length !== 1 ? 's' : '');
    tbody.innerHTML = signatures.map((signature, index) => `
      <tr>
        <td class="td-mono td-m">${index + 1}</td>
        <td><strong>${escapeHtml(signature.treasurerName || 'Unknown')}</strong></td>
        <td class="td-mono td-m">${new Date(signature.createdAt).toLocaleDateString('en-PH', { month: 'short', day: 'numeric', year: 'numeric' })}</td>
        <td>${signature.isActive
          ? '<span class="badge bg">Active</span>'
          : '<span class="badge" style="background:rgba(255,255,255,.05);color:var(--text-d)">Superseded</span>'}</td>
        <td>
          <div style="background:#fff;border-radius:6px;padding:4px 8px;display:inline-block">
            <img src="${signature.signatureData}" alt="Signature preview" style="height:36px;max-width:160px;display:block;object-fit:contain"/>
          </div>
        </td>
      </tr>
    `).join('');
  } catch {}
}

