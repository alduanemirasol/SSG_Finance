    if (!opt || !opt.dataset.status) { statusEl.textContent = ''; return; }

    const status   = opt.dataset.status;
    const color    = status === 'Current' ? '#5fdd8e' : '#fbbf24';
    const yearStart = opt.dataset.yearStart;
    const yearEnd   = opt.dataset.yearEnd;
    const semLabel  = opt.value === 'First' ? '1st' : '2nd';

    statusEl.innerHTML = `
        <span style="color:${color};font-weight:600">● ${status}</span>
        &nbsp;·&nbsp; A.Y. ${yearStart}–${yearEnd} &nbsp;·&nbsp; ${semLabel} Semester
