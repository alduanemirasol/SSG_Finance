    console.error('Failed to load students:', err);
  }
}

async function ensureStudentsFresh(force = false) {
  const now = Date.now();
  const staleMs = 30000; // Refresh every 30s at most unless forced
  if (force || STUDENTS.length === 0 || (now - STUDENTS_LAST_FETCH) > staleMs) {
    await loadStudents();
  }
}

// Load available semesters into the dropdown
async function loadAvailableSemesters() {
    try {
        const res  = await fetch('/Home/GetAvailableSemesters');
        const data = await res.json();
        const sel  = document.getElementById('of-sem');

        if (!data.success || !data.fees.length) {
            sel.innerHTML = '<option value="">No semesters with fees set</option>';
            return;
        }

        sel.innerHTML = data.fees.map(f => {
            const semLabel    = f.semester === 'First' ? '1st' : '2nd';
            const statusColor = f.semesterStatus === 'Current' ? '#5fdd8e' : '#fbbf24';
            return `<option value="${f.semester}"
                            data-full-amount-id="${f.fullAmountId}"
                            data-year-start="${f.yearStart}"
                            data-year-end="${f.yearEnd}"
                            data-amount="${f.amount}"
                            data-status="${f.semesterStatus}">
                        ${f.yearStart}–${f.yearEnd} · ${semLabel} Semester · ${f.semesterStatus}
                    </option>`;
        }).join('');

        // ── AUTO-SELECT the Current semester ──
        const currentIndex = data.fees.findIndex(f => f.semesterStatus === 'Current');
        if (currentIndex !== -1) sel.selectedIndex = currentIndex;

        // Trigger status label update
        updateSemesterStatusLabel();
    } catch (err) {
        console.error('Failed to load semesters:', err);
    }
}

// Show the status badge below the dropdown
function updateSemesterStatusLabel() {
    const sel      = document.getElementById('of-sem');
    const opt      = sel.options[sel.selectedIndex];
    const statusEl = document.getElementById('of-sem-status');
    if (!opt || !opt.dataset.status) { statusEl.textContent = ''; return; }

    const status   = opt.dataset.status;
    const color    = status === 'Current' ? '#5fdd8e' : '#fbbf24';
    const yearStart = opt.dataset.yearStart;
    const yearEnd   = opt.dataset.yearEnd;
    const semLabel  = opt.value === 'First' ? '1st' : '2nd';

    statusEl.innerHTML = `
        <span style="color:${color};font-weight:600">● ${status}</span>
        &nbsp;·&nbsp; A.Y. ${yearStart}–${yearEnd} &nbsp;·&nbsp; ${semLabel} Semester
    `;

    // Update REQ_FEE to match selected semester
    REQ_FEE = parseFloat(opt.dataset.amount) || REQ_FEE;
    document.getElementById('of-amount').placeholder = REQ_FEE.toFixed(2);

    // Re-check payment status if amount is already entered
    if (document.getElementById('of-amount').value) checkPaymentStatus();
}

