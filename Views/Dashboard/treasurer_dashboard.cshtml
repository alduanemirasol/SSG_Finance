// Receipt images selected for the expense currently being recorded.
let expenseImageFiles = [];

function addExpenseImages(input) {
  const allowed = ['image/jpeg', 'image/png', 'image/webp'];
  [...input.files].forEach(f => {
    if (!allowed.includes(f.type)) { showToast(`"${f.name}" is not a JPG/PNG/WEBP image.`, 'fail'); return; }
    if (f.size > 5 * 1024 * 1024) { showToast(`"${f.name}" is larger than 5MB.`, 'fail'); return; }
    expenseImageFiles.push(f);
  });
  input.value = ''; // allow re-selecting the same file / adding more
  renderExpenseImagePreviews();
}

function removeExpenseImage(i) {
  expenseImageFiles.splice(i, 1);
  renderExpenseImagePreviews();
}

function renderExpenseImagePreviews() {
  const box = document.getElementById('ex-image-previews');
  if (!box) return;
  box.innerHTML = expenseImageFiles.map((f, i) => {
    const url = URL.createObjectURL(f);
    return `<div style="position:relative;width:64px;height:64px;border-radius:8px;overflow:hidden;border:1px solid rgba(255,255,255,.12)">
      <img src="${url}" style="width:100%;height:100%;object-fit:cover;display:block"/>
      <button type="button" onclick="removeExpenseImage(${i})" title="Remove"
        style="position:absolute;top:2px;right:2px;width:18px;height:18px;border-radius:50%;background:#ef4444;border:none;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:11px;line-height:1;padding:0">×</button>
    </div>`;
  }).join('');
}

// Lowest the running balance reaches on or after `dayStr` (YYYY-MM-DD), mirroring the
// server's date-aware spending limit. An expense dated that day may not exceed this.
function minBalanceOnOrAfter(dayStr) {
  const day = (dayStr || '').split('T')[0];
  const events = allTransactions().map(t => ({
    date: ((t.fullDate || t.date) || '').split('T')[0],
    amt:  t.type === 'income' ? t.amt : -t.amt
  }));
  const points = [...new Set(events.filter(e => e.date > day).map(e => e.date))];
  points.push(day);
  let min = Infinity;
  for (const tpt of points) {
    const bal = events.filter(e => e.date <= tpt).reduce((s, e) => s + e.amt, 0);
    if (bal < min) min = bal;
  }
  return min === Infinity ? 0 : min;
}

async function saveExpense() {
  let desc = document.getElementById('ex-desc').value.trim();
  let amt  = parseFloat(document.getElementById('ex-amount').value) || 0;
  let date = document.getElementById('ex-date').value || today();
  if (!desc || !amt) { showToast('Description and amount are required.', 'fail'); return; }

  // Date-aware spending limit: recording this expense on its date must not drive the
  // running balance negative on that date or any later point (mirrors the server check).
  const availableOnDate = minBalanceOnOrAfter(date);
  if (amt > availableOnDate) {
    showToast('Recording ' + p(amt) + ' on this date would make the balance negative. Available on/after that date: ' + p(availableOnDate) + '.', 'fail');
    return;
  }

  try {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const fd = new FormData();
    fd.append('description', desc);
    fd.append('amount', amt);
    fd.append('expenseDate', toTimestamp(date));
    expenseImageFiles.forEach(f => fd.append('images', f));

    const res = await fetch('/Home/AddExpense', {
      method: 'POST',
      headers: { 'RequestVerificationToken': token }, // no Content-Type: browser sets multipart boundary
      body: fd
    });
    const data = await res.json();
    if (data.success) {
      closeModal('modal-expense');
      document.getElementById('ex-desc').value = '';
      document.getElementById('ex-amount').value = '';
      expenseImageFiles = [];
      renderExpenseImagePreviews();
      await renderDashboard();
      await renderCharts();
      await renderExpenses();
      showToast('Expense recorded.', 'ok');
    } else {
