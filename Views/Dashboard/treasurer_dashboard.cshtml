async function saveExpense() {
  let desc = document.getElementById('ex-desc').value.trim();
  let amt  = parseFloat(document.getElementById('ex-amount').value) || 0;
  let date = document.getElementById('ex-date').value || today();
  if (!desc || !amt) { showToast('Description and amount are required.', 'fail'); return; }

  // Spending limit: an expense cannot exceed the remaining balance (cash on hand).
  const allTx = allTransactions();
  const totalIncome   = allTx.filter(t => t.type === 'income').reduce((s, t) => s + t.amt, 0);
  const totalExpenses = allTx.filter(t => t.type === 'expense').reduce((s, t) => s + t.amt, 0);
  const remainingBalance = totalIncome - totalExpenses;
  if (amt > remainingBalance) {
    showToast('Remaining balance is not enough for this new expense. Available: ' + p(remainingBalance) + '.', 'fail');
    return;
  }

  try {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const res = await fetch('/Home/AddExpense', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
      body: JSON.stringify({
        description: desc,
        amount: amt,
        expenseDate: new Date(date + 'T00:00:00').toISOString()
      })
    });
    const data = await res.json();
    if (data.success) {
      closeModal('modal-expense');
      document.getElementById('ex-desc').value = '';
      document.getElementById('ex-amount').value = '';
      await renderDashboard();
      await renderCharts();
      await renderExpenses();
      showToast('Expense recorded.', 'ok');
    } else {
      showToast(data.message || 'Failed to save expense.', 'fail');
    }
  } catch (err) {
    console.error('Failed to save expense:', err);
    showToast('Failed to save expense. Please try again.', 'fail');
  }
}

