async function populateFeeSySemDropdown() {
  try {
    const res  = await fetch('/Home/GetSchoolYears');
    const data = await res.json();
    const sel  = document.getElementById('fee-sy-sem');
    if (!sel || !data.success) return;

    const semesters = [];
    const sorted = [...data.schoolYears].sort((a, b) => b.yearStart - a.yearStart);
    sorted.forEach(sy => {
      semesters.push({
        schoolYearId: sy.schoolYearId,
        yearStart:    sy.yearStart,
        yearEnd:      sy.yearEnd,
        semester:     'First',
        label:        `${sy.yearStart}–${sy.yearEnd} · 1st Semester`
      });
      semesters.push({
        schoolYearId: sy.schoolYearId,
        yearStart:    sy.yearStart,
        yearEnd:      sy.yearEnd,
        semester:     'Second',
        label:        `${sy.yearStart}–${sy.yearEnd} · 2nd Semester`
      });
    });

    sel.innerHTML = '<option value="">Select school year & semester</option>' +
      semesters.map(s =>
        `<option value="${s.schoolYearId}|${s.semester}"
                 data-school-year-id="${s.schoolYearId}"
                 data-semester="${s.semester}">
           ${s.label}
         </option>`
      ).join('');
  } catch {}
}

