function allTransactions() {
    let rows = [];

    DB.orgFees.forEach(x => rows.push({
        type: 'income',
        cat: 'Org Fee',
        paymentType: 'Org Fee',
        desc: 'N/A',
        sem: x.sem || 'N/A',
        from: orgFeeFrom(x),
        balance: Math.max((x.amtRequired || 0) - (x.amt || 0), 0),
        status: x.status || '—',
        amt: x.amt,
        date: x.date,
        fullDate: x.fullDate || x.date,  // ← use full timestamp
        receipt: x.receipt || '—',
        src: 'OrgFee',
        sid: x.id,
        schoolYear: x.schoolYear || null,
        studentName: x.name,
        schoolId: x.schoolId,
        course: x.course,
        yearSection: x.yr
    }));

    DB.funds.forEach(x => rows.push({
        type: 'income',
        cat: x.cat || 'Other',
        paymentType: x.cat || 'Other Fund',
        desc: x.desc || 'N/A',
        sem: 'N/A',
        from: x.source || x.receivedBy || '—',
        balance: null,
        status: 'N/A',
        amt: x.amt,
        date: x.date,
        fullDate: x.fullDate || x.date,  // ← use full timestamp
        receipt: 'N/A',
        src: 'OtherFund',
        sid: x.id,
        schoolYear: x.schoolYear || null,
        studentName: '',
        schoolId: '',
        course: '',
        yearSection: ''
    }));

    DB.expenses.forEach(x => rows.push({
        type: 'expense',
        cat: 'Expense',
        paymentType: 'Expense',
        desc: x.desc || 'N/A',
        sem: 'N/A',
        from: (x.recordedBy || '—') + ' (Treasurer)',
        balance: null,
        status: 'N/A',
        amt: x.amt,
        date: x.date,
        fullDate: x.fullDate || x.date,  // ← use full timestamp
        receipt: 'N/A',
        src: 'Expense',
        sid: x.id,
        schoolYear: x.schoolYear || null,
        images: x.images || [],
        studentName: '',
        schoolId: '',
        course: '',
        yearSection: ''
    }));

    // Sort by full datetime descending (newest first), with a safe fallback
    return rows.sort((a, b) => {
        const ta = Date.parse(a.fullDate);
        const tb = Date.parse(b.fullDate);
        const va = isNaN(ta) ? Date.parse(a.date) || 0 : ta;
        const vb = isNaN(tb) ? Date.parse(b.date) || 0 : tb;
        return vb - va;
    });
}

function totalIncome()   { return DB.orgFees.reduce((s,x)=>s+x.amt,0) + DB.funds.reduce((s,x)=>s+x.amt,0); }
