<body>

<!-- Avatar preview modal: click anywhere to close -->
<div id="avatarModal" onclick="closeAvatarModal()">
  <div class="av-inner">
    <img id="avatarModalImg" src="" alt="" />
    <div class="av-name" id="avatarModalName"></div>
    <div class="av-hint">Click anywhere to close</div>
  </div>
</div>

<!-- Receipt image gallery lightbox (swipeable) -->
<div id="expense-image-modal" onclick="if(event.target===this)closeExpenseImageModal()"
     style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.82);backdrop-filter:blur(4px);align-items:center;justify-content:center;gap:14px;padding:24px">
  <button type="button" id="expense-gallery-prev" onclick="expenseGalleryPrev(event)" aria-label="Previous receipt"
          style="flex-shrink:0;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;font-size:26px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center">‹</button>
  <div style="display:flex;flex-direction:column;align-items:center;gap:12px;min-width:0">
    <img id="expense-image-modal-img" src="" alt="Receipt"
         style="max-width:78vw;max-height:80vh;object-fit:contain;border-radius:10px;box-shadow:0 20px 60px rgba(0,0,0,.6)"/>
    <div id="expense-gallery-counter"
         style="color:#fff;font-size:12.5px;font-weight:600;background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.14);border-radius:20px;padding:5px 14px">1 / 1</div>
  </div>
  <button type="button" id="expense-gallery-next" onclick="expenseGalleryNext(event)" aria-label="Next receipt"
          style="flex-shrink:0;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;font-size:26px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center">›</button>
  <button type="button" onclick="closeExpenseImageModal()" aria-label="Close"
          style="position:absolute;top:18px;right:22px;width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center">✕</button>
</div>

<div class="top-accent"></div>

<!-- ── SIDEBAR ── -->
<aside class="sidebar">
  <div class="sb-brand">
    <div class="sb-logo">
      <img src="~/logo.png" alt="SSG Finance Logo" />
    </div>
    <div>
      <div class="sb-brand-name">SSG Finance</div>
      <div class="sb-brand-sub">Treasurer</div>
    </div>
  </div>

  <div class="sb-label">Overview</div>
  <div class="nav-item active" onclick="showPage('dashboard',this)">
    <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
    Dashboard
