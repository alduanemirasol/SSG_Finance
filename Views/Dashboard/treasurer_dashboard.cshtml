async function searchStudents(q) {
  let list = document.getElementById('of-list');
  const query = (q || '').trim().toLowerCase();
  if (!query) { list.style.display = 'none'; return; }

  try {
    const sel = document.getElementById('of-sem');
    const opt = sel?.options[sel.selectedIndex];
    const fullAmountId = opt?.dataset?.fullAmountId || '';
    const response = await fetch('/Home/GetStudentsForPayment?q=' + encodeURIComponent(query) + '&fullAmountId=' + encodeURIComponent(fullAmountId));
    const data = await response.json();
    if (!data.success) {
      list.style.display = 'block';
      const msg = data.message ? String(data.message) : 'Unable to load students.';
      list.innerHTML = `<div style="padding:10px 12px;font-size:12px;color:var(--text-d)">${msg}</div>`;
      return;
    }

    const res = data.students.map(s => ({
      userId: s.userId,
      schoolId: s.schoolId,
      name: s.name,
      courseCode: s.courseCode,
      yearSection: s.yearSection,
      hasPaid: s.hasPaid,
      hasPartial: s.hasPartial
    }));

    list.style.display = 'block';
    list.innerHTML = res.length ? res.map(s => `
      <div class="student-item${s.hasPaid ? ' paid' : ''}" 
           onclick="${s.hasPaid ? '' : `selectStudent(${s.userId},'${s.name.replace(/'/g, "\\'")}','${s.courseCode.replace(/'/g, "\\'")}','${s.yearSection.replace(/'/g, "\\'")}','${s.schoolId.replace(/'/g, "\\'")}')`}">
        <div>
          <div class="student-name">
            ${s.name} 
            ${s.hasPaid ? '<span class="badge by" style="font-size:9px">Paid</span>' : ''}
            ${s.hasPartial && !s.hasPaid ? '<span class="badge by" style="font-size:9px;background:rgba(251,191,36,.18);color:#fbbf24">Partial</span>' : ''}
          </div>
          <div class="student-info">${s.schoolId} · ${s.courseCode} ${s.yearSection}</div>
        </div>
      </div>`).join('')
      : '<div style="padding:10px 12px;font-size:12px;color:var(--text-d)">No students found.</div>';
  } catch (err) {
    console.error('Failed to search students:', err);
    list.style.display = 'block';
    list.innerHTML = '<div style="padding:10px 12px;font-size:12px;color:var(--text-d)">Request failed while loading students.</div>';
  }
}

