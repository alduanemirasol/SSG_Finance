async function populateChartSchoolYears() {
    try {
        const res = await fetch('/Home/GetSchoolYears');
        const data = await res.json();
        const sel = document.getElementById('chart-sy');
        if (!sel || !data.success) return;

        const current = data.schoolYears.find(sy => sy.yearStatus === 'Current');
        sel.innerHTML = '<option value="">All School Years</option>' +
            data.schoolYears.map(sy =>
                `<option value="${sy.yearStart}–${sy.yearEnd}">${sy.yearStart}–${sy.yearEnd}</option>`
