}

function renderSemesterSummaryCard(label, sem, schoolYear) {
  if (!sem) {
    return `<div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:14px 16px">
      <div style="font-size:11px;font-weight:700;color:#fff;margin-bottom:8px">${label}</div>
      <div style="font-size:12px;color:var(--text-d)">No fee configured for ${schoolYear || 'current school year'}.</div>
    </div>`;
  }
  return `<div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:14px 16px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
      <div style="font-size:11px;font-weight:700;color:#fff">${label}</div>
      ${feeStatusBadge(sem.feeStatus)}
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px">
      <div>
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-d);margin-bottom:3px">Required</div>
        <div style="font-family:'DM Mono',monospace;font-size:13px;font-weight:600;color:#fff">${p(sem.requiredAmount)}</div>
      </div>
      <div>
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-d);margin-bottom:3px">Paid</div>
        <div style="font-family:'DM Mono',monospace;font-size:13px;font-weight:600;color:#5fdd8e">${p(sem.totalPaid)}</div>
      </div>
      <div>
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-d);margin-bottom:3px">Balance</div>
        <div style="font-family:'DM Mono',monospace;font-size:13px;font-weight:600;color:#fbbf24">${p(sem.balance)}</div>
      </div>
    </div>
  </div>`;
}

function renderReceiptCell(paymentId, receiptNumber, hasReceipt) {
  if (!hasReceipt || !receiptNumber || receiptNumber === '—') {
    return '<span style="color:var(--text-d)">—</span>';
  }
  const safeReceipt = escapeHtml(receiptNumber);
  const receiptArg = String(receiptNumber).replace(/\\/g, '\\\\').replace(/'/g, "\\'");
  return `<button type="button" class="btn-outline" style="padding:3px 8px;font-size:10.5px;font-family:'DM Mono',monospace" onclick="viewReceipt('OrgFee', ${paymentId}, '${receiptArg}')">${safeReceipt}</button>`;
}

async function loadStudentsPage() {
  const tbody = document.getElementById('students-page-tbody');
  if (tbody) tbody.innerHTML = '<tr class="empty-row"><td colspan="7">Loading students…</td></tr>';

  try {
    const res = await fetch('/Home/GetTreasurerStudentsWithFees');
    const data = await res.json();
    if (!data.success) {
      if (tbody) tbody.innerHTML = `<tr class="empty-row"><td colspan="7">${escapeHtml(data.message || 'Failed to load students.')}</td></tr>`;
      return;
    }
    ALL_STUDENTS_PAGE = data.students || [];
    const sub = document.getElementById('students-page-sub');
    if (sub && data.schoolYear && data.schoolYear !== 'N/A') {
      sub.textContent = `${ALL_STUDENTS_PAGE.length} approved student${ALL_STUDENTS_PAGE.length !== 1 ? 's' : ''} · A.Y. ${data.schoolYear}`;
    }
    populateStudentsPageFilters();
    applyStudentsPageFilters();
  } catch (err) {
    console.error('Failed to load students page:', err);
    if (tbody) tbody.innerHTML = '<tr class="empty-row"><td colspan="7">Failed to load students.</td></tr>';
  }
}

function renderStudentsPage(filtered) {
  const data = (filtered ?? ALL_STUDENTS_PAGE)
    .slice()
    .sort((a, b) => String(a.name || '').localeCompare(String(b.name || ''), undefined, { sensitivity: 'base' }));
  const tbody = document.getElementById('students-page-tbody');
  const sub = document.getElementById('students-page-sub');
  if (!tbody) return;

  if (sub && !sub.textContent.includes('A.Y.')) {
    sub.textContent = `${data.length} approved student${data.length !== 1 ? 's' : ''} (including treasurers)`;
  }

  if (!data.length) {
    tbody.innerHTML = '<tr class="empty-row"><td colspan="7">No students found.</td></tr>';
    return;
  }

  tbody.innerHTML = data.map((s, i) => {
    const courseYr = `${escapeHtml(s.courseCode)} ${escapeHtml(s.yearSection)}`;
    const roleTag = s.role === 'Treasurer'
      ? ' <span style="font-size:10px;font-weight:600;background:rgba(249,115,22,.15);color:#fdba74;border:1px solid rgba(249,115,22,.25);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Treasurer</span>'
      : '';
    const inactiveTag = !s.isActive
      ? ' <span style="font-size:10px;font-weight:600;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Inactive</span>'
      : '';
    return `<tr>
      <td class="td-mono td-m">${i + 1}</td>
      <td class="td-mono td-m">${escapeHtml(s.schoolId)}</td>
      <td><strong>${escapeHtml(s.name)}</strong>${roleTag}${inactiveTag}</td>
      <td class="td-m">${courseYr}</td>
      <td>${feeStatusBadge(s.firstSemStatus)}</td>
      <td>${feeStatusBadge(s.secondSemStatus)}</td>
      <td>
        <button class="btn-outline" style="padding:5px 12px;font-size:11px" onclick="openStudentOrgFeeModal(${s.userId})">
          Org Fees
        </button>
      </td>
    </tr>`;
  }).join('');
}

function filterStudentsPage(q) {
  studentsPageQ = (q || '').toLowerCase().trim();
  applyStudentsPageFilters();
}

function populateStudentsPageFilters() {
  const courseSel = document.getElementById('students-filter-course');
  if (!courseSel) return;

  const courses = [...new Set(ALL_STUDENTS_PAGE.map(s => (s.courseCode || '').trim()).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: 'base' }));

  courseSel.innerHTML = '<option value="">All Courses</option>' + courses.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('');

  if (studentsPageCourse && courses.includes(studentsPageCourse)) courseSel.value = studentsPageCourse;
  else studentsPageCourse = '';

  fetch('/Home/GetSchoolYears')
    .then(r => r.json())
    .then(data => {
      const sySel = document.getElementById('students-filter-sy');
      if (!sySel || !data.success) return;
      sySel.innerHTML = '<option value="">All School Years</option>' +
        data.schoolYears.map(sy =>
          `<option value="${sy.yearStart}–${sy.yearEnd}">${sy.yearStart}–${sy.yearEnd}</option>`
        ).join('');
    })
    .catch(() => {});
}

function applyStudentsPageFilters() {
  studentsPageCourse = document.getElementById('students-filter-course')?.value || '';
  const filterSY  = document.getElementById('students-filter-sy')?.value  || '';
  const filterSem = document.getElementById('students-filter-sem')?.value || '';

  const filtered = ALL_STUDENTS_PAGE.filter(s => {
    const name        = (s.name        || '').toLowerCase();
    const schoolId    = (s.schoolId    || '').toLowerCase();
    const course      = (s.courseCode  || '').toLowerCase();
    const yearSection = (s.yearSection || '').toLowerCase();

    const matchesQ      = !studentsPageQ
      || name.includes(studentsPageQ)
      || schoolId.includes(studentsPageQ)
      || course.includes(studentsPageQ)
      || yearSection.includes(studentsPageQ);

    const matchesCourse = !studentsPageCourse || (s.courseCode || '') === studentsPageCourse;
    const matchesSY = !filterSY || (s.schoolYear || '') === filterSY;
    const matchesSem = !filterSem || (
      filterSem === 'First'  ? s.firstSemStatus  !== undefined :
      filterSem === 'Second' ? s.secondSemStatus !== undefined : true
    );

    return matchesQ && matchesCourse && matchesSY && matchesSem;
  });

  renderStudentsPage(filtered);
}

async function openStudentOrgFeeModal(userId) {
  const nameEl = document.getElementById('student-orgfee-name');
  const subEl = document.getElementById('student-orgfee-sub');
  const summaryEl = document.getElementById('student-orgfee-summary');
  const tbody = document.getElementById('student-orgfee-tbody');

  nameEl.textContent = 'Student Org Fees';
  subEl.textContent = 'Loading…';
  summaryEl.innerHTML = '';
  tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-d)">Loading…</td></tr>';
  openModal('modal-student-orgfee');

  try {
    const res = await fetch('/Home/GetStudentOrgFeeDetails?userId=' + encodeURIComponent(userId));
    const data = await res.json();
    if (!data.success) {
      subEl.textContent = data.message || 'Unable to load org fee details.';
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-d)">No data available.</td></tr>';
      return;
    }

    const s = data.student;
    nameEl.textContent = s.name;
    subEl.textContent = `${s.schoolId} · ${s.courseCode} ${s.yearSection}${s.role === 'Treasurer' ? ' · Treasurer' : ''}${data.schoolYear ? ' · A.Y. ' + data.schoolYear : ''}`;

    summaryEl.innerHTML = `
      <div style="font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:10px">Current School Year · ${escapeHtml(data.schoolYear || 'N/A')}</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
        ${renderSemesterSummaryCard('1st Semester', data.firstSemester, data.schoolYear)}
        ${renderSemesterSummaryCard('2nd Semester', data.secondSemester, data.schoolYear)}
      </div>`;

    const txs = data.transactions || [];
    if (!txs.length) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-d)">No org fee transactions recorded.</td></tr>';
      return;
    }

    tbody.innerHTML = txs.map(t => {
      const semLabel = t.semester === 'First' ? '1st' : '2nd';
      return `<tr style="border-bottom:1px solid rgba(255,255,255,.04)">
        <td style="padding:9px 12px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text-m)">${fd(t.date)}</td>
        <td style="padding:9px 12px;color:var(--text)">${escapeHtml(t.schoolYear)} · ${semLabel}</td>
        <td style="padding:9px 12px">${renderReceiptCell(t.paymentId, t.receiptNumber, t.hasReceipt)}</td>
        <td style="padding:9px 12px;text-align:right;font-family:'DM Mono',monospace;font-size:12px;font-weight:500;color:#5fdd8e">${p(t.amount)}</td>
        <td style="padding:9px 12px">${feeStatusBadge(t.paymentStatus)}</td>
      </tr>`;
    }).join('');
  } catch (err) {
    console.error('Failed to load student org fee details:', err);
    subEl.textContent = 'Failed to load org fee details.';
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-d)">Request failed.</td></tr>';
  }
}

