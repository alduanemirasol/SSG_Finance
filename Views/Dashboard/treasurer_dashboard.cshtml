// ── HOVER DROPDOWN (fixed-position, escapes scroll containers) ──────────────
// Uses JS positioning so the menu never gets clipped by overflow:auto parents.
(function() {
  let _activeHdrop = null;

  function openHdrop(hdrop) {
    if (_activeHdrop && _activeHdrop !== hdrop) closeAllHdrops();
    const menu = hdrop.querySelector('.hdrop-menu');
    if (!menu) return;
    const btn  = hdrop.querySelector('button:not([disabled])');
    if (!btn) return;
    const r = btn.getBoundingClientRect();
    menu.style.top   = (r.bottom + 5) + 'px';
    menu.style.right = (window.innerWidth - r.right) + 'px';
    menu.style.left  = 'auto';
    menu.classList.add('open');
    _activeHdrop = hdrop;
  }

  function closeAllHdrops() {
    document.querySelectorAll('.hdrop-menu.open').forEach(m => m.classList.remove('open'));
    _activeHdrop = null;
  }

  document.addEventListener('mouseover', function(e) {
    const hdrop = e.target.closest('.hdrop');
    if (hdrop) openHdrop(hdrop);

    // Tooltip positioning
    const tipWrap = e.target.closest('.tip-wrap');
    if (tipWrap) {
      const tip = tipWrap.querySelector('.tip');
      if (tip) {
        const r = tipWrap.getBoundingClientRect();
        tip.style.top  = (r.bottom + 5) + 'px';
        tip.style.left = (r.left + r.width / 2) + 'px';
        tip.classList.add('show');
      }
    }
  });

  document.addEventListener('mouseout', function(e) {
    // Tooltip only. The dropdown is intentionally NOT closed on mouseout: the
    // menu sits a few px below its trigger, and closing here would slam it shut
    // the moment the cursor crossed that gap to click an item. Closing is now
    // handled by outside-click / Escape / item-selection below.
    const tipWrap = e.target.closest('.tip-wrap');
    if (tipWrap && !tipWrap.contains(e.relatedTarget)) {
      const tip = tipWrap.querySelector('.tip');
      if (tip) tip.classList.remove('show');
    }
  });

  // Click handling: tapping the trigger opens the menu (so it also works on
  // touch, which has no hover); clicking a receipt item runs its action and
  // closes; clicking anywhere else closes.
  document.addEventListener('click', function(e) {
    if (e.target.closest('.hdrop-item')) { closeAllHdrops(); return; }
    const hdrop = e.target.closest('.hdrop');
    if (hdrop) { openHdrop(hdrop); return; }
    closeAllHdrops();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeAllHdrops();
  });
})();

