async function openNewReportModal() {
  nrCurrentType = 'Event';
  document.getElementById('nr-title').value     = '';
  document.getElementById('nr-date-from').value = '';
  document.getElementById('nr-date-to').value   = '';
  document.getElementById('nr-sem').value        = '';

  // fetch school years from API and store for auto-check logic
  const sySel = document.getElementById('nr-sy');
  sySel.innerHTML = '<option value="">-- Select --</option>';
  try {
    const res  = await fetch('/Home/GetSchoolYears');
    const data = await res.json();
    if (data.success) {
      nrSchoolYears = data.schoolYears;
      data.schoolYears.forEach(sy => {
        const opt = document.createElement('option');
        opt.value = sy.schoolYearId;
        opt.textContent = `${sy.yearStart}–${sy.yearEnd}`;
        if (sy.yearStatus === 'Current') opt.selected = true;
        sySel.appendChild(opt);
      });
    }
  } catch { /* leave empty */ }

  nrSetType('Event');

  // open modal manually to avoid the global date auto-fill overwriting our cleared fields
  document.getElementById('modal-new-report').classList.add('open');

  nrFilterItems();
}

function nrSetType(type) {
  nrCurrentType = type;
  ['Event','Semester','Annual'].forEach(t => {
    document.getElementById(`nr-btn-${t.toLowerCase()}`).classList.toggle('active', t === type);
  });
  document.getElementById('nr-date-wrap').style.display = type === 'Event'    ? 'flex' : 'none';
  document.getElementById('nr-sem-wrap').style.display  = type === 'Semester' ? ''     : 'none';
  const desc = {
    Event:    'For a specific activity or event — pick the exact date range it covers.',
    Semester: 'Covers one full semester of the selected school year.',
    Annual:   'Covers the entire selected school year.'
  };
  const d = document.getElementById('nr-type-desc');
  if (d) d.textContent = desc[type] || '';
  nrFilterItems();
}

function nrInRange(itemDate, from, to) {
  const d = (itemDate || '').split('T')[0];
  if (from && d < from) return false;
  if (to   && d > to)   return false;
  return true;
}

function nrGetAutoRange() {
  const syId  = document.getElementById('nr-sy').value;
  const sem   = document.getElementById('nr-sem').value;
  const from  = document.getElementById('nr-date-from').value;
  const to    = document.getElementById('nr-date-to').value;

  if (nrCurrentType === 'Event') {
    return { from, to, active: !!(from || to) };
  }

  if (!syId) return { from: null, to: null, active: false };
  const sy = nrSchoolYears.find(s => String(s.schoolYearId) === String(syId));
  if (!sy) return { from: null, to: null, active: false };

  if (nrCurrentType === 'Annual') {
    // Whole school year: match by the school-year tag the backend already
    // assigned to each transaction (by calendar-year boundary), NOT by the
    // semester date window. This way expenses/funds dated in the semester
    // break or after the 2nd semester ends (e.g. graduation) are still included.
    return { schoolYearLabel: `${sy.yearStart}–${sy.yearEnd}`, active: true };
  }

  if (nrCurrentType === 'Semester') {
    if (sem === 'First') {
      const f = sy.firstSemStart  ? sy.firstSemStart.split('T')[0]  : `${sy.yearStart}-08-01`;
      const t = sy.firstSemEnd    ? sy.firstSemEnd.split('T')[0]    : `${sy.yearStart}-12-31`;
      return { from: f, to: t, active: true };
    }
    if (sem === 'Second') {
      const f = sy.secondSemStart ? sy.secondSemStart.split('T')[0] : `${sy.yearEnd}-01-01`;
      const t = sy.secondSemEnd   ? sy.secondSemEnd.split('T')[0]   : `${sy.yearEnd}-05-31`;
      return { from: f, to: t, active: true };
    }
    // no semester chosen yet — match the whole school year
    const f = sy.firstSemStart  || `${sy.yearStart}-08-01`;
    const t = sy.secondSemEnd   || sy.firstSemEnd || `${sy.yearEnd}-07-31`;
    return { from: f.split('T')[0], to: t.split('T')[0], active: true };
  }

  return { from: null, to: null, active: false };
}

function nrFilterItems() {
  const { from, to, active, schoolYearLabel } = nrGetAutoRange();
  const expenses = [...(DB.expenses || [])].sort((a,b) => new Date(b.fullDate||b.date) - new Date(a.fullDate||a.date));
  const funds    = [...(DB.funds    || [])].sort((a,b) => new Date(b.fullDate||b.date) - new Date(a.fullDate||a.date));
  const fmt = n => '₱' + Number(n).toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  const renderList = (items, name, color, emptyMsg) => {
    if (items.length === 0)
      return `<div style="color:var(--text-d);font-size:12px;padding:6px 4px">${emptyMsg}</div>`;

    let inRangeCount = 0;
    const rows = items.map(item => {
      // Annual reports match by school-year tag; Event/Semester match by date window.
      const inRange = active
        ? (schoolYearLabel ? item.schoolYear === schoolYearLabel : nrInRange(item.date, from, to))
        : false;
      if (inRange) inRangeCount++;
      const dimmed  = active && !inRange;
      const label   = name === 'nr-expense' ? (item.desc||'—') : (item.desc||item.source||'—');
      const extra   = name === 'nr-fund' && item.source ? ` · ${escapeHtml(item.source)}` : '';
      return `
      <label class="nr-item" style="${dimmed ? 'opacity:.45' : ''}">
        <input type="checkbox" name="${name}" value="${item.id}" ${inRange ? 'checked' : ''}/>
        <div style="flex:1;min-width:0">
          <div style="font-size:12.5px;font-weight:600;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escapeHtml(label)}</div>
          <div style="font-size:11px;color:var(--text-m);margin-top:1px">${fd(item.date)}${extra}</div>
        </div>
        <div style="font-family:'DM Mono',monospace;font-size:12px;color:${color};flex-shrink:0">${fmt(item.amt)}</div>
      </label>`;
    }).join('');

    // When a period is active but nothing fell inside it, tell the user instead
    // of leaving them with a list of greyed-out rows.
    const notice = (active && inRangeCount === 0)
      ? '<div style="color:var(--text-d);font-size:11.5px;padding:6px 4px 8px">None in the selected period — check any below to include them anyway.</div>'
      : '';
    return notice + rows;
  };

  document.getElementById('nr-expenses-list').innerHTML =
    renderList(expenses, 'nr-expense', '#f87171', 'No expenses recorded yet.');

  document.getElementById('nr-funds-list').innerHTML =
    renderList(funds, 'nr-fund', '#5fdd8e', 'No other funds recorded yet.');
}

async function submitNewReport() {
  const title = document.getElementById('nr-title').value.trim();
  if (!title) { showToast('Please enter a report title.', 'fail'); return; }

  const expenseIds = [...document.querySelectorAll('input[name="nr-expense"]:checked')].map(cb => parseInt(cb.value));
  const fundIds    = [...document.querySelectorAll('input[name="nr-fund"]:checked')].map(cb => parseInt(cb.value));

  if (expenseIds.length === 0 && fundIds.length === 0) {
    showToast('Select at least one transaction.', 'fail'); return;
  }

  const syId = document.getElementById('nr-sy').value;
  const sem  = document.getElementById('nr-sem').value;

  const payload = {
    reportType:   nrCurrentType,
    title,
    schoolYearId: syId ? parseInt(syId) : null,
    semester:     sem  || null,
    dateFrom:     document.getElementById('nr-date-from').value || null,
    dateTo:       document.getElementById('nr-date-to').value   || null,
    expenseIds,
    fundIds
  };

  try {
    const res  = await fetch('/Home/CreateReport', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      showToast('Report created.', 'ok');
      closeModal('modal-new-report');
      await loadReports();
      viewReport(data.reportId);
    } else {
      showToast(data.message || 'Failed to create report.', 'fail');
    }
  } catch { showToast('Network error.', 'fail'); }
}

