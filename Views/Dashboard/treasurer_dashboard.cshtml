function feeStatusBadge(status) {
  const s = (status || 'Unpaid').toLowerCase();
  if (s === 'paid') return '<span class="badge bg">Paid</span>';
  if (s === 'partial') return '<span class="badge by">Partial</span>';
  if (s === 'n/a') return '<span class="badge" style="background:rgba(255,255,255,.06);color:var(--text-d)">N/A</span>';
  return '<span class="badge br">Unpaid</span>';
}

function renderCurrentFeesTable(currentSchoolYear, fees) {
  const list = Array.isArray(fees) ? fees : [];

  const rowsHtml = list.length
    ? list.map(f => {
        const semLabel = f.semester === 'First' ? '1st Semester'
                       : f.semester === 'Second' ? '2nd Semester'
                       : (f.semester || '—');
        const balColor = f.balance > 0 ? '#f87171' : '#5fdd8e';
        return `<tr>
          <td style="padding:9px 12px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text-m)">${escapeHtml(f.schoolYear || 'N/A')}</td>
          <td style="padding:9px 12px;color:var(--text)">${semLabel}</td>
          <td style="padding:9px 12px;font-family:'DM Mono',monospace;color:${balColor}">${p(f.balance)}</td>
          <td style="padding:9px 12px;font-family:'DM Mono',monospace;color:var(--text)">${p(f.requiredAmount)}</td>
          <td style="padding:9px 12px">${feeStatusBadge(f.feeStatus)}</td>
        </tr>`;
      }).join('')
    : `<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-d)">No applicable fees found.</td></tr>`;

  return `
    <div style="font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:10px">Current Fees</div>
    <div style="border:1px solid rgba(255,255,255,.08);border-radius:10px;overflow:hidden">
      <table style="width:100%;border-collapse:collapse;font-size:12px">
        <thead>
          <tr style="background:rgba(255,255,255,.04)">
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">School Year</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Semester</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Balance</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Amount</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Status</th>
          </tr>
        </thead>
        <tbody>
          ${rowsHtml}
        </tbody>
      </table>
    </div>`;
}

function renderReceiptCell(paymentId, receiptNumber, hasReceipt) {
  if (!hasReceipt || !receiptNumber || receiptNumber === '—') {
    return '<span style="color:var(--text-d)">—</span>';
  }
  const safeReceipt = escapeHtml(receiptNumber);
  const receiptArg = String(receiptNumber).replace(/\\/g, '\\\\').replace(/'/g, "\\'");
  return `<button type="button" class="btn-outline" style="padding:3px 8px;font-size:10.5px;font-family:'DM Mono',monospace" onclick="viewReceipt('OrgFee', ${paymentId}, '${receiptArg}')">${safeReceipt}</button>`;
}

async function loadStudentsPage(schoolYear = null) {
    const tbody = document.getElementById('students-page-tbody');
    if (tbody) tbody.innerHTML = '<tr class="empty-row"><td colspan="7">Loading students…</td></tr>';

    const sySel = document.getElementById('students-filter-sy');

    // Init the SY dropdown only once
    await initStudentsPageFilters();

    const selectedSY = schoolYear || sySel?.value || '';

    try {
        const url = selectedSY
            ? `/Home/GetTreasurerStudentsWithFees?schoolYear=${encodeURIComponent(selectedSY)}`
            : '/Home/GetTreasurerStudentsWithFees';

        const res = await fetch(url);
        const data = await res.json();
        if (!data.success) {
            if (tbody) tbody.innerHTML = `<tr class="empty-row"><td colspan="7">${escapeHtml(data.message || 'Failed to load students.')}</td></tr>`;
            return;
        }
        ALL_STUDENTS_PAGE = data.students || [];

        // Resolve which semester is "current" for this school year (and the
        // fallback the breakdown/status filter use for past years).
        computeSemContext();
        updateSemHeaderIndicators();

        // Only refresh course filter, NOT school year dropdown
        populateStudentsPageFilters();
        applyStudentsPageFilters();
    } catch (err) {
        console.error('Failed to load students page:', err);
        if (tbody) tbody.innerHTML = '<tr class="empty-row"><td colspan="7">Failed to load students.</td></tr>';
    }
}

function renderStudentsPage(filtered) {
  // Default ordering is a "stack": the most recently recorded payment sits at the
  // top. Students with no payment fall to the bottom, then ties break by name.
  const data = (filtered ?? ALL_STUDENTS_PAGE)
    .slice()
    .sort((a, b) => {
      const ta = a.lastPaymentDate ? new Date(a.lastPaymentDate).getTime() : 0;
      const tb = b.lastPaymentDate ? new Date(b.lastPaymentDate).getTime() : 0;
      if (tb !== ta) return tb - ta;
      return String(a.name || '').localeCompare(String(b.name || ''), undefined, { sensitivity: 'base' });
    });
  _lastStudentsFiltered = data;
  const tbody = document.getElementById('students-page-tbody');
  if (!tbody) return;

  if (!data.length) {
    tbody.innerHTML = '<tr class="empty-row"><td colspan="7">No students found.</td></tr>';
    return;
  }

  // Renders the receipt buttons for one semester. A semester can hold more than
  // one receipt (e.g. two partial payments); each opens the receipt modal.
  const receiptBtns = (receipts) => {
    if (!receipts || !receipts.length) return '<span style="color:var(--text-d)">—</span>';
    return receipts.map(rc => {
      const safe = String(rc.receiptNumber || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
      return `<button type="button" class="btn-outline" style="padding:2px 6px;font-size:10px;font-family:'DM Mono',monospace"
                onclick="viewReceipt('OrgFee', ${rc.paymentId}, '${safe}')">${escapeHtml(rc.receiptNumber || '')}</button>`;
    }).join(' ');
  };

  tbody.innerHTML = data.map((s, i) => {
    const courseYr = `${escapeHtml(s.courseCode)} ${escapeHtml(fmtYearSection(s.yearSection))}`;
    const roleTag = s.role === 'Treasurer'
      ? ' <span style="font-size:10px;font-weight:600;background:rgba(249,115,22,.15);color:#fdba74;border:1px solid rgba(249,115,22,.25);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Treasurer</span>'
      : '';
    const inactiveTag = !s.isActive
      ? ' <span style="font-size:10px;font-weight:600;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Inactive</span>'
      : '';

    // Build a sem cell: Balance · Amount Paid · Status · Receipts, stacked.
    // Graduated/N/A students collapse to a single "N/A" row instead of zeroed lines.
    const semCell = (required, paid, status, receipts) => {
      if ((status || '').toLowerCase() === 'n/a' || (required <= 0 && paid <= 0)) {
        return `<div style="color:var(--text-d);font-size:11px">N/A</div>`;
      }
      const bal = Math.max(0, (required || 0) - (paid || 0));
      const balColor = bal > 0 ? '#f87171' : '#5fdd8e';
      return `
        <div style="display:flex;flex-direction:column;gap:2px;font-family:'DM Mono',monospace;font-size:11px;line-height:1.35">
          <div style="color:${balColor}"><span style="color:var(--text-d);font-family:inherit">Bal:</span> ${p(bal)}</div>
          <div style="color:var(--text)"><span style="color:var(--text-d)">Paid:</span> ${p(paid || 0)}</div>
          <div>${feeStatusBadge(status)}</div>
          <div style="display:flex;flex-wrap:wrap;gap:4px;align-items:center;margin-top:2px;font-family:'DM Sans',sans-serif">
            <span style="color:var(--text-d);font-size:10px">Receipts:</span> ${receiptBtns(receipts)}
          </div>
        </div>`;
    };

    return `<tr>
      <td class="td-mono td-m">${i + 1}</td>
      <td class="td-mono td-m">${escapeHtml(s.schoolId)}</td>
      <td><strong>${escapeHtml(s.name)}</strong>${roleTag}${inactiveTag}</td>
      <td class="td-m">${courseYr}</td>
      <td>${semCell(s.firstSemRequired,  s.firstSemPaid,  s.firstSemStatus,  s.firstSemReceipts)}</td>
      <td>${semCell(s.secondSemRequired, s.secondSemPaid, s.secondSemStatus, s.secondSemReceipts)}</td>
      <td>
        <button class="btn-outline" title="View Org Fees" aria-label="View Org Fees"
                style="padding:6px 8px;display:inline-flex;align-items:center;justify-content:center"
                onclick="openStudentOrgFeeModal(${s.userId})">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </button>
      </td>
    </tr>`;
  }).join('');
}

// Resolve which semester the breakdown + status filter operate on.
//  _currentSem   = the live semester for the loaded school year, or null (past year).
//  _breakdownSem = _currentSem when there is one, otherwise a sensible fallback
//                  (the later semester that has a fee) so the card still works.
function computeSemContext() {
  const s = ALL_STUDENTS_PAGE[0];
  let current = null;
  if (s) {
    if (s.firstSemIsCurrent) current = 'first';
    else if (s.secondSemIsCurrent) current = 'second';
  }
  _currentSem = current;
  if (current) {
    _breakdownSem = current;
  } else if (s && (s.secondSemRequired || 0) > 0) {
    _breakdownSem = 'second';
  } else {
    _breakdownSem = 'first';
  }
}

// Put a "Current" badge on whichever semester column is the live one. Only the
// real current semester gets the badge — past school years show none.
function updateSemHeaderIndicators() {
  const badge = '<span style="font-size:9px;font-weight:700;background:var(--green-glow);color:#5fdd8e;border:1px solid rgba(74,222,128,.3);border-radius:5px;padding:1px 6px;margin-left:6px;letter-spacing:.04em;text-transform:uppercase;vertical-align:middle">Current</span>';
  const b1 = document.getElementById('th-sem1-badge');
  const b2 = document.getElementById('th-sem2-badge');
  if (b1) b1.innerHTML = _currentSem === 'first'  ? badge : '';
  if (b2) b2.innerHTML = _currentSem === 'second' ? badge : '';
}

// Count students by org-fee status for the current semester. Uses the list
// filtered by search/course/year/SY (but NOT the status filter, so the card
// always shows the full distribution).
function renderPaymentBreakdown() {
  const list = _lastStudentsForBreakdown || [];
  const key = _breakdownSem === 'second' ? 'secondSemStatus' : 'firstSemStatus';

  let paid = 0, partial = 0, unpaid = 0;
  list.forEach(s => {
    switch ((s[key] || '').toLowerCase()) {
      case 'paid':    paid++;    break;
      case 'partial': partial++; break;
      case 'unpaid':  unpaid++;  break;
      // 'n/a' (graduated / not applicable) is intentionally excluded
    }
  });

  const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  set('bd-total',   list.length);
  set('bd-paid',    paid);
  set('bd-partial', partial);
  set('bd-unpaid',  unpaid);

  const lbl = document.getElementById('bd-sem-label');
  if (lbl) {
    const semText = _breakdownSem === 'second' ? '2nd Semester' : '1st Semester';
    lbl.textContent = _currentSem ? `Current · ${semText}` : semText;
  }
}

// Shortcut: jump straight to the Record Payment page with the Org Fee tab active.
function goToOrgFeePayment() {
  const incomeNav = document.querySelector('.nav-item[onclick*="income"]');
  showPage('income', incomeNav);
  setTimeout(() => { if (typeof switchIncomeTab === 'function') switchIncomeTab('orgfee'); }, 60);
}

// "Default" button: clear search + status + course + year, set school year back
// to the current one, and return the list to its default latest-payment stack.
function resetStudentsPageFilters() {
  studentsPageQ = '';
  const search = document.getElementById('students-search');
  if (search) search.value = '';

  const statusSel = document.getElementById('students-filter-status');
  if (statusSel) statusSel.value = '';
  const courseSel = document.getElementById('students-filter-course');
  if (courseSel) courseSel.value = '';
  const yearSel = document.getElementById('students-filter-year');
  if (yearSel) yearSel.value = '';

  const sySel = document.getElementById('students-filter-sy');
  if (sySel && CURRENT_SCHOOL_YEAR && CURRENT_SCHOOL_YEAR.yearStart) {
    const cur = `${CURRENT_SCHOOL_YEAR.yearStart}–${CURRENT_SCHOOL_YEAR.yearEnd}`;
    const hasOption = [...sySel.options].some(o => o.value === cur);
    sySel.value = hasOption ? cur : '';
  }

  // Reload for the (now current) school year, which re-renders with the stack sort.
  loadStudentsPage(sySel ? sySel.value : null);
}

function filterStudentsPage(q) {
  studentsPageQ = (q || '').toLowerCase().trim();
  applyStudentsPageFilters();
}

// Call this ONCE on initial page load
async function initStudentsPageFilters() {
    const sySel = document.getElementById('students-filter-sy');
    if (!sySel || sySel.dataset.listenerAttached) return;

    try {
        const res = await fetch('/Home/GetSchoolYears');
        const data = await res.json();
        if (!data.success) return;

        const currentSY = data.schoolYears.find(sy => sy.yearStatus === 'Current');

        sySel.innerHTML = data.schoolYears.map(sy =>
            `<option value="${sy.yearStart}–${sy.yearEnd}">${sy.yearStart}–${sy.yearEnd}</option>`
        ).join('');

        if (currentSY) {
            sySel.value = `${currentSY.yearStart}–${currentSY.yearEnd}`;
        }

        sySel.dataset.listenerAttached = 'true';
        sySel.addEventListener('change', async () => {
            await loadStudentsPage(sySel.value);
            await refreshDashboardStats();
        });
    } catch {}
}

// Call this every time data reloads — only refreshes course filter
function populateStudentsPageFilters() {
    const courseSel = document.getElementById('students-filter-course');
    if (!courseSel) return;

    const courses = [...new Set(ALL_STUDENTS_PAGE.map(s => (s.courseCode || '').trim()).filter(Boolean))]
        .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: 'base' }));

    const prevCourse = courseSel.value;
    courseSel.innerHTML = '<option value="">All Courses</option>' +
        courses.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('');

    // Restore previously selected course
    if (prevCourse) courseSel.value = prevCourse;
}

function applyStudentsPageFilters() {
  studentsPageCourse = document.getElementById('students-filter-course')?.value || '';
  const yearFilter = document.getElementById('students-filter-year')?.value || '';
  const statusFilter = document.getElementById('students-filter-status')?.value || '';

  // Base list: everything except the payment-status filter. The breakdown card
  // counts this, so its Paid/Partial/Unpaid totals always reflect the full
  // distribution and don't collapse when a status is selected.
  const base = ALL_STUDENTS_PAGE.filter(s => {
    const name = (s.name || '').toLowerCase();
    const schoolId = (s.schoolId || '').toLowerCase();
    const course = (s.courseCode || '').toLowerCase();
    const yearSection = (s.yearSection || '').toLowerCase();
    const matchesQ = !studentsPageQ
      || name.includes(studentsPageQ) || schoolId.includes(studentsPageQ)
      || course.includes(studentsPageQ) || yearSection.includes(studentsPageQ);
    const matchesCourse = !studentsPageCourse || (s.courseCode || '') === studentsPageCourse;
    // yearSection looks like "3-A" → the year level is the part before the dash.
    const studentYear = (s.yearSection || '').split('-')[0].trim();
    const matchesYear = !yearFilter || studentYear === yearFilter;
    return matchesQ && matchesCourse && matchesYear;
  });

  _lastStudentsForBreakdown = base;
  renderPaymentBreakdown();

  // Table list: optionally narrowed to the chosen payment status (matched against
  // the current semester's status, same semester the breakdown uses).
  const statusKey = _breakdownSem === 'second' ? 'secondSemStatus' : 'firstSemStatus';
  const filtered = statusFilter
    ? base.filter(s => (s[statusKey] || '').toLowerCase() === statusFilter.toLowerCase())
    : base;

  renderStudentsPage(filtered);
}

async function openStudentOrgFeeModal(userId) {
  const nameEl = document.getElementById('student-orgfee-name');
  const subEl = document.getElementById('student-orgfee-sub');
  const tbody = document.getElementById('student-orgfee-tbody');

  // Stash the userId so refreshes after edit can reload the same student.
  window._currentOrgFeeUserId = userId;

  nameEl.textContent = 'Student Org Fees';
  subEl.textContent = 'Loading…';
  tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-d)">Loading…</td></tr>';
  openModal('modal-student-orgfee');

  try {
    const res = await fetch('/Home/GetStudentOrgFeeDetails?userId=' + encodeURIComponent(userId));
    const data = await res.json();
    if (!data.success) {
      subEl.textContent = data.message || 'Unable to load org fee details.';
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-d)">No data available.</td></tr>';
      return;
    }

    const s = data.student;
    nameEl.textContent = s.name;
    subEl.textContent = `${s.schoolId} · ${s.courseCode} ${s.yearSection}${s.role === 'Treasurer' ? ' · Treasurer' : ''}${data.schoolYear ? ' · A.Y. ' + data.schoolYear : ''}`;

    const fees = data.fees || [];
    const txs  = data.transactions || [];

    if (!fees.length && !txs.length) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-d)">No org fee records.</td></tr>';
      return;
    }

    // ── HYBRID LAYOUT ──
    // Build a unified key set: every (schoolYear, semester) from BOTH fees and txs,
    // so a payment to a semester that no longer has an open fee still shows up,
    // and a current semester with no payments still appears as an unpaid row.
    const groupKey = (sy, sem) => `${sy || ''}|${sem || ''}`;
    const groups = new Map();

    // Seed from fees (semesters that should appear even with no payments)
    fees.forEach(f => {
      const k = groupKey(f.schoolYear, f.semester);
      if (!groups.has(k)) groups.set(k, { schoolYear: f.schoolYear, semester: f.semester, fee: null, payments: [] });
      groups.get(k).fee = f;
    });

    // Add any payment-only groups (e.g. fully-paid prior semester that fees[] omitted)
    txs.forEach(t => {
      const k = groupKey(t.schoolYear, t.semester);
      if (!groups.has(k)) groups.set(k, { schoolYear: t.schoolYear, semester: t.semester, fee: null, payments: [] });
      groups.get(k).payments.push(t);
    });

    // Distribute payments into their groups (in case fee existed first)
    groups.forEach(g => { g.payments = []; });
    txs.forEach(t => {
      const k = groupKey(t.schoolYear, t.semester);
      groups.get(k).payments.push(t);
    });

    // Sort: the current school-year + semester floats to the very top, then the
    // rest fall in most-recent-first order (newer year first, 2nd sem before 1st).
    const sorted = [...groups.values()].sort((a, b) => {
      const aCur = a.fee && a.fee.isCurrent ? 1 : 0;
      const bCur = b.fee && b.fee.isCurrent ? 1 : 0;
      if (aCur !== bCur) return bCur - aCur;
      const sa = parseInt((a.schoolYear || '').split('–')[0], 10) || 0;
      const sb = parseInt((b.schoolYear || '').split('–')[0], 10) || 0;
      if (sa !== sb) return sb - sa;
      const semOrder = { 'First': 1, 'Second': 2 };
      return (semOrder[b.semester] || 0) - (semOrder[a.semester] || 0);
    });

    // Build rows. Each group emits one parent semester row plus a nested payment row per payment.
    const html = sorted.map(g => {
      const semLabel = g.semester === 'First' ? '1st Semester'
                     : g.semester === 'Second' ? '2nd Semester' : (g.semester || '—');
      const totalPaid = g.payments.reduce((s, p) => s + (p.amount || 0), 0);
      const required = g.fee?.requiredAmount ?? null;
      const balance  = g.fee ? g.fee.balance : (required != null ? Math.max(0, required - totalPaid) : 0);
      // Derive the status straight from the figures we actually display (balance +
      // amount paid) so the badge can never contradict them. A balance of 0 with at
      // least one payment must read "Paid", never "Partial".
      let status;
      if (required != null && required <= 0) {
        status = 'N/A';
      } else if (totalPaid <= 0) {
        status = 'Unpaid';
      } else if (balance <= 0) {
        status = 'Paid';
      } else {
        status = 'Partial';
      }
      const balColor = balance > 0 ? '#f87171' : '#5fdd8e';

      const summaryHtml = `
        <div style="display:flex;flex-direction:column;gap:2px;font-family:'DM Mono',monospace;font-size:11px;line-height:1.35">
          <div style="color:${balColor}"><span style="color:var(--text-d);font-family:inherit">Bal:</span> ${p(balance)}</div>
          <div style="color:var(--text)"><span style="color:var(--text-d)">Paid:</span> ${p(totalPaid)}</div>
          <div>${feeStatusBadge(status)}</div>
        </div>`;

      const parentRow = `
        <tr style="border-top:1px solid rgba(255,255,255,.07);background:rgba(255,255,255,.02)">
          <td style="padding:10px 12px;color:var(--text);font-weight:600">${semLabel}<br><span style="font-size:10.5px;font-weight:400;color:var(--text-d);font-family:'DM Mono',monospace">${escapeHtml(g.schoolYear || '—')}</span></td>
          <td style="padding:10px 12px">${summaryHtml}</td>
          <td style="padding:10px 12px;color:var(--text-d);font-size:11px">${g.payments.length ? g.payments.length + ' payment' + (g.payments.length === 1 ? '' : 's') : 'No payments'}</td>
          <td></td>
          <td></td>
        </tr>`;

      const paymentRows = g.payments
        .slice()
        .sort((a, b) => new Date(a.date) - new Date(b.date))
        .map(t => {
          const receiptCell = renderReceiptCell(t.paymentId, t.receiptNumber, t.hasReceipt);
          const safeReceipt = (t.receiptNumber || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
          const actions = `
            <div style="display:inline-flex;gap:6px;justify-content:flex-end">
              <button class="btn-outline" title="Print" aria-label="Print"
                      style="padding:5px 7px;display:inline-flex;align-items:center;justify-content:center"
                      onclick="printPaymentReceipt(${t.paymentId}, '${safeReceipt}')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              </button>
              <button class="btn-outline" title="Edit amount" aria-label="Edit amount"
                      style="padding:5px 7px;display:inline-flex;align-items:center;justify-content:center"
                      onclick="editPaymentFromModal(${t.paymentId})">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
            </div>`;
          return `
            <tr>
              <td style="padding:8px 12px;padding-left:28px;color:var(--text-d);font-size:11px">↳ payment</td>
              <td style="padding:8px 12px;text-align:left;font-family:'DM Mono',monospace;font-size:12px;color:#5fdd8e">${p(t.amount)}</td>
              <td style="padding:8px 12px">${receiptCell}</td>
              <td style="padding:8px 12px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text-m)">${fd(t.date)}</td>
              <td style="padding:8px 12px;text-align:right">${actions}</td>
            </tr>`;
        }).join('');

      return parentRow + paymentRows;
    }).join('');

    tbody.innerHTML = html;
  } catch (err) {
    console.error('Failed to load student org fee details:', err);
    subEl.textContent = 'Failed to load org fee details.';
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-d)">Request failed.</td></tr>';
  }
}

// Close the student org-fee modal and forget the current student, so a later
// edit on an unrelated payment (e.g. from the History page) doesn't re-open it.
function closeStudentOrgFeeModal() {
  window._currentOrgFeeUserId = null;
  closeModal('modal-student-orgfee');
}

// Wait for the receipt-paper element to appear in the DOM after viewReceipt
// kicks off its render. Falls back to a hard timeout so we always print eventually.
function awaitReceiptReady(timeoutMs = 2500) {
  return new Promise(resolve => {
    const start = Date.now();
    const tick = () => {
      const paper = document.querySelector('.receipt-paper');
      // The paper exists once its container modal is open; check visibility too
      // so we don't print an empty paper that's still being populated.
      const modalOpen = document.querySelector('.receipt-modal.open');
      if (paper && modalOpen && paper.textContent.trim().length > 0) {
        // Give the browser one extra frame to actually paint
        requestAnimationFrame(() => resolve(true));
        return;
      }
      if (Date.now() - start > timeoutMs) { resolve(false); return; }
      setTimeout(tick, 60);
    };
    tick();
  });
}

// Print the receipt. The @@media print stylesheet hides everything except the
// .receipt-paper, so only the receipt itself appears in the print preview.
//
// IMPORTANT — the date and URL at the top of the printed page come from the
// browser, not from this code. They cannot be removed by CSS or JS; the user
// must uncheck "Headers and footers" in the print dialog's More Settings
// (the browser remembers this setting). We blank the document title for the
// duration of the print so at least that part of the header is empty.
async function printPaymentReceipt(paymentId, receiptNumber) {
  await viewReceipt('OrgFee', paymentId, receiptNumber);
  await awaitReceiptReady();

  showToast('Tip: in More settings, uncheck "Headers and footers" for a clean print.', 'ok');

  const originalTitle = document.title;
  document.title = ' ';
  try {
    window.print();
  } finally {
    setTimeout(() => { document.title = originalTitle; }, 250);
  }
}

