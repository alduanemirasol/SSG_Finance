      }).join('')
    : `<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-d)">No applicable fees found.</td></tr>`;

  return `
    <div style="font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:10px">Current Fees</div>
    <div style="border:1px solid rgba(255,255,255,.08);border-radius:10px;overflow:hidden">
      <table style="width:100%;border-collapse:collapse;font-size:12px">
        <thead>
          <tr style="background:rgba(255,255,255,.04)">
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">School Year</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Semester</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Balance</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Amount</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Status</th>
          </tr>
        </thead>
        <tbody>
          ${rowsHtml}
        </tbody>
      </table>
    </div>`;
}

function renderReceiptCell(paymentId, receiptNumber, hasReceipt) {
  if (!hasReceipt || !receiptNumber || receiptNumber === '—') {
    return '<span style="color:var(--text-d)">—</span>';
  }
  const safeReceipt = escapeHtml(receiptNumber);
  const receiptArg = String(receiptNumber).replace(/\\/g, '\\\\').replace(/'/g, "\\'");
  return `<button type="button" class="btn-outline" style="padding:3px 8px;font-size:10.5px;font-family:'DM Mono',monospace" onclick="printPaymentReceipt(${paymentId}, '${receiptArg}')">${safeReceipt}</button>`;
}

async function loadStudentsPage(schoolYear = null) {
    const tbody = document.getElementById('students-page-tbody');
    if (tbody) tbody.innerHTML = '<tr class="empty-row"><td colspan="7">Loading students…</td></tr>';

    const sySel = document.getElementById('students-filter-sy');

    // Init the SY dropdown only once
    await initStudentsPageFilters();

    const selectedSY = schoolYear || sySel?.value || '';

    try {
        const url = selectedSY
            ? `/Home/GetTreasurerStudentsWithFees?schoolYear=${encodeURIComponent(selectedSY)}`
            : '/Home/GetTreasurerStudentsWithFees';

        const res = await fetch(url);
        const data = await res.json();
        if (!data.success) {
            if (tbody) tbody.innerHTML = `<tr class="empty-row"><td colspan="7">${escapeHtml(data.message || 'Failed to load students.')}</td></tr>`;
            return;
        }
        ALL_STUDENTS_PAGE = data.students || [];

        // Resolve which semester is "current" for this school year (and the
        // fallback the breakdown/status filter use for past years).
        computeSemContext();
        updateSemHeaderIndicators();

        // Only refresh course filter, NOT school year dropdown
        populateStudentsPageFilters();
        applyStudentsPageFilters();
    } catch (err) {
        console.error('Failed to load students page:', err);
        if (tbody) tbody.innerHTML = '<tr class="empty-row"><td colspan="8">Failed to load students.</td></tr>';
    }
}

function renderStudentsPage(filtered) {
  // Default ordering is a "stack": the most recently recorded payment sits at the
  // top. Students with no payment fall to the bottom, then ties break by name.
  const data = (filtered ?? ALL_STUDENTS_PAGE)
    .slice()
    .sort((a, b) => {
      const ta = a.lastPaymentDate ? new Date(a.lastPaymentDate).getTime() : 0;
      const tb = b.lastPaymentDate ? new Date(b.lastPaymentDate).getTime() : 0;
      if (tb !== ta) return tb - ta;
      return String(a.name || '').localeCompare(String(b.name || ''), undefined, { sensitivity: 'base' });
    });
  _lastStudentsFiltered = data;
  const tbody = document.getElementById('students-page-tbody');
  if (!tbody) return;

  if (!data.length) {
    tbody.innerHTML = '<tr class="empty-row"><td colspan="7">No students found.</td></tr>';
    return;
  }

  tbody.innerHTML = data.map((s, i) => {
    const courseYr = `${escapeHtml(s.courseCode)} ${escapeHtml(fmtYearSection(s.yearSection))}`;
    const roleTag = s.role === 'Treasurer'
      ? ' <span style="font-size:10px;font-weight:600;background:rgba(249,115,22,.15);color:#fdba74;border:1px solid rgba(249,115,22,.25);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Treasurer</span>'
      : '';
    const inactiveTag = !s.isActive
      ? ' <span style="font-size:10px;font-weight:600;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Inactive</span>'
      : '';

    // Is the 1st semester settled? (fully paid, or nothing was ever owed.) The
    // 2nd-semester Pay button stays locked until this is true, so payments are
    // always applied to the earlier term first.
    const firstSettled = Math.max(0, (s.firstSemRequired || 0) - (s.firstSemPaid || 0)) <= 0;

    // Sem cell: balance + Pay button, or Paid badge. semNum is 1 or 2; the 2nd
    // semester only shows a Pay button once the 1st semester is settled.
    const semCell = (required, paid, status, semNum) => {
      const sl = (status || '').toLowerCase();
      if (sl === 'n/a' || (!required && !paid)) return '<span style="color:var(--text-d);font-size:11px">—</span>';
      if (sl === 'paid') return '<span style="font-family:\'DM Mono\',monospace;font-size:12px;color:#5fdd8e">₱0.00 <span style="color:var(--text-d)">(paid)</span></span>';
      const bal = Math.max(0, (required || 0) - (paid || 0));
      const balSpan = `<span style="font-family:'DM Mono',monospace;font-size:12px;color:#f87171">₱${bal.toFixed(2)}</span>`;
      if (semNum === 2 && !firstSettled) {
        return `<div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
          ${balSpan}
          <span class="tip-wrap">
            <span style="font-size:10px;color:var(--text-d);display:inline-flex;align-items:center;gap:3px;cursor:default">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Locked
            </span>
            <span class="tip">Settle 1st semester first</span>
          </span>
        </div>`;
      }
      return `<div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
        ${balSpan}
        <button type="button" class="btn-primary" style="padding:2px 10px;font-size:10.5px;border-radius:5px"
                onclick="quickPayStudent(${s.userId}, ${semNum}, ${parseInt(s.schoolYear) || 'null'})">Pay</button>
      </div>`;
    };

    return `<tr>
      <td class="td-mono td-m">${i + 1}</td>
      <td class="td-mono td-m">${escapeHtml(s.schoolId)}</td>
      <td><strong>${escapeHtml(s.name)}</strong>${roleTag}${inactiveTag}</td>
      <td class="td-m">${courseYr}</td>
      <td>${semCell(s.firstSemRequired,  s.firstSemPaid,  s.firstSemStatus,  1)}</td>
      <td>${semCell(s.secondSemRequired, s.secondSemPaid, s.secondSemStatus, 2)}</td>
      <td style="text-align:center;vertical-align:middle">
        <div style="display:inline-flex;gap:6px;justify-content:center;align-items:center">
          <div class="tip-wrap">
            <button class="btn-outline" style="padding:5px 7px;display:inline-flex;align-items:center;justify-content:center"
                    onclick="openStudentOrgFeeModal(${s.userId})">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <span class="tip">Ledger</span>
          </div>
          <div class="tip-wrap">
            <button class="${s.schoolYearId ? 'btn-outline' : 'btn-primary'}" style="padding:5px 7px;display:inline-flex;align-items:center;justify-content:center"
                    onclick="openPaymentStartModal(${s.userId})">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </button>
            <span class="tip">Set the term from which the student begins to be charged fees</span>
          </div>
        </div>
      </td>
    </tr>`;
  }).join('');
}

// ── STUDENT LIST ROW ACTIONS ─────────────────────────────────────────────
// Look up a loaded student row by userId (search the filtered set first, then all).
function findStudentRow(userId) {
  const list = (_lastStudentsFiltered && _lastStudentsFiltered.length)
    ? _lastStudentsFiltered : ALL_STUDENTS_PAGE;
  return (list || []).find(x => String(x.userId) === String(userId)) || null;
}

// PRINT — fully client-side. Opens a clean printable summary of the student's
// org-fee standing built from the row data already on screen (no server call).
function printStudentRecord(userId) {
  const s = findStudentRow(userId);
  if (!s) { showToast('Student not found.', 'fail'); return; }

  const row = (label, required, paid, status) => {
    const bal = Math.max(0, (required || 0) - (paid || 0));
    return `<tr>
      <td>${label}</td>
      <td style="text-align:right">${p(required || 0)}</td>
      <td style="text-align:right">${p(paid || 0)}</td>
      <td style="text-align:right">${p(bal)}</td>
      <td>${escapeHtml(status || '—')}</td>
    </tr>`;
  };

  const win = window.open('', '_blank', 'width=820,height=900');
  if (!win) { showToast('Pop-up blocked. Allow pop-ups to print.', 'fail'); return; }
  win.document.write(`<!DOCTYPE html><html><head><meta charset="utf-8">
    <title>Student Record — ${escapeHtml(s.name)}</title>
    <style>
      *{font-family:'Segoe UI',Arial,sans-serif;color:#111}
      body{padding:38px 44px}
      h1{font-size:20px;margin:0 0 2px}
      .sub{color:#555;font-size:13px;margin-bottom:22px}
      table{width:100%;border-collapse:collapse;margin-top:10px;font-size:13px}
      th,td{padding:9px 10px;border-bottom:1px solid #e5e7eb;text-align:left}
      th{font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#555;background:#f8fafc}
      .meta{font-size:13px;line-height:1.7;margin-bottom:8px}
      .meta b{display:inline-block;min-width:130px;color:#444}
      .ft{margin-top:34px;font-size:11px;color:#888}
      @@media print{body{padding:18px}}
    </style></head><body>
    <h1>Student Org-Fee Record</h1>
    <div class="sub">SSG Finance Management System</div>
    <div class="meta"><b>Name:</b> ${escapeHtml(s.name)}</div>
    <div class="meta"><b>CTU ID:</b> ${escapeHtml(s.schoolId || '—')}</div>
    <div class="meta"><b>Course · Year & Section:</b> ${escapeHtml(s.courseCode || '')} ${escapeHtml(fmtYearSection(s.yearSection) || '')}</div>
    <table>
      <thead><tr><th>Semester</th><th style="text-align:right">Required</th><th style="text-align:right">Paid</th><th style="text-align:right">Balance</th><th>Status</th></tr></thead>
      <tbody>
        ${row('1st Semester', s.firstSemRequired, s.firstSemPaid, s.firstSemStatus)}
        ${row('2nd Semester', s.secondSemRequired, s.secondSemPaid, s.secondSemStatus)}
      </tbody>
    </table>
    <div class="ft">Printed ${new Date().toLocaleString('en-PH')}</div>
    <script>window.onload=function(){window.print();}<\/script>
    </body></html>`);
  win.document.close();
}

// EDIT AMOUNT — opens the per-student amount editor.
function openEditAmountModal(userId) {
  const s = findStudentRow(userId);
  if (!s) { showToast('Student not found.', 'fail'); return; }
  document.getElementById('edit-amount-userid').value = userId;
  document.getElementById('edit-amount-sub').textContent =
    `${s.name} · ${s.schoolId || ''}`.trim();
  // Default the semester picker to the current semester if known.
  const semSel = document.getElementById('edit-amount-sem');
  semSel.value = (_currentSem === 'second') ? 'Second' : 'First';
  document.getElementById('edit-amount-value').value = '';
  openModal('modal-edit-amount');
}

async function submitEditAmount() {
  const userId   = document.getElementById('edit-amount-userid').value;
  const semester = document.getElementById('edit-amount-sem').value;
  const amount   = parseFloat(document.getElementById('edit-amount-value').value);
  if (!userId)                { showToast('Student not found.', 'fail'); return; }
  if (!amount || amount <= 0) { showToast('Please enter a valid amount.', 'fail'); return; }

  try {
    // Backend action to add: POST /Home/SetStudentFeeAmount
    //   body: { userId:int, semester:"First"|"Second", amount:decimal }
    //   returns: { success:bool, message:string }
    const res  = await fetch('/Home/SetStudentFeeAmount', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body:    JSON.stringify({ userId: parseInt(userId), semester, amount })
    });
    const data = await res.json();
    if (data.success) {
      showToast(data.message || 'Amount updated.', 'ok');
      closeModal('modal-edit-amount');
      await loadStudentsPage(document.getElementById('students-filter-sy')?.value || null);
    } else {
      showToast(data.message || 'Failed to update amount.', 'fail');
    }
  } catch { showToast('Request failed.', 'fail'); }
}

// PAYMENT START — picks the school year + semester from which this student's
// payment obligation begins (the two fields moved out of sign-up).
async function openPaymentStartModal(userId) {
  const s = findStudentRow(userId);
  if (!s) { showToast('Student not found.', 'fail'); return; }
  document.getElementById('payment-start-userid').value = userId;
  document.getElementById('payment-start-sub').textContent =
    `${s.name} · ${s.schoolId || ''}`.trim();

  // Populate school-year options from the same source the rest of the app uses.
  const sySel = document.getElementById('payment-start-sy');
  sySel.innerHTML = '<option value="">Loading…</option>';
  try {
    const res  = await fetch('/Home/GetSchoolYears');
    const data = await res.json();
    if (data.success && data.schoolYears.length) {
      sySel.innerHTML = data.schoolYears.map(sy => {
        const id    = sy.schoolYearId ?? sy.SchoolYearId;
        const label = `${sy.yearStart ?? sy.YearStart}–${sy.yearEnd ?? sy.YearEnd}`;
        return `<option value="${id}">${label}</option>`;
      }).join('');
      const cur = data.schoolYears.find(sy => (sy.yearStatus ?? sy.YearStatus) === 'Current');
      if (cur) sySel.value = String(cur.schoolYearId ?? cur.SchoolYearId);
    } else {
      sySel.innerHTML = '<option value="">No school years found</option>';
    }
  } catch {
    sySel.innerHTML = '<option value="">Failed to load</option>';
  }
  openModal('modal-payment-start');
}

