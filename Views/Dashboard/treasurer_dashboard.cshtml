function editFee(fullAmountId, currentAmount) {
    const newAmount = prompt('Enter new fee amount:', currentAmount);
    if (newAmount === null) return; // cancelled
    const amount = parseFloat(newAmount);
    if (!amount || amount <= 0) { showToast('Please enter a valid amount.', 'fail'); return; }

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    fetch('/Home/EditFee', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
        body: JSON.stringify({ fullAmountId, amount })
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) { showToast(data.message, 'ok'); refreshFees(); }
        else showToast(data.message, 'fail');
    })
    .catch(() => showToast('Request failed.', 'fail'));
}

async function changeFeeStatus(fullAmountId, currentStatus) {
    const newStatus = currentStatus === 'Current' ? 'Ended' : 'Current';
    if (!confirm(`Set this fee as ${newStatus}?`)) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    try {
        const res  = await fetch('/Home/SetFeeStatus', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
            body:    JSON.stringify({ fullAmountId, status: newStatus })
        });
        const data = await res.json();
        if (data.success) { showToast(data.message, 'ok'); refreshFees(); }
        else showToast(data.message, 'fail');
    } catch { showToast('Request failed.', 'fail'); }
}

async function viewReceipt(type, id, receipt) {
  document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));

  if (type !== 'OrgFee' || !receipt || receipt === '—') {
    showToast('No receipt number recorded for this entry.', 'fail');
    return;
  }

  try {
    const res = await fetch('/Home/GetOrgFeeReceipt?paymentId=' + encodeURIComponent(id));
    const data = await res.json();

    if (!data.success || !data.receipt) {
      showToast(data.message || 'Receipt not found.', 'fail');
      return;
    }

    const r = data.receipt;
    const amount = Number(r.amount || 0);
    const status = r.status || 'Partial';
    const issueDate = (r.paymentDate || r.issueDate) ? new Date(r.paymentDate || r.issueDate) : new Date();
    const formattedDate = issueDate.toLocaleDateString('en-PH', { month: '2-digit', day: '2-digit', year: '2-digit' });
    const semLabel = r.semester === 'First' ? '1st Semester' : r.semester === 'Second' ? '2nd Semester' : (r.semester || '');
    const term = [r.schoolYear, semLabel].filter(Boolean).join(' - ');
    const courseLine = [r.course, r.yearSection].filter(Boolean).join(' ');

    const studentName = (r.studentName || '').toUpperCase();
    const receiptNo   = r.receiptNumber || receipt;

    document.getElementById('tr-receipt-title').textContent = 'Receipt - ' + (term || 'Org Fee');

    // Populate both copies with the same data
    const copies = ['tr-rp', 'own-tr-rp'];
    copies.forEach(pfx => {
      const g = id => document.getElementById(`${pfx}-${id}`);
      if (g('receipt-no')) g('receipt-no').textContent = receiptNo;
      if (g('date'))       g('date').textContent       = formattedDate;
      if (g('name'))       g('name').textContent       = studentName || '—';
      if (g('id'))         g('id').textContent         = r.studentId || '—';
      if (g('course'))     g('course').textContent     = courseLine || '—';
      if (g('term'))       g('term').textContent       = term || '—';
      if (g('amount'))     g('amount').textContent     = '₱ ' + amount.toFixed(2);
      if (g('amount-words')) g('amount-words').textContent = amountToWords(amount);
      if (g('received-by'))  g('received-by').textContent = r.issuedByName || 'Treasurer';

      const statusEl = g('status');
      if (statusEl) { statusEl.textContent = status; statusEl.className = 'rp-status-badge ' + status.toLowerCase(); }

      const sigImg = g('sig-image');
      if (sigImg) {
        sigImg.removeAttribute('src');
        sigImg.style.display = 'none';
        if (r.signatureData) { sigImg.src = r.signatureData; sigImg.style.display = 'block'; }
      }
    });

    document.getElementById('treasurerReceiptModal').classList.add('open');
  } catch (err) {
    console.error('Failed to load receipt:', err);
    showToast('Failed to load receipt.', 'fail');
  }
}

