// Render the receipt-image thumbnails for an expense row (clickable to view full size).
function expenseReceiptCell(images) {
  const list = Array.isArray(images) ? images : [];
  if (!list.length) return '<span class="td-m" style="color:var(--text-d)">N/A</span>';
  const more  = list.length - 1;
  const badge = more > 0
    ? `<span style="position:absolute;bottom:-5px;right:-5px;min-width:18px;height:18px;padding:0 4px;border-radius:9px;background:#27a744;border:2px solid var(--card,#0f2918);color:#fff;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;line-height:1">+${more}</span>`
    : '';
  const data = escapeHtml(JSON.stringify(list));
  return `<div data-images="${data}" onclick="openExpenseGallery(this)"
               title="${list.length} receipt photo${list.length > 1 ? 's' : ''} — click to view"
               style="position:relative;display:inline-block;cursor:pointer">
            <img src="${escapeHtml(list[0])}"
                 style="width:38px;height:38px;object-fit:cover;border-radius:6px;border:1px solid rgba(255,255,255,.15);display:block"/>
            ${badge}
          </div>`;
}

// Receipt image gallery lightbox with prev/next navigation.
let EXPENSE_GALLERY = { images: [], index: 0 };

function openExpenseGallery(el) {
  let imgs = [];
  try { imgs = JSON.parse(el.getAttribute('data-images') || '[]'); } catch {}
  if (!imgs.length) return;
  EXPENSE_GALLERY = { images: imgs, index: 0 };
  renderExpenseGallery();
  document.getElementById('expense-image-modal').style.display = 'flex';
}

function renderExpenseGallery() {
  const { images, index } = EXPENSE_GALLERY;
  if (!images.length) return;
  document.getElementById('expense-image-modal-img').src = images[index];
  const multi = images.length > 1;
  const counter = document.getElementById('expense-gallery-counter');
  counter.textContent = `${index + 1} / ${images.length}`;
  counter.style.display = multi ? 'block' : 'none';
  document.getElementById('expense-gallery-prev').style.display = multi ? 'flex' : 'none';
  document.getElementById('expense-gallery-next').style.display = multi ? 'flex' : 'none';
}

function expenseGalleryPrev(e) {
  if (e) e.stopPropagation();
  const n = EXPENSE_GALLERY.images.length;
  if (!n) return;
  EXPENSE_GALLERY.index = (EXPENSE_GALLERY.index - 1 + n) % n;
  renderExpenseGallery();
}

function expenseGalleryNext(e) {
  if (e) e.stopPropagation();
  const n = EXPENSE_GALLERY.images.length;
  if (!n) return;
  EXPENSE_GALLERY.index = (EXPENSE_GALLERY.index + 1) % n;
  renderExpenseGallery();
}

function closeExpenseImageModal() {
  const modal = document.getElementById('expense-image-modal');
  if (modal) modal.style.display = 'none';
}

// Keyboard navigation while the gallery is open.
document.addEventListener('keydown', (e) => {
  const modal = document.getElementById('expense-image-modal');
  if (!modal || modal.style.display !== 'flex') return;
  if (e.key === 'ArrowLeft')       expenseGalleryPrev();
  else if (e.key === 'ArrowRight') expenseGalleryNext();
  else if (e.key === 'Escape')     closeExpenseImageModal();
});

