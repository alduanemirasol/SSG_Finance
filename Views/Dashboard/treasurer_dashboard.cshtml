// ── UTILS ────────────────────────────────────────────────────────
function p(n) { return '₱' + Number(n).toLocaleString('en-PH', { minimumFractionDigits: 2 }); }
function fd(d) {
  if (!d) return '—';
  return new Date(d.split('T')[0] + 'T00:00').toLocaleDateString('en-PH', { month: 'short', day: 'numeric', year: 'numeric' });
}
function today() { return new Date().toISOString().split('T')[0]; }
// Build an ISO timestamp for a YYYY-MM-DD date.
// If it's today's date, stamp the current time so freshly-added entries
// sort to the top of history; otherwise use midnight of that day.
function toTimestamp(dateStr) {
  if (dateStr === today()) return new Date().toISOString();
  return new Date(dateStr + 'T00:00:00').toISOString();
}
function orgFeeFrom(x) {
  // From for org fees: Name · ID · Course Year-Section
  const parts = [
    x.name || '—',
    x.schoolId ? 'ID: ' + x.schoolId : '',
    [x.course, x.yr].filter(Boolean).join(' ')
  ].filter(Boolean);
  return parts.join(' · ');
}
