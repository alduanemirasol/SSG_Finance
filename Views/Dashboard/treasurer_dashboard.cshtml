}

// "Default" button: clear search + status + course + year, set school year back
// to the current one, and return the list to its default latest-payment stack.
async function resetStudentsPageFilters() {
  studentsPageQ = '';
  const search = document.getElementById('students-search');
  if (search) search.value = '';

  const statusSel = document.getElementById('students-filter-status');
  if (statusSel) statusSel.value = '';
  const courseSel = document.getElementById('students-filter-course');
  if (courseSel) courseSel.value = '';
  const yearSel = document.getElementById('students-filter-year');
  if (yearSel) yearSel.value = '';

  const sySel = document.getElementById('students-filter-sy');
  if (sySel && CURRENT_SCHOOL_YEAR && CURRENT_SCHOOL_YEAR !== 'Not Set') {
    const normalizedCurrent = CURRENT_SCHOOL_YEAR.replace(/\s*[–-]\s*/g, '–');
    const hasOption = [...sySel.options].some(o => o.value === normalizedCurrent);
    sySel.value = hasOption ? normalizedCurrent : '';
  }

  // Reload for the (now current) school year, which re-renders with the stack sort.
  await loadStudentsPage(sySel ? sySel.value : null);
  await refreshDashboardStats();
}

function filterStudentsPage(q) {
  studentsPageQ = (q || '').toLowerCase().trim();
  applyStudentsPageFilters();
}

// Call this ONCE on initial page load
async function initStudentsPageFilters() {
    const sySel = document.getElementById('students-filter-sy');
    if (!sySel || sySel.dataset.listenerAttached) return;

    try {
        const res = await fetch('/Home/GetSchoolYears');
        const data = await res.json();
        if (!data.success) return;

        const currentSY = data.schoolYears.find(sy => sy.yearStatus === 'Current');

        sySel.innerHTML = data.schoolYears.map(sy =>
            `<option value="${sy.yearStart}–${sy.yearEnd}">${sy.yearStart}–${sy.yearEnd}</option>`
        ).join('') + '<option value="">All School Years</option>';

        if (currentSY) {
            sySel.value = `${currentSY.yearStart}–${currentSY.yearEnd}`;
        }

        sySel.dataset.listenerAttached = 'true';
        sySel.addEventListener('change', async () => {
            await loadStudentsPage(sySel.value);
            await refreshDashboardStats();
        });
    } catch {}
}

// Call this every time data reloads — only refreshes course filter
function populateStudentsPageFilters() {
    const courseSel = document.getElementById('students-filter-course');
    if (!courseSel) return;

    const courses = [...new Set(ALL_STUDENTS_PAGE.map(s => (s.courseCode || '').trim()).filter(Boolean))]
        .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: 'base' }));

    const prevCourse = courseSel.value;
    courseSel.innerHTML = '<option value="">All Courses</option>' +
        courses.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('');

    // Restore previously selected course
    if (prevCourse) courseSel.value = prevCourse;
}

function applyStudentsPageFilters() {
  studentsPageCourse = document.getElementById('students-filter-course')?.value || '';
  const yearFilter = document.getElementById('students-filter-year')?.value || '';
  const statusFilter = document.getElementById('students-filter-status')?.value || '';

  // Base list: everything except the payment-status filter. The breakdown card
  // counts this, so its Paid/Partial/Unpaid totals always reflect the full
  // distribution and don't collapse when a status is selected.
  const base = ALL_STUDENTS_PAGE.filter(s => {
    const name = (s.name || '').toLowerCase();
    const schoolId = (s.schoolId || '').toLowerCase();
    const course = (s.courseCode || '').toLowerCase();
    const yearSection = (s.yearSection || '').toLowerCase();
    const matchesQ = !studentsPageQ
      || name.includes(studentsPageQ) || schoolId.includes(studentsPageQ)
      || course.includes(studentsPageQ) || yearSection.includes(studentsPageQ);
    const matchesCourse = !studentsPageCourse || (s.courseCode || '') === studentsPageCourse;
    // yearSection looks like "3-A" → the year level is the part before the dash.
    const studentYear = (s.yearSection || '').split('-')[0].trim();
    const matchesYear = !yearFilter || studentYear === yearFilter;
    return matchesQ && matchesCourse && matchesYear;
  });

  _lastStudentsForBreakdown = base;
  renderPaymentBreakdown();

  // Table list: optionally narrowed to the chosen payment status.
  // "Paid" requires BOTH semesters to be Paid.
  // "Partial" / "Unpaid" shows students where EITHER semester matches.
  const filtered = statusFilter
    ? base.filter(s => {
        const s1 = (s.firstSemStatus  || '').toLowerCase();
        const s2 = (s.secondSemStatus || '').toLowerCase();
        const f  = statusFilter.toLowerCase();
        if (f === 'paid') return s1 === 'paid' && s2 === 'paid';
        return s1 === f || s2 === f;
      })
    : base;

  renderStudentsPage(filtered);
}

async function openStudentOrgFeeModal(userId) {
  const nameEl = document.getElementById('student-orgfee-name');
  const subEl = document.getElementById('student-orgfee-sub');
  const tbody = document.getElementById('student-orgfee-tbody');

  // Stash the userId so refreshes after edit can reload the same student.
  window._currentOrgFeeUserId = userId;

  nameEl.textContent = 'Ledger';
  subEl.textContent = 'Loading…';
  tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:24px;color:var(--text-d)">Loading…</td></tr>';
  openModal('modal-student-orgfee');

  try {
    const res = await fetch('/Home/GetStudentOrgFeeDetails?userId=' + encodeURIComponent(userId));
    const data = await res.json();
    if (!data.success) {
      subEl.textContent = data.message || 'Unable to load org fee details.';
      tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:24px;color:var(--text-d)">No data available.</td></tr>';
      return;
    }

    const s = data.student;
    nameEl.textContent = s.name;
    subEl.textContent = `${s.schoolId} · ${s.courseCode} ${s.yearSection}${s.role === 'Treasurer' ? ' · Treasurer' : ''}${data.schoolYear ? ' · A.Y. ' + data.schoolYear : ''}`;

    const fees = data.fees || [];
    const txs  = data.transactions || [];

    if (!fees.length && !txs.length) {
      tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:24px;color:var(--text-d)">No org fee records.</td></tr>';
      return;
    }

    // ── HYBRID LAYOUT ──
    // Build a unified key set: every (schoolYear, semester) from BOTH fees and txs,
    // so a payment to a semester that no longer has an open fee still shows up,
    // and a current semester with no payments still appears as an unpaid row.
    const groupKey = (sy, sem) => `${sy || ''}|${sem || ''}`;
    const groups = new Map();

    // Seed from fees (semesters that should appear even with no payments)
    fees.forEach(f => {
      const k = groupKey(f.schoolYear, f.semester);
      if (!groups.has(k)) groups.set(k, { schoolYear: f.schoolYear, semester: f.semester, fee: null, payments: [] });
      groups.get(k).fee = f;
    });

    // Add any payment-only groups (e.g. fully-paid prior semester that fees[] omitted)
    txs.forEach(t => {
      const k = groupKey(t.schoolYear, t.semester);
      if (!groups.has(k)) groups.set(k, { schoolYear: t.schoolYear, semester: t.semester, fee: null, payments: [] });
      groups.get(k).payments.push(t);
    });

    // Distribute payments into their groups (in case fee existed first)
    groups.forEach(g => { g.payments = []; });
    txs.forEach(t => {
      const k = groupKey(t.schoolYear, t.semester);
      groups.get(k).payments.push(t);
    });

    // Sort: the current school-year + semester floats to the very top, then the
    // rest fall in most-recent-first order (newer year first, 2nd sem before 1st).
    const sorted = [...groups.values()].sort((a, b) => {
      const aCur = a.fee && a.fee.isCurrent ? 1 : 0;
      const bCur = b.fee && b.fee.isCurrent ? 1 : 0;
      if (aCur !== bCur) return bCur - aCur;
      const sa = parseInt((a.schoolYear || '').split('–')[0], 10) || 0;
      const sb = parseInt((b.schoolYear || '').split('–')[0], 10) || 0;
      if (sa !== sb) return sb - sa;
      const semOrder = { 'First': 1, 'Second': 2 };
      return (semOrder[b.semester] || 0) - (semOrder[a.semester] || 0);
    });

    // Flat table: one row per semester group
    const ledgerUserId = window._currentOrgFeeUserId;
    const html = sorted.map((g, idx) => {
      const semLabel = g.semester === 'First' ? '1st Semester'
                     : g.semester === 'Second' ? '2nd Semester' : (g.semester || '—');
      const totalPaid = g.payments.reduce((sum, pay) => sum + (pay.amount || 0), 0);
      const required  = g.fee?.requiredAmount ?? null;
      const balance   = g.fee ? g.fee.balance : (required != null ? Math.max(0, required - totalPaid) : 0);

      let status;
      if (required != null && required <= 0) status = 'N/A';
      else if (totalPaid <= 0) status = 'Unpaid';
      else if (balance <= 0)  status = 'Paid';
      else                    status = 'Partial';

      // Most recent payment date
      const dates = g.payments.map(pay => pay.date).filter(Boolean).sort();
      const latestDate = dates.length ? fd(dates[dates.length - 1]) : '—';

      // Receipt hover-dropdown items — show receipt no. + amount + date so partial payments are easy to trace
      const rcItems = g.payments
        .filter(pay => pay.hasReceipt && pay.receiptNumber)
        .sort((a, b) => new Date(a.date) - new Date(b.date))
        .map(pay => {
          const safe = (pay.receiptNumber || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
          return `<button class="hdrop-item" onclick="printPaymentReceipt(${pay.paymentId},'${safe}')"
                    style="flex-direction:column;align-items:flex-start;gap:1px;padding:7px 12px">
            <span style="display:flex;align-items:center;gap:5px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text)">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              ${escapeHtml(pay.receiptNumber)}
            </span>
            <span style="font-size:10px;color:var(--text-d);padding-left:15px">${p(pay.amount || 0)} &nbsp;·&nbsp; ${fd(pay.date)}</span>
          </button>`;
        }).join('');

      const receiptIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`;

      const receiptAction = rcItems
        ? `<div class="hdrop">
             <button class="btn-outline" style="padding:5px 7px;display:inline-flex;align-items:center;justify-content:center">${receiptIcon}</button>
             <div class="hdrop-menu"><div class="hdrop-label">Receipts</div>${rcItems}</div>
           </div>`
        : `<button class="btn-outline" disabled style="padding:5px 7px;display:inline-flex;align-items:center;justify-content:center;opacity:.4;cursor:not-allowed">${receiptIcon}</button>`;

      // Edit button — valid only within 30 days of the most recent payment
      const sortedPays = g.payments.slice().sort((a, b) => new Date(b.date) - new Date(a.date));
      const latestPay  = sortedPays[0];
      const thirtyDaysAgo = new Date(); thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
      const canEdit = latestPay && latestPay.paymentId && new Date(latestPay.date) >= thirtyDaysAgo;
      const editSvg = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
      const editAction = canEdit
        ? `<div class="tip-wrap">
             <button class="btn-outline" style="padding:5px 7px;display:inline-flex;align-items:center;justify-content:center"
                     onclick="editPaymentFromModal(${latestPay.paymentId})">${editSvg}</button>
             <span class="tip">Edit payment</span>
           </div>`
        : `<div class="tip-wrap">
             <button class="btn-outline" disabled style="padding:5px 7px;display:inline-flex;align-items:center;justify-content:center;opacity:.35;cursor:not-allowed">${editSvg}</button>
             <span class="tip">${latestPay ? 'Locked — older than 30 days' : 'No payment to edit'}</span>
           </div>`;

      return `<tr style="border-bottom:1px solid rgba(255,255,255,.04)">
        <td style="padding:10px 12px;color:var(--text-m);font-size:11px">${idx + 1}</td>
        <td style="padding:10px 12px;color:var(--text);font-weight:600">${semLabel}</td>
        <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text-m)">${escapeHtml(g.schoolYear || '—')}</td>
        <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:12px;color:${balance > 0 ? '#f87171' : '#5fdd8e'}">${p(balance)}</td>
        <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:12px;color:var(--text)">${p(totalPaid)}</td>
        <td style="padding:10px 12px">${feeStatusBadge(status)}</td>
        <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text-m)">${latestDate}</td>
        <td style="padding:10px 12px;text-align:right">
          <div style="display:inline-flex;gap:6px;align-items:center">
            ${receiptAction}
            ${editAction}
          </div>
        </td>
      </tr>`;
    }).join('');

    tbody.innerHTML = html;
  } catch (err) {
    console.error('Failed to load student org fee details:', err);
    subEl.textContent = 'Failed to load org fee details.';
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--text-d)">Request failed.</td></tr>';
  }
}

