      loadOrgFeePayments(),
      loadOtherFunds(),
      loadExpenses()
    ]);
    await renderDashboard();
    await populateChartSchoolYears();
    setTimeout(renderCharts, 100);
    await loadStudentsPage();
    await refreshDashboardStats();
  }
  if (name === 'history')   { await populateHistoryFilters(); await renderHistory(); }
  if (name === 'income')    await initIncomePage();
  if (name === 'expenses')  { await renderExpenses(); const exd = document.getElementById('ex-date'); if (exd && !exd.value) exd.value = today(); }
  if (name === 'reports')   { await loadReports(); await populateChartSchoolYears(); setTimeout(renderCharts, 100); }
  if (name === 'settings')  await refreshSchoolYears();
}

