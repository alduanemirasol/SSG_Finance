async function showPage(name, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  if (el) el.classList.add('active');
  if (name === 'dashboard') { await renderDashboard(); setTimeout(renderCharts, 100); }
  if (name === 'history')   await renderHistory();
  if (name === 'students')  await loadStudentsPage();
  if (name === 'income')    await initIncomePage();
  if (name === 'expenses')  await renderExpenses();
  if (name === 'settings')  await refreshSchoolYears();
}

