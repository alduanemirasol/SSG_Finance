function checkEditPaymentStatus() {
  const amt      = parseFloat(document.getElementById('edit-orgfee-amount').value) || 0;
  const required = parseFloat(document.getElementById('edit-orgfee-full-amount').value) || REQ_FEE;
  const el       = document.getElementById('edit-orgfee-status');

  if (!amt) {
    el.textContent = 'Enter amount to determine status';
    el.style.color = '#5fdd8e';
    el.style.background = 'rgba(39,167,68,.08)';
    el.style.borderColor = 'rgba(39,167,68,.15)';
    return;
  }
  if (amt >= required) {
    el.textContent = '✓ Full payment — Status: Paid';
    el.style.color = '#5fdd8e';
    el.style.background = 'rgba(39,167,68,.08)';
    el.style.borderColor = 'rgba(39,167,68,.15)';
  } else {
    el.textContent = '⚠ Partial — ₱' + amt.toFixed(2) + ' of ₱' + required.toFixed(2);
    el.style.color = '#fbbf24';
    el.style.background = 'rgba(251,191,36,.08)';
    el.style.borderColor = 'rgba(251,191,36,.15)';
  }
}

async function saveEditedOrgFee() {
  const id            = parseInt(document.getElementById('edit-orgfee-id').value);
  const amount        = parseFloat(document.getElementById('edit-orgfee-amount').value) || 0;
  const fullAmount    = parseFloat(document.getElementById('edit-orgfee-full-amount').value) || REQ_FEE;
  const receiptNumber = document.getElementById('edit-orgfee-receipt').value.trim();

  if (!amount) { showToast('Enter a valid amount.', 'fail'); return; }

  try {
    const res = await fetch('/Home/UpdateOrgFeePayment', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body: JSON.stringify({ id, amount, fullAmount, receiptNumber })
    });
    if (!res.ok) {
      const text = await res.text().catch(() => '');
      console.error('UpdateOrgFeePayment error response:', res.status, text);
      showToast(`Update failed (${res.status}).`, 'fail');
      return;
    }
    const data = await res.json();
    if (data.success) {
      closeModal('modal-edit-orgfee');
      await loadOrgFeePayments();
      await renderHistory();
      await renderDashboard();
      await loadStudentsPage();
      showToast('Payment updated successfully.', 'ok');
      if (window._currentOrgFeeUserId) {
        openStudentOrgFeeModal(window._currentOrgFeeUserId);
      }
    } else {
      showToast(data.message || 'Failed to update.', 'fail');
    }
  } catch (err) {
    console.error('saveEditedOrgFee failed:', err);
    showToast('Request failed: ' + (err?.message || 'unknown error'), 'fail');
  }
}

