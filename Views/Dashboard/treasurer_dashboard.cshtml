async function showPage(name, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  if (el) el.classList.add('active');
  if (name === 'dashboard') {
    await Promise.all([
      loadOrgFeePayments(),
      loadOtherFunds(),
      loadExpenses()
    ]);
    await renderDashboard();
    await populateChartSchoolYears();
    setTimeout(renderCharts, 100);
    await refreshDashboardStats();
    await loadStudentsPage();
  }
  if (name === 'history')   await renderHistory();
  if (name === 'income')    await initIncomePage();
  if (name === 'expenses')  { await renderExpenses(); const exd = document.getElementById('ex-date'); if (exd && !exd.value) exd.value = today(); }
  if (name === 'settings')  await refreshSchoolYears();
}

