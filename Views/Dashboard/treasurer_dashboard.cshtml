  const id          = parseInt(document.getElementById('edit-sy-id').value);
  const firstStart  = document.getElementById('edit-sy-first-start').value  || null;
  const firstEnd    = document.getElementById('edit-sy-first-end').value    || null;
  const secondStart = document.getElementById('edit-sy-second-start').value || null;
  const secondEnd   = document.getElementById('edit-sy-second-end').value   || null;

  try {
    const res  = await fetch('/Home/UpdateSchoolYearDates', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body:    JSON.stringify({
        schoolYearId:   id,
        firstSemStart:  firstStart  ? new Date(firstStart).toISOString()  : null,
        firstSemEnd:    firstEnd    ? new Date(firstEnd).toISOString()    : null,
        secondSemStart: secondStart ? new Date(secondStart).toISOString() : null,
        secondSemEnd:   secondEnd   ? new Date(secondEnd).toISOString()   : null
      })
    });
    const data = await res.json();
    if (data.success) {
      closeModal('modal-edit-sy');
      showToast(data.message, 'ok');
      await refreshSchoolYears();
    } else {
      showToast(data.message, 'fail');
    }
  } catch { showToast('Request failed.', 'fail'); }
}

