function allTransactions() {
    let rows = [];

    DB.orgFees.forEach(x => rows.push({
        type: 'income',
        cat: 'Org Fee',
        desc: 'Org Fee – ' + x.name + ' (' + x.course + ' ' + x.yr + ')',
        amt: x.amt,
        date: x.date,
        fullDate: x.fullDate || x.date,  // ← use full timestamp
        receipt: x.receipt || '—',
        src: 'OrgFee',
        sid: x.id,
        schoolYear: x.schoolYear || null,
        studentName: x.name,
        schoolId: x.schoolId,
        course: x.course,
        yearSection: x.yr
    }));

    DB.funds.forEach(x => rows.push({
        type: 'income',
        cat: 'Other Receivable',
        desc: x.desc + (x.source ? ' – from ' + x.source : ''),
        amt: x.amt,
        date: x.date,
        fullDate: x.fullDate || x.date,  // ← use full timestamp
        receipt: '—',
        src: 'OtherFund',
        sid: x.id,
        schoolYear: x.schoolYear || null,
        studentName: '',
        schoolId: '',
        course: '',
        yearSection: ''
    }));

    DB.expenses.forEach(x => rows.push({
        type: 'expense',
        cat: 'Expense',
        desc: x.desc,
        amt: x.amt,
        date: x.date,
        fullDate: x.fullDate || x.date,  // ← use full timestamp
        receipt: '—',
        src: 'Expense',
        sid: x.id,
        schoolYear: x.schoolYear || null,
        studentName: '',
        schoolId: '',
        course: '',
        yearSection: ''
    }));

    // Sort by full datetime descending
    return rows.sort((a, b) => {
        const da = new Date(a.fullDate);
        const db = new Date(b.fullDate);
        return db - da;
    });
}

function totalIncome()   { return DB.orgFees.reduce((s,x)=>s+x.amt,0) + DB.funds.reduce((s,x)=>s+x.amt,0); }
function totalExpenses() { return DB.expenses.reduce((s,x)=>s+x.amt,0); }

