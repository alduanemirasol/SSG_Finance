// ── STUDENT SEARCH ────────────────────────────────────────────────
async function searchStudents(q) {
  let list = document.getElementById('of-list');
  const query = (q || '').trim().toLowerCase();
  if (!query) { list.style.display = 'none'; return; }

  try {
    const sel = document.getElementById('of-sem');
    const opt = sel?.options[sel.selectedIndex];
    const fullAmountId = opt?.dataset?.fullAmountId || '';
    const response = await fetch('/Home/GetStudentsForPayment?q=' + encodeURIComponent(query) + '&fullAmountId=' + encodeURIComponent(fullAmountId));
    const data = await response.json();
    if (!data.success) {
      list.style.display = 'block';
      const msg = data.message ? String(data.message) : 'Unable to load students.';
      list.innerHTML = `<div style="padding:10px 12px;font-size:12px;color:var(--text-d)">${msg}</div>`;
      return;
    }

    const res = data.students.map(s => ({
      userId: s.userId,
      schoolId: s.schoolId,
      name: s.name,
      courseCode: s.courseCode,
      yearSection: s.yearSection,
      hasPaid: s.hasPaid,
      hasPartial: s.hasPartial
    }));

    list.style.display = 'block';
    list.innerHTML = res.length ? res.map(s => `
      <div class="student-item${s.hasPaid ? ' paid' : ''}" 
           onclick="${s.hasPaid ? '' : `selectStudent(${s.userId},'${s.name.replace(/'/g, "\\'")}','${s.courseCode.replace(/'/g, "\\'")}','${s.yearSection.replace(/'/g, "\\'")}','${s.schoolId.replace(/'/g, "\\'")}')`}">
        <div>
          <div class="student-name">
            ${s.name} 
            ${s.hasPaid ? '<span class="badge by" style="font-size:9px">Paid</span>' : ''}
            ${s.hasPartial ? '<span class="badge by" style="font-size:9px;background:rgba(251,191,36,.18);color:#fbbf24">Partial</span>' : ''}
          </div>
          <div class="student-info">${s.schoolId} · ${s.courseCode} ${s.yearSection}</div>
        </div>
      </div>`).join('')
      : '<div style="padding:10px 12px;font-size:12px;color:var(--text-d)">No students found.</div>';
  } catch (err) {
    console.error('Failed to search students:', err);
    list.style.display = 'block';
    list.innerHTML = '<div style="padding:10px 12px;font-size:12px;color:var(--text-d)">Request failed while loading students.</div>';
  }
}

function selectStudent(uid, name, course, yr, sid) {
  selStudent = { userId: uid };
  document.getElementById('of-uid').value = uid;
  document.getElementById('of-sel-name').textContent = name;
  document.getElementById('of-sel-info').textContent = sid + ' · ' + course + ' ' + yr;
  document.getElementById('of-selected').style.display = 'block';
  document.getElementById('of-list').style.display = 'none';
  document.getElementById('of-search').value = name;
  if (!document.getElementById('of-amount').value) document.getElementById('of-amount').value = REQ_FEE;
  checkPaymentStatus();
}

function checkPaymentStatus() {
  let amt = parseFloat(document.getElementById('of-amount').value) || 0;
  let el  = document.getElementById('of-status');
  if (!amt) { el.textContent = 'Enter amount to determine status'; el.style.color='#5fdd8e'; el.style.background='rgba(39,167,68,.08)'; el.style.borderColor='rgba(39,167,68,.15)'; return; }
  if (amt >= REQ_FEE) { el.textContent = '✓ Full payment — Status: Paid';  el.style.color='#5fdd8e'; el.style.background='rgba(39,167,68,.08)'; el.style.borderColor='rgba(39,167,68,.15)'; }
  else                { el.textContent = '⚠ Partial — ₱'+amt.toFixed(2)+' of ₱'+REQ_FEE; el.style.color='#fbbf24'; el.style.background='rgba(251,191,36,.08)'; el.style.borderColor='rgba(251,191,36,.15)'; }
}

// ── SAVE FUNCTIONS ───────────────────────────────────────────────
async function saveOrgFee() {
  if (!selStudent) { showToast('Please select a student first.', 'fail'); return; }

  const sel     = document.getElementById('of-sem');
  const sem     = sel.value;
  const opt     = sel.options[sel.selectedIndex];
  const fullAmountId = parseInt(opt?.dataset?.fullAmountId) || 0;
  if (!sem) { showToast('Please select a semester.', 'fail'); return; }

  const amt     = parseFloat(document.getElementById('of-amount').value) || 0;
  const receipt = document.getElementById('of-receipt').value.trim();
  if (!amt) { showToast('Enter an amount.', 'fail'); return; }

  try {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const res = await fetch('/Home/AddOrgFeePayment', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
      body: JSON.stringify({
        userId: selStudent.userId,
        amount: amt,
        semester: sem,
        fullAmountId,
        receiptNumber: receipt
      })
    });
    const data = await res.json();
    if (data.success) {
      closeModal('modal-orgfee');
      selStudent = null;
      ['of-search','of-amount','of-receipt'].forEach(f=>document.getElementById(f).value='');
      document.getElementById('of-selected').style.display='none';
      await renderDashboard();
      await renderCharts();
      await renderIncome();
      showToast('Org fee payment recorded successfully.', 'ok');
    } else {
      showToast(data.message || 'Failed to save payment.', 'fail');
    }
  } catch (err) {
    console.error('Failed to save org fee:', err);
    showToast('Failed to save payment. Please try again.', 'fail');
  }
}

