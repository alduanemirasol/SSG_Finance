// Resolve which semester the breakdown + status filter operate on.
//  _currentSem   = the live semester for the loaded school year, or null (past year).
//  _breakdownSem = _currentSem when there is one, otherwise a sensible fallback
//                  (the later semester that has a fee) so the card still works.
function computeSemContext() {
  const s = ALL_STUDENTS_PAGE[0];
  let current = null;
  if (s) {
    if (s.firstSemIsCurrent) current = 'first';
    else if (s.secondSemIsCurrent) current = 'second';
  }
  _currentSem = current;
  if (current) {
    _breakdownSem = current;
  } else if (s && (s.secondSemRequired || 0) > 0) {
    _breakdownSem = 'second';
  } else {
    _breakdownSem = 'first';
  }
}

// Put a "Current" badge on whichever semester column is the live one. Only the
// real current semester gets the badge — past school years show none.
function updateSemHeaderIndicators() {
  const badge = '<span style="font-size:9px;font-weight:700;background:var(--green-glow);color:#5fdd8e;border:1px solid rgba(74,222,128,.3);border-radius:5px;padding:1px 6px;margin-left:6px;letter-spacing:.04em;text-transform:uppercase;vertical-align:middle">Current</span>';
  const b1 = document.getElementById('th-sem1-badge');
  const b2 = document.getElementById('th-sem2-badge');
  if (b1) b1.innerHTML = _currentSem === 'first'  ? badge : '';
  if (b2) b2.innerHTML = _currentSem === 'second' ? badge : '';
}

// Count students by org-fee status for the current semester. Uses the list
// filtered by search/course/year/SY (but NOT the status filter, so the card
// always shows the full distribution).
function renderPaymentBreakdown() {
  const list = _lastStudentsForBreakdown || [];
  const key = _breakdownSem === 'second' ? 'secondSemStatus' : 'firstSemStatus';

  let paid = 0, partial = 0, unpaid = 0;
  list.forEach(s => {
    switch ((s[key] || '').toLowerCase()) {
      case 'paid':    paid++;    break;
      case 'partial': partial++; break;
      case 'unpaid':  unpaid++;  break;
      // 'n/a' (graduated / not applicable) is intentionally excluded
    }
  });

  const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  set('bd-total',   list.length);
  set('bd-paid',    paid);
  set('bd-partial', partial);
  set('bd-unpaid',  unpaid);

  const lbl = document.getElementById('bd-sem-label');
  if (lbl) {
    const semText = _breakdownSem === 'second' ? '2nd Semester' : '1st Semester';
    lbl.textContent = _currentSem ? `Current · ${semText}` : semText;
  }
}

// Navigate to Record Payment with the student pre-selected.
// Shortcut: jump straight to the Record Payment page with the Org Fee tab active.
function goToOrgFeePayment() {
  const incomeNav = document.querySelector('.nav-item[onclick*="income"]');
  showPage('income', incomeNav);
  setTimeout(() => { if (typeof switchIncomeTab === 'function') switchIncomeTab('orgfee'); }, 60);
}

// Pay button in the student list: navigate to Record Payment and pre-fill the student + semester.
async function quickPayStudent(userId, semNum, yearStart = null) {
  const s = findStudentRow(userId);
  if (!s) { showToast('Student not found.', 'fail'); return; }

  const incomeNav = document.querySelector('.nav-item[onclick*="income"]');
  showPage('income', incomeNav);
  await new Promise(r => setTimeout(r, 80));
  if (typeof switchIncomeTab === 'function') switchIncomeTab('orgfee');
  await new Promise(r => setTimeout(r, 80));

  // Pre-select the EXACT term the Pay button represents: the school year currently
  // shown in the students table + the clicked semester. Only if that term has no
  // option do we fall back to a Current term, then any matching semester.
  const sel = document.getElementById('page-of-sem');
  if (sel && sel.options.length) {
    const targetSem = semNum === 1 ? 'First' : 'Second';
    let exactIdx = -1, currentIdx = -1, firstIdx = -1;
    for (let i = 0; i < sel.options.length; i++) {
      const o = sel.options[i];
      if (o.value !== targetSem) continue;
      if (firstIdx === -1) firstIdx = i;
      if (o.dataset.status === 'Current' && currentIdx === -1) currentIdx = i;
      if (yearStart != null && String(o.dataset.yearStart) === String(yearStart)) { exactIdx = i; break; }
    }
    const idx = exactIdx !== -1 ? exactIdx : (currentIdx !== -1 ? currentIdx : firstIdx);
    if (idx !== -1) { sel.selectedIndex = idx; await pageOnSemesterChange(); }
  }

  await pageSelectStudent(s.userId, s.name, s.courseCode, s.yearSection, s.schoolId);

  // Lock the term to the semester the treasurer paid from. Done last so nothing
  // in the select/student setup above clears it.
  setPageSemLock(true);
}

// Lock/unlock the Record Payment term selector. When locked (arrived via a Pay
// button) the treasurer can't switch terms; manual navigation/search unlocks it.
function setPageSemLock(locked) {
  const sel = document.getElementById('page-of-sem');
  if (sel) {
    sel.disabled = locked;
    sel.style.opacity = locked ? '.75' : '';
    sel.style.cursor  = locked ? 'not-allowed' : '';
  }
  const note = document.getElementById('page-of-sem-lock-note');
  if (note) note.style.display = locked ? 'block' : 'none';
}

// Edit button in the student list: open the existing edit-orgfee modal pre-filled
// with the latest payment for that semester.
function openSemPaymentEdit(paymentId, currentPaid, fullAmount, label) {
  document.getElementById('edit-orgfee-id').value          = paymentId;
  document.getElementById('edit-orgfee-amount').value      = currentPaid;
  document.getElementById('edit-orgfee-full-amount').value = fullAmount;
