async function deleteFee(fullAmountId) {
  if (!confirm('Delete this fee record?')) return;
  try {
    const res  = await fetch('/Home/DeleteFee', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body:    JSON.stringify({ fullAmountId })
    });
    const data = await res.json();
    if (data.success) { showToast(data.message, 'ok'); await refreshFees(); }
    else showToast(data.message, 'fail');
  } catch { showToast('Request failed.', 'fail'); }
