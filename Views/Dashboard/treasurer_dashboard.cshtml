async function downloadTreasurerReceiptPDF() {
  const receiptEl  = document.getElementById('trBothReceiptPapers');
  const studentName = (document.getElementById('tr-rp-name')?.textContent || 'Student')
    .replace(/[^\w\s-]+/g, '').trim().replace(/\s+/g, '_');
  const receiptNo = (document.getElementById('tr-rp-receipt-no')?.textContent || 'receipt')
    .replace(/[^\w-]+/g, '-')
    .replace(/^-+|-+$/g, '');

  showToast('Generating PDF...', 'ok');
  try {
    const canvas = await html2canvas(receiptEl, {
      scale: 2,
      useCORS: true,
      backgroundColor: '#f9f8f5',
      logging: false
    });

    const imgData = canvas.toDataURL('image/png');
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF({
      orientation: 'portrait',
      unit: 'mm',
      format: [216, 330]
    });

    const pageWidth = pdf.internal.pageSize.getWidth();
    const pageHeight = pdf.internal.pageSize.getHeight();
    const margin = 8;
    const imgWidth = pageWidth - margin * 2;
    const imgHeight = (canvas.height * imgWidth) / canvas.width;

    pdf.addImage(imgData, 'PNG', margin, margin, imgWidth, Math.min(imgHeight, pageHeight - margin * 2));
    pdf.save(`${studentName}_${receiptNo}.pdf`);
    showToast('PDF downloaded successfully.', 'ok');
  } catch (err) {
    console.error('Failed to export receipt PDF:', err);
    showToast('Failed to generate PDF.', 'fail');
  }
}

// Populate the edit-deadline notice inside modal-edit-orgfee.
// payDateStr — ISO date/datetime string of the original payment.
function updateEditOrgFeeNotice(payDateStr) {
  const notice  = document.getElementById('edit-orgfee-deadline-notice');
  const textEl  = document.getElementById('edit-orgfee-deadline-text');
  if (!notice || !textEl) return;

  if (!payDateStr) { notice.style.display = 'none'; return; }

  const payDate      = new Date(payDateStr);
  const deadline     = new Date(payDate);
  deadline.setMonth(deadline.getMonth() + 1);

  const now          = new Date();
  const daysLeft     = Math.ceil((deadline - now) / (1000 * 60 * 60 * 24));
  const deadlineStr  = deadline.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' });

  if (daysLeft > 0) {
    textEl.textContent = `This payment record will become read-only on ${deadlineStr}. `
      + `Please complete any corrections before that date `
      + `(${daysLeft} day${daysLeft === 1 ? '' : 's'} remaining).`;
    notice.style.display = 'flex';
  } else {
    notice.style.display = 'none';
  }
}

