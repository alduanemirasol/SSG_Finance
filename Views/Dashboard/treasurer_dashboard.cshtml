@model MyMvcApp.Models.DashboardViewModel
@{
    ViewData["Title"] = "Treasurer Dashboard";
    var firstName = Context.Session.GetString("FirstName") ?? "Treasurer";
    var lastName  = Context.Session.GetString("LastName") ?? "";
    var schoolId  = Context.Session.GetString("SchoolId") ?? "";
    var initials  = (firstName.Length > 0 ? firstName[0].ToString() : "") + (lastName.Length > 0 ? lastName[0].ToString() : "");
}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SSG Finance — Treasurer</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
/* ── RESET & ROOT ── */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#071a0c;--sidebar:#081509;
  --green:#27a744;--green-d:#1a7a4a;
  --green-glow:rgba(39,167,68,.18);--green-glow2:rgba(39,167,68,.08);
  --glass:rgba(255,255,255,.045);
  --text:#e8f5ec;--text-m:rgba(232,245,236,.6);--text-d:rgba(232,245,236,.35);
  --card:#0f2918;--card-b:rgba(255,255,255,.07);
  --green-badge:rgba(39,167,68,.18);--green-badge-t:#5fdd8e;
  --yellow-badge:rgba(251,191,36,.14);--yellow-badge-t:#fbbf24;
  --red-badge:rgba(239,68,68,.14);--red-badge-t:#f87171;
  --blue-badge:rgba(59,130,246,.14);--blue-badge-t:#93c5fd;
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);display:flex;min-height:100vh;color:var(--text);font-size:14px;overflow:hidden}

/* ── SIDEBAR ── */
.sidebar{width:218px;background:var(--sidebar);border-right:1px solid rgba(255,255,255,.05);display:flex;flex-direction:column;flex-shrink:0}
.sb-brand{display:flex;align-items:center;gap:10px;padding:20px 16px 18px;border-bottom:1px solid rgba(255,255,255,.05)}
.sb-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 14px rgba(39,167,68,.3)}
.sb-logo svg{width:18px;height:18px}
.sb-logo img{width:100%;height:100%;object-fit:cover;border-radius:10px}
.sb-brand-name{font-size:13.5px;font-weight:700;color:#fff;letter-spacing:-.01em}
.sb-brand-sub{font-size:10px;color:rgba(39,167,68,.85);letter-spacing:.1em;text-transform:uppercase;margin-top:1px}
.sb-label{font-size:9.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--text-d);padding:16px 16px 5px}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 12px;margin:1px 8px;border-radius:8px;font-size:13px;font-weight:500;color:var(--text-m);cursor:pointer;transition:all .15s;border:1px solid transparent}
.nav-item:hover{background:var(--glass);color:var(--text)}
.nav-item.active{background:var(--green-glow);color:#5fdd8e;border-color:rgba(74,222,128,.12)}
.nav-item svg{width:15px;height:15px;flex-shrink:0;opacity:.85}
.sb-spacer{flex:1}
.sb-user{padding:10px 8px;border-top:1px solid rgba(255,255,255,.05)}
.user-card{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;background:var(--glass)}
.user-av{width:30px;height:30px;border-radius:7px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.user-name{font-size:12px;font-weight:600;color:#fff}
.user-role{font-size:10.5px;color:var(--text-d)}
.signout{display:flex;align-items:center;gap:7px;padding:7px 10px;margin-top:3px;border-radius:8px;font-size:12.5px;font-weight:500;color:var(--text-d);cursor:pointer;transition:all .15s}
.signout:hover{background:rgba(239,68,68,.08);color:#f87171}
.signout svg{width:14px;height:14px}

/* ── MAIN ── */
.main{flex:1;min-width:0;padding:32px 32px 60px;background:var(--bg);overflow-y:auto;height:100vh;position:relative}
.main::before{content:'';position:absolute;top:-80px;right:-80px;width:380px;height:380px;background:radial-gradient(circle,rgba(39,167,68,.06) 0%,transparent 70%);pointer-events:none;border-radius:50%}
.top-accent{height:2px;background:linear-gradient(90deg,transparent,var(--green),transparent);position:fixed;top:0;left:0;right:0;z-index:10}

/* ── PAGES ── */
.page{display:none}.page.active{display:block}
.page-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px}
.page-title{font-size:22px;font-weight:800;color:#fff;letter-spacing:-.03em}
.page-sub{font-size:12px;color:var(--text-m);margin-top:2px}

/* ── STAT CARDS ── */
.stat-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px}
.stat-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;padding:18px 20px;position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px}
.stat-card.green::before{background:linear-gradient(90deg,transparent,rgba(39,167,68,.35),transparent)}
.stat-card.red::before{background:linear-gradient(90deg,transparent,rgba(239,68,68,.35),transparent)}
.stat-card.blue::before{background:linear-gradient(90deg,transparent,rgba(59,130,246,.35),transparent)}
.stat-card.yellow::before{background:linear-gradient(90deg,transparent,rgba(251,191,36,.35),transparent)}
.stat-lbl{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:8px}
.stat-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.stat-val{font-size:28px;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em}
.stat-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center}
.stat-icon svg{width:15px;height:15px}
.stat-icon.g{background:rgba(39,167,68,.15)}
.stat-icon.r{background:rgba(239,68,68,.12)}
.stat-icon.b{background:rgba(59,130,246,.12)}
.stat-icon.y{background:rgba(251,191,36,.12)}
.stat-sub{font-size:10.5px;color:var(--text-d);padding-top:6px;border-top:1px solid rgba(255,255,255,.05)}

/* ── CONTENT CARDS ── */
.content-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;margin-bottom:14px;position:relative;overflow:visible}
.content-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;border-radius:14px 14px 0 0;background:linear-gradient(90deg,transparent,rgba(39,167,68,.2),transparent)}
.cc-hdr{display:flex;align-items:center;justify-content:space-between;padding:14px 20px 12px;border-bottom:1px solid rgba(255,255,255,.05)}
.cc-title{font-size:13.5px;font-weight:700;color:#fff}

/* ── CHARTS ── */
.charts-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:14px;margin-bottom:14px}
.chart-wrap{padding:16px;height:210px;position:relative}
.donut-wrap{padding:16px;display:flex;flex-direction:column;align-items:center;gap:10px}
.donut-canvas{width:150px;height:150px}
.donut-legend{width:100%;display:flex;flex-direction:column;gap:5px}
.dl-row{display:flex;align-items:center;justify-content:space-between;font-size:11.5px}
.dl-dot{width:9px;height:9px;border-radius:2px;margin-right:7px;flex-shrink:0}
.dl-lbl{display:flex;align-items:center;color:var(--text-m)}
.dl-val{font-family:'DM Mono',monospace;font-weight:500;font-size:11.5px}

/* ── TABLE ── */
.toolbar{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;border-bottom:1px solid rgba(255,255,255,.05);gap:10px;flex-wrap:wrap}
.search-box{display:flex;align-items:center;gap:7px;border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:7px 12px;background:rgba(255,255,255,.04);min-width:210px;transition:all .15s}
.search-box:focus-within{border-color:var(--green);background:rgba(39,167,68,.06)}
.search-box input{border:none;outline:none;font-family:inherit;font-size:12.5px;color:var(--text);width:100%;background:transparent}
.search-box input::placeholder{color:var(--text-d)}
.search-box svg{width:14px;height:14px;color:var(--text-d);flex-shrink:0}
.filter-select{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:7px 28px 7px 11px;font-size:12px;color:var(--text-m);font-family:inherit;cursor:pointer;outline:none;appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23e8f5ec%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 6px center;background-size:18px}
.filter-select option{background:#0a1f10}
table{width:100%;border-collapse:collapse;font-size:12.5px}
thead th{padding:10px 16px;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);border-bottom:1px solid rgba(255,255,255,.05);text-align:left;white-space:nowrap;background:rgba(255,255,255,.02)}
tbody tr{border-bottom:1px solid rgba(255,255,255,.04);transition:background .1s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:rgba(39,167,68,.04)}
td{padding:11px 16px;color:var(--text);vertical-align:middle}
.td-m{color:var(--text-m)}.td-mono{font-family:'DM Mono',monospace;font-size:11.5px}
.empty-row td{text-align:center;padding:40px;color:var(--text-d);font-size:12.5px}

/* ── BADGES ── */
.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:10.5px;font-weight:600}
.bg{background:var(--green-badge);color:var(--green-badge-t)}
.by{background:var(--yellow-badge);color:var(--yellow-badge-t)}
.br{background:var(--red-badge);color:var(--red-badge-t)}
.bb{background:var(--blue-badge);color:var(--blue-badge-t)}

/* ── BUTTONS ── */
.btn-primary{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:12.5px;font-weight:600;cursor:pointer;border:none;font-family:inherit;transition:all .15s;background:var(--green);color:#fff}
.btn-primary:hover{background:#22963d;transform:translateY(-1px)}
.btn-outline{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;background:transparent;border:1px solid rgba(255,255,255,.12);color:var(--text-m)}
.btn-outline:hover{border-color:var(--green);color:#5fdd8e;background:var(--green-glow2)}
.btn-danger{display:inline-flex;align-items:center;gap:5px;padding:5px 11px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;background:var(--red-badge);color:var(--red-badge-t);border:1px solid rgba(239,68,68,.2)}
.btn-danger:hover{background:rgba(239,68,68,.22)}

/* ── AMOUNT COLORS ── */
.amt-in{color:#5fdd8e;font-family:'DM Mono',monospace;font-size:12px;font-weight:500}
.amt-out{color:#f87171;font-family:'DM Mono',monospace;font-size:12px;font-weight:500}
.amt-neu{color:var(--text-m);font-family:'DM Mono',monospace;font-size:12px}

/* ── SUMMARY ROW ── */
.summary-row{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid rgba(255,255,255,.06)}
.summary-cell{padding:12px 20px;text-align:center}
.summary-cell:not(:last-child){border-right:1px solid rgba(255,255,255,.06)}
.summary-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-d);margin-bottom:4px}
.summary-val{font-family:'DM Mono',monospace;font-size:14px;font-weight:500}

/* ── INCOME CARDS ── */
.income-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.income-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;padding:22px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.income-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(39,167,68,.2),transparent)}
.income-card:hover{border-color:rgba(39,167,68,.25);background:rgba(39,167,68,.06);transform:translateY(-1px)}
.income-card-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:14px}
.income-card-icon svg{width:20px;height:20px}
.income-card-title{font-size:14px;font-weight:700;color:#fff;margin-bottom:4px}
.income-card-desc{font-size:12px;color:var(--text-m);line-height:1.6;margin-bottom:16px}

/* ── REPORT CARDS ── */
.report-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;padding:18px}
.report-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:16px;cursor:pointer;transition:all .18s}
.report-card:hover{background:var(--green-glow2);border-color:rgba(39,167,68,.22);transform:translateY(-1px)}
.report-card-icon{width:38px;height:38px;border-radius:10px;background:rgba(39,167,68,.15);display:flex;align-items:center;justify-content:center;margin-bottom:11px}
.report-card-icon svg{width:17px;height:17px}
.report-card-title{font-size:13px;font-weight:700;color:#fff;margin-bottom:4px}
.report-card-desc{font-size:11.5px;color:var(--text-m);line-height:1.5}

/* ── MODAL ── */
.modal-overlay{display:none;position:fixed;inset:0;z-index:500;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(4px)}
.modal-box{position:relative;z-index:1;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:28px 30px;width:100%;max-width:500px;box-shadow:0 24px 60px rgba(0,0,0,.5);max-height:90vh;overflow-y:auto}
.modal-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px}
.modal-title{font-size:16px;font-weight:700;color:#fff}
.modal-sub{font-size:11.5px;color:var(--text-m);margin-top:2px}
.modal-close{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.form-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-d);margin-bottom:6px;display:block}
.form-group{margin-bottom:13px}
.form-input{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none;transition:border-color .2s}
.form-input:focus{border-color:var(--green);background:rgba(39,167,68,.06)}
.form-input::placeholder{color:var(--text-d)}
.form-select{width:100%;background:#0a1f10;border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none;cursor:pointer;appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23fff%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 10px center;background-size:20px}
.form-select option{background:#0a1f10}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.modal-footer{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,.06)}
.status-box{font-size:12px;padding:8px 12px;border-radius:7px;border:1px solid rgba(39,167,68,.15);background:rgba(39,167,68,.08);color:#5fdd8e}

/* ── STUDENT SEARCH ── */
.student-list{max-height:160px;overflow-y:auto;border:1px solid rgba(255,255,255,.1);border-radius:7px;background:#0a1f10;margin-top:5px;display:none}
.student-item{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,.05);transition:background .1s}
.student-item:last-child{border-bottom:none}
.student-item:hover{background:rgba(39,167,68,.08)}
.student-item.paid{opacity:.4;pointer-events:none}
.student-name{font-size:12.5px;font-weight:600;color:#fff}
.student-info{font-size:11px;color:var(--text-m)}

/* ── REPORT PREVIEW ── */
.rp-sum{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px}
.rp-sum-card{border-radius:10px;padding:14px}
.rp-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--text-d);margin-bottom:5px}
.rp-val{font-family:'DM Mono',monospace;font-size:18px;font-weight:500}

/* ── SETTINGS ── */
.settings-tabs{display:flex;gap:2px;margin-bottom:20px;border-bottom:1px solid rgba(255,255,255,.06);flex-wrap:wrap}
.settings-tab{display:flex;align-items:center;gap:7px;padding:9px 16px;border:none;border-bottom:2px solid transparent;background:transparent;color:var(--text-m);font-size:12.5px;font-weight:500;cursor:pointer;font-family:inherit;transition:all .15s;margin-bottom:-1px}
.settings-tab:hover{color:var(--text)}
.settings-tab.active{color:#5fdd8e;border-bottom-color:#27a744}
.settings-panel{display:none}.settings-panel.active{display:block}
.settings-label{font-size:11px;color:var(--text-m);display:block;margin-bottom:4px}
.sig-pad-note{font-size:12px;color:var(--text-m);margin-bottom:14px;line-height:1.6}
.sig-canvas-wrap{position:relative;border:1.5px solid rgba(255,255,255,.15);border-radius:10px;background:#fff;overflow:hidden;cursor:crosshair;width:100%;max-width:560px}
#sig-canvas{display:block;width:100%;touch-action:none}
#sig-placeholder{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;font-size:13px;color:rgba(0,0,0,.3);font-style:italic}
.sig-actions{display:flex;gap:10px;margin-top:14px;flex-wrap:wrap}
.sig-preview-wrap{display:none;margin-top:22px;padding-top:18px;border-top:1px solid rgba(255,255,255,.06)}
.sig-preview-label{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:10px}
.sig-preview-box{background:#fff;border-radius:8px;padding:12px 16px;display:inline-block;border:1px solid rgba(255,255,255,.1)}
.sig-preview-box img{max-height:80px;max-width:400px;display:block}
.sig-preview-date{font-size:11px;color:var(--text-d);margin-top:6px}

/* ── TOAST ── */
#toast{position:fixed;bottom:20px;right:20px;padding:10px 18px;border-radius:9px;font-size:12.5px;font-weight:500;background:#1f2937;color:#fff;opacity:0;transform:translateY(8px);transition:opacity .25s,transform .25s;z-index:999;pointer-events:none;box-shadow:0 8px 24px rgba(0,0,0,.4)}
#toast.show{opacity:1;transform:translateY(0)}
#toast.ok{background:#052e16;border:1px solid rgba(39,167,68,.3)}
#toast.fail{background:#450a0a;border:1px solid rgba(239,68,68,.3)}

/* ── DROPDOWN ── */
.dropdown-wrap{position:relative;display:inline-block}
.dot-btn{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.dot-btn:hover{background:rgba(255,255,255,.1);color:var(--text)}
.dropdown-menu{display:none;position:absolute;right:0;bottom:34px;top:auto;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:10px;min-width:160px;z-index:9999;box-shadow:0 8px 24px rgba(0,0,0,.4);overflow:hidden}
.dropdown-menu.open{display:block}
.dropdown-item{display:flex;align-items:center;gap:8px;padding:9px 14px;font-size:12.5px;color:var(--text-m);cursor:pointer;transition:background .1s}
.dropdown-item:hover{background:rgba(39,167,68,.08);color:var(--text)}
.dropdown-item.danger{color:var(--red-badge-t)}
.dropdown-item.danger:hover{background:rgba(239,68,68,.08)}

/* Receipt preview */
.receipt-modal{display:none;position:fixed;inset:0;z-index:700;align-items:center;justify-content:center}
.receipt-modal.open{display:flex}
.receipt-modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(6px)}
.receipt-modal-inner{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:12px;max-height:95vh;overflow-y:auto;padding:16px}
.receipt-controls{display:flex;align-items:center;gap:10px;background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:8px 14px;width:100%;max-width:360px}
.receipt-ctrl-title{flex:1;font-size:12.5px;font-weight:600;color:var(--text-m)}
.btn-pdf{display:inline-flex;align-items:center;gap:6px;padding:6px 16px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:1px solid rgba(39,167,68,.3);background:rgba(39,167,68,.15);color:#5fdd8e;transition:all .15s;font-family:inherit;flex-shrink:0}
.btn-pdf:hover{background:rgba(39,167,68,.25);transform:translateY(-1px)}
.btn-receipt-close{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;font-family:inherit;flex-shrink:0}
.btn-receipt-close:hover{background:rgba(239,68,68,.12);color:#f87171}
.receipt-paper{width:360px;min-height:560px;background:#ffffff;border:1px solid #ccc;box-shadow:0 8px 40px rgba(0,0,0,.45);padding:30px 28px 34px;font-family:'Libre Baskerville',Georgia,serif;color:#111;position:relative;flex-shrink:0}
.receipt-paper::before{display:none}
.rp-header{text-align:center;margin-bottom:18px;position:relative;z-index:1}
.rp-org{font-size:13px;font-weight:700;letter-spacing:.01em;margin-bottom:2px}
.rp-campus{font-size:10.5px;font-weight:400}
.rp-divider{border:none;border-top:1px solid #555;margin:10px 0 8px}
.rp-type{font-size:10px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin-top:8px}
.rp-copy{font-size:9.5px;font-style:italic;color:#444;margin-top:2px}
.rp-meta{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:16px;position:relative;z-index:1;gap:8px}
.rp-meta-label{font-size:10px;font-weight:400}
.rp-meta-value{font-size:10.5px;font-weight:700;color:#111;border-bottom:1px solid #888;min-width:88px;display:inline-block;padding-bottom:2px;text-align:center}
.rp-meta-value.date-val{color:#111}
.rp-section-title{text-align:center;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:14px;position:relative;z-index:1}
.rp-field{display:flex;align-items:baseline;margin-bottom:10px;position:relative;z-index:1}
.rp-field-label{font-size:10px;font-weight:400;min-width:115px;flex-shrink:0}
.rp-field-value{flex:1;font-size:10.5px;font-weight:700;border-bottom:1px solid #888;padding-bottom:2px;min-height:16px;padding-left:4px;font-family:'Libre Baskerville',Georgia,serif}
.rp-field-value.handwritten{font-style:italic;font-size:11px;letter-spacing:.01em}
.rp-status-badge{display:inline-block;padding:0;border:none;border-radius:0;font-size:10.5px;font-weight:700;font-style:italic;color:#111;background:none}
.rp-status-badge.paid{border:none;color:#111;background:none}
.rp-status-badge.partial{border:none;color:#111;background:none}
.rp-signature-section{margin-top:26px;display:flex;justify-content:flex-end;position:relative;z-index:1}
.rp-sig-block{text-align:center;min-width:150px}
.rp-sig-label{font-size:10px;margin-bottom:5px}
.rp-sig-line{display:none}
.rp-sig-name-label{font-size:9px;color:#555}
.rp-watermark{display:none}

@@media (max-width: 768px){
  .receipt-modal-inner{padding:10px}
  .receipt-controls{max-width:96vw;padding:8px 10px;gap:6px}
  .receipt-ctrl-title{font-size:11px}
  .btn-pdf{padding:6px 10px;font-size:10.5px}
  .receipt-paper{width:94vw;min-height:auto;padding:22px 16px 26px}
  .rp-org{font-size:12px}
  .rp-campus{font-size:10px}
  .rp-field-label{min-width:98px;font-size:9.5px}
  .rp-field-value,.rp-status-badge{font-size:10px}
}
</style>
</head>
<body>

<div class="top-accent"></div>

<!-- ── SIDEBAR ── -->
<aside class="sidebar">
  <div class="sb-brand">
    <div class="sb-logo">
      <img src="~/logo.png" alt="SSG Finance Logo" />
    </div>
    <div>
      <div class="sb-brand-name">SSG Finance</div>
      <div class="sb-brand-sub">Treasurer</div>
    </div>
  </div>

  <div class="sb-label">Overview</div>
  <div class="nav-item active" onclick="showPage('dashboard',this)">
    <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
    Dashboard
  </div>
  <div class="nav-item" onclick="showPage('history',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    Transaction History
  </div>
  <div class="nav-item" onclick="showPage('students',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    Students
  </div>

  <div class="sb-label">Transactions</div>
  <div class="nav-item" onclick="showPage('income',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12l7-7 7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Add Income
  </div>
  <div class="nav-item" onclick="showPage('expenses',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 19V5M5 12l7 7 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Add Expense
  </div>

  <div class="sb-label">Reports</div>
  <div class="nav-item" onclick="showPage('reports',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><rect x="9" y="3" width="6" height="4" rx="1" stroke="currentColor" stroke-width="1.8"/><path d="M9 12h6M9 16h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    Create Report
  </div>

  <div class="sb-label">System</div>
  <div class="nav-item" onclick="showPage('settings',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" stroke-width="1.8"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" stroke="currentColor" stroke-width="1.8"/></svg>
    Settings
  </div>

  <div class="sb-spacer"></div>
  <div class="sb-user">
    <div class="user-card">
      <div class="user-av">@initials.ToUpper()</div>
      <div>
        <div class="user-name">@firstName @lastName</div>
        <div class="user-role">Treasurer</div>
      </div>
    </div>
    <div class="signout" onclick="window.location.href='@Url.Action("Logout", "Home")'">
      <svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Sign Out
    </div>
  </div>
</aside>

<!-- ── MAIN ── -->
<div class="main">

  <!-- DASHBOARD -->
  <div class="page active" id="page-dashboard">
    <div class="page-hdr">
      <div>
        <div class="page-title">Dashboard</div>
        <div class="page-sub">A.Y. 2025–2026 · 1st Semester</div>
      </div>
      <div style="font-size:11.5px;color:var(--text-m);background:rgba(39,167,68,.1);border:1px solid rgba(39,167,68,.2);padding:6px 13px;border-radius:8px;display:flex;align-items:center;gap:6px">
        <span style="width:6px;height:6px;border-radius:50%;background:#4ade80;box-shadow:0 0 6px #4ade80;display:inline-block"></span>
        Live
      </div>
    </div>

    <!-- REMAINING BALANCE — inline display, no card -->
    <div style="margin-bottom:16px;padding:14px 20px;background:transparent;border:none;border-radius:14px;display:flex;align-items:center;justify-content:space-between">
      <div>
        <div style="font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:4px">Remaining Balance</div>
        <div style="font-size:28px;font-weight:800;color:#fff;letter-spacing:-.04em" id="s-balance">₱0.00</div>
        <div style="font-size:10.5px;margin-top:4px" id="s-balance-sub">Income − Expenses</div>
      </div>
    </div>

    <!-- CHARTS -->
    <div style="margin-bottom:14px">
      <div class="content-card">
        <div class="cc-hdr">
          <div class="cc-title">Monthly Overview</div>
          <select class="filter-select" id="chart-mode" onchange="updateCharts()">
            <option value="both">Income vs Expenses</option>
            <option value="income">Income only</option>
            <option value="expense">Expenses only</option>
          </select>
        </div>
        <div class="chart-wrap"><canvas id="barChart"></canvas></div>
      </div>
    </div>
    <!-- hidden donut elements so JS doesn't error -->
    <div style="display:none">
      <canvas id="donutChart"></canvas>
      <div id="donut-legend"></div>
    </div>
  </div>

  <!-- HISTORY -->
  <div class="page" id="page-history">
    <div class="page-hdr">
      <div><div class="page-title">Transaction History</div><div class="page-sub">Complete record of all financial entries</div></div>
    </div>

    <!-- Summary row moved above the table -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px">
      <div style="background:var(--card);border:1px solid var(--card-b);border-radius:12px;padding:14px 18px">
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-d);margin-bottom:5px">Total Revenue</div>
        <div class="amt-in" style="font-family:'DM Mono',monospace;font-size:18px;font-weight:600" id="h-income">₱0.00</div>
      </div>
      <div style="background:var(--card);border:1px solid var(--card-b);border-radius:12px;padding:14px 18px">
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-d);margin-bottom:5px">Total Expenses</div>
        <div class="amt-out" style="font-family:'DM Mono',monospace;font-size:18px;font-weight:600" id="h-expense">₱0.00</div>
      </div>
      <div style="background:var(--card);border:1px solid var(--card-b);border-radius:12px;padding:14px 18px">
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-d);margin-bottom:5px">Collectable Org Fee</div>
        <div style="font-family:'DM Mono',monospace;font-size:18px;font-weight:600" id="h-balance">₱0.00</div>
      </div>
    </div>

    <div class="content-card">
      <div class="toolbar">
        <div class="search-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="8" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke-width="1.8" stroke-linecap="round"/></svg>
          <input type="text" placeholder="Search by description, student name, school ID, course…" oninput="filterHistory(this.value)"/>
        </div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
          <select class="filter-select" id="hist-filter-type" onchange="applyHistoryFilters()">
            <option value="">All Types</option>
            <option value="income">Income</option>
            <option value="expense">Expense</option>
          </select>
        </div>
      </div>
      <table>
        <thead><tr><th>Date</th><th>Description</th><th>Student Info</th><th>Receipt / OR</th><th>Amount</th><th></th></tr></thead>
        <tbody id="history-tbody"></tbody>
      </table>
    </div>
  </div>

  <!-- STUDENTS -->
  <div class="page" id="page-students">
    <div class="page-hdr">
      <div>
        <div class="page-title">Students</div>
        <div class="page-sub" id="students-page-sub">All approved students and treasurers</div>
      </div>
    </div>
    <div class="content-card">
      <div class="toolbar">
        <div class="search-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="8" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke-width="1.8" stroke-linecap="round"/></svg>
          <input type="text" placeholder="Search by name, school ID, course…" oninput="filterStudentsPage(this.value)"/>
        </div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
          <select class="filter-select" id="students-filter-course" onchange="applyStudentsPageFilters()">
            <option value="">All Courses</option>
          </select>
          <select class="filter-select" id="students-filter-sy" onchange="applyStudentsPageFilters()">
            <option value="">All School Years</option>
          </select>
          <select class="filter-select" id="students-filter-sem" onchange="applyStudentsPageFilters()">
            <option value="">All Semesters</option>
            <option value="First">1st Semester</option>
            <option value="Second">2nd Semester</option>
          </select>
        </div>
      </div>
      <table>
        <thead><tr><th>#</th><th>School ID</th><th>Name</th><th>Course · Year &amp; Section</th><th>1st Sem</th><th>2nd Sem</th><th>Org Fees</th></tr></thead>
        <tbody id="students-page-tbody">
          <tr class="empty-row"><td colspan="7">Loading students…</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- INCOME -->
  <div class="page" id="page-income">
    <div class="page-hdr">
      <div><div class="page-title">Add Income</div><div class="page-sub">Record student fees and other receivable funds</div></div>
    </div>

    <!-- TYPE TABS -->
    <div style="display:flex;gap:8px;margin-bottom:20px">
      <button id="income-tab-orgfee" onclick="switchIncomeTab('orgfee')"
        style="display:inline-flex;align-items:center;gap:6px;padding:8px 18px;border-radius:8px;font-size:12.5px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;background:var(--green);color:#fff;border:none">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        Org Fee
      </button>
      <button id="income-tab-fund" onclick="switchIncomeTab('fund')"
        style="display:inline-flex;align-items:center;gap:6px;padding:8px 18px;border-radius:8px;font-size:12.5px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;background:transparent;border:1px solid rgba(255,255,255,.12);color:var(--text-m)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6" stroke="currentColor" stroke-width="1.8"/></svg>
        Other Fund
      </button>
    </div>

    <!-- ORG FEE FORM -->
    <div id="income-panel-orgfee" class="content-card" style="max-width:600px">
      <div class="cc-hdr">
        <div class="cc-title">Student Organizational Fee</div>
        <span style="font-size:11.5px;color:var(--text-m)">Required: <strong style="color:#5fdd8e" id="page-fee-amount">₱0.00</strong></span>
      </div>
      <div style="padding:22px">
        <div class="form-group">
          <label class="form-label">Search Student (name or school ID)</label>
          <input class="form-input" id="page-of-search" placeholder="Type to search…" oninput="pageSearchStudents(this.value)"/>
          <div class="student-list" id="page-of-list"></div>
        </div>
        <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:10px 12px;margin-bottom:13px;display:none" id="page-of-selected">
          <div style="font-size:10px;color:var(--text-d);margin-bottom:2px">Selected student</div>
          <div style="font-size:13px;font-weight:600;color:#fff" id="page-of-sel-name">—</div>
          <div style="font-size:11px;color:var(--text-m)" id="page-of-sel-info">—</div>
          <input type="hidden" id="page-of-uid"/>
        </div>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">School Year & Semester</label>
            <select class="form-select" id="page-of-sem" onchange="pageOnSemesterChange()">
              <option value="">Loading...</option>
            </select>
            <div style="font-size:10.5px;color:var(--text-d);margin-top:4px" id="page-of-sem-status"></div>
          </div>
          <div class="form-group">
            <label class="form-label">Amount Paid (₱)</label>
            <input class="form-input" id="page-of-amount" type="number" placeholder="0.00" oninput="pageCheckPaymentStatus()"/>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Payment Status</label>
          <div class="status-box" id="page-of-status">Enter amount to determine status</div>
        </div>
        <div class="form-group">
          <label class="form-label">Receipt Number</label>
          <input class="form-input" id="page-of-receipt" placeholder="Generating…" style="font-family:'DM Mono',monospace"/>
          <div style="font-size:10.5px;color:var(--text-d);margin-top:4px">Auto-generated</div>
        </div>
        <div style="display:flex;justify-content:flex-end;padding-top:16px;border-top:1px solid rgba(255,255,255,.06)">
          <button class="btn-primary" onclick="pageSubmitOrgFee()">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            Save Payment
          </button>
        </div>
      </div>
    </div>

    <!-- OTHER FUND FORM -->
    <div id="income-panel-fund" class="content-card" style="max-width:600px;display:none">
      <div class="cc-hdr"><div class="cc-title">Other Receivable Fund</div></div>
      <div style="padding:22px">
        <div class="form-group">
          <label class="form-label">Source / Received From</label>
          <input class="form-input" id="page-fn-source" placeholder="e.g. Alumni Association, CHED…"/>
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <input class="form-input" id="page-fn-desc" placeholder="e.g. Fundraising proceeds – T-shirt sale"/>
        </div>
        <div class="form-group">
          <label class="form-label">Category</label>
          <select class="form-select" id="page-fn-cat">
            <option>Donation</option><option>Grant</option><option>Fundraising</option>
            <option>Event Proceeds</option><option>Sponsorship</option><option>Other</option>
          </select>
        </div>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Amount (₱)</label>
            <input class="form-input" id="page-fn-amount" type="number" placeholder="0.00"/>
          </div>
          <div class="form-group">
            <label class="form-label">Date Received</label>
            <input class="form-input" type="date" id="page-fn-date"/>
          </div>
        </div>
        <div style="display:flex;justify-content:flex-end;padding-top:16px;border-top:1px solid rgba(255,255,255,.06)">
          <button class="btn-primary" onclick="pageSubmitFund()">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            Save Fund
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- EXPENSES -->
  <div class="page" id="page-expenses">
    <div class="page-hdr">
      <div><div class="page-title">Add Expense</div><div class="page-sub">Track organizational expenditures</div></div>
      <button class="btn-primary" onclick="openModal('modal-expense')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
        Add Expense
      </button>
    </div>
    <div class="stat-grid-3">
      <div class="stat-card red"><div class="stat-lbl">Total Expenses</div><div class="stat-row"><div class="stat-val" id="e-total">₱0.00</div><div class="stat-icon r"><svg viewBox="0 0 24 24" fill="none"><path d="M12 19V5M5 12l7 7 7-7" stroke="#f87171" stroke-width="1.8" stroke-linecap="round"/></svg></div></div><div class="stat-sub">All recorded</div></div>
      <div class="stat-card yellow"><div class="stat-lbl">No. of Records</div><div class="stat-row"><div class="stat-val" id="e-count">0</div><div class="stat-icon y"><svg viewBox="0 0 24 24" fill="none"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="#fbbf24" stroke-width="1.8" stroke-linecap="round"/><rect x="9" y="3" width="6" height="4" rx="1" stroke="#fbbf24" stroke-width="1.8"/></svg></div></div><div class="stat-sub">Transactions</div></div>
      <div class="stat-card red"><div class="stat-lbl">Largest Expense</div><div class="stat-row"><div class="stat-val" id="e-max">₱0.00</div><div class="stat-icon r"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#f87171" stroke-width="1.8"/><path d="M12 8v4l3 3" stroke="#f87171" stroke-width="1.8" stroke-linecap="round"/></svg></div></div><div class="stat-sub">Single transaction</div></div>
    </div>
    <div class="content-card">
      <div class="cc-hdr"><div class="cc-title">Expense Records</div><span class="badge br" id="exp-badge">0 records</span></div>
      <div class="toolbar">
        <div class="search-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="8" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke-width="1.8" stroke-linecap="round"/></svg>
          <input type="text" placeholder="Search expenses…" oninput="filterExpenses(this.value)"/>
        </div>
      </div>
      <table>
        <thead><tr><th>Date</th><th>Description</th><th>Amount</th><th>Recorded By</th><th></th></tr></thead>
        <tbody id="expenses-tbody"></tbody>
      </table>
    </div>
  </div>

  <!-- REPORTS -->
  <div class="page" id="page-reports">
    <div class="page-hdr"><div><div class="page-title">Create Report</div><div class="page-sub">Generate financial reports for submission or review</div></div></div>
    <div class="content-card" style="margin-bottom:14px">
      <div class="cc-hdr"><div class="cc-title">Report Generator</div></div>
      <div style="padding:16px 20px;display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:12px;align-items:flex-end">
        <div><label class="form-label">Report Type</label><select class="form-select" id="r-type"><option>Summary Report</option><option>Income Statement</option><option>Expense Report</option><option>Audit Trail</option></select></div>
        <div><label class="form-label">Period From</label><input type="date" class="form-input" id="r-from" value="2026-01-01"/></div>
        <div><label class="form-label">Period To</label><input type="date" class="form-input" id="r-to" value="2026-12-31"/></div>
        <button class="btn-primary" onclick="generateReport()" style="height:38px;white-space:nowrap">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          Generate
        </button>
      </div>
    </div>
    <div class="content-card" style="margin-bottom:14px">
      <div class="cc-hdr"><div class="cc-title">Report Templates</div></div>
      <div class="report-grid">
        <div class="report-card" onclick="quickReport('Summary Report')"><div class="report-card-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="#5fdd8e" stroke-width="1.8"/><rect x="9" y="3" width="6" height="4" rx="1" stroke="#5fdd8e" stroke-width="1.8"/><path d="M9 12h6M9 16h4" stroke="#5fdd8e" stroke-width="1.8" stroke-linecap="round"/></svg></div><div class="report-card-title">Summary Report</div><div class="report-card-desc">Full overview of income, expenses, and remaining balance.</div></div>
        <div class="report-card" onclick="quickReport('Income Statement')"><div class="report-card-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12l7-7 7 7" stroke="#5fdd8e" stroke-width="1.8" stroke-linecap="round"/></svg></div><div class="report-card-title">Income Statement</div><div class="report-card-desc">Breakdown of all org fees and other receivable funds.</div></div>
        <div class="report-card" onclick="quickReport('Expense Report')"><div class="report-card-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M12 19V5M5 12l7 7 7-7" stroke="#f87171" stroke-width="1.8" stroke-linecap="round"/></svg></div><div class="report-card-title">Expense Report</div><div class="report-card-desc">All expenditures with descriptions and dates.</div></div>
        <div class="report-card" onclick="quickReport('Audit Trail')"><div class="report-card-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#fbbf24" stroke-width="1.8"/></svg></div><div class="report-card-title">Audit Trail</div><div class="report-card-desc">Full timestamped log for compliance and audits.</div></div>
        <div class="report-card" onclick="quickReport('Summary Report')"><div class="report-card-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M3 3v18h18M7 16l4-4 4 4 4-4" stroke="#93c5fd" stroke-width="1.8" stroke-linecap="round"/></svg></div><div class="report-card-title">Cash Flow Report</div><div class="report-card-desc">Monthly inflows and outflows over time.</div></div>
        <div class="report-card" onclick="quickReport('Income Statement')"><div class="report-card-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="#5fdd8e" stroke-width="1.8" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="#5fdd8e" stroke-width="1.8"/></svg></div><div class="report-card-title">Section Breakdown</div><div class="report-card-desc">Org fee collection status per year and section.</div></div>
      </div>
    </div>
    <div class="content-card" id="report-preview" style="display:none">
      <div class="cc-hdr">
        <div class="cc-title" id="report-preview-title">Report Preview</div>
        <div style="display:flex;gap:8px">
          <button class="btn-outline" onclick="window.print()">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6v-8z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            Print
          </button>
          <button class="btn-primary" onclick="showToast('PDF export — wire to /Treasurer/GenerateReport endpoint.','ok')">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            Export PDF
          </button>
        </div>
      </div>
      <div id="report-body" style="padding:22px 20px"></div>
    </div>
  </div>

  <!-- SETTINGS -->
  <div class="page" id="page-settings">
    <div class="page-hdr">
      <div>
        <div class="page-title">Settings</div>
        <div class="page-sub">System configuration</div>
      </div>
    </div>

    <!-- Settings Tabs -->
    <div class="settings-tabs">
      <button class="settings-tab active" onclick="switchSettingsTab('sy',this)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        School Year & Semester
      </button>
      <button class="settings-tab" onclick="switchSettingsTab('courses',this)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        Manage Courses
      </button>
      <button class="settings-tab" onclick="switchSettingsTab('fees',this)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M12 6v2m0 8v2M9 9.5A3 3 0 0112 8a3 3 0 010 6 3 3 0 00-3 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        Set Fee Amount
      </button>
      <button class="settings-tab" onclick="switchSettingsTab('signature',this)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <path d="M20 19c0 1-1.5 2-4 2s-4-1-4-2 1.5-2 4-2 4 1 4 2z" stroke="currentColor" stroke-width="1.8"/>
          <path d="M20 19V5L9 14l-2 5 5-2 8-8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Signature
      </button>
    </div>

    <!-- SCHOOL YEAR & SEMESTER -->
    <div class="settings-panel active" id="settings-sy">
      <div class="content-card" style="margin-bottom:14px">
        <div class="cc-hdr"><div class="cc-title">Add School Year</div></div>
        <div style="padding:20px 24px">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
              <label class="settings-label">Year Start</label>
              <input id="sy-yearStart" type="number" class="form-input" placeholder="e.g. 2025" />
            </div>
            <div>
              <label class="settings-label">Year End</label>
              <input id="sy-yearEnd" type="number" class="form-input" placeholder="e.g. 2026" />
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end">
            <button class="btn-primary" onclick="addSchoolYear()">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
              Add School Year
            </button>
          </div>
        </div>
      </div>

      <div class="content-card">
        <div class="cc-hdr"><div class="cc-title">School Years</div><span class="badge by" id="sy-count-badge">0 total</span></div>
        <table>
          <thead><tr><th>#</th><th>School Year</th><th>Semesters</th><th>Status</th><th></th></tr></thead>
          <tbody id="sy-tbody">
            <tr class="empty-row"><td colspan="5">No school years found.</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- MANAGE COURSES -->
    <div class="settings-panel" id="settings-courses">
      <div class="content-card" style="margin-bottom:14px">
        <div class="cc-hdr"><div class="cc-title">Add Course</div></div>
        <div style="padding:20px 24px">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
              <label class="settings-label">Course Code</label>
              <input id="course-code" type="text" class="form-input" placeholder="e.g. BSIT" />
            </div>
            <div>
              <label class="settings-label">Course Name</label>
              <input id="course-name" type="text" class="form-input" placeholder="e.g. BS Information Technology" />
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end">
            <button class="btn-primary" onclick="addCourse()">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
              Add Course
            </button>
          </div>
        </div>
      </div>

      <div class="content-card">
        <div class="cc-hdr"><div class="cc-title">Courses</div><span class="badge by" id="courses-count-badge">0 total</span></div>
        <table>
          <thead><tr><th>#</th><th>Code</th><th>Course Name</th><th></th></tr></thead>
          <tbody id="courses-tbody">
            <tr class="empty-row"><td colspan="4">No courses found.</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- SET FEE AMOUNT -->
    <div class="settings-panel" id="settings-fees">
      <div class="content-card" style="margin-bottom:14px">
        <div class="cc-hdr"><div class="cc-title">Set Organization Fee</div></div>
        <div style="padding:20px 24px">
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
              <label class="settings-label">School Year</label>
              <select id="fee-schoolYear" class="form-select">
                <option value="">Select school year</option>
              </select>
            </div>
            <div>
              <label class="settings-label">Semester</label>
              <select id="fee-semester" class="form-select">
                <option value="First">1st Semester</option>
                <option value="Second">2nd Semester</option>
              </select>
            </div>
            <div>
              <label class="settings-label">Amount (₱)</label>
              <input id="fee-amount" type="number" step="0.01" class="form-input" placeholder="e.g. 200.00" />
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end">
            <button class="btn-primary" onclick="setFeeAmount()">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
              Set Fee Amount
            </button>
          </div>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
        <div class="content-card">
          <div style="padding:16px 20px">
            <div style="font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:6px">1st Semester Fee</div>
            <div style="font-size:28px;font-weight:800;color:#fff;letter-spacing:-.03em" id="fee-1st-val">₱—</div>
            <div style="font-size:11px;color:var(--text-m);margin-top:3px" id="fee-1st-sub">No fee set</div>
          </div>
        </div>
        <div class="content-card">
          <div style="padding:16px 20px">
            <div style="font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:6px">2nd Semester Fee</div>
            <div style="font-size:28px;font-weight:800;color:#fff;letter-spacing:-.03em" id="fee-2nd-val">₱—</div>
            <div style="font-size:11px;color:var(--text-m);margin-top:3px" id="fee-2nd-sub">No fee set</div>
          </div>
        </div>
      </div>

      <div class="content-card">
        <div class="cc-hdr"><div class="cc-title">Fee History</div></div>
        <table>
          <thead><tr><th>School Year</th><th>Semester</th><th>Amount</th><th>Status</th><th></th></tr></thead>
          <tbody id="fee-history-tbody">
            <tr class="empty-row"><td colspan="5">No fee records found.</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- SIGNATURE -->
    <div class="settings-panel" id="settings-signature">
      <div class="content-card" style="margin-bottom:14px">
        <div class="cc-hdr">
          <div class="cc-title">My Signature</div>
          <span class="badge by" id="sig-status-badge">Not saved</span>
        </div>
        <div style="padding:20px 24px">
          <div class="sig-pad-note">Sign inside the white area. Saved versions remain in the signature history.</div>

          <div class="sig-canvas-wrap">
            <canvas id="sig-canvas" width="560" height="160"></canvas>
            <div id="sig-placeholder">Draw your signature here...</div>
          </div>

          <div class="sig-actions">
            <button class="btn-primary" onclick="saveSignature()">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M17 21v-8H7v8M7 3v5h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
              Save Signature
            </button>
            <button class="btn-outline" onclick="clearSignature()">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                <path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Clear
            </button>
          </div>

          <div id="sig-preview-wrap" class="sig-preview-wrap">
            <div class="sig-preview-label">Currently Saved Signature</div>
            <div class="sig-preview-box">
              <img id="sig-preview-img" src="" alt="Saved signature"/>
            </div>
            <div class="sig-preview-date" id="sig-preview-date"></div>
          </div>
        </div>
      </div>

      <div class="content-card">
        <div class="cc-hdr">
          <div class="cc-title">Signature History</div>
          <span class="badge by" id="sig-history-count">0 records</span>
        </div>
        <table>
          <thead>
            <tr><th>#</th><th>Treasurer</th><th>Date Saved</th><th>Status</th><th>Preview</th></tr>
          </thead>
          <tbody id="sig-history-tbody">
            <tr class="empty-row"><td colspan="5">No signatures found.</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div><!-- /main -->

@Html.AntiForgeryToken()

<!-- ── MODALS ── -->

<!-- Type picker -->
<div class="modal-overlay" id="modal-pick">
  <div class="modal-backdrop" onclick="closeModal('modal-pick')"></div>
  <div class="modal-box" style="max-width:360px">
    <div class="modal-hdr"><div><div class="modal-title">Add Transaction</div><div class="modal-sub">Choose a transaction type</div></div><button class="modal-close" onclick="closeModal('modal-pick')">✕</button></div>
    <div style="display:flex;flex-direction:column;gap:8px">
      <button class="btn-primary" style="justify-content:flex-start;padding:12px 14px" onclick="closeModal('modal-pick');openModal('modal-orgfee')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>Student Organizational Fee</button>
      <button class="btn-outline" style="justify-content:flex-start;padding:12px 14px" onclick="closeModal('modal-pick');openModal('modal-fund')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6" stroke="currentColor" stroke-width="1.8"/></svg>Other Receivable Fund</button>
      <button class="btn-outline" style="justify-content:flex-start;padding:12px 14px;color:#f87171;border-color:rgba(239,68,68,.2)" onclick="closeModal('modal-pick');openModal('modal-expense')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 19V5M5 12l7 7 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>Expense</button>
    </div>
  </div>
</div>

<!-- Org Fee Modal -->
<div class="modal-overlay" id="modal-orgfee">
  <div class="modal-backdrop" onclick="closeModal('modal-orgfee')"></div>
  <div class="modal-box">
    <div class="modal-hdr"><div><div class="modal-title">Organizational Fee</div><div class="modal-sub" id="org-fee-modal-sub">Student SSG membership fee — Current: ₱200.00</div></div><button class="modal-close" onclick="closeModal('modal-orgfee')">✕</button></div>
    <div class="form-group">
      <label class="form-label">Search Student (name or school ID)</label>
      <input class="form-input" id="of-search" placeholder="Type to search…" oninput="searchStudents(this.value)"/>
      <div class="student-list" id="of-list"></div>
    </div>
    <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:10px 12px;margin-bottom:13px;display:none" id="of-selected">
      <div style="font-size:10px;color:var(--text-d);margin-bottom:2px">Selected student</div>
      <div style="font-size:13px;font-weight:600;color:#fff" id="of-sel-name">—</div>
      <div style="font-size:11px;color:var(--text-m)" id="of-sel-info">—</div>
      <input type="hidden" id="of-uid"/>
    </div>
    <div class="form-grid">
      <div class="form-group">
    <label class="form-label">School Year & Semester</label>
    <select class="form-select" id="of-sem" onchange="onSemesterChange()">
        <option value="">Loading...</option>
    </select>
    <div style="font-size:10.5px;color:var(--text-d);margin-top:4px" id="of-sem-status"></div>
</div>
      <div class="form-group"><label class="form-label">Amount Paid (₱)</label><input class="form-input" id="of-amount" type="number" placeholder="200.00" oninput="checkPaymentStatus()"/></div>
    </div>
    <div class="form-group"><label class="form-label">Payment Status</label><div class="status-box" id="of-status">Enter amount to determine status</div></div>
    <div class="form-group">
    <label class="form-label">Receipt Number</label>
    <input class="form-input" id="of-receipt" placeholder="Generating…" style="font-family:'DM Mono',monospace"/>
    <div style="font-size:10.5px;color:var(--text-d);margin-top:4px">Auto-generated</div>
</div>
    <div class="modal-footer"><button class="btn-outline" onclick="closeModal('modal-orgfee')">Cancel</button><button class="btn-primary" onclick="saveOrgFee()">Save Payment</button></div>
  </div>
</div>

<!-- Other Fund Modal -->
<div class="modal-overlay" id="modal-fund">
  <div class="modal-backdrop" onclick="closeModal('modal-fund')"></div>
  <div class="modal-box">
    <div class="modal-hdr"><div><div class="modal-title">Record Other Receivable Fund</div><div class="modal-sub">Donations, grants, fundraising — maps to other_funds</div></div><button class="modal-close" onclick="closeModal('modal-fund')">✕</button></div>
    <div class="form-group"><label class="form-label">Source / Received From</label><input class="form-input" id="fn-source" placeholder="e.g. Alumni Association, CHED…"/></div>
    <div class="form-group"><label class="form-label">Description</label><input class="form-input" id="fn-desc" placeholder="e.g. Fundraising proceeds – T-shirt sale"/></div>
