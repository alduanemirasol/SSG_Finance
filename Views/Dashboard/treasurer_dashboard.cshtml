async function renderHistory() {
  // Ensure data is loaded
  if (DB.orgFees.length === 0 || historyStudentFilter) {
    await Promise.all([loadOrgFeePayments(), loadOtherFunds(), loadExpenses()]);
  }

  const students = historyStudentFilter ?? [];

  // Filter existing transactions by query, type and category
  const tx = allTransactions()
    .filter(t => !histType || t.src === histType)
    .filter(t => !histCat || t.src !== 'OtherFund' || (t.cat || '') === histCat)
    .filter(t => {
      if (!histSY && !histSem) return true;

      const normalize = s => (s || '').replace(/\s*[–-]\s*/g, '');

      if (t.src === 'OrgFee') {
        const fee = DB.orgFees.find(f => f.id === t.sid);
        if (!fee) return false;
        const syMatch  = !histSY  || normalize(fee.schoolYear) === normalize(histSY);
        const semMatch = !histSem || fee.sem === histSem;
        return syMatch && semMatch;
      }

      if (t.src === 'Expense' || t.src === 'OtherFund') {
        if (!histSY) return true;
        if (!t.schoolYear) return false;
        return normalize(t.schoolYear) === normalize(histSY);
      }

      return true;
    })
    .filter(t =>
      !histQ ||
      (t.desc && t.desc.toLowerCase().includes(histQ.toLowerCase())) ||
      (t.from && t.from.toLowerCase().includes(histQ.toLowerCase())) ||
      (t.studentName && t.studentName.toLowerCase().includes(histQ.toLowerCase())) ||
      (t.schoolId && t.schoolId.toLowerCase().includes(histQ.toLowerCase())) ||
      (t.course && t.course.toLowerCase().includes(histQ.toLowerCase())) ||
      (t.yearSection && t.yearSection.toLowerCase().includes(histQ.toLowerCase()))
    );

  // Build rows for unpaid students (only shown when type is All or Org Fees, and no category filter)
  let unpaidRows = '';
  if ((!histType || histType === 'OrgFee') && !histCat) {
    unpaidRows = students
      .filter(s => s.status === 'Unpaid')
      .map(s => `
        <tr style="opacity:0.6">
          <td><strong>Org Fee</strong> <span class="badge by" style="font-size:9px">Unpaid</span></td>
          <td class="td-m">N/A</td>
          <td class="td-m">—</td>
          <td class="td-m">
            <div style="font-size:11px">
              <strong>${s.name}</strong> · <span style="color:var(--text-d)">ID: ${s.schoolId}</span> · ${s.courseCode} ${s.yearSection}
            </div>
          </td>
          <td class="td-m" style="color:var(--text-d)">—</td>
          <td class="td-mono td-m">—</td>
          <td>${feeStatusBadge('Unpaid')}</td>
          <td class="td-m" style="color:var(--text-d)">—</td>
          <td class="td-mono td-m">—</td>
          <td></td>
        </tr>`).join('');
  }

  // Rows from existing transactions
  const _histOneMonthAgo = new Date(); _histOneMonthAgo.setMonth(_histOneMonthAgo.getMonth() - 1);
  const txRows = tx.map(t => {
    const isOrg = t.src === 'OrgFee';
    const semLabel = t.sem === 'First' ? '1st Sem' : t.sem === 'Second' ? '2nd Sem' : 'N/A';
    const hasReceipt = isOrg && t.receipt && t.receipt !== '—';
    const editCall = isOrg
      ? `editIncome('OrgFee',${t.sid})`
      : `editTransaction('${t.src}',${t.sid})`;
    const txTooOld = new Date(t.fullDate || t.date) < _histOneMonthAgo;
    const editBtn = txTooOld
      ? `<button type="button" class="btn-outline" disabled title="Edit locked — transaction is older than 1 month"
           style="padding:4px 10px;font-size:11px;opacity:.4;cursor:not-allowed">
           <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
           Edit
         </button>`
      : `<button type="button" class="btn-outline" style="padding:4px 10px;font-size:11px" onclick="${editCall}">
           <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
           Edit
         </button>`;
    return `
    <tr>
      <td><strong>${escapeHtml(t.paymentType)}</strong></td>
      <td class="td-m">${escapeHtml(t.desc)}</td>
      <td class="td-m">${isOrg ? semLabel : 'N/A'}</td>
      <td class="td-m" style="font-size:11px">${escapeHtml(t.from)}</td>
      <td class="${t.type==='income'?'amt-in':'amt-out'}">${t.type==='income'?'+':'-'}${p(t.amt)}</td>
      <td class="td-mono td-m">${isOrg ? p(t.balance) : 'N/A'}</td>
      <td>${isOrg ? feeStatusBadge(t.status) : '<span class="td-m" style="color:var(--text-d)">N/A</span>'}</td>
      <td>${isOrg ? renderReceiptCell(t.sid, t.receipt, hasReceipt) : expenseReceiptCell(t.images)}</td>
      <td class="td-mono td-m">${fd(t.date)}</td>
      <td>${editBtn}</td>
    </tr>`;
  }).join('');

  const combined = txRows + unpaidRows;

  // Totals always reflect ALL data, regardless of filters/search
  const allTx = allTransactions();
  const inc = allTx.filter(t=>t.type==='income').reduce((s,t)=>s+t.amt,0);
  const exp = allTx.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amt,0);

  // Collectable Org Fee: sum of (required - paid) for each student who hasn't fully paid
  // Group payments by userId + fullAmountId to get per-student totals
  const paidMap = {};
  DB.orgFees.forEach(f => {
    const key = f.userId + '_' + (f.fullAmountId || f.sem);
    if (!paidMap[key]) paidMap[key] = { paid: 0, required: f.amtRequired || 0 };
    paidMap[key].paid += f.amt;
  });

  document.getElementById('history-tbody').innerHTML = combined ||
    '<tr class="empty-row"><td colspan="10">No results found.</td></tr>';
}

