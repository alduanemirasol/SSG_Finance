}

function pageCheckPaymentStatus() {
  const amt = parseFloat(document.getElementById('page-of-amount').value) || 0;
  const el  = document.getElementById('page-of-status');

  if (!amt) {
    el.textContent = 'Enter amount to determine status';
    el.style.color = '#5fdd8e';
    el.style.background = 'rgba(39,167,68,.08)';
    el.style.borderColor = 'rgba(39,167,68,.15)';
    return;
  }

  const cumulative = pagePreviouslyPaid + amt;

  if (cumulative >= pageReqFee) {
    if (pagePreviouslyPaid > 0) {
      el.innerHTML = `✓ Fully Paid &nbsp;·&nbsp;
        <span style="color:#5fdd8e">₱${pagePreviouslyPaid.toFixed(2)}</span>
        <span style="color:var(--text-m)"> + </span>
        <span style="color:#5fdd8e">₱${amt.toFixed(2)}</span>
        <span style="color:var(--text-m)"> = </span>
        <span style="color:#5fdd8e">₱${cumulative.toFixed(2)}</span>`;
    } else {
      el.innerHTML = `✓ Fully Paid &nbsp;·&nbsp;
        <span style="color:#5fdd8e">₱${amt.toFixed(2)}</span>`;
    }
    el.style.color = '#5fdd8e';
    el.style.background = 'rgba(39,167,68,.08)';
    el.style.borderColor = 'rgba(39,167,68,.15)';
  } else {
    if (pagePreviouslyPaid > 0) {
      el.innerHTML = `⚠ Partial &nbsp;·&nbsp;
        <span style="color:#fbbf24">₱${pagePreviouslyPaid.toFixed(2)}</span>
        <span style="color:var(--text-m)"> + </span>
        <span style="color:#fbbf24">₱${amt.toFixed(2)}</span>
        <span style="color:var(--text-m)"> = </span>
        <span style="color:#fbbf24">₱${cumulative.toFixed(2)}</span>
        <span style="color:var(--text-m)"> of </span>
        <span style="color:#fff">₱${pageReqFee.toFixed(2)}</span>`;
    } else {
      el.innerHTML = `⚠ Partial &nbsp;·&nbsp;
        <span style="color:#fbbf24">₱${amt.toFixed(2)}</span>
        <span style="color:var(--text-m)"> of </span>
        <span style="color:#fff">₱${pageReqFee.toFixed(2)}</span>`;
    }
    el.style.color = '#fbbf24';
    el.style.background = 'rgba(251,191,36,.08)';
    el.style.borderColor = 'rgba(251,191,36,.15)';
  }
}

async function pageSubmitOrgFee() {
  if (!pageSelStudent) { showToast('Please select a student first.', 'fail'); return; }
  const sel     = document.getElementById('page-of-sem');
  const opt     = sel.options[sel.selectedIndex];
  const sem     = sel.value;
  const fullAmountId = parseInt(opt?.dataset?.fullAmountId) || 0;
  const amt     = parseFloat(document.getElementById('page-of-amount').value) || 0;
  const receipt = document.getElementById('page-of-receipt').value.trim();
  if (!sem) { showToast('Please select a semester.', 'fail'); return; }
  if (!amt)  { showToast('Enter an amount.', 'fail'); return; }
  try {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const res  = await fetch('/Home/AddOrgFeePayment', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
      body: JSON.stringify({ userId: pageSelStudent.userId, amount: amt, semester: sem, fullAmountId, receiptNumber: receipt })
    });
    const data = await res.json();
    if (data.success) {
      showToast('Org fee payment recorded successfully.', 'ok');
      // Reset form
      pageSelStudent = null;
      pagePreviouslyPaid = 0;
      ['page-of-search','page-of-amount','page-of-receipt'].forEach(f => document.getElementById(f).value = '');
      document.getElementById('page-of-selected').style.display = 'none';
      document.getElementById('page-of-status').textContent = 'Enter amount to determine status';
      const nextRes = await fetch('/Home/GetNextReceiptNumber');
      const nextData = await nextRes.json();
      if (nextData.success) document.getElementById('page-of-receipt').value = nextData.receiptNumber;
      await renderDashboard();
      renderCharts();
    } else {
      showToast(data.message || 'Failed to save payment.', 'fail');
    }
  } catch { showToast('Failed to save payment. Please try again.', 'fail'); }
}

async function pageSubmitFund() {
