        </div>
        <div style="background:rgba(39,167,68,.08);border:1px solid var(--green-badge-bd);border-radius:11px;padding:14px 16px">
          <div style="font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:8px">Paid</div>
          <div style="font-size:26px;font-weight:800;color:#5fdd8e;line-height:1;letter-spacing:-.03em" id="bd-paid">0</div>
        </div>
        <div style="background:rgba(251,191,36,.08);border:1px solid var(--yellow-badge-bd);border-radius:11px;padding:14px 16px">
          <div style="font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:8px">Partial</div>
