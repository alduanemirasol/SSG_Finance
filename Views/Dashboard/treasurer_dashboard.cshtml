  if (!schoolYearId)          { showToast('Please select a school year & semester.', 'fail'); return; }
  if (!semester)              { showToast('Please select a semester.', 'fail'); return; }
  if (!amount || amount <= 0) { showToast('Please enter a valid amount.', 'fail'); return; }

  try {
    const res  = await fetch('/Home/SetFeeAmount', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body:    JSON.stringify({ schoolYearId, semester, amount })
