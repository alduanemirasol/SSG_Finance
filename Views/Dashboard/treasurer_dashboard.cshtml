        if (current) sel.value = `${current.yearStart}–${current.yearEnd}`;

        // Rebuild months for the auto-selected school year
        await rebuildMonthsDropdown(sel.value);
    } catch {}
}

function renderCharts() {
    const selectedSY    = (document.getElementById('chart-sy')?.value || '').replace(/\s*[–-]\s*/g, '–');
    const selectedSem   = document.getElementById('chart-sem')?.value || '';   // '', '1', or '2'
    const selectedMonth = document.getElementById('chart-month')?.value;
    const mode          = document.getElementById('chart-mode')?.value || 'both';

    // Resolve the semester window from the cached range (set when SY was picked).
    // No school year selected = semester filter is ignored (we need bounds to apply it).
    let semStart = null, semEnd = null;
    const syRange = window.currentSYDateRange;
    if (selectedSem && syRange) {
        if (selectedSem === '1') {
            semStart = syRange.firstSemStart;
            semEnd   = syRange.firstSemEnd;
        } else if (selectedSem === '2') {
            semStart = syRange.secondSemStart;
            semEnd   = syRange.secondSemEnd;
        }
    }
    // Split the whole school year at the 2nd semester's start instead of clamping to
    // each semester's exact start/end. This way transactions dated in the semester
    // break or after the 2nd semester ends (e.g. graduation) still count — toward the
    // 1st semester if before the split, toward the 2nd semester if on/after it.
    const semBoundary = syRange ? syRange.secondSemStart : null;
    const inSemester = (date) => {
        if (!selectedSem || !syRange) return true;      // not applying
        if (semBoundary) {
            return selectedSem === '1' ? date < semBoundary : date >= semBoundary;
        }
        // No 2nd-semester start configured — fall back to the exact window.
        if (!semStart || !semEnd) return true;
        return date >= semStart && date <= semEnd;
    };

    // Build month labels
    const allMonths = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    let labels;

    if (selectedMonth !== '' && selectedMonth !== null && selectedMonth !== undefined) {
        // Single month selected — show days 1-31
        labels = Array.from({ length: 31 }, (_, i) => `${i + 1}`);
    } else {
        // All months — show Jan–Dec
        labels = allMonths;
    }

    // Build per-category arrays
    let mOrgFee = new Array(labels.length).fill(0);
    let mFunds  = new Array(labels.length).fill(0);
    let mInc    = new Array(labels.length).fill(0);
    let mExp    = new Array(labels.length).fill(0);

    allTransactions()
        .filter(t => {
            const date = new Date(t.fullDate || t.date + 'T00:00');
            if (!inSemester(date)) return false;
            if (selectedMonth !== '' && selectedMonth !== null && selectedMonth !== undefined) {
                const syMatch = !selectedSY || (t.schoolYear || '') === selectedSY;
                return date.getMonth() === parseInt(selectedMonth) && syMatch;
            } else {
                if (!selectedSY) return true;
                return (t.schoolYear || '') === selectedSY;
            }
        })
        .forEach(t => {
            const date  = new Date(t.fullDate || t.date + 'T00:00');
            const index = (selectedMonth !== '' && selectedMonth !== null && selectedMonth !== undefined)
                ? date.getDate() - 1
                : date.getMonth();

            if (t.type === 'expense')        mExp[index]    += t.amt;
            else if (t.src === 'OrgFee')     mOrgFee[index] += t.amt;
            else if (t.src === 'OtherFund')  mFunds[index]  += t.amt;

            if (t.type === 'income') mInc[index] += t.amt;
        });

    // Build datasets based on selected mode
    let datasets = [];
    switch (mode) {
        case 'all':
            datasets = [
                { label: 'Org Fee',      data: mOrgFee, backgroundColor: 'rgba(39,167,68,.75)',  borderRadius: 4, borderSkipped: false },
                { label: 'Other Funds',  data: mFunds,  backgroundColor: 'rgba(59,130,246,.75)', borderRadius: 4, borderSkipped: false },
                { label: 'Expenses',     data: mExp,    backgroundColor: 'rgba(239,68,68,.65)',  borderRadius: 4, borderSkipped: false },
            ];
            break;
        case 'both':
            datasets = [
                { label: 'Income',   data: mInc, backgroundColor: 'rgba(39,167,68,.75)', borderRadius: 4, borderSkipped: false },
                { label: 'Expenses', data: mExp, backgroundColor: 'rgba(239,68,68,.65)', borderRadius: 4, borderSkipped: false },
            ];
            break;
        case 'orgfee':
            datasets = [
                { label: 'Organizational Fee', data: mOrgFee, backgroundColor: 'rgba(39,167,68,.75)', borderRadius: 4, borderSkipped: false },
            ];
            break;
        case 'funds':
            datasets = [
                { label: 'Other Funds', data: mFunds, backgroundColor: 'rgba(59,130,246,.75)', borderRadius: 4, borderSkipped: false },
            ];
            break;
        case 'expense':
            datasets = [
                { label: 'Expenses', data: mExp, backgroundColor: 'rgba(239,68,68,.65)', borderRadius: 4, borderSkipped: false },
            ];
            break;
        default:
            datasets = [
                { label: 'Income',   data: mInc, backgroundColor: 'rgba(39,167,68,.75)', borderRadius: 4, borderSkipped: false },
                { label: 'Expenses', data: mExp, backgroundColor: 'rgba(239,68,68,.65)', borderRadius: 4, borderSkipped: false },
            ];
    }

    if (barChart) barChart.destroy();
    const canvas = document.getElementById('barChart');
    if (!canvas) return;

    barChart = new Chart(canvas, {
        type: 'bar',
        data: { labels, datasets },
        plugins: [{
            id: 'barValueLabels',
            afterDatasetsDraw(chart) {
                const ctx = chart.ctx;
                chart.data.datasets.forEach((dataset, i) => {
                    chart.getDatasetMeta(i).data.forEach((bar, j) => {
                        const v = dataset.data[j];
                        if (!v) return;
                        ctx.save();
                        ctx.fillStyle = 'rgba(232,245,236,0.85)';
                        ctx.font = 'bold 9px sans-serif';
                        ctx.textAlign = 'center';
                        ctx.textBaseline = 'bottom';
                        ctx.fillText(p(v), bar.x, bar.y - 3);
                        ctx.restore();
                    });
                });
            }
        }],
        options: {
            responsive: true, maintainAspectRatio: false,
            layout: { padding: { top: 18 } },
            // Drill down: clicking a month (while in the all-months view) opens that month's days.
            onClick: (evt, _els, chart) => {
                const monthSel = document.getElementById('chart-month');
                if (!monthSel || monthSel.value !== '') return; // only from the monthly view
                const pts = chart.getElementsAtEventForMode(evt, 'index', { intersect: false }, true);
                if (!pts.length) return;
                selectChartMonth(pts[0].index);
            },
            onHover: (evt, _els, chart) => {
                const monthSel = document.getElementById('chart-month');
                const drillable = monthSel && monthSel.value === '';
                const pts = drillable ? chart.getElementsAtEventForMode(evt, 'index', { intersect: false }, true) : [];
                if (evt?.native?.target) evt.native.target.style.cursor = pts.length ? 'pointer' : 'default';
            },
            plugins: {
                legend: { display: datasets.length > 1, labels: { color: 'rgba(232,245,236,.5)', font: { size: 11 }, boxWidth: 10, padding: 12 } },
                tooltip: { callbacks: { label: ctx => ' ' + p(ctx.parsed.y) } }
            },
            scales: {
                x: { grid: { display: false }, ticks: { color: 'rgba(232,245,236,.4)', font: { size: 10 } } },
                y: { grid: { color: 'rgba(255,255,255,.05)' }, ticks: { color: 'rgba(232,245,236,.4)', font: { size: 10 }, callback: v => '₱' + v.toLocaleString() } }
            }
        }
    });
}

const MONTH_NAMES = ['January','February','March','April','May','June',
                     'July','August','September','October','November','December'];

async function onChartSYChange() {
    const selectedSY = document.getElementById('chart-sy').value;
    await rebuildMonthsDropdown(selectedSY);
    updateCharts();
    await refreshDashboardStats();
}

// Caches the selected school year's semester date bounds in
// window.currentSYDateRange, so the semester filter in renderCharts() can apply
// them. (The month dropdown was removed; this no longer builds any options.)
async function rebuildMonthsDropdown(selectedSY) {
    // Reset the cached semester range; semester filtering needs an SY to work.
    window.currentSYDateRange = null;
    if (!selectedSY) return;

    try {
        const res  = await fetch('/Home/GetSchoolYearDateRange?schoolYear=' + encodeURIComponent(selectedSY));
        const data = await res.json();
        if (!data.success) return;

        // Cache so the semester filter in renderCharts can use these bounds.
        window.currentSYDateRange = {
            firstSemStart:  data.firstSemStart  ? new Date(data.firstSemStart)  : null,
            firstSemEnd:    data.firstSemEnd    ? new Date(data.firstSemEnd)    : null,
            secondSemStart: data.secondSemStart ? new Date(data.secondSemStart) : null,
            secondSemEnd:   data.secondSemEnd   ? new Date(data.secondSemEnd)   : null
        };
    } catch { /* leave range uncached */ }
}

// "Default" button: reset the Monthly Overview filters back to the initial load
// (current school year, all semesters, all transactions).
async function resetChartFilters() {
    const semSel  = document.getElementById('chart-sem');
    const modeSel = document.getElementById('chart-mode');
    if (semSel)  semSel.value  = '';
    if (modeSel) modeSel.value = 'all';
    await populateChartSchoolYears();   // re-selects the current school year + recaches range
    updateCharts();
}

// Drill into a month's daily view (used by the bar-chart click handler).
function selectChartMonth(monthIndex) {
  const sel = document.getElementById('chart-month');
  if (!sel) return;
  const val = String(monthIndex);
  // The month dropdown only lists months within the selected school year; if the clicked
  // month isn't there yet, add it so the value sticks and the chart can switch to days.
  if (![...sel.options].some(o => o.value === val)) {
    const opt = document.createElement('option');
    opt.value = val;
    opt.textContent = MONTH_NAMES[monthIndex];
    sel.appendChild(opt);
  }
  sel.value = val;
  updateCharts();
}

function updateCharts() { renderCharts(); }

// ── INCOME ───────────────────────────────────────────────────────
async function renderIncome() {
  await loadOrgFeePayments();
  await loadOtherFunds();

  let rows = [
    ...DB.orgFees.map(x=>({ type:'OrgFee',    id:x.id, date:x.date, desc:'Org Fee – '+x.name+' ('+x.course+' '+x.yr+')', cat:'Org Fee',         amt:x.amt, receipt:x.receipt||'—' })),
    ...DB.funds.map(x  =>({ type:'OtherFund', id:x.id, date:x.date, desc:x.desc+(x.source?' – '+x.source:''),            cat:'Other Receivable', amt:x.amt, receipt:'—' }))
  ].sort((a,b)=>b.date.localeCompare(a.date));
}

// ── INLINE INCOME PAGE ───────────────────────────────────────────
let pageSelStudent = null;
let pageReqFee = 200;
let pagePreviouslyPaid = 0;
// When the selected student still owes an earlier school year, the server will reject
// the payment. We mirror that here so the treasurer is blocked before Save, not after.
let pagePriorBlock = null;

// Show/hide the prior-year settlement block and enable/disable the Save button to match.
function pageSetPriorBlock(label) {
  pagePriorBlock = label || null;
  const note = document.getElementById('page-of-prior-block');
  const txt  = document.getElementById('page-of-prior-block-text');
  const save = document.getElementById('page-of-save');
  if (pagePriorBlock) {
    if (txt) txt.textContent = `Settle the ${pagePriorBlock} balance first before paying this term.`;
    if (note) note.style.display = 'flex';
    if (save) { save.disabled = true; save.style.opacity = '.5'; save.style.cursor = 'not-allowed'; }
  } else {
    if (note) note.style.display = 'none';
    if (save) { save.disabled = false; save.style.opacity = ''; save.style.cursor = ''; }
  }
}

function switchIncomeTab(tab) {
  document.getElementById('income-panel-orgfee').style.display = tab === 'orgfee' ? 'block' : 'none';
  document.getElementById('income-panel-fund').style.display   = tab === 'fund'   ? 'block' : 'none';
  const orgBtn  = document.getElementById('income-tab-orgfee');
  const fundBtn = document.getElementById('income-tab-fund');
  if (tab === 'orgfee') {
    orgBtn.style.background  = 'var(--green)'; orgBtn.style.color  = '#fff'; orgBtn.style.border = 'none';
    fundBtn.style.background = 'transparent';  fundBtn.style.color = 'var(--text-m)'; fundBtn.style.border = '1px solid rgba(255,255,255,.12)';
  } else {
    fundBtn.style.background = 'var(--green)'; fundBtn.style.color = '#fff'; fundBtn.style.border = 'none';
    orgBtn.style.background  = 'transparent';  orgBtn.style.color  = 'var(--text-m)'; orgBtn.style.border  = '1px solid rgba(255,255,255,.12)';
  }
}

async function initIncomePage() {
  // Fresh page visit: term selector starts unlocked (Pay-button flow re-locks it).
  setPageSemLock(false);
  // Load semesters
  try {
    const res  = await fetch('/Home/GetAvailableSemesters');
    const data = await res.json();
    const sel  = document.getElementById('page-of-sem');
    if (!data.success || !data.fees.length) {
      sel.innerHTML = '<option value="">No semesters with fees set</option>';
    } else {
      sel.innerHTML = data.fees.map(f => {
        const semLabel = f.semester === 'First' ? '1st' : '2nd';
        return `<option value="${f.semester}"
                        data-full-amount-id="${f.fullAmountId}"
                        data-year-start="${f.yearStart}"
                        data-year-end="${f.yearEnd}"
                        data-amount="${f.amount}"
                        data-status="${f.semesterStatus}">
                    ${f.yearStart}–${f.yearEnd} · ${semLabel} Semester · ${f.semesterStatus}
                </option>`;
      }).join('');
      // ── AUTO-SELECT the Current semester ──
      const currentIndex = data.fees.findIndex(f => f.semesterStatus === 'Current');
      if (currentIndex !== -1) sel.selectedIndex = currentIndex;
      pageUpdateSemesterStatusLabel();
    }
  } catch {}
  // Auto-fill receipt
  try {
    const receiptRes = await fetch('/Home/GetNextReceiptNumber');
    const receiptData = await receiptRes.json();
    if (receiptData.success) document.getElementById('page-of-receipt').value = receiptData.receiptNumber;
  } catch {}
  // Set date
  const dateEl = document.getElementById('page-fn-date');
  if (dateEl) dateEl.value = today();  // ← always overwrite with today
}

async function pageUpdateSemesterStatusLabel(studentId = null) {
  const sel = document.getElementById('page-of-sem');
  const opt = sel.options[sel.selectedIndex];
  const statusEl = document.getElementById('page-of-sem-status');
  if (!opt || !opt.dataset.status) { statusEl.textContent = ''; return null; }

  pageReqFee = parseFloat(opt.dataset.amount) || pageReqFee;
  document.getElementById('page-of-amount').placeholder = pageReqFee.toFixed(2);
  document.getElementById('page-fee-amount').textContent = '₱' + pageReqFee.toFixed(2);

  if (!studentId) {
    pagePreviouslyPaid = 0;
    pageSetPriorBlock(null);
    const status = opt.dataset.status;
    const color  = status === 'Current' ? '#5fdd8e' : '#fbbf24';
    statusEl.innerHTML = `<span style="color:${color};font-weight:600">● ${status}</span>
      &nbsp;·&nbsp; A.Y. ${opt.dataset.yearStart}–${opt.dataset.yearEnd}
      &nbsp;·&nbsp; ${opt.value === 'First' ? '1st' : '2nd'} Semester`;
    return pageReqFee;
  }

  try {
    const fullAmountId = opt.dataset.fullAmountId;
    const res = await fetch(
      '/Home/GetStudentFeeStatus?userId=' + encodeURIComponent(studentId) +
      '&fullAmountId=' + encodeURIComponent(fullAmountId)
    );
    const data = await res.json();
    if (!data.success) { statusEl.textContent = ''; pageSetPriorBlock(null); return null; }

    // Earlier school year still owed → block here so the treasurer isn't rejected at Save.
    pageSetPriorBlock(data.priorBlock);

    const paid = Number(data.totalPaid) || 0;
    const unpaid = Number(data.balance) || 0;

    if (data.status === 'Paid') {
      pagePreviouslyPaid = paid;
      statusEl.innerHTML = `<span style="color:#5fdd8e;font-weight:600">● Fully Paid</span>`;
      document.getElementById('page-of-amount').value = '';
      pageCheckPaymentStatus();
      return 0;
    } else if (data.status === 'Partial') {
      pagePreviouslyPaid = paid;
      statusEl.innerHTML = `
        <span style="color:#5fdd8e;font-weight:600">Paid = ₱${paid.toFixed(2)}</span>
        &nbsp;·&nbsp;
        <span style="color:#f87171">Unpaid = ₱${unpaid.toFixed(2)}</span>`;
      document.getElementById('page-of-amount').value = unpaid.toFixed(2);
    } else {
      pagePreviouslyPaid = 0;
      statusEl.innerHTML = `
        <span style="color:#f87171;font-weight:600">● Unpaid</span>
        &nbsp;·&nbsp;
        <span style="color:#f87171">Unpaid = ₱${pageReqFee.toFixed(2)}</span>`;
      document.getElementById('page-of-amount').value = pageReqFee.toFixed(2);
    }

    pageCheckPaymentStatus();
    return unpaid;
  } catch {
    statusEl.textContent = '';
    pageSetPriorBlock(null);
    return null;
  }
}

async function pageOnSemesterChange() {
  pagePreviouslyPaid = 0;
  const searchVal = document.getElementById('page-of-search').value.trim();
  document.getElementById('page-of-amount').value = '';
  document.getElementById('page-of-status').textContent = 'Enter amount to determine status';
  await pageUpdateSemesterStatusLabel(pageSelStudent?.userId ?? null);
  if (searchVal) {
    pageSearchStudents(searchVal);
  } else {
    document.getElementById('page-of-list').style.display = 'none';
  }
}

async function pageSearchStudents(q) {
  // Treasurer is manually searching → release any term lock from a Pay button.
  setPageSemLock(false);
  const list  = document.getElementById('page-of-list');
  const query = (q || '').trim();
  if (!query) { list.style.display = 'none'; return; }
  try {
    const sel = document.getElementById('page-of-sem');
    const opt = sel?.options[sel.selectedIndex];
    const fullAmountId = opt?.dataset?.fullAmountId || '';
    const res  = await fetch('/Home/GetStudentsForPayment?q=' + encodeURIComponent(query) + '&fullAmountId=' + encodeURIComponent(fullAmountId));
    const data = await res.json();
    list.style.display = 'block';
    if (!data.success || !data.students.length) {
      list.innerHTML = '<div style="padding:10px 12px;font-size:12px;color:var(--text-d)">No students found.</div>';
      return;
    }
    list.innerHTML = data.students.map(s => `
      <div class="student-item${s.hasPaid ? ' paid' : ''}"
           onclick="${s.hasPaid ? '' : `pageSelectStudent(${s.userId},'${s.name.replace(/'/g,"\\'")}','${s.courseCode.replace(/'/g,"\\'")}','${s.yearSection.replace(/'/g,"\\'")}','${s.schoolId.replace(/'/g,"\\'")}')`}">
        <div>
          <div class="student-name">
            ${s.name}
            ${s.hasPaid ? '<span class="badge by" style="font-size:9px">Paid</span>' : ''}
            ${s.hasPartial && !s.hasPaid ? '<span class="badge by" style="font-size:9px;background:rgba(251,191,36,.18);color:#fbbf24">Partial</span>' : ''}
          </div>
          <div class="student-info">${s.schoolId} · ${s.courseCode} ${s.yearSection}</div>
        </div>
      </div>`).join('');
  } catch {
    list.innerHTML = '<div style="padding:10px 12px;font-size:12px;color:var(--text-d)">Request failed.</div>';
  }
}

async function pageSelectStudent(uid, name, course, yr, sid) {
  pageSelStudent = { userId: uid };
  document.getElementById('page-of-uid').value = uid;
  document.getElementById('page-of-sel-name').textContent = name;
  document.getElementById('page-of-sel-info').textContent = sid + ' · ' + course + ' ' + yr;
  document.getElementById('page-of-selected').style.display = 'block';
  document.getElementById('page-of-list').style.display = 'none';
  document.getElementById('page-of-search').value = name;
  document.getElementById('page-of-amount').value = '';
  document.getElementById('page-of-status').textContent = 'Enter amount to determine status';
  await pageUpdateSemesterStatusLabel(uid);
}

function pageCheckPaymentStatus() {
  const amt = parseFloat(document.getElementById('page-of-amount').value) || 0;
  const el  = document.getElementById('page-of-status');

  if (!amt) {
    el.textContent = 'Enter amount to determine status';
    el.style.color = '#5fdd8e';
    el.style.background = 'rgba(39,167,68,.08)';
    el.style.borderColor = 'rgba(39,167,68,.15)';
    return;
  }

  const cumulative = pagePreviouslyPaid + amt;

  if (cumulative >= pageReqFee) {
    if (pagePreviouslyPaid > 0) {
      el.innerHTML = `✓ Fully Paid &nbsp;·&nbsp;
        <span style="color:#5fdd8e">₱${pagePreviouslyPaid.toFixed(2)}</span>
        <span style="color:var(--text-m)"> + </span>
        <span style="color:#5fdd8e">₱${amt.toFixed(2)}</span>
        <span style="color:var(--text-m)"> = </span>
        <span style="color:#5fdd8e">₱${cumulative.toFixed(2)}</span>`;
    } else {
      el.innerHTML = `✓ Fully Paid &nbsp;·&nbsp;
        <span style="color:#5fdd8e">₱${amt.toFixed(2)}</span>`;
    }
    el.style.color = '#5fdd8e';
    el.style.background = 'rgba(39,167,68,.08)';
    el.style.borderColor = 'rgba(39,167,68,.15)';
  } else {
    if (pagePreviouslyPaid > 0) {
      el.innerHTML = `⚠ Partial &nbsp;·&nbsp;
        <span style="color:#fbbf24">₱${pagePreviouslyPaid.toFixed(2)}</span>
        <span style="color:var(--text-m)"> + </span>
        <span style="color:#fbbf24">₱${amt.toFixed(2)}</span>
        <span style="color:var(--text-m)"> = </span>
        <span style="color:#fbbf24">₱${cumulative.toFixed(2)}</span>
        <span style="color:var(--text-m)"> of </span>
        <span style="color:#fff">₱${pageReqFee.toFixed(2)}</span>`;
    } else {
      el.innerHTML = `⚠ Partial &nbsp;·&nbsp;
        <span style="color:#fbbf24">₱${amt.toFixed(2)}</span>
        <span style="color:var(--text-m)"> of </span>
        <span style="color:#fff">₱${pageReqFee.toFixed(2)}</span>`;
    }
    el.style.color = '#fbbf24';
    el.style.background = 'rgba(251,191,36,.08)';
    el.style.borderColor = 'rgba(251,191,36,.15)';
  }
}

async function pageSubmitOrgFee() {
  if (!pageSelStudent) { showToast('Please select a student first.', 'fail'); return; }
  if (pagePriorBlock) {
    showToast(`Settle the ${pagePriorBlock} balance first before paying this term.`, 'fail');
    return;
  }
  const sel     = document.getElementById('page-of-sem');
  const opt     = sel.options[sel.selectedIndex];
  const sem     = sel.value;
  const fullAmountId = parseInt(opt?.dataset?.fullAmountId) || 0;
  const amt     = parseFloat(document.getElementById('page-of-amount').value) || 0;
  const receipt = document.getElementById('page-of-receipt').value.trim();
  if (!sem) { showToast('Please select a semester.', 'fail'); return; }
  if (!amt)  { showToast('Enter an amount.', 'fail'); return; }
  try {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const res  = await fetch('/Home/AddOrgFeePayment', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
      body: JSON.stringify({ userId: pageSelStudent.userId, amount: amt, semester: sem, fullAmountId, receiptNumber: receipt })
    });
    const data = await res.json();
    if (data.success) {
      showToast('Org fee payment recorded successfully.', 'ok');
      // Reset form
      pageSelStudent = null;
      pagePreviouslyPaid = 0;
      pageSetPriorBlock(null);
      setPageSemLock(false);
      ['page-of-search','page-of-amount','page-of-receipt'].forEach(f => document.getElementById(f).value = '');
      document.getElementById('page-of-selected').style.display = 'none';
      document.getElementById('page-of-status').textContent = 'Enter amount to determine status';
      const nextRes = await fetch('/Home/GetNextReceiptNumber');
      const nextData = await nextRes.json();
      if (nextData.success) document.getElementById('page-of-receipt').value = nextData.receiptNumber;
      await renderDashboard();
      renderCharts();
    } else {
      showToast(data.message || 'Failed to save payment.', 'fail');
    }
  } catch { showToast('Failed to save payment. Please try again.', 'fail'); }
}

async function pageSubmitFund() {
  const source = document.getElementById('page-fn-source').value.trim();
  const desc   = document.getElementById('page-fn-desc').value.trim();
  const cat    = document.getElementById('page-fn-cat').value;
  const amt    = parseFloat(document.getElementById('page-fn-amount').value) || 0;
  const date   = document.getElementById('page-fn-date').value || today();
  if (!desc || !amt) { showToast('Description and amount are required.', 'fail'); return; }
  try {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const res  = await fetch('/Home/AddOtherFund', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
      body: JSON.stringify({ source, description: desc, category: cat, amount: amt, receivedDate: toTimestamp(date) })
    });
    const data = await res.json();
    if (data.success) {
      showToast('Fund recorded successfully.', 'ok');
      ['page-fn-source','page-fn-desc','page-fn-amount'].forEach(f => document.getElementById(f).value = '');
      await renderDashboard();
      renderCharts();
    } else {
      showToast(data.message || 'Failed to save fund.', 'fail');
    }
  } catch { showToast('Failed to save fund. Please try again.', 'fail'); }
}

