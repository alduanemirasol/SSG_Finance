function quickReport(type) { document.getElementById('r-type').value = type; generateReport(); }

function generateReport() {
  let type = document.getElementById('r-type').value;
  let from = document.getElementById('r-from').value;
  let to   = document.getElementById('r-to').value;
  let all  = allTransactions().filter(t => (!from||t.date>=from) && (!to||t.date<=to));
  let rows = type==='Income Statement' ? all.filter(t=>t.type==='income') :
             type==='Expense Report'   ? all.filter(t=>t.type==='expense') : all;
  let inc  = all.filter(t=>t.type==='income').reduce((s,t)=>s+t.amt,0);
  let exp  = all.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amt,0);
  let bal  = inc - exp;

  document.getElementById('report-preview').style.display = 'block';
  document.getElementById('report-preview-title').textContent = type;
  document.getElementById('report-body').innerHTML = `
    <div class="rp-sum">
      <div class="rp-sum-card" style="background:rgba(39,167,68,.08);border:1px solid rgba(39,167,68,.15)"><div class="rp-lbl">Total Income</div><div class="rp-val" style="color:#5fdd8e">+${p(inc)}</div></div>
      <div class="rp-sum-card" style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.15)"><div class="rp-lbl">Total Expenses</div><div class="rp-val" style="color:#f87171">-${p(exp)}</div></div>
      <div class="rp-sum-card" style="background:rgba(59,130,246,.08);border:1px solid rgba(59,130,246,.15)"><div class="rp-lbl">Remaining Balance</div><div class="rp-val" style="color:${bal>=0?'#5fdd8e':'#f87171'}">${bal>=0?'+':''}${p(bal)}</div></div>
    </div>
    <table style="width:100%;border-collapse:collapse;font-size:12px">
      <thead><tr style="border-bottom:1px solid rgba(255,255,255,.07)">
        <th style="padding:8px 14px;text-align:left;color:var(--text-d);font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase">Date</th>
        <th style="padding:8px 14px;text-align:left;color:var(--text-d);font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase">Description</th>
        <th style="padding:8px 14px;text-align:left;color:var(--text-d);font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase">Category</th>
        <th style="padding:8px 14px;text-align:right;color:var(--text-d);font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase">Amount</th>
      </tr></thead>
