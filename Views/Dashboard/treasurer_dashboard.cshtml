async function refreshDashboardStats() {
  // On the Dashboard, the visible school-year dropdown is the student-list one
  // (students-filter-sy). The chart-sy dropdown lives on the Report page. Read
  // whichever is present so a single picker drives both stats and student list.
  const sySel = document.getElementById('students-filter-sy');
  const syInitialized = sySel?.dataset.listenerAttached === 'true';
  const rawSY = sySel != null ? (sySel.value ?? '') : (document.getElementById('chart-sy')?.value || '');
  const selectedSY = rawSY.replace(/\s*[–-]\s*/g, '–');

  // Fall back to current SY only before the dropdown is initialized (first load).
  // Once initialized, an empty value means the user explicitly chose "All School Years".
  const effectiveSY = selectedSY || (!syInitialized && CURRENT_SCHOOL_YEAR && CURRENT_SCHOOL_YEAR !== 'Not Set' ? CURRENT_SCHOOL_YEAR.replace(/\s*[–-]\s*/g, '–') : '');
  const tx = allTransactions().filter(t => !effectiveSY || (t.schoolYear || '') === effectiveSY);
  const collected = tx.filter(t => t.type === 'income').reduce((s, t) => s + t.amt, 0);
  const expenses  = tx.filter(t => t.type === 'expense').reduce((s, t) => s + t.amt, 0);

  const collectedEl = document.getElementById('s-collected');
  const expensesEl  = document.getElementById('s-expenses');
  if (collectedEl) collectedEl.textContent = p(collected);
  if (expensesEl)  expensesEl.textContent  = p(expenses);

  // Remaining Balance = CUMULATIVE cash on hand: selected year + all previous years.
  const selStart = selectedSY ? parseInt(selectedSY.split('–')[0], 10) : null;
  const cumTx = allTransactions().filter(t => {
    if (selStart === null) return true; // "All School Years" = everything
    const tyStart = parseInt((t.schoolYear || '').split('–')[0], 10);
    if (isNaN(tyStart)) return false;
    return tyStart <= selStart;
  });
  const cumCollected = cumTx.filter(t => t.type === 'income').reduce((s, t) => s + t.amt, 0);
  const cumExpenses  = cumTx.filter(t => t.type === 'expense').reduce((s, t) => s + t.amt, 0);

  const balanceEl = document.getElementById('s-balance');
  if (balanceEl) balanceEl.textContent = p(cumCollected - cumExpenses);

  // ── Trend indicators: compare last 30 days vs the 30 days before that.
  // This is independent of the selected school year — it answers "what's the
  // current pace?" rather than "what's the year-to-date total?".
  const now = new Date();
  const day = 24 * 60 * 60 * 1000;
  const start30  = new Date(now.getTime() - 30 * day);
  const start60  = new Date(now.getTime() - 60 * day);

  const everyTx = allTransactions();
  const inRange = (t, a, b) => {
    const d = new Date(t.fullDate || (t.date + 'T00:00'));
    return d >= a && d < b;
  };

  const last30Inc  = everyTx.filter(t => t.type === 'income'  && inRange(t, start30, now)).reduce((s, t) => s + t.amt, 0);
  const prev30Inc  = everyTx.filter(t => t.type === 'income'  && inRange(t, start60, start30)).reduce((s, t) => s + t.amt, 0);
  const last30Exp  = everyTx.filter(t => t.type === 'expense' && inRange(t, start30, now)).reduce((s, t) => s + t.amt, 0);
  const prev30Exp  = everyTx.filter(t => t.type === 'expense' && inRange(t, start60, start30)).reduce((s, t) => s + t.amt, 0);

  // Render a trend line. `positiveIsGood` flips the color logic for expenses:
  // for collected/balance, "up" is green; for expenses, "up" is red.
  const renderTrend = (id, current, previous, positiveIsGood = true) => {
    const el = document.getElementById(id);
    if (!el) return;
    const delta = current - previous;
    if (Math.abs(delta) < 0.01 && previous === 0 && current === 0) {
      el.innerHTML = '<span style="color:var(--text-d)">—</span>';
      return;
    }
    const up = delta >= 0;
    const arrow = up ? '↑' : '↓';
    const good = positiveIsGood ? up : !up;
    const color = good ? '#5fdd8e' : '#f87171';
    el.innerHTML = `<span style="color:${color}">${arrow} ${p(Math.abs(delta))}</span>`;
  };

  renderTrend('s-collected-trend', last30Inc,             prev30Inc,             true);
  renderTrend('s-expenses-trend',  last30Exp,             prev30Exp,             false);
  renderTrend('s-balance-trend',   last30Inc - last30Exp, prev30Inc - prev30Exp, true);

  // Collectable: ask the server for the effective year (defaults to current SY).
  try {
    const url = effectiveSY
      ? '/Home/GetCollectableOrgFee?schoolYear=' + encodeURIComponent(effectiveSY)
      : '/Home/GetCollectableOrgFee';
    const res = await fetch(url);
    const data = await res.json();
    const cEl = document.getElementById('s-collectable');
    if (cEl) cEl.textContent = p(data.success ? data.collectable : 0);
    const cCountEl = document.getElementById('s-collectable-count');
    if (cCountEl) {
      const n = data.success ? (data.membersCount || 0) : 0;
      cCountEl.textContent = n > 0 ? `${n} member${n !== 1 ? 's' : ''} still owe` : ' ';
    }
  } catch {}
}

