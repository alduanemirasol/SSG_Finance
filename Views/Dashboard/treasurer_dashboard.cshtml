  document.getElementById('e-max').textContent   = p(mx);
  document.getElementById('exp-badge').textContent = DB.expenses.length + ' records';
  document.getElementById('expenses-tbody').innerHTML = exp.map(e => `
    <tr>
      <td class="td-mono td-m">${fd(e.date)}</td>
      <td><strong>${e.desc}</strong></td>
      <td class="amt-out">-${p(e.amt)}</td>
      <td class="td-m">Treasurer</td>
      <td><button class="btn-danger" onclick="deleteTx('Expense',${e.id})">Delete</button></td>
    </tr>`).join('') || '<tr class="empty-row"><td colspan="5">No expenses yet.</td></tr>';
