async function deleteTx(type, id) {
  if (!confirm('Delete this transaction? This cannot be undone.')) return;

  try {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    let endpoint = '';
    if (type==='OrgFee') endpoint = '/Home/DeleteOrgFeePayment';
    else if (type==='OtherFund') endpoint = '/Home/DeleteOtherFund';
    else endpoint = '/Home/DeleteExpense';

    const res = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
      body: JSON.stringify({ id: id })
    });
    const data = await res.json();
    if (data.success) {
      if (type==='OrgFee')    DB.orgFees  = DB.orgFees.filter(x=>x.id!==id);
      else if (type==='OtherFund') DB.funds = DB.funds.filter(x=>x.id!==id);
      else                    DB.expenses = DB.expenses.filter(x=>x.id!==id);
      await renderDashboard();
      await renderCharts();
      await renderHistory();
      await renderIncome();
      await renderExpenses();
      showToast('Transaction deleted.', 'ok');
    } else {
      showToast(data.message || 'Failed to delete transaction.', 'fail');
    }
  } catch (err) {
    console.error('Failed to delete transaction:', err);
    showToast('Failed to delete transaction. Please try again.', 'fail');
  }
}

