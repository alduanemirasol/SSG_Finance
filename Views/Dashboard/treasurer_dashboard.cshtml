<script>
function toggleDropdown(btn) {
  const menu = btn.nextElementSibling;
  const isOpen = menu.classList.contains('open');
  // close all open dropdowns first
  document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
  if (!isOpen) menu.classList.add('open');
}

// close dropdowns when clicking outside
document.addEventListener('click', e => {
  if (!e.target.closest('.dropdown-wrap')) {
    document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
  }
});

// ── CONFIG ──────────────────────────────────────────────────────
let REQ_FEE = 200; // Will be updated from current semester fee

// ── DATA STORE ───
let DB = {
  orgFees: [],
  funds: [],
  expenses: []
};

let STUDENTS = [];
let ALL_STUDENTS_PAGE = [];
let _lastStudentsFiltered = [];
let _lastStudentsForBreakdown = [];
let _currentSem = null;     // 'first' | 'second' | null  (live semester of the loaded school year)
let _breakdownSem = 'first'; // semester the breakdown + status filter operate on (falls back for past years)
let studentsPageQ = '';
let studentsPageCourse = '';
let CURRENT_SCHOOL_YEAR = null;
let CURRENT_SEMESTER = null;
let STUDENTS_LAST_FETCH = 0;

// ── STATE ────────────────────────────────────────────────────────
let histQ = '', histType = '', expQ = '';
let histSY = '', histSem = '';

// Apply all history filters (school year, semester, type)
function applyHistoryFilters() {
  histType = document.getElementById('hist-filter-type')?.value ?? '';
  histSY   = '';
  histSem  = '';
  renderHistory();
}
let selStudent = null;
let barChart, donutChart;

// ── UTILS ────────────────────────────────────────────────────────
function p(n) { return '₱' + Number(n).toLocaleString('en-PH', { minimumFractionDigits: 2 }); }
function fd(d) {
  if (!d) return '—';
  return new Date(d.split('T')[0] + 'T00:00').toLocaleDateString('en-PH', { month: 'short', day: 'numeric', year: 'numeric' });
}
function today() { return new Date().toISOString().split('T')[0]; }
function escapeHtml(value) {
  return String(value ?? '').replace(/[&<>"']/g, ch => ({
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#39;'
  }[ch]));
}
// A yearSection like "5-A" means the student has completed the 4-year program,
// so it displays as "4 Completed". Anything else is shown as-is.
function fmtYearSection(yearSection) {
  const ys = String(yearSection ?? '').trim();
  const yearPart = ys.split('-')[0].trim();
  return yearPart === '5' ? 'Graduate' : ys;
}
function amountToWords(amount) {
  if (amount === 0) return 'Zero Pesos Only';
  const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine',
                'Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen',
                'Seventeen', 'Eighteen', 'Nineteen'];
  const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];

  function say(n) {
    if (n < 20) return ones[n];
    if (n < 100) return tens[Math.floor(n / 10)] + (n % 10 ? ' ' + ones[n % 10] : '');
    if (n < 1000) return ones[Math.floor(n / 100)] + ' Hundred' + (n % 100 ? ' ' + say(n % 100) : '');
    if (n < 1000000) return say(Math.floor(n / 1000)) + ' Thousand' + (n % 1000 ? ' ' + say(n % 1000) : '');
    return say(Math.floor(n / 1000000)) + ' Million' + (n % 1000000 ? ' ' + say(n % 1000000) : '');
  }

  const pesos = Math.floor(amount);
  const cents = Math.round((amount - pesos) * 100);
  let result = say(pesos) + ' Peso' + (pesos !== 1 ? 's' : '');
  if (cents > 0) result += ' and ' + say(cents) + ' Centavo' + (cents !== 1 ? 's' : '');
  return result + ' Only';
}

