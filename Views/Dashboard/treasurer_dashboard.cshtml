// Wait for the receipt-paper element to appear in the DOM after viewReceipt
// kicks off its render. Falls back to a hard timeout so we always print eventually.
function awaitReceiptReady(timeoutMs = 2500) {
  return new Promise(resolve => {
    const start = Date.now();
    const tick = () => {
      const paper = document.querySelector('.receipt-paper');
      // The paper exists once its container modal is open; check visibility too
      // so we don't print an empty paper that's still being populated.
      const modalOpen = document.querySelector('.receipt-modal.open');
      if (paper && modalOpen && paper.textContent.trim().length > 0) {
        // Give the browser one extra frame to actually paint
        requestAnimationFrame(() => resolve(true));
        return;
      }
      if (Date.now() - start > timeoutMs) { resolve(false); return; }
      setTimeout(tick, 60);
    };
    tick();
  });
}

// Print the receipt. The @@media print stylesheet hides everything except the
// .receipt-paper, so only the receipt itself appears in the print preview.
//
// IMPORTANT — the date and URL at the top of the printed page come from the
// browser, not from this code. They cannot be removed by CSS or JS; the user
// must uncheck "Headers and footers" in the print dialog's More Settings
// (the browser remembers this setting). We blank the document title for the
// duration of the print so at least that part of the header is empty.
async function printPaymentReceipt(paymentId, receiptNumber) {
  await viewReceipt('OrgFee', paymentId, receiptNumber);
  await awaitReceiptReady();

  showToast('Tip: in More settings, uncheck "Headers and footers" for a clean print.', 'ok');

  const originalTitle = document.title;
  const studentName = (document.getElementById('tr-rp-name')?.textContent || '').trim().replace(/\s+/g, '_');
  const receiptNo   = (document.getElementById('tr-rp-receipt-no')?.textContent || 'receipt').trim();
  document.title = studentName && receiptNo ? `${studentName}_${receiptNo}` : receiptNo || ' ';
  try {
    window.print();
  } finally {
    document.title = originalTitle;
    closeTreasurerReceipt();
  }
}

