let nrCurrentType = 'Event';
let nrSchoolYears = [];

async function loadReports() {
  try {
    const res  = await fetch('/Home/GetReports');
    const data = await res.json();
    if (!data.success) return;
    const body = document.getElementById('rpt-list-body');
    if (!data.reports.length) {
      body.innerHTML = '<div style="padding:24px;text-align:center;color:var(--text-d);font-size:13px">No reports yet.</div>';
      return;
    }
    const fmt = n => '₱' + Number(n).toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const badgeClass = t => t === 'Event' ? 'event' : t === 'Semester' ? 'semester' : 'annual';
    body.innerHTML = data.reports.map(r => `
      <div class="rpt-row" onclick="viewReport(${r.reportId})">
