async function rebuildMonthsDropdown(selectedSY) {
    const sel = document.getElementById('chart-month');
    const currentVal = sel.value;

    // Reset the cached semester range; semester filtering needs an SY to work.
    window.currentSYDateRange = null;

    if (!selectedSY) {
        // No school year selected — show all months
        sel.innerHTML = '<option value="">All Months</option>' +
            MONTH_NAMES.map((m, i) => `<option value="${i}">${m}</option>`).join('');
        sel.value = currentVal;
        return;
    }

    try {
        const res  = await fetch('/Home/GetSchoolYearDateRange?schoolYear=' + encodeURIComponent(selectedSY));
        const data = await res.json();

        if (!data.success) {
            sel.innerHTML = '<option value="">All Months</option>' +
                MONTH_NAMES.map((m, i) => `<option value="${i}">${m}</option>`).join('');
            return;
        }

        // Cache so the semester filter in renderCharts can use these bounds.
        window.currentSYDateRange = {
            firstSemStart:  data.firstSemStart  ? new Date(data.firstSemStart)  : null,
            firstSemEnd:    data.firstSemEnd    ? new Date(data.firstSemEnd)    : null,
            secondSemStart: data.secondSemStart ? new Date(data.secondSemStart) : null,
            secondSemEnd:   data.secondSemEnd   ? new Date(data.secondSemEnd)   : null
        };

        // Determine month range
        // Use firstSemStart as the start, secondSemEnd as the end
        // Fall back to firstSemEnd if secondSemEnd is null
        const startDate = data.firstSemStart  ? new Date(data.firstSemStart)  : null;
        const endDate   = data.secondSemEnd   ? new Date(data.secondSemEnd)   :
                          data.firstSemEnd    ? new Date(data.firstSemEnd)    : null;

        if (!startDate || !endDate) {
            sel.innerHTML = '<option value="">All Months</option>' +
                MONTH_NAMES.map((m, i) => `<option value="${i}">${m}</option>`).join('');
            return;
        }

        const startMonth = startDate.getMonth(); // e.g. 7 = August
        const endMonth   = endDate.getMonth();   // e.g. 5 = June

        let months = [];

        // Handle wrapping across year boundary (e.g. Aug–June spans two calendar years)
        if (startMonth <= endMonth) {
            // Same calendar year range (e.g. Jan–Jun)
            for (let m = startMonth; m <= endMonth; m++)
                months.push(m);
        } else {
            // Wraps across year boundary (e.g. Aug–Jun)
            for (let m = startMonth; m <= 11; m++) months.push(m);
            for (let m = 0; m <= endMonth; m++)  months.push(m);
        }

        sel.innerHTML = '<option value="">All Months</option>' +
            months.map(m => `<option value="${m}">${MONTH_NAMES[m]}</option>`).join('');

        // Restore previous selection if still valid
        if ([...sel.options].some(o => o.value === currentVal))
            sel.value = currentVal;

    } catch {
        sel.innerHTML = '<option value="">All Months</option>' +
            MONTH_NAMES.map((m, i) => `<option value="${i}">${m}</option>`).join('');
    }
}

