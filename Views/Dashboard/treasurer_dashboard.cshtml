    document.getElementById('edit-orgfee-id').value          = fee.id;
    document.getElementById('edit-orgfee-amount').value      = fee.amt;
    document.getElementById('edit-orgfee-receipt').value     = fee.receipt || '';
    document.getElementById('edit-orgfee-sub').textContent   = fee.name + ' — ' + fee.sem;

    document.getElementById('edit-orgfee-full-amount').value = REQ_FEE;

    checkEditPaymentStatus();
    updateEditOrgFeeNotice(fee.fullDate || fee.date || null);
    openModal('modal-edit-orgfee');

  } else {
    // OtherFund — find record and open the fund modal pre-filled
    const fund = DB.funds.find(f => f.id === id);
    if (!fund) { showToast('Record not found.', 'fail'); return; }
    document.getElementById('fn-source').value = fund.source || '';
    document.getElementById('fn-desc').value   = fund.desc  || '';
