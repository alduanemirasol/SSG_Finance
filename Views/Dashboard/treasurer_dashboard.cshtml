    const sel = document.getElementById('of-sem');
    const opt = sel?.options[sel.selectedIndex];
    const fullAmountId = opt?.dataset?.fullAmountId || '';
    const res = await fetch(`/Home/GetStudentsForPayment?fullAmountId=${encodeURIComponent(fullAmountId)}`);
    const data = await res.json();
    if (data.success) {
      STUDENTS = data.students.map(s => ({
        userId: s.userId,
        schoolId: s.schoolId,
        name: s.name,
        courseCode: s.courseCode,
        yearSection: s.yearSection,
        hasPaid: s.hasPaid
      }));
      STUDENTS_LAST_FETCH = Date.now();
    } else {
      console.error('Failed to load students:', data.message || 'Unknown error');
