@model MyMvcApp.Models.DashboardViewModel
@{
    ViewData["Title"] = "Treasurer Dashboard";
    var firstName = Context.Session.GetString("FirstName") ?? "Treasurer";
    var lastName  = Context.Session.GetString("LastName") ?? "";
    var schoolId  = Context.Session.GetString("SchoolId") ?? "";
    var initials  = (firstName.Length > 0 ? firstName[0].ToString() : "") + (lastName.Length > 0 ? lastName[0].ToString() : "");
}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SSG Finance - Treasurer</title>
<link rel="icon" type="image/png" href="~/favicon.png">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
/* ── RESET & ROOT ── */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#071a0c;--sidebar:#081509;
  --green:#27a744;--green-d:#1a7a4a;
  --green-glow:rgba(39,167,68,.18);--green-glow2:rgba(39,167,68,.08);
  --glass:rgba(255,255,255,.045);
  --text:#e8f5ec;--text-m:rgba(232,245,236,.6);--text-d:rgba(232,245,236,.35);
  --card:#0f2918;--card-b:rgba(255,255,255,.07);
  --green-badge:rgba(39,167,68,.28);--green-badge-t:#7eeaa3;--green-badge-bd:rgba(39,167,68,.55);
  --yellow-badge:rgba(251,191,36,.24);--yellow-badge-t:#fcd34d;--yellow-badge-bd:rgba(251,191,36,.55);
  --red-badge:rgba(239,68,68,.24);--red-badge-t:#fca5a5;--red-badge-bd:rgba(239,68,68,.55);
  --blue-badge:rgba(59,130,246,.14);--blue-badge-t:#93c5fd;
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);display:flex;min-height:100vh;color:var(--text);font-size:14px;overflow:hidden}

/* ── SIDEBAR ── */
.sidebar{width:218px;background:var(--sidebar);border-right:1px solid rgba(255,255,255,.05);display:flex;flex-direction:column;flex-shrink:0}
.sb-brand{display:flex;align-items:center;gap:10px;padding:20px 16px 18px;border-bottom:1px solid rgba(255,255,255,.05)}
.sb-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 14px rgba(39,167,68,.3)}
.sb-logo svg{width:18px;height:18px}
.sb-logo img{width:100%;height:100%;object-fit:cover;border-radius:10px}
.sb-brand-name{font-size:13.5px;font-weight:700;color:#fff;letter-spacing:-.01em}
.sb-brand-sub{font-size:10px;color:rgba(39,167,68,.85);letter-spacing:.1em;text-transform:uppercase;margin-top:1px}
.sb-label{font-size:9.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--text-d);padding:16px 16px 5px}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 12px;margin:1px 8px;border-radius:8px;font-size:13px;font-weight:500;color:var(--text-m);cursor:pointer;transition:all .15s;border:1px solid transparent}
.nav-item:hover{background:var(--glass);color:var(--text)}
.nav-item.active{background:var(--green-glow);color:#5fdd8e;border-color:rgba(74,222,128,.12)}
.nav-item svg{width:15px;height:15px;flex-shrink:0;opacity:.85}
.sb-spacer{flex:1}
.sb-user{padding:10px 8px;border-top:1px solid rgba(255,255,255,.05)}
.user-card{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;background:var(--glass)}
.user-av{width:30px;height:30px;border-radius:7px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.user-name{font-size:12px;font-weight:600;color:#fff}
.user-role{font-size:10.5px;color:var(--text-d)}
.signout{display:flex;align-items:center;gap:7px;padding:7px 10px;margin-top:3px;border-radius:8px;font-size:12.5px;font-weight:500;color:var(--text-d);cursor:pointer;transition:all .15s}
.signout:hover{background:rgba(239,68,68,.08);color:#f87171}
.signout svg{width:14px;height:14px}

/* ── MAIN ── */
.main{flex:1;min-width:0;padding:32px 32px 60px;background:var(--bg);overflow-y:auto;height:100vh;position:relative}
.main::before{content:'';position:absolute;top:-80px;right:-80px;width:380px;height:380px;background:radial-gradient(circle,rgba(39,167,68,.06) 0%,transparent 70%);pointer-events:none;border-radius:50%}
.top-accent{height:2px;background:linear-gradient(90deg,transparent,var(--green),transparent);position:fixed;top:0;left:0;right:0;z-index:10}

/* ── PAGES ── */
.page{display:none;max-width:1200px;margin-left:auto;margin-right:auto}.page.active{display:block}
.page-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px}
.page-title{font-size:22px;font-weight:800;color:#fff;letter-spacing:-.03em}
.page-sub{font-size:12px;color:var(--text-m);margin-top:2px}

/* ── STAT CARDS ── */
.stat-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px}
.stat-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;padding:18px 20px;position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px}
.stat-card.green::before{background:linear-gradient(90deg,transparent,rgba(39,167,68,.35),transparent)}
.stat-card.red::before{background:linear-gradient(90deg,transparent,rgba(239,68,68,.35),transparent)}
.stat-card.blue::before{background:linear-gradient(90deg,transparent,rgba(59,130,246,.35),transparent)}
.stat-card.yellow::before{background:linear-gradient(90deg,transparent,rgba(251,191,36,.35),transparent)}
.stat-lbl{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:8px}
.stat-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.stat-val{font-size:28px;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em}
.stat-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center}
.stat-icon svg{width:15px;height:15px}
.stat-icon.g{background:rgba(39,167,68,.15)}
.stat-icon.r{background:rgba(239,68,68,.12)}
.stat-icon.b{background:rgba(59,130,246,.12)}
.stat-icon.y{background:rgba(251,191,36,.12)}
.stat-sub{font-size:10.5px;color:var(--text-d);padding-top:6px;border-top:1px solid rgba(255,255,255,.05)}

/* ── CONTENT CARDS ── */
.content-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;margin-bottom:14px;position:relative;overflow:visible}
.content-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;border-radius:14px 14px 0 0;background:linear-gradient(90deg,transparent,rgba(39,167,68,.2),transparent)}
.cc-hdr{display:flex;align-items:center;justify-content:space-between;padding:14px 20px 12px;border-bottom:1px solid rgba(255,255,255,.05)}
.cc-title{font-size:13.5px;font-weight:700;color:#fff}

/* ── CHARTS ── */
.charts-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:14px;margin-bottom:14px}
.chart-wrap{padding:16px;height:210px;position:relative}
.donut-wrap{padding:16px;display:flex;flex-direction:column;align-items:center;gap:10px}
.donut-canvas{width:150px;height:150px}
.donut-legend{width:100%;display:flex;flex-direction:column;gap:5px}
.dl-row{display:flex;align-items:center;justify-content:space-between;font-size:11.5px}
.dl-dot{width:9px;height:9px;border-radius:2px;margin-right:7px;flex-shrink:0}
.dl-lbl{display:flex;align-items:center;color:var(--text-m)}
.dl-val{font-family:'DM Mono',monospace;font-weight:500;font-size:11.5px}

/* ── TABLE ── */
.toolbar{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;border-bottom:1px solid rgba(255,255,255,.05);gap:10px;flex-wrap:wrap}
.search-box{display:flex;align-items:center;gap:7px;border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:7px 12px;background:rgba(255,255,255,.04);min-width:210px;transition:all .15s}
.search-box:focus-within{border-color:var(--green);background:rgba(39,167,68,.06)}
.search-box input{border:none;outline:none;font-family:inherit;font-size:12.5px;color:var(--text);width:100%;background:transparent}
.search-box input::placeholder{color:var(--text-d)}
.search-box svg{width:14px;height:14px;color:var(--text-d);flex-shrink:0}
.filter-select{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:7px 28px 7px 11px;font-size:12px;color:var(--text-m);font-family:inherit;cursor:pointer;outline:none;appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23e8f5ec%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 6px center;background-size:18px}
.filter-select option{background:#0a1f10}
table{width:100%;border-collapse:collapse;font-size:12.5px}
thead th{padding:10px 16px;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);border-bottom:1px solid rgba(255,255,255,.05);text-align:left;white-space:nowrap;background:rgba(255,255,255,.02)}
tbody tr{border-bottom:1px solid rgba(255,255,255,.04);transition:background .1s}
tbody tr:last-child{border-bottom:none}
tbody tr:nth-child(even){background:rgba(255,255,255,.015)}
tbody tr:hover{background:rgba(39,167,68,.07)}
td{padding:11px 16px;color:var(--text);vertical-align:middle}
.td-m{color:var(--text-m)}.td-mono{font-family:'DM Mono',monospace;font-size:11.5px}
.empty-row td{text-align:center;padding:40px;color:var(--text-d);font-size:12.5px}

/* ── BADGES ── */
.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:10.5px;font-weight:700;letter-spacing:.02em;border:1px solid transparent}
.bg{background:var(--green-badge);color:var(--green-badge-t);border-color:var(--green-badge-bd)}
.by{background:var(--yellow-badge);color:var(--yellow-badge-t);border-color:var(--yellow-badge-bd)}
.br{background:var(--red-badge);color:var(--red-badge-t);border-color:var(--red-badge-bd)}
.bb{background:var(--blue-badge);color:var(--blue-badge-t)}

/* ── BUTTONS ── */
.btn-primary{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:12.5px;font-weight:600;cursor:pointer;border:none;font-family:inherit;transition:all .15s;background:var(--green);color:#fff}
.btn-primary:hover{background:#22963d;transform:translateY(-1px)}
.btn-outline{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;background:transparent;border:1px solid rgba(255,255,255,.12);color:var(--text-m)}
.btn-outline:hover{border-color:var(--green);color:#5fdd8e;background:var(--green-glow2)}
.btn-danger{display:inline-flex;align-items:center;gap:5px;padding:5px 11px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;background:var(--red-badge);color:var(--red-badge-t);border:1px solid rgba(239,68,68,.2)}
.btn-danger:hover{background:rgba(239,68,68,.22)}

/* ── AMOUNT COLORS ── */
.amt-in{color:#5fdd8e;font-family:'DM Mono',monospace;font-size:12px;font-weight:500}
.amt-out{color:#f87171;font-family:'DM Mono',monospace;font-size:12px;font-weight:500}
.amt-neu{color:var(--text-m);font-family:'DM Mono',monospace;font-size:12px}

/* ── SUMMARY ROW ── */
.summary-row{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid rgba(255,255,255,.06)}
.summary-cell{padding:12px 20px;text-align:center}
.summary-cell:not(:last-child){border-right:1px solid rgba(255,255,255,.06)}
.summary-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-d);margin-bottom:4px}
.summary-val{font-family:'DM Mono',monospace;font-size:14px;font-weight:500}

/* ── INCOME CARDS ── */
.income-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.income-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;padding:22px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.income-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(39,167,68,.2),transparent)}
.income-card:hover{border-color:rgba(39,167,68,.25);background:rgba(39,167,68,.06);transform:translateY(-1px)}
.income-card-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:14px}
.income-card-icon svg{width:20px;height:20px}
.income-card-title{font-size:14px;font-weight:700;color:#fff;margin-bottom:4px}
.income-card-desc{font-size:12px;color:var(--text-m);line-height:1.6;margin-bottom:16px}

/* ── REPORT CARDS ── */
.report-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;padding:18px}
.report-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:16px;cursor:pointer;transition:all .18s}
.report-card:hover{background:var(--green-glow2);border-color:rgba(39,167,68,.22);transform:translateY(-1px)}
.report-card-icon{width:38px;height:38px;border-radius:10px;background:rgba(39,167,68,.15);display:flex;align-items:center;justify-content:center;margin-bottom:11px}
.report-card-icon svg{width:17px;height:17px}
.report-card-title{font-size:13px;font-weight:700;color:#fff;margin-bottom:4px}
.report-card-desc{font-size:11.5px;color:var(--text-m);line-height:1.5}

/* ── MODAL ── */
.modal-overlay{display:none;position:fixed;inset:0;z-index:500;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(4px)}
.modal-box{position:relative;z-index:1;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:28px 30px;width:100%;max-width:500px;box-shadow:0 24px 60px rgba(0,0,0,.5);max-height:90vh;overflow-y:auto}
.modal-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px}
.modal-title{font-size:16px;font-weight:700;color:#fff}
.modal-sub{font-size:11.5px;color:var(--text-m);margin-top:2px}
.modal-close{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.form-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-d);margin-bottom:6px;display:block}
.form-group{margin-bottom:13px}
.form-input{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none;transition:border-color .2s}
.form-input:focus{border-color:var(--green);background:rgba(39,167,68,.06)}
.form-input::placeholder{color:var(--text-d)}
.form-select{width:100%;background:#0a1f10;border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none;cursor:pointer;appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23fff%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 10px center;background-size:20px}
.form-select option{background:#0a1f10}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.modal-footer{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,.06)}
.status-box{font-size:12px;padding:8px 12px;border-radius:7px;border:1px solid rgba(39,167,68,.15);background:rgba(39,167,68,.08);color:#5fdd8e}

/* ── STUDENT SEARCH ── */
.student-list{max-height:160px;overflow-y:auto;border:1px solid rgba(255,255,255,.1);border-radius:7px;background:#0a1f10;margin-top:5px;display:none}
.student-item{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,.05);transition:background .1s}
.student-item:last-child{border-bottom:none}
.student-item:hover{background:rgba(39,167,68,.08)}
.student-item.paid{opacity:.4;pointer-events:none}
.student-name{font-size:12.5px;font-weight:600;color:#fff}
.student-info{font-size:11px;color:var(--text-m)}

/* ── REPORT PREVIEW ── */
.rp-sum{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px}
.rp-sum-card{border-radius:10px;padding:14px}
.rp-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--text-d);margin-bottom:5px}
.rp-val{font-family:'DM Mono',monospace;font-size:18px;font-weight:500}

/* ── SETTINGS ── */
.settings-tabs{display:flex;gap:2px;margin-bottom:20px;border-bottom:1px solid rgba(255,255,255,.06);flex-wrap:wrap}
.settings-tab{display:flex;align-items:center;gap:7px;padding:9px 16px;border:none;border-bottom:2px solid transparent;background:transparent;color:var(--text-m);font-size:12.5px;font-weight:500;cursor:pointer;font-family:inherit;transition:all .15s;margin-bottom:-1px}
.settings-tab:hover{color:var(--text)}
.settings-tab.active{color:#5fdd8e;border-bottom-color:#27a744}
.settings-panel{display:none}.settings-panel.active{display:block}
.settings-label{font-size:11px;color:var(--text-m);display:block;margin-bottom:4px}
.sig-pad-note{font-size:12px;color:var(--text-m);margin-bottom:14px;line-height:1.6}
.sig-canvas-wrap{position:relative;border:1.5px solid rgba(255,255,255,.15);border-radius:10px;background:#fff;overflow:hidden;cursor:crosshair;width:100%;max-width:560px}
#sig-canvas{display:block;width:100%;touch-action:none}
#sig-placeholder{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;font-size:13px;color:rgba(0,0,0,.3);font-style:italic}
.sig-actions{display:flex;gap:10px;margin-top:14px;flex-wrap:wrap}
.sig-preview-wrap{display:none;margin-top:22px;padding-top:18px;border-top:1px solid rgba(255,255,255,.06)}
.sig-preview-label{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:10px}
.sig-preview-box{background:#fff;border-radius:8px;padding:12px 16px;display:inline-block;border:1px solid rgba(255,255,255,.1)}
.sig-preview-box img{max-height:80px;max-width:400px;display:block}
.sig-preview-date{font-size:11px;color:var(--text-d);margin-top:6px}

/* ── TOAST ── */
#toast{position:fixed;bottom:20px;right:20px;padding:10px 18px;border-radius:9px;font-size:12.5px;font-weight:500;background:#1f2937;color:#fff;opacity:0;transform:translateY(8px);transition:opacity .25s,transform .25s;z-index:999;pointer-events:none;box-shadow:0 8px 24px rgba(0,0,0,.4)}
#toast.show{opacity:1;transform:translateY(0)}
#toast.ok{background:#052e16;border:1px solid rgba(39,167,68,.3)}
#toast.fail{background:#450a0a;border:1px solid rgba(239,68,68,.3)}

/* ── DROPDOWN ── */
.dropdown-wrap{position:relative;display:inline-block}
.dot-btn{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.dot-btn:hover{background:rgba(255,255,255,.1);color:var(--text)}
.dropdown-menu{display:none;position:absolute;right:0;bottom:34px;top:auto;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:10px;min-width:160px;z-index:9999;box-shadow:0 8px 24px rgba(0,0,0,.4);overflow:hidden}
.dropdown-menu.open{display:block}
.dropdown-item{display:flex;align-items:center;gap:8px;padding:9px 14px;font-size:12.5px;color:var(--text-m);cursor:pointer;transition:background .1s}
.dropdown-item:hover{background:rgba(39,167,68,.08);color:var(--text)}
.dropdown-item.danger{color:var(--red-badge-t)}
.dropdown-item.danger:hover{background:rgba(239,68,68,.08)}

/* Receipt preview */
.receipt-modal{display:none;position:fixed;inset:0;z-index:700;align-items:center;justify-content:center}
.receipt-modal.open{display:flex}
.receipt-modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(6px)}
.receipt-modal-inner{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:12px;max-height:95vh;overflow-y:auto;padding:16px}
.receipt-controls{display:flex;align-items:center;gap:10px;background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:8px 14px;width:100%;max-width:620px}
.receipt-ctrl-title{flex:1;font-size:12.5px;font-weight:600;color:var(--text-m)}
.btn-pdf{display:inline-flex;align-items:center;gap:6px;padding:6px 16px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:1px solid rgba(39,167,68,.3);background:rgba(39,167,68,.15);color:#5fdd8e;transition:all .15s;font-family:inherit;flex-shrink:0}
.btn-pdf:hover{background:rgba(39,167,68,.25);transform:translateY(-1px)}
.btn-receipt-close{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;font-family:inherit;flex-shrink:0}
.btn-receipt-close:hover{background:rgba(239,68,68,.12);color:#f87171}

/* ── THE ACTUAL RECEIPT (white paper) — matches student design ── */
.receipt-paper{
  width:620px;
  min-height:auto;
  background:#f9f8f5;
  border:1px solid #ccc;
  box-shadow:0 8px 40px rgba(0,0,0,.45);
  padding:24px 56px 28px;
  font-family:Arial, Helvetica, sans-serif;
  color:#111;
  position:relative;
  flex-shrink:0;
}
.receipt-paper::before{
  content:'';
  position:absolute;
  inset:0;
  background:repeating-linear-gradient(0deg,transparent,transparent 31px,rgba(180,180,200,.18) 31px,rgba(180,180,200,.18) 32px);
  pointer-events:none;
}

.rp-header{text-align:center;margin-bottom:12px;position:relative;z-index:1}
.rp-org{font-size:16px;font-weight:700;letter-spacing:.01em;margin-bottom:1px}
.rp-campus{font-size:11px;font-weight:400}
.rp-divider{border:none;border-top:1px solid #555;margin:8px 0 6px}
.rp-type{font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin-top:6px}
.rp-copy{font-size:10px;font-style:italic;color:#444;margin-top:1px}

.rp-meta{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;position:relative;z-index:1;gap:8px}
.rp-meta-label{font-size:11px;font-weight:400}
.rp-meta-value{font-size:12px;font-weight:700;color:#c0392b;border-bottom:1px solid #888;min-width:140px;display:inline-block;padding-bottom:2px;text-align:center}
.rp-meta-value.date-val{color:#111}

.rp-section-title{text-align:center;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px;position:relative;z-index:1}

.rp-field{display:flex;align-items:baseline;margin-bottom:6px;position:relative;z-index:1}
.rp-field-label{font-size:12px;font-weight:400;min-width:150px;flex-shrink:0}
.rp-field-value{flex:1;font-size:12px;font-weight:700;border-bottom:1px solid #888;padding-bottom:2px;min-height:18px;padding-left:6px;font-family:Arial,Helvetica,sans-serif}
.rp-field-value.handwritten{font-family:Arial,Helvetica,sans-serif;font-style:none;font-size:12px;letter-spacing:.01em}

.rp-status-badge{display:inline-block;padding:1px 10px;border:1.5px solid #555;border-radius:4px;font-size:12px;font-weight:700;font-style:italic;background:#fff}
.rp-status-badge.paid{border-color:transparent;color:#1a7a4a;background:transparent}
.rp-status-badge.partial{border-color:transparent;color:#b45309;background:transparent}
.rp-status-badge.pending{border-color:transparent;color:#92400e;background:transparent}

.rp-signature-section{margin-top:24px;display:flex;justify-content:flex-end;position:relative;z-index:1}
.rp-sig-block{text-align:center;min-width:220px}
.rp-sig-label{font-size:11px;margin-bottom:6px}
.rp-sig-line{display:none}
.rp-sig-name-label{font-size:10px;color:#555}
.rp-watermark{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-35deg);font-size:90px;font-weight:700;color:rgba(0,0,0,.04);pointer-events:none;letter-spacing:.2em;z-index:0;font-family:Arial,sans-serif;text-transform:uppercase}

@@media (max-width: 768px){
  .receipt-modal-inner{padding:8px}
  .receipt-controls{max-width:95vw}
  /* Scale the whole receipt down as one unit so mobile looks identical to desktop */
  .receipt-paper{
    transform: scale(0.56);
    transform-origin: top center;
    margin-bottom: -420px;
  }
}

/* ── PRINT STYLES ──
   When the user prints (or saves as PDF) from the receipt viewer, only the
   .receipt-paper element should appear on the page. Everything else — the
   sidebar, dashboard content, modal chrome, controls, even the dark backdrop —
   is hidden, and the receipt is lifted out of its modal positioning and placed
   cleanly on a white page. */
@@media print {
  /* Hide everything by default */
  body * { visibility: hidden !important; }

  /* Force a clean white page with black text. Override body's flex layout AND
     full-viewport heights so the receipt isn't pushed down a page by hidden
     elements that still occupy layout space. */
  html, body {
    background: #ffffff !important;
    color: #000000 !important;
    margin: 0 !important;
    padding: 0 !important;
    display: block !important;
    overflow: visible !important;
    min-height: 0 !important;
    height: auto !important;
  }

  /* The dashboard main content panel is height:100vh on screen. Hidden during
     print, but still occupying layout space unless we collapse it. */
  .main, .sidebar, .top-accent {
    display: none !important;
  }

  /* Reveal only the receipt paper and its children */
  .receipt-paper, .receipt-paper * { visibility: visible !important; }

  /* Lift the receipt out of its centered modal layout. The receipt sits inside
     a fixed-position .receipt-modal with a flex inner container; for print we
     reset it so the receipt sits at the top of the page with equal side margins. */
  .receipt-modal,
  .receipt-modal-inner {
    position: static !important;
    display: block !important;
    width: auto !important;
    background: #ffffff !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    padding: 0 !important;
    margin: 0 !important;
    max-height: none !important;
    overflow: visible !important;
  }
  .receipt-modal-backdrop { display: none !important; }
  .receipt-controls      { display: none !important; }

  .receipt-paper {
    position: static !important;
    transform: none !important;     /* undo mobile down-scaling */
    margin: 0px auto 0 !important; /* 50px top, equal left/right via auto */
    box-shadow: none !important;
    border: none !important;
    background: #ffffff !important; /* override tinted off-white for clean print */
    page-break-inside: avoid;
  }
  .receipt-paper::before { display: none !important; }

  /* Browsers default to dropping background colors when printing; force them on
     for the receipt so its tinted fields and signature line still appear. */
  .receipt-paper, .receipt-paper * {
    -webkit-print-color-adjust: exact !important;
    print-color-adjust:         exact !important;
  }

  /* Hide standard chrome we never want on a printed receipt */
  .modal-overlay, .toast, header, footer { display: none !important; }

  /* Reasonable print page. Setting size + zero margin-related properties
     coaxes Chromium-family browsers into omitting the page header/footer in
     some builds. Note: the "Headers and footers" toggle in the browser print
     dialog is the only fully reliable way to suppress them — this is a
     best-effort fallback. */
  @@page {
    margin: 12mm;
    size: auto;
    marks: none;
  }
}
</style>
</head>
