            <div class="dropdown-item has-submenu" onclick="showProfRoleSubmenu(this, @p.AccountId)">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                Change Role
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" style="margin-left:auto"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                <!-- submenu -->
                <div class="dropdown-menu" id="prof-role-submenu-@p.AccountId" style="display:none;position:absolute;left:-140px;top:0;min-width:130px">
                    <div class="dropdown-item" onclick="changeProfRole(@p.AccountId, 'Professor'); event.stopPropagation()">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 14l9-5-9-5-9 5 9 5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Professor
                    </div>
                    <div class="dropdown-item" onclick="changeProfRole(@p.AccountId, 'Admin'); event.stopPropagation()">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
