                    <td class="td-m">${escapeHtml(r.courseCode ?? '—')} ${fmtYearLevel(r.yearLevel, r.section)}</td>
                    <td class="td-m">${r.role ?? '—'}</td>
                    <td class="td-mono td-m">${fd(r.createdAt)}</td>
                    <td>
                        <div class="action-btns">
