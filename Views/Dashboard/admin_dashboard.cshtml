                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                    <button class="${s.schoolYearId ? 'btn-outline' : 'btn-primary'}" title="Set the term from which the student begins to be charged fees" aria-label="Start of payment" style="padding:6px 8px;display:inline-flex;align-items:center;justify-content:center" onclick="openPaymentStartModal(${s.userId})">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    </button>
