async function deleteSchoolYear(schoolYearId) {
    if (!confirm('Delete this school year? This cannot be undone.')) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    try {
        const res  = await fetch('/Home/DeleteSchoolYear', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
            body:    JSON.stringify({ schoolYearId })
        });
        const data = await res.json();
        if (data.success) { showToast(data.message, 'ok'); refreshSchoolYears(); }
        else showToast(data.message, 'fail');
    } catch { showToast('Request failed.', 'fail'); }
}

async function deleteCourse(courseId) {
    if (!confirm('Delete this course? Students assigned to it will lose their course.')) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    try {
        const res  = await fetch('/Home/DeleteCourse', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
            body:    JSON.stringify({ courseId })
        });
        const data = await res.json();
        if (data.success) { showToast(data.message, 'ok'); refreshCourses(); }
        else showToast(data.message, 'fail');
    } catch { showToast('Request failed.', 'fail'); }
}

async function deleteFee(fullAmountId) {
    if (!confirm('Delete this fee record? This cannot be undone.')) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    try {
        const res  = await fetch('/Home/DeleteFee', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
            body:    JSON.stringify({ fullAmountId })
        });
        const data = await res.json();
        if (data.success) { showToast(data.message, 'ok'); refreshFees(); }
        else showToast(data.message, 'fail');
    } catch { showToast('Request failed.', 'fail'); }
}

function editFee(fullAmountId, currentAmount) {
    const newAmount = prompt('Enter new fee amount:', currentAmount);
    if (newAmount === null) return; // cancelled
    const amount = parseFloat(newAmount);
    if (!amount || amount <= 0) { showToast('Please enter a valid amount.', 'fail'); return; }

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    fetch('/Home/EditFee', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
        body: JSON.stringify({ fullAmountId, amount })
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) { showToast(data.message, 'ok'); refreshFees(); }
        else showToast(data.message, 'fail');
    })
    .catch(() => showToast('Request failed.', 'fail'));
}

async function changeFeeStatus(fullAmountId, currentStatus) {
    const newStatus = currentStatus === 'Current' ? 'Ended' : 'Current';
    if (!confirm(`Set this fee as ${newStatus}?`)) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    try {
        const res  = await fetch('/Home/SetFeeStatus', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
            body:    JSON.stringify({ fullAmountId, status: newStatus })
        });
        const data = await res.json();
        if (data.success) { showToast(data.message, 'ok'); refreshFees(); }
        else showToast(data.message, 'fail');
    } catch { showToast('Request failed.', 'fail'); }
}

