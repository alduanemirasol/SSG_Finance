                           <span style="font-size:14px;font-weight:700;color:#fff">${escapeHtml(initials.toUpperCase())}</span>
                       </div>`;
                return `
                <tr id="req-row-${r.accountId}">
                    <td class="td-mono td-m">${i + 1}</td>
                    <td class="td-mono td-m">${r.schoolId ?? '—'}</td>
