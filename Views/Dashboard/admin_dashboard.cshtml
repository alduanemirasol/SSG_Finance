async function refreshSchoolYears() {
    try {
        const res  = await fetch('/Home/GetSchoolYears');
        const data = await res.json();
        if (!data.success) return;

        const tbody = document.getElementById('sy-tbody');
        const badge = document.getElementById('sy-count-badge');
        if (badge) badge.textContent = data.schoolYears.length + ' total';

        if (data.schoolYears.length === 0) {
            tbody.innerHTML = '<tr class="empty-row"><td colspan="5">No school years found.</td></tr>';
            return;
        }

        tbody.innerHTML = data.schoolYears.map((sy, i) => `
            <tr>
                <td class="td-mono td-m">${i + 1}</td>
                <td><strong>${sy.yearStart} – ${sy.yearEnd}</strong></td>
                <td>
                    ${sy.hasFirst  ? '<span class="badge bg" style="margin-right:4px">1st</span>' : '<span class="badge" style="background:rgba(255,255,255,.05);color:var(--text-d);margin-right:4px">1st</span>'}
                    ${sy.hasSecond ? '<span class="badge bg">2nd</span>'                           : '<span class="badge" style="background:rgba(255,255,255,.05);color:var(--text-d)">2nd</span>'}
                </td>
                <td>
                    ${sy.yearStatus === 'Current'
                        ? '<span class="badge bg">Current</span>'
                        : '<span class="badge" style="background:rgba(255,255,255,.05);color:var(--text-d)">Ended</span>'}
                </td>
                <td style="text-align:right">
                    <button class="btn-rj" onclick="deleteSchoolYear(${sy.schoolYearId})" style="font-size:11px;padding:5px 12px">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Delete
                    </button>
                </td>
            </tr>
        `).join('');

        // also refresh the school year dropdown in fee section
        const sel = document.getElementById('fee-schoolYear');
        if (sel) {
            sel.innerHTML = '<option value="">Select school year</option>' +
                data.schoolYears.map(sy => `<option value="${sy.schoolYearId}">${sy.yearStart} – ${sy.yearEnd}</option>`).join('');
        }
    } catch {}
}

