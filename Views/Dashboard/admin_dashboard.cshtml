    async function populateFeeSySemDropdown() {
        try {
            const res  = await fetch('/Home/GetSchoolYears');
            const data = await res.json();
            const sel  = document.getElementById('fee-sy-sem');
            if (!sel || !data.success) return;

            const sorted = [...data.schoolYears].sort((a, b) => b.yearStart - a.yearStart);
            const options = [];
            sorted.forEach(sy => {
                options.push({ schoolYearId: sy.schoolYearId, semester: 'First',  label: `${sy.yearStart}–${sy.yearEnd} · 1st Semester` });
                options.push({ schoolYearId: sy.schoolYearId, semester: 'Second', label: `${sy.yearStart}–${sy.yearEnd} · 2nd Semester` });
            });

            sel.innerHTML = '<option value="">Select school year &amp; semester</option>' +
                options.map(s =>
                    `<option value="${s.schoolYearId}|${s.semester}" data-school-year-id="${s.schoolYearId}" data-semester="${s.semester}">${s.label}</option>`
                ).join('');
        } catch {}
    }

