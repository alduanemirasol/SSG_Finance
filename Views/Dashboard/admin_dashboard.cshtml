async function toggleActivation(accountId, el) {
    const row = document.querySelector(`[data-account="${accountId}"]`);
    const isActive = row.getAttribute('data-active') === 'true';
    const action = isActive ? 'deactivate' : 'reactivate';

    if (!confirm(`Are you sure you want to ${action} this account?`)) return;

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    try {
        const res = await fetch('/Home/ToggleAccountActivation', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token ?? ''
            },
            body: JSON.stringify({ accountId: accountId })
        });

        const data = await res.json();

        if (data.success) {
            row.setAttribute('data-active', data.isActive.toString());

            // update button text and color
            const span = el.querySelector('span');
            if (span) span.textContent = data.isActive ? 'Deactivate Account' : 'Reactivate Account';
            el.classList.remove('danger', 'reactivate');
            el.classList.add(data.isActive ? 'danger' : 'reactivate');

            // update the name cell — add/remove red color and badge
            const nameCell = row.querySelector('td:nth-child(2)');
            if (nameCell) {
                const strong = nameCell.querySelector('strong');
                const nameText = strong ? strong.textContent : '';

                if (!data.isActive) {
                    // deactivated → red + badge
                    nameCell.innerHTML = `
                        <strong style="color:#f87171">${nameText}</strong>
                        <span class="deactivated-badge" style="font-size:10px;font-weight:600;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25);border-radius:5px;padding:1px 7px;margin-left:8px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle;">Deactivated</span>
                    `;
                    row.style.opacity = '0.45';
                } else {
                    // reactivated → back to normal
                    nameCell.innerHTML = `<strong>${nameText}</strong>`;
                    row.style.opacity = '1';
                }
            }

            showToast(data.message, 'ok');
        } else {
            showToast(data.message, 'fail');
        }
    } catch {
        showToast('Request failed. Please try again.', 'fail');
    }

    // close the dropdown
    document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
}

