    async function openStudentOrgFeeModal(userId) {
        const nameEl = document.getElementById('student-orgfee-name');
        const subEl  = document.getElementById('student-orgfee-sub');
        const tbody  = document.getElementById('student-orgfee-tbody');
        nameEl.textContent = 'Student Org Fees';
        subEl.textContent  = 'Loading…';
        tbody.innerHTML    = '<tr><td colspan="8" style="text-align:center;padding:24px;color:var(--text-d)">Loading…</td></tr>';
        openModal('modal-student-orgfee');
        try {
            const res  = await fetch('/Home/GetStudentOrgFeeDetails?userId=' + encodeURIComponent(userId));
            const data = await res.json();
            if (!data.success) {
                subEl.textContent = data.message || 'Unable to load org fee details.';
                tbody.innerHTML   = '<tr><td colspan="8" style="text-align:center;padding:24px;color:var(--text-d)">No data available.</td></tr>';
                return;
            }
            const s = data.student;
            nameEl.textContent = s.name;
            subEl.textContent  = `${s.schoolId} · ${s.courseCode} ${fmtYearSection(s.yearSection)}${s.role === 'Treasurer' ? ' · Treasurer' : ''}${data.schoolYear ? ' · A.Y. ' + data.schoolYear : ''}`;

            const fees = data.fees || [];
            const txs  = data.transactions || [];

            if (!fees.length && !txs.length) {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:24px;color:var(--text-d)">No org fee records.</td></tr>';
                return;
            }

            const groupKey = (sy, sem) => `${sy || ''}|${sem || ''}`;
            const groups   = new Map();
            fees.forEach(f => {
                const k = groupKey(f.schoolYear, f.semester);
                if (!groups.has(k)) groups.set(k, { schoolYear: f.schoolYear, semester: f.semester, fee: null, payments: [] });
                groups.get(k).fee = f;
            });
            txs.forEach(t => {
                const k = groupKey(t.schoolYear, t.semester);
                if (!groups.has(k)) groups.set(k, { schoolYear: t.schoolYear, semester: t.semester, fee: null, payments: [] });
            });
            groups.forEach(g => { g.payments = []; });
            txs.forEach(t => { groups.get(groupKey(t.schoolYear, t.semester)).payments.push(t); });

            const sorted = [...groups.values()].sort((a, b) => {
                const aCur = a.fee && a.fee.isCurrent ? 1 : 0;
                const bCur = b.fee && b.fee.isCurrent ? 1 : 0;
                if (aCur !== bCur) return bCur - aCur;
                const sa = parseInt((a.schoolYear || '').split('–')[0], 10) || 0;
                const sb = parseInt((b.schoolYear || '').split('–')[0], 10) || 0;
                if (sa !== sb) return sb - sa;
                const semOrder = { 'First': 1, 'Second': 2 };
                return (semOrder[b.semester] || 0) - (semOrder[a.semester] || 0);
            });

            tbody.innerHTML = sorted.map((g, idx) => {
                const semLabel  = g.semester === 'First' ? '1st Semester' : g.semester === 'Second' ? '2nd Semester' : (g.semester || '—');
                const totalPaid = g.payments.reduce((sum, t) => sum + (t.amount || 0), 0);
                const required  = g.fee?.requiredAmount ?? null;
                const balance   = g.fee ? g.fee.balance : (required != null ? Math.max(0, required - totalPaid) : 0);
                let status;
                if (required != null && required <= 0) status = 'N/A';
                else if (totalPaid <= 0)               status = 'Unpaid';
                else if (balance <= 0)                 status = 'Paid';
                else                                   status = 'Partial';

                // Most recent payment date for this semester group.
                const dates = g.payments.map(t => t.date).filter(Boolean).sort();
                const latestDate = dates.length ? fd(dates[dates.length - 1]) : '—';

                // Receipts: one button per payment that has a receipt. Admins can
                // view/print receipts but not edit, so there is no edit action.
                const rcButtons = g.payments
                    .filter(t => t.hasReceipt && t.receiptNumber)
                    .sort((a, b) => new Date(a.date) - new Date(b.date))
                    .map(t => {
                        const safe = String(t.receiptNumber || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
                        return `<button type="button" class="btn-outline" style="padding:2px 7px;font-size:10px;font-family:'DM Mono',monospace"
                                    onclick="printPaymentReceipt(${t.paymentId},'${safe}')">${escapeHtml(t.receiptNumber)}</button>`;
                    }).join(' ');
                const receiptCell = rcButtons || '<span style="color:var(--text-d)">—</span>';

                return `<tr style="border-bottom:1px solid rgba(255,255,255,.04)">
                    <td style="padding:10px 12px;color:var(--text-m);font-size:11px">${idx + 1}</td>
                    <td style="padding:10px 12px;color:var(--text);font-weight:600">${semLabel}</td>
                    <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text-m)">${escapeHtml(g.schoolYear || '—')}</td>
                    <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:12px;color:${balance > 0 ? '#f87171' : '#5fdd8e'}">${p(balance)}</td>
                    <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:12px;color:var(--text)">${p(totalPaid)}</td>
                    <td style="padding:10px 12px">${feeStatusBadge(status)}</td>
                    <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text-m)">${latestDate}</td>
                    <td style="padding:10px 12px">${receiptCell}</td>
                </tr>`;
            }).join('');

        } catch (err) {
            console.error('Failed to load student org fee details:', err);
            subEl.textContent = 'Failed to load org fee details.';
            tbody.innerHTML   = '<tr><td colspan="8" style="text-align:center;padding:24px;color:var(--text-d)">Request failed.</td></tr>';
        }
    }

    // ── START OF PAYMENT (per student) ───────────────────────────────────────
    // Sets the school year + semester from which the student begins to be charged
    // org fees. Backend: POST /Home/SetStudentPaymentStart (Treasurer or Admin).
    async function openPaymentStartModal(userId) {
        const s = ALL_STUDENTS_PAGE.find(x => String(x.userId) === String(userId));
        if (!s) { showToast('Student not found.', 'fail'); return; }
        document.getElementById('payment-start-userid').value = userId;
        document.getElementById('payment-start-sub').textContent = `${s.name} · ${s.schoolId || ''}`.trim();

        const sySel = document.getElementById('payment-start-sy');
        sySel.innerHTML = '<option value="">Loading…</option>';
        try {
            const res  = await fetch('/Home/GetSchoolYears');
            const data = await res.json();
            if (data.success && data.schoolYears.length) {
                sySel.innerHTML = data.schoolYears.map(sy => {
                    const id    = sy.schoolYearId ?? sy.SchoolYearId;
                    const label = `${sy.yearStart ?? sy.YearStart}–${sy.yearEnd ?? sy.YearEnd}`;
                    return `<option value="${id}">${label}</option>`;
                }).join('');
                const cur = data.schoolYears.find(sy => (sy.yearStatus ?? sy.YearStatus) === 'Current');
                if (cur) sySel.value = String(cur.schoolYearId ?? cur.SchoolYearId);
            } else {
                sySel.innerHTML = '<option value="">No school years found</option>';
            }
        } catch {
            sySel.innerHTML = '<option value="">Failed to load</option>';
        }
        openModal('modal-payment-start');
    }

    async function submitPaymentStart() {
        const userId       = document.getElementById('payment-start-userid').value;
        const schoolYearId = parseInt(document.getElementById('payment-start-sy').value);
        const semester     = document.getElementById('payment-start-sem').value;
        if (!userId)        { showToast('Student not found.', 'fail'); return; }
        if (!schoolYearId)  { showToast('Please select a school year.', 'fail'); return; }
        if (!semester)      { showToast('Please select a semester.', 'fail'); return; }

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        try {
            const res  = await fetch('/Home/SetStudentPaymentStart', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body:    JSON.stringify({ userId: parseInt(userId), schoolYearId, semester })
            });
            const data = await res.json();
            if (data.success) {
                showToast(data.message || 'Payment start set.', 'ok');
                closeModal('modal-payment-start');
                await refreshStudents(document.getElementById('students-filter-sy')?.value || null);
            } else {
                showToast(data.message || 'Failed to set payment start.', 'fail');
            }
        } catch { showToast('Request failed.', 'fail'); }
    }


