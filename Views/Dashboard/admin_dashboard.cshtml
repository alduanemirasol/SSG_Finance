                        ${avatarInner}
                        ${trashBtn}
                    </div>
                </td>
                <td style="color:${s.isActive ? 'inherit' : '#f87171'}"><strong>${escapeHtml(s.name)}</strong>${roleTag}${statusTag}${inactiveTag}</td>
                <td class="td-m"><div style="font-size:12px;color:var(--text-m)">${escapeHtml(s.courseCode)} ${escapeHtml(fmtYearSection(s.yearSection))}</div></td>
                <td>${admSemCell(s.firstSemRequired,  s.firstSemPaid,  s.firstSemStatus)}</td>
                <td>${admSemCell(s.secondSemRequired, s.secondSemPaid, s.secondSemStatus)}</td>
                <td style="text-align:center">
                  <div style="display:inline-flex;gap:6px;align-items:center;justify-content:center">
                    <button class="btn-outline" title="View ledger" aria-label="View ledger" style="padding:6px 8px;display:inline-flex;align-items:center;justify-content:center" onclick="openStudentOrgFeeModal(${s.userId})">
