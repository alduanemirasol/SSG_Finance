    // Central refresh dispatcher — refreshes whichever page is currently active
    async function refreshCurrentPage() {
        const activePage = document.querySelector('.page.active');
        if (!activePage) return;

        const pageId = activePage.id.replace('page-', '');

        switch (pageId) {
            case 'dashboard':   await refreshDashboard(); await refreshRequests(); break;
            case 'students':    await refreshStudents();    break;
            case 'professors':  await refreshProfessors();  break;
            case 'settings':
                await refreshSchoolYears();
                await refreshCourses();
                await refreshFees();
                break;
        }
    }

    // Refreshes the dashboard stat cards
    async function refreshDashboard() {
        try {
            const res  = await fetch('/Home/GetDashboardStats');
            const data = await res.json();
            if (!data.success) return;

            // Update stat cards by ID — safe regardless of card order
            const registered = document.getElementById('dash-registered');
            const students   = document.getElementById('dash-students');
            const treasurers = document.getElementById('dash-treasurers');
            const professors = document.getElementById('dash-professors');
            const admins     = document.getElementById('dash-admins');

            if (registered) registered.textContent = data.approvedCount  ?? 0;
            if (students)   students.textContent   = data.studentCount   ?? 0;
            if (treasurers) treasurers.textContent = data.treasurerCount ?? 0;
            if (professors) professors.textContent = data.professorCount ?? 0;
            if (admins)     admins.textContent     = data.adminCount     ?? 0;

        } catch(e) { console.error('refreshDashboard failed:', e); }
    }

    // ── Global click interceptor ──────────────────────────────────────
    // Attaches to the document so it catches ALL button/action clicks,
    // including dynamically rendered ones (dropdowns, modals, etc.)

    document.addEventListener('click', async function(e) {
        const target = e.target.closest(
            'button, .btn-ap, .btn-rj, .btn-outline, .dropdown-item, .nav-item, .stat-icon[onclick]'
        );

        if (!target) return;
        if (target.classList.contains('nav-item')) return;
        if (target.classList.contains('dot-btn')) return;
        if (target.textContent.trim() === 'Cancel') return;
        if (target.onclick && target.getAttribute('onclick')?.includes('close')) return;
        if (target.classList.contains('has-submenu')) return;

        setTimeout(async () => {
            await refreshCurrentPage();
        }, 600);
    }, true); // useCapture = true so we run after the element's own onclick

