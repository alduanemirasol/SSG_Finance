    function awaitReceiptReady(timeoutMs = 2500) {
      return new Promise(resolve => {
        const start = Date.now();
        const tick = () => {
          const paper = document.querySelector('.receipt-paper');
          const modalOpen = document.querySelector('.receipt-modal.open');
          if (paper && modalOpen && paper.textContent.trim().length > 0) { requestAnimationFrame(() => resolve(true)); return; }
          if (Date.now() - start > timeoutMs) { resolve(false); return; }
          setTimeout(tick, 60);
        };
        tick();
      });
    }

    async function viewReceipt(type, id, receipt) {
      if (type !== 'OrgFee' || !receipt || receipt === '—') { showToast('No receipt number recorded.', 'fail'); return; }
      try {
        const res  = await fetch('/Home/GetOrgFeeReceipt?paymentId=' + encodeURIComponent(id));
        const data = await res.json();
        if (!data.success || !data.receipt) { showToast(data.message || 'Receipt not found.', 'fail'); return; }
        const r = data.receipt;
        const amount = Number(r.amount || 0);
        const status = r.status || 'Partial';
        const issueDate = (r.paymentDate || r.issueDate) ? new Date(r.paymentDate || r.issueDate) : new Date();
        const formattedDate = issueDate.toLocaleDateString('en-PH', { month:'2-digit', day:'2-digit', year:'2-digit' });
        const semLabel = r.semester === 'First' ? '1st Semester' : r.semester === 'Second' ? '2nd Semester' : (r.semester || '');
        const term = [r.schoolYear, semLabel].filter(Boolean).join(' - ');
        const courseLine = [r.course, r.yearSection].filter(Boolean).join(' ');
        const studentName = (r.studentName || '').toUpperCase();
        const receiptNo   = r.receiptNumber || receipt;
        document.getElementById('tr-receipt-title').textContent = 'Receipt — ' + (term || 'Org Fee');
        ['tr-rp', 'own-tr-rp'].forEach(pfx => {
          const g = id => document.getElementById(`${pfx}-${id}`);
          if (g('receipt-no'))    g('receipt-no').textContent    = receiptNo;
          if (g('date'))          g('date').textContent          = formattedDate;
          if (g('name'))          g('name').textContent          = studentName || '—';
          if (g('id'))            g('id').textContent            = r.studentId || '—';
          if (g('course'))        g('course').textContent        = courseLine || '—';
          if (g('term'))          g('term').textContent          = term || '—';
          if (g('amount'))        g('amount').textContent        = '₱ ' + amount.toFixed(2);
          if (g('amount-words'))  g('amount-words').textContent  = amountToWords(amount);
          if (g('received-by'))   g('received-by').textContent   = r.issuedByName || 'Treasurer';
          const statusEl = g('status');
          if (statusEl) { statusEl.textContent = status; statusEl.className = 'rp-status-badge ' + status.toLowerCase(); }
          const sigImg = g('sig-image');
          if (sigImg) { sigImg.removeAttribute('src'); sigImg.style.display = 'none'; if (r.signatureData) { sigImg.src = r.signatureData; sigImg.style.display = 'block'; } }
        });
        document.getElementById('treasurerReceiptModal').classList.add('open');
      } catch (err) {
        console.error('Failed to load receipt:', err);
        showToast('Failed to load receipt.', 'fail');
      }
    }

    async function printPaymentReceipt(paymentId, receiptNumber) {
      await viewReceipt('OrgFee', paymentId, receiptNumber);
      await awaitReceiptReady();
      showToast('Tip: uncheck "Headers and footers" for a clean print.', 'ok');
      const originalTitle = document.title;
      const sName = (document.getElementById('tr-rp-name')?.textContent || '').trim().replace(/\s+/g,'_');
      const rNo   = (document.getElementById('tr-rp-receipt-no')?.textContent || 'receipt').trim();
      document.title = sName && rNo ? `${sName}_${rNo}` : rNo || ' ';
      try { window.print(); } finally { document.title = originalTitle; closeTreasurerReceipt(); }
    }

    async function downloadTreasurerReceiptPDF() {
      const receiptEl = document.getElementById('trBothReceiptPapers');
      const sName = (document.getElementById('tr-rp-name')?.textContent || 'Student').replace(/[^\w\s-]+/g,'').trim().replace(/\s+/g,'_');
      const rNo   = (document.getElementById('tr-rp-receipt-no')?.textContent || 'receipt').replace(/[^\w-]+/g,'-').replace(/^-+|-+$/g,'');
      showToast('Generating PDF...', 'ok');
      try {
        const canvas = await html2canvas(receiptEl, { scale:2, useCORS:true, backgroundColor:'#f9f8f5', logging:false });
        const imgData = canvas.toDataURL('image/png');
        const { jsPDF } = window.jspdf;
        const pdf = new jsPDF({ orientation:'portrait', unit:'mm', format:[216,330] });
        const pw = pdf.internal.pageSize.getWidth(), ph = pdf.internal.pageSize.getHeight(), m = 8;
        const iw = pw - m*2;
        pdf.addImage(imgData, 'PNG', m, m, iw, Math.min((canvas.height * iw) / canvas.width, ph - m*2));
        pdf.save(`${sName}_${rNo}.pdf`);
        showToast('PDF downloaded successfully.', 'ok');
      } catch (err) { console.error(err); showToast('Failed to generate PDF.', 'fail'); }
    }

</script>

