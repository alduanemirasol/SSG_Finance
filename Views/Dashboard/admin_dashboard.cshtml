// ================================================================
// AUTO-REFRESH SYSTEM
// Wraps every button click to trigger a data refresh automatically
// ================================================================

// Central refresh dispatcher — refreshes whichever page is currently active
async function refreshCurrentPage() {
    const activePage = document.querySelector('.page.active');
    if (!activePage) return;

    const pageId = activePage.id.replace('page-', '');

    switch (pageId) {
        case 'dashboard':   await refreshDashboard();   break;
        case 'requests':    await refreshRequests();    break;
        case 'students':    await refreshStudents();    break;
        case 'professors':  await refreshProfessors();  break;
        case 'settings':
            await refreshSchoolYears();
            await refreshCourses();
            await refreshFees();
            break;
    }
}

// Refreshes the dashboard stat cards and recent requests table
async function refreshDashboard() {
    try {
        const res  = await fetch('/Home/GetDashboardStats');
        const data = await res.json();
        if (!data.success) return;

        // Update stat cards by ID — safe regardless of card order
        const registered = document.getElementById('dash-registered');
        const students   = document.getElementById('dash-students');
        const treasurers = document.getElementById('dash-treasurers');
        const professors = document.getElementById('dash-professors');
        const admins     = document.getElementById('dash-admins');

        if (registered) registered.textContent = data.approvedCount  ?? 0;
        if (students)   students.textContent   = data.studentCount   ?? 0;
        if (treasurers) treasurers.textContent = data.treasurerCount ?? 0;
        if (professors) professors.textContent = data.professorCount ?? 0;
        if (admins)     admins.textContent     = data.adminCount     ?? 0;

        // Update pending nav badge
        const badge = document.querySelector('#nav-requests .nav-badge');
        const pendingCount = data.pendingCount ?? 0;
        if (pendingCount > 0) {
            if (badge) {
                badge.textContent = pendingCount;
            } else {
                const navReq = document.getElementById('nav-requests');
                if (navReq) {
                    const b = document.createElement('span');
                    b.className   = 'nav-badge';
                    b.textContent = pendingCount;
                    navReq.appendChild(b);
                }
            }
        } else {
            if (badge) badge.remove();
        }

        // Update the sub-header pending count
        const pendingSub = document.querySelector('#page-requests .page-sub');
        if (pendingSub) pendingSub.textContent = `${pendingCount} pending approval`;

        // Refresh the recent requests table
        const tbody = document.getElementById('recent-tbody');
        if (!tbody) return;

        const allRequests = data.recentRequests ?? [];

        if (allRequests.length === 0) {
            tbody.innerHTML = '<tr class="empty-row"><td colspan="5">No account requests found.</td></tr>';
            return;
        }

        tbody.innerHTML = allRequests.map((r, i) => {
            const hidden = i >= 5 ? 'display:none' : '';
            return `
                <tr class="recent-row" style="${hidden}">
                    <td class="td-mono td-m">${r.schoolId ?? '—'}</td>
                    <td><strong>${r.fullname}</strong></td>
                    <td class="td-m">${r.courseCode ?? '—'}</td>
                    <td class="td-m">${r.yearLevel ?? '—'}-${r.section ?? '—'}</td>
                    <td class="td-mono td-m">${r.createdAt}</td>
                </tr>`;
        }).join('');

        // Update "View All" button
        const viewAllBtn = document.getElementById('view-all-btn');
        if (viewAllBtn) {
            const wrap = viewAllBtn.closest('.view-all-wrap');
            if (allRequests.length > 5) {
                if (wrap) wrap.style.display = '';
                viewAllBtn.setAttribute('data-total', allRequests.length);
                viewAllBtn.textContent = `View All (${allRequests.length})`;
                viewAllBtn.setAttribute('data-expanded', 'false');
            } else {
                if (wrap) wrap.style.display = 'none';
            }
        }

        // Update total badge on recent requests card
        const totalBadge = document.querySelector('#page-dashboard .badge.by');
        if (totalBadge) totalBadge.textContent = `${allRequests.length} total`;

    } catch(e) { console.error('refreshDashboard failed:', e); }
}

// ── Global click interceptor ──────────────────────────────────────
// Attaches to the document so it catches ALL button/action clicks,
// including dynamically rendered ones (dropdowns, modals, etc.)

document.addEventListener('click', async function(e) {
    const target = e.target.closest(
        'button, .btn-ap, .btn-rj, .btn-outline, .dropdown-item, .nav-item, .stat-icon[onclick]'
    );

    if (!target) return;
    if (target.id === 'view-all-btn') return;
    if (target.classList.contains('nav-item')) return;
    if (target.classList.contains('dot-btn')) return;
    if (target.textContent.trim() === 'Cancel') return;
    if (target.onclick && target.getAttribute('onclick')?.includes('close')) return;
    if (target.classList.contains('has-submenu')) return;

    setTimeout(async () => {
        await refreshCurrentPage();
    }, 600);
}, true); // useCapture = true so we run after the element's own onclick

</script>
</body>
</html>
