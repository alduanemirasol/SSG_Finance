    <div class="settings-panel" id="settings-courses">
      <div class="content-card" style="margin-bottom:14px">
        <div class="cc-hdr"><div class="cc-title">Add Course</div></div>
        <div style="padding:20px 24px">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
              <label class="settings-label">Course Code</label>
              <input id="course-code" type="text" class="settings-input" placeholder="e.g. BSIT" />
            </div>
            <div>
              <label class="settings-label">Course Name</label>
              <input id="course-name" type="text" class="settings-input" placeholder="e.g. BS Information Technology" />
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end">
            <button class="btn-ap" onclick="addCourse()">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
              Add Course
            </button>
          </div>
        </div>
      </div>

      <div class="content-card">
        <div class="cc-hdr"><div class="cc-title">Courses</div><span class="badge by" id="courses-count-badge">0 total</span></div>
        <div class="tbl-wrap">
          <table>
            <thead><tr><th>#</th><th>Code</th><th>Course Name</th><th></th></tr></thead>
            <tbody id="courses-tbody">
              <tr class="empty-row"><td colspan="4">No courses found.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- SET FEE AMOUNT -->
    <div class="settings-panel" id="settings-fees">
      <div class="content-card" style="margin-bottom:14px">
        <div class="cc-hdr"><div class="cc-title">Set Organization Fee</div></div>
        <div style="padding:20px 24px">
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
              <label class="settings-label">School Year</label>
              <select id="fee-schoolYear" class="settings-input" style="appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23fff%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 10px center;background-size:20px;background-color:#0a1f10;cursor:pointer">
                <option value="">Select school year</option>
              </select>
            </div>
            <div>
              <label class="settings-label">Semester</label>
              <select id="fee-semester" class="settings-input" style="appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23fff%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 10px center;background-size:20px;background-color:#0a1f10;cursor:pointer">
                <option value="First">1st Semester</option>
                <option value="Second">2nd Semester</option>
              </select>
            </div>
            <div>
              <label class="settings-label">Amount (₱)</label>
              <input id="fee-amount" type="number" step="0.01" class="settings-input" placeholder="e.g. 150.00" />
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end">
            <button class="btn-ap" onclick="setFeeAmount()">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
              Set Fee Amount
            </button>
          </div>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
