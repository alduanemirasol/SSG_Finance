    // ================================================================
    // SERVER-SENT EVENTS — live updates pushed from the server
    // ================================================================
    (function() {
        function connect() {
            const sse = new EventSource('/Home/Events');

            sse.addEventListener('accounts-changed', () => {
                refreshRequests();
                refreshDashboard();
                const p = document.querySelector('.page.active')?.id?.replace('page-','');
                if (p === 'students')   refreshStudents();
                if (p === 'professors') refreshProfessors();
            });

            sse.addEventListener('fees-changed', () => {
                const p = document.querySelector('.page.active')?.id?.replace('page-','');
                if (p === 'settings') { refreshFees(); refreshSchoolYears(); }
            });

            sse.addEventListener('school-years-changed', () => {
                const p = document.querySelector('.page.active')?.id?.replace('page-','');
                if (p === 'settings') refreshSchoolYears();
            });

            sse.addEventListener('courses-changed', () => {
                const p = document.querySelector('.page.active')?.id?.replace('page-','');
                if (p === 'settings') refreshCourses();
            });

            sse.addEventListener('payments-changed', () => {
                const p = document.querySelector('.page.active')?.id?.replace('page-','');
                if (p === 'students') refreshStudents();
            });

            sse.onerror = () => {
                sse.close();
                setTimeout(connect, 5000);
            };
        }
        connect();
    })();


