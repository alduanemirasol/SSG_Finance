    // ── STUDENTS PAGE (treasurer-style fee view + admin management actions) ──
    let ALL_STUDENTS_PAGE = [];
    let studentsPageQ = '';
    let studentsPageCourse = '';

    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, ch => ({
            '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        }[ch]));
    }

    function feeStatusBadge(status) {
        const s = (status || 'Unpaid').toLowerCase();
        if (s === 'paid') return '<span class="badge bg">Paid</span>';
        if (s === 'partial') return '<span class="badge by">Partial</span>';
        if (s === 'n/a') return '<span class="badge" style="background:rgba(255,255,255,.06);color:var(--text-d)">N/A</span>';
        return '<span class="badge br">Unpaid</span>';
    }

    async function refreshStudents(schoolYear = null) {
        const tbody = document.getElementById('students-tb');
        const sySel = document.getElementById('students-filter-sy');
        await initStudentsPageFilters();
        const selectedSY = schoolYear || sySel?.value || '';
        try {
            const url = selectedSY
                ? `/Home/GetTreasurerStudentsWithFees?schoolYear=${encodeURIComponent(selectedSY)}`
                : '/Home/GetTreasurerStudentsWithFees';
            const res  = await fetch(url);
            const data = await res.json();
            if (!data.success) {
                if (tbody) tbody.innerHTML = `<tr class="empty-row"><td colspan="8">${escapeHtml(data.message || 'Failed to load students.')}</td></tr>`;
                return;
            }
            ALL_STUDENTS_PAGE = data.students || [];
            populateStudentsPageFilters();
            applyStudentsPageFilters();
        } catch {
            if (tbody) tbody.innerHTML = '<tr class="empty-row"><td colspan="8">Failed to load students.</td></tr>';
        }
    }

    function renderStudentsPage(filtered) {
        const data = (filtered ?? ALL_STUDENTS_PAGE).slice()
            .sort((a, b) => {
                const ta = a.lastPaymentDate ? new Date(a.lastPaymentDate).getTime() : 0;
                const tb = b.lastPaymentDate ? new Date(b.lastPaymentDate).getTime() : 0;
                if (tb !== ta) return tb - ta;
                return String(a.name || '').localeCompare(String(b.name || ''), undefined, { sensitivity: 'base' });
            });
        const tbody = document.getElementById('students-tb');
        if (!tbody) return;
        if (!data.length) {
            tbody.innerHTML = '<tr class="empty-row"><td colspan="8">No students found.</td></tr>';
            return;
        }

        // Clean single-line cell, matching the treasurer's student list:
        // "₱0.00 (paid)" when settled, otherwise the amount due. Admins cannot
        // record payments, so there is no Pay button; receipts are viewable in
        // the per-student ledger modal (the eye button) instead.
        const admSemCell = (required, paid, status) => {
            const sl = (status || '').toLowerCase();
            if (sl === 'n/a' || ((required || 0) <= 0 && (paid || 0) <= 0))
                return '<span style="color:var(--text-d);font-size:11px">—</span>';
            if (sl === 'paid')
                return '<span style="font-family:\'DM Mono\',monospace;font-size:12px;color:#5fdd8e">₱0.00 <span style="color:var(--text-d)">(paid)</span></span>';
            const bal = Math.max(0, (required || 0) - (paid || 0));
            return `<span style="font-family:'DM Mono',monospace;font-size:12px;color:#f87171">₱${bal.toFixed(2)}</span>`;
        };

        tbody.innerHTML = data.map((s, i) => {
            const initials = s.name.split(',').map(part => part.trim()).filter(Boolean).map(part => part[0] ?? '').join('').toUpperCase().slice(0, 2);
            const trashBtn = s.avatarPath
                ? `<button onclick="deleteAvatar(${s.userId},this)" title="Remove photo"
                     style="position:absolute;bottom:0;right:0;width:20px;height:20px;border-radius:50%;background:#ef4444;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;z-index:1">
                     <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                   </button>`
                : '';
            const avatarInner = s.avatarPath
                ? `<div onclick="openAvatarModal('${escapeHtml(s.avatarPath)}','${escapeHtml(s.name)}')"
                       style="width:50px;height:50px;border-radius:10px;overflow:hidden;border:1.5px solid rgba(39,167,68,.3);cursor:pointer;flex-shrink:0">
                       <img src="${escapeHtml(s.avatarPath)}" style="width:50px;height:50px;object-fit:cover;display:block;pointer-events:none">
                   </div>`
                : `<div style="width:50px;height:50px;border-radius:10px;overflow:hidden;border:1.5px solid rgba(39,167,68,.3);background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                       <span style="font-size:14px;font-weight:700;color:#fff">${initials}</span>
                   </div>`;
            const roleTag = s.role === 'Treasurer'
                ? ' <span style="font-size:10px;font-weight:600;background:rgba(249,115,22,.15);color:#fdba74;border:1px solid rgba(249,115,22,.25);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Treasurer</span>'
                : '';
            const inactiveTag = !s.isActive
                ? ' <span style="font-size:10px;font-weight:600;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Deactivated</span>'
                : '';
            const isGraduated = String(s.yearSection ?? '').trim().split('-')[0].trim() === '5';
            const statusTag = s.academicStatus === 'Dropped'
                ? ' <span style="font-size:10px;font-weight:600;background:rgba(148,163,184,.15);color:#cbd5e1;border:1px solid rgba(148,163,184,.3);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Dropped</span>'
                : isGraduated
                    ? ' <span style="font-size:10px;font-weight:600;background:rgba(59,130,246,.15);color:#93c5fd;border:1px solid rgba(59,130,246,.3);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Graduated</span>'
                    : ' <span style="font-size:10px;font-weight:600;background:rgba(39,167,68,.15);color:#5fdd8e;border:1px solid rgba(39,167,68,.3);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Enrolled</span>';
            return `<tr data-account="${s.accountId}" data-active="${s.isActive}">
                <td class="td-mono td-m">${i + 1}</td>
                <td class="td-m"><div style="font-family:'DM Mono',monospace;font-size:12px;font-weight:700;color:var(--text)">${escapeHtml(s.schoolId)}</div></td>
                <td style="padding:8px 10px;vertical-align:middle;width:76px">
