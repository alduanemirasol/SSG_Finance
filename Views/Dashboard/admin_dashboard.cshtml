@model MyMvcApp.Models.DashboardViewModel
@{
    Layout = null;
    var firstName     = Context.Session.GetString("FirstName") ?? "Admin";
    var lastName      = Context.Session.GetString("LastName") ?? "";
    var middleName    = Context.Session.GetString("MiddleName") ?? "";
    var schoolId      = Context.Session.GetString("SchoolId") ?? "";
    var email         = Context.Session.GetString("Email") ?? "";
    var accountId     = Context.Session.GetString("AccountId") ?? "";
    var initials      = (firstName.Length > 0 ? firstName[0].ToString() : "") + (lastName.Length > 0 ? lastName[0].ToString() : "");
    var avatarPath    = Context.Session.GetString("AvatarPath") ?? "";
    var middleInitial = middleName.Length > 0 ? middleName[0].ToString().ToUpper() + "." : "";
    var displayName   = (firstName + (middleInitial.Length > 0 ? " " + middleInitial : "") + (lastName.Length > 0 ? " " + lastName : "")).Trim();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="/js/csrf.js"></script>
    <title>SSG Finance - Admin Panel</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=DM+Mono:wght@400;500&display=swap');

        *{box-sizing:border-box;margin:0;padding:0}
        :root{
          --bg:#071a0c;
          --bg2:#0c2413;
          --sidebar:#081509;
          --green:#27a744;
          --green-d:#1a7a4a;
          --green-glow:rgba(39,167,68,.18);
          --green-glow2:rgba(39,167,68,.08);
          --glass:rgba(255,255,255,.045);
          --glass-b:rgba(255,255,255,.09);
          --text:#e8f5ec;
          --text-m:rgba(232,245,236,.6);
          --text-d:rgba(232,245,236,.35);
          --card:#0f2918;
          --card-b:rgba(255,255,255,.07);
          --green-badge:rgba(39,167,68,.18);
          --green-badge-t:#5fdd8e;
          --yellow-badge:rgba(251,191,36,.14);
          --yellow-badge-t:#fbbf24;
          --red-badge:rgba(239,68,68,.14);
          --red-badge-t:#f87171;
        }
        body{font-family:'DM Sans',sans-serif;background:var(--bg);display:flex;min-height:100vh;color:var(--text);font-size:14px;width:100%;overflow:hidden}
        .sidebar{width:210px;background:var(--sidebar);border-right:1px solid rgba(255,255,255,.05);display:flex;flex-direction:column;flex-shrink:0}
        .sb-brand{display:flex;align-items:center;gap:10px;padding:20px 16px 18px;border-bottom:1px solid rgba(255,255,255,.05)}
        .sb-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 14px rgba(39,167,68,.3)}
        .sb-logo svg{width:18px;height:18px}
        .sb-logo img{width:100%;height:100%;object-fit:cover;border-radius:10px}
        .sb-brand-name{font-size:13.5px;font-weight:700;color:#fff;letter-spacing:-.01em}
        .sb-brand-sub{font-size:10px;color:rgba(39,167,68,.85);letter-spacing:.1em;text-transform:uppercase;margin-top:1px}
        .sb-label{font-size:9.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--text-d);padding:16px 16px 5px}
        .nav-item{display:flex;align-items:center;gap:9px;padding:8px 12px;margin:1px 8px;border-radius:8px;font-size:13px;font-weight:500;color:var(--text-m);cursor:pointer;transition:all .15s;text-decoration:none;position:relative}
        .nav-item:hover{background:var(--glass);color:var(--text)}
        .nav-item.active{background:var(--green-glow);color:#5fdd8e;border:1px solid rgba(74,222,128,.12)}
        .nav-item svg{width:15px;height:15px;flex-shrink:0;opacity:.85}
        .nav-badge{margin-left:auto;background:#dc2626;color:#fff;font-size:9px;font-weight:700;min-width:17px;height:17px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 5px}
        .sb-spacer{flex:1}
        .sb-user{padding:10px 8px 10px;border-top:1px solid rgba(255,255,255,.05)}
        .user-card{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;background:var(--glass)}
        .user-av{width:36px;min-width:36px;height:36px;border-radius:8px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden}
        .user-av img{width:100%;height:100%;object-fit:cover;display:block;border-radius:8px;pointer-events:none}
        .user-name{font-size:12px;font-weight:600;color:#fff}
        .user-role{font-size:10.5px;color:var(--text-d)}
        .signout{display:flex;align-items:center;gap:7px;padding:7px 10px;margin-top:3px;border-radius:8px;font-size:12.5px;font-weight:500;color:var(--text-d);cursor:pointer;transition:all .15s}
        .signout:hover{background:rgba(239,68,68,.08);color:#f87171}
        .signout svg{width:14px;height:14px}

        /* ── PROFILE HERO ── */
        .profile-hero{display:flex;flex-direction:column;align-items:center;padding:32px 20px 24px;border-bottom:1px solid rgba(255,255,255,.05)}
        .profile-avatar-wrap{position:relative;width:88px;height:88px;margin-bottom:14px;flex-shrink:0}
        .profile-avatar{width:88px;height:88px;border-radius:50%;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:700;color:#fff;overflow:hidden;border:2px solid rgba(39,167,68,.3);box-shadow:0 0 18px rgba(39,167,68,.18)}
        .profile-avatar img{width:100%;height:100%;object-fit:cover;display:block}
        .avatar-edit-badge{position:absolute;bottom:0;right:0;width:28px;height:28px;border-radius:50%;background:var(--green);border:2px solid var(--card);display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;z-index:3;transition:background .15s,transform .15s;box-shadow:0 2px 6px rgba(0,0,0,.35)}
        .avatar-edit-badge:hover{background:#2fbf52;transform:scale(1.08)}
        .profile-hero-name{font-size:16px;font-weight:700;color:#fff;text-align:center;letter-spacing:-.01em;line-height:1.3}
        .profile-hero-role{font-size:11.5px;color:var(--text-d);margin-top:3px}
        .profile-fields{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:20px}
        .profile-field{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:12px 16px}
        .profile-field label{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);display:block;margin-bottom:4px}
        .profile-field span{font-size:13px;font-weight:500;color:var(--text);word-break:break-word}
        .notice{display:flex;align-items:flex-start;gap:10px;padding:13px 16px;border-radius:10px;margin-bottom:16px}
        .notice svg{width:16px;height:16px;flex-shrink:0;margin-top:1px}
        .notice-text{font-size:12px;color:var(--text-m);line-height:1.6}

        .main{margin-left:0;flex:1;min-width:0;padding:36px 36px 60px;background:var(--bg);overflow-y:auto;overflow-x:hidden;position:relative;height:100vh}
        .main::before{content:'';position:absolute;top:-80px;right:-80px;width:380px;height:380px;background:radial-gradient(circle,rgba(39,167,68,.06) 0%,transparent 70%);pointer-events:none;border-radius:50%}

        .page{display:none;max-width:1200px;margin-left:auto;margin-right:auto}.page.active{display:block}

        .page-hdr{display:flex;align-items:center;justify-content:center;text-align:center;margin-bottom:22px;position:relative}
        .page-title{font-size:22px;font-weight:800;color:#fff;letter-spacing:-.03em}
        .page-sub{font-size:12px;color:var(--text-m);margin-top:2px}

        .stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px;width:100%}
        .stat-col{display:flex;flex-direction:column;gap:12px}
        .stat-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;padding:18px 20px;display:flex;flex-direction:column;gap:8px;position:relative;overflow:hidden;backdrop-filter:blur(8px)}
        .stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(39,167,68,.25),transparent)}
        .stat-card-half{flex:1;padding:13px 16px;gap:5px}
        .stat-card-half .stat-val{font-size:26px}
        .stat-lbl{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d)}
        .stat-row{display:flex;align-items:center;justify-content:space-between}
        .stat-val{font-size:34px;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em}
        .stat-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center}
        .stat-icon.g{background:rgba(39,167,68,.15)}
        .stat-icon.y{background:rgba(251,191,36,.12)}
        .stat-icon svg{width:15px;height:15px}
        .stat-trend{font-size:11px;font-weight:500;color:var(--green)}
        .stat-trend.warn{color:#fbbf24}

        /* ── ACCOUNTS OVERVIEW (added) ── */
        .acct-overview{margin-bottom:18px;width:100%}
        .acct-summary-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;padding:20px 24px;display:flex;gap:24px;align-items:stretch;position:relative;overflow:hidden;backdrop-filter:blur(8px);margin-bottom:12px}
        .acct-summary-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(39,167,68,.25),transparent)}
        .acct-summary-left{flex:0 0 300px;display:flex;flex-direction:column;justify-content:center}
        .acct-summary-lbl{font-size:10.5px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--text-d);margin-bottom:10px}
        .acct-summary-row{display:flex;align-items:center;gap:14px}
        .acct-summary-num{font-size:46px;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em}
        .acct-approved-badge{display:inline-flex;align-items:center;gap:5px;padding:5px 11px;border-radius:20px;font-size:11.5px;font-weight:600;background:var(--green-badge);color:var(--green-badge-t)}
        .acct-approved-badge.warn{background:var(--yellow-badge);color:var(--yellow-badge-t)}
        .acct-approved-badge svg{width:13px;height:13px}
        .acct-summary-sub{font-size:12px;color:var(--text-m);margin-top:10px}
        .acct-summary-divider{width:1px;background:rgba(255,255,255,.07);flex-shrink:0}
        .acct-summary-right{flex:1;display:flex;flex-direction:column;justify-content:center;min-width:0}
        .acct-dist-lbl{font-size:10.5px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--text-d);margin-bottom:14px}
        .acct-legend{display:flex;flex-wrap:wrap;gap:18px;margin-bottom:14px}
        .acct-leg{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--text-m)}
        .acct-leg i{width:9px;height:9px;border-radius:50%;flex-shrink:0}
        .acct-leg b{color:#fff;font-weight:700;margin-left:2px}
        .acct-bar{display:flex;gap:5px;height:13px;width:100%}
        .acct-bar span{height:100%;border-radius:5px;min-width:3px;transition:width .4s}
        .acct-cards{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
        .acct-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;padding:18px 20px;position:relative;overflow:hidden;backdrop-filter:blur(8px)}
        .acct-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(39,167,68,.18),transparent)}
        .acct-card-top{display:flex;align-items:center;gap:11px;margin-bottom:14px}
        .acct-card-ic{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .acct-card-ic svg{width:19px;height:19px}
        .acct-card-name{font-size:13.5px;font-weight:700;color:#fff;line-height:1.2}
        .acct-card-role{font-size:11px;color:var(--text-d);margin-top:1px}
        .acct-card-bot{display:flex;align-items:center;gap:14px}
        .acct-card-num{font-size:34px;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em;flex-shrink:0}
        .acct-card-track{flex:1;height:7px;border-radius:5px;background:rgba(255,255,255,.07);overflow:hidden}
        .acct-card-fill{height:100%;border-radius:5px;transition:width .4s}
        @@media (max-width:1100px){.acct-cards{grid-template-columns:repeat(2,1fr)}.acct-summary-card{flex-direction:column;gap:18px}.acct-summary-left{flex:none}.acct-summary-divider{width:auto;height:1px}}

        .content-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;overflow:visible;margin-bottom:16px;backdrop-filter:blur(8px);position:relative;width:100%;isolation:isolate}
        .content-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(39,167,68,.2),transparent);z-index:1}
        .cc-hdr{display:flex;align-items:center;justify-content:space-between;padding:15px 20px 13px;border-bottom:1px solid rgba(255,255,255,.05)}
        .cc-title{font-size:13.5px;font-weight:700;color:#fff;letter-spacing:-.01em}

        .toolbar{display:flex;align-items:center;justify-content:space-between;padding:13px 20px;border-bottom:1px solid rgba(255,255,255,.05)}
        .search-box{display:flex;align-items:center;gap:7px;border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:7px 12px;font-size:12.5px;color:var(--text-m);background:rgba(255,255,255,.04);min-width:220px;transition:all .15s}
        .search-box:focus-within{border-color:var(--green);background:rgba(39,167,68,.06);box-shadow:0 0 0 3px var(--green-glow2)}
        .search-box input{border:none;outline:none;font-family:inherit;font-size:12.5px;color:var(--text);width:100%;background:transparent}
        .search-box input::placeholder{color:var(--text-d)}
        .search-box svg{width:14px;height:14px;color:var(--text-d);flex-shrink:0}

        .tbl-wrap{overflow-x:visible}
        /* Scrollable table viewport: vertical + horizontal scrollbars, sticky header */
        .tbl-scroll{max-height:min(540px,62vh);overflow:auto;scrollbar-width:thin;scrollbar-color:rgba(39,167,68,.45) rgba(255,255,255,.04)}
        .tbl-scroll thead th{position:sticky;top:0;z-index:4;background:#142d1d}
        .tbl-scroll::-webkit-scrollbar{width:10px;height:10px}
        .tbl-scroll::-webkit-scrollbar-track{background:rgba(255,255,255,.03)}
        .tbl-scroll::-webkit-scrollbar-thumb{background:rgba(39,167,68,.4);border-radius:6px;border:2px solid transparent;background-clip:padding-box}
        .tbl-scroll::-webkit-scrollbar-thumb:hover{background:rgba(39,167,68,.6);background-clip:padding-box}
        .tbl-scroll::-webkit-scrollbar-corner{background:transparent}
        table{width:100%;border-collapse:collapse;font-size:12.5px}
        thead th{padding:10px 15px;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);border-bottom:1px solid rgba(255,255,255,.05);text-align:left;white-space:nowrap;background:rgba(255,255,255,.02)}
        tbody tr{border-bottom:1px solid rgba(255,255,255,.04);transition:background .1s}
        tbody tr:last-child{border-bottom:none}
        tbody tr:hover{background:rgba(39,167,68,.05)}
        td{padding:11px 15px;color:var(--text);vertical-align:middle}
        .td-m{color:var(--text-m)}
        .td-mono{font-family:'DM Mono',monospace;font-size:11.5px}

        .badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:10.5px;font-weight:600;letter-spacing:.02em}
        .bg{background:var(--green-badge);color:var(--green-badge-t)}
        .by{background:var(--yellow-badge);color:var(--yellow-badge-t)}
        .br{background:var(--red-badge);color:var(--red-badge-t)}

        .action-btns{display:flex;align-items:center;gap:6px}
        .btn-ap,.btn-rj{display:inline-flex;align-items:center;gap:4px;padding:5px 12px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid transparent;transition:all .15s;font-family:inherit;white-space:nowrap}
        .btn-ap{background:var(--green-badge);color:var(--green-badge-t);border-color:rgba(39,167,68,.25)}
        .btn-ap:hover{background:rgba(39,167,68,.28);transform:translateY(-1px)}
        .btn-rj{background:var(--red-badge);color:var(--red-badge-t);border-color:rgba(239,68,68,.2)}
        .btn-rj:hover{background:rgba(239,68,68,.22);transform:translateY(-1px)}

        .empty-row td{text-align:center;padding:40px;color:var(--text-d);font-size:12.5px}

        .view-all-wrap{display:flex;justify-content:center;padding:14px 0 4px}
        .btn-outline{padding:7px 24px;border:1px solid rgba(255,255,255,.12);border-radius:7px;font-size:12px;font-weight:600;color:var(--text-m);background:transparent;cursor:pointer;font-family:inherit;transition:all .15s}
        .btn-outline:hover{border-color:var(--green);color:var(--green);background:var(--green-glow2)}
        /* Used by the Payment Start modal (ported from the treasurer dashboard) */
        .btn-primary{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:12.5px;font-weight:600;cursor:pointer;border:none;font-family:inherit;transition:all .15s;background:var(--green);color:#fff}
        .btn-primary:hover{background:#22963d;transform:translateY(-1px)}
        .form-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-d);margin-bottom:6px;display:block}
        .form-input{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none;transition:border-color .2s}
        .form-input:focus{border-color:var(--green);background:rgba(39,167,68,.06)}
        .form-input::placeholder{color:var(--text-d)}
        .form-input option{background:#0a1f10;color:#fff}
        .form-input option:checked{background:#1a6e2e;color:#fff}

        #toast{position:fixed;bottom:20px;right:20px;padding:10px 18px;border-radius:9px;font-size:12.5px;font-weight:500;background:#1f2937;color:#fff;opacity:0;transform:translateY(8px);transition:opacity .25s,transform .25s;z-index:999;pointer-events:none;display:flex;align-items:center;gap:7px;box-shadow:0 8px 24px rgba(0,0,0,.4)}
        #toast.show{opacity:1;transform:translateY(0)}
        #toast.ok{background:#052e16;border:1px solid rgba(39,167,68,.3)}
        #toast.fail{background:#450a0a;border:1px solid rgba(239,68,68,.3)}

        .top-accent{height:2px;background:linear-gradient(90deg,transparent,var(--green),transparent);position:absolute;top:0;left:0;right:0}
        .stat-icon[onclick]:hover{background:rgba(39,167,68,.28);transform:scale(1.1);transition:all .15s}
        .dropdown-wrap{position:relative;display:inline-block}
        .dot-btn{background:transparent;border:none;color:var(--text-m);cursor:pointer;padding:4px 6px;border-radius:6px;display:flex;align-items:center;justify-content:center;transition:all .15s}
        .dot-btn:hover{background:var(--glass);color:var(--text)}
        .dropdown-menu{display:none;position:absolute;right:0;top:32px;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:10px;min-width:180px;z-index:100;padding:4px;box-shadow:0 8px 24px rgba(0,0,0,.4)}
        .dropdown-menu.open{display:block}
        .dropdown-item{display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:7px;font-size:12.5px;font-weight:500;color:var(--text-m);cursor:pointer;transition:all .15s;white-space:nowrap}
        .dropdown-item:hover{background:var(--glass);color:var(--text)}
        .dropdown-item.danger{color:var(--red-badge-t)}
        .dropdown-item.danger:hover{background:rgba(239,68,68,.08);color:#f87171}
        .dropdown-item.reactivate{color:#5fdd8e}
        .dropdown-item.reactivate:hover{background:rgba(39,167,68,.08);color:#4ade80}
        .dropdown-item.has-submenu{position:relative;overflow:visible;}
        .dropdown-menu{overflow:visible;}
        .settings-tab{display:flex;align-items:center;gap:7px;padding:9px 16px;border:none;border-bottom:2px solid transparent;background:transparent;color:var(--text-m);font-size:12.5px;font-weight:500;cursor:pointer;font-family:inherit;transition:all .15s;margin-bottom:-1px}
        .settings-tab:hover{color:var(--text)}
        .settings-tab.active{color:#5fdd8e;border-bottom-color:#27a744}
        .settings-panel{display:none}.settings-panel.active{display:block}
        .settings-label{font-size:11px;color:var(--text-m);display:block;margin-bottom:4px}
        .settings-input{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none;transition:border-color .2s}
        .settings-input:focus{border-color:var(--green);box-shadow:0 0 0 3px var(--green-glow2)}
        /* ── ORG FEE MODAL + FILTER (added) ── */
        .modal-overlay{display:none;position:fixed;inset:0;z-index:600;align-items:center;justify-content:center}
        .modal-overlay.open{display:flex}
        .modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(4px)}
        .modal-box{position:relative;z-index:1;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:28px 30px;width:100%;max-width:500px;box-shadow:0 24px 60px rgba(0,0,0,.5);max-height:90vh;overflow-y:auto}
        .modal-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px}
        .modal-title{font-size:16px;font-weight:700;color:#fff}
        .modal-sub{font-size:11.5px;color:var(--text-m);margin-top:2px}
        .modal-close{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .modal-footer{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,.06)}
        .btn-outline{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;background:transparent;border:1px solid rgba(255,255,255,.12);color:var(--text-m)}
        .btn-outline:hover{border-color:var(--green);color:#5fdd8e;background:rgba(39,167,68,.08)}
        .filter-select{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:7px 28px 7px 11px;font-size:12px;color:var(--text-m);font-family:inherit;cursor:pointer;outline:none;appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23e8f5ec%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 6px center;background-size:18px}
        .filter-select option{background:#0a1f10}

        /* ── AVATAR PREVIEW MODAL ── */
        #avatarModal{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.75);backdrop-filter:blur(4px);align-items:center;justify-content:center;cursor:pointer}
        #avatarModal.open{display:flex}
        #avatarModal img{width:280px;height:280px;border-radius:50%;object-fit:cover;border:4px solid rgba(39,167,68,.6);box-shadow:0 20px 60px rgba(0,0,0,.6);pointer-events:none}
        #avatarModal .av-name{margin-top:16px;font-size:14px;font-weight:600;color:#fff;text-align:center;letter-spacing:.02em}
        #avatarModal .av-hint{margin-top:6px;font-size:11px;color:rgba(255,255,255,.45);text-align:center}
        #avatarModal .av-inner{display:flex;flex-direction:column;align-items:center}

        /* ── RECEIPT MODAL ── */
        .receipt-modal{display:none;position:fixed;inset:0;z-index:700;align-items:center;justify-content:center}
        .receipt-modal.open{display:flex}
        .receipt-modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(6px)}
        .receipt-modal-inner{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:12px;max-height:95vh;overflow-y:auto;padding:16px}
        .receipt-controls{display:flex;align-items:center;gap:10px;background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:8px 14px;width:100%;max-width:620px}
        .receipt-ctrl-title{flex:1;font-size:12.5px;font-weight:600;color:var(--text-m)}
        .btn-pdf{display:inline-flex;align-items:center;gap:6px;padding:6px 16px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:1px solid rgba(39,167,68,.3);background:rgba(39,167,68,.15);color:#5fdd8e;transition:all .15s;font-family:inherit;flex-shrink:0}
        .btn-pdf:hover{background:rgba(39,167,68,.25)}
        .btn-receipt-close{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;font-family:inherit;flex-shrink:0}
        .btn-receipt-close:hover{background:rgba(239,68,68,.12);color:#f87171}
        .receipt-paper{width:620px;min-height:auto;background:#fff;border:1px solid #ccc;box-shadow:0 8px 40px rgba(0,0,0,.45);padding:24px 56px 28px;font-family:Arial,Helvetica,sans-serif;color:#111;position:relative;flex-shrink:0}
        .rp-header{text-align:center;margin-bottom:12px;position:relative;z-index:1}
        .rp-org{font-size:12px;font-weight:700;letter-spacing:.01em;margin-bottom:1px}
        .rp-campus{font-size:11px;font-weight:400}
        .rp-divider{border:none;border-top:1px solid #555;margin:8px 0 6px}
        .rp-type{font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin-top:6px}
        .rp-copy{font-size:11px;font-style:italic;color:#111;margin-top:1px}
        .rp-meta{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;position:relative;z-index:1;gap:8px}
        .rp-meta-label{font-size:11px;font-weight:400}
        .rp-meta-value{font-size:12px;font-weight:700;color:#111;border-bottom:1px solid #888;min-width:140px;display:inline-block;padding-bottom:2px;text-align:center}
        .rp-section-title{text-align:center;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px;position:relative;z-index:1}
        .rp-field{display:flex;align-items:baseline;margin-bottom:6px;position:relative;z-index:1}
        .rp-field-label{font-size:12px;font-weight:400;min-width:150px;flex-shrink:0}
        .rp-field-value{flex:1;font-size:12px;font-weight:700;border-bottom:1px solid #888;padding-bottom:2px;min-height:18px;padding-left:6px;font-family:Arial,Helvetica,sans-serif}
        .rp-field-value.handwritten{font-family:Arial,Helvetica,sans-serif;font-style:none;font-size:12px;letter-spacing:.01em}
        .rp-status-badge{display:inline-block;padding:1px 10px;border:none;font-size:12px;font-weight:700;background:transparent;color:#111}
        .rp-signature-section{margin-top:24px;display:flex;justify-content:flex-end;position:relative;z-index:1}
        .rp-sig-block{text-align:center;min-width:220px}
        .rp-sig-label{font-size:11px;margin-bottom:6px}
        .rp-sig-name-label{font-size:11px;color:#111}
        .rp-watermark{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-35deg);font-size:90px;font-weight:700;color:rgba(0,0,0,.04);pointer-events:none;letter-spacing:.2em;z-index:0;font-family:Arial,sans-serif;text-transform:uppercase}
        @@media (max-width:768px){.receipt-paper{transform:scale(0.56);transform-origin:top center;margin-bottom:-420px}}
        @@media print{
          /* Hide ALL direct body children first — this collapses layout so nothing occupies space */
          body > *{display:none!important}

          html,body{
            background:#fff!important;margin:0!important;padding:0!important;
            display:block!important;overflow:visible!important;
            height:auto!important;min-height:0!important;
          }

          /* Reveal only the receipt modal */
          #treasurerReceiptModal{
            display:block!important;position:static!important;
            background:#fff!important;padding:0!important;margin:0!important;
          }
          #treasurerReceiptModal .receipt-modal-backdrop,
          #treasurerReceiptModal .receipt-controls{display:none!important}
          #treasurerReceiptModal .receipt-modal-inner{
            display:block!important;position:static!important;
            padding:0!important;margin:0!important;
            max-height:none!important;overflow:visible!important;
            background:#fff!important;
          }

          #trBothReceiptPapers{position:static!important;display:block!important}
          .receipt-paper{
            position:static!important;transform:none!important;
            margin:0 auto!important;box-shadow:none!important;
            border:none!important;background:#fff!important;
            page-break-inside:avoid;
          }
          .receipt-paper,.receipt-paper *{
            -webkit-print-color-adjust:exact!important;
            print-color-adjust:exact!important;
          }
          .receipt-cut-line,.receipt-cut-line *{visibility:visible!important}
          @@page{margin:12mm;size:auto}
        }
    </style>
</head>
<body>

<div class="top-accent"></div>
<div style="display:flex;min-height:100vh;width:100%;position:relative">

<aside class="sidebar">
  <div class="sb-brand">
    <div class="sb-logo">
      <img src="~/logo.png" alt="SSG Finance Logo" />
    </div>
    <div>
      <div class="sb-brand-name">SSG Finance</div>
      <div class="sb-brand-sub">Admin Panel</div>
    </div>
  </div>

  <div class="sb-label">Main</div>
  <a class="nav-item active" id="nav-dashboard" onclick="showPage('dashboard',this)">
    <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
    Dashboard
  </a>

  <div class="sb-label">Users</div>
  <a class="nav-item" id="nav-students" onclick="showPage('students',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 12v5c0 1.657 2.686 3 6 3s6-1.343 6-3v-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    Students
  </a>
  <a class="nav-item" id="nav-professors" onclick="showPage('professors',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    Professors
  </a>

  <div class="sb-label">System</div>
  <a class="nav-item" id="nav-settings" onclick="showPage('settings',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" stroke-width="1.8"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" stroke="currentColor" stroke-width="1.8"/></svg>
    Settings
  </a>

  <div class="sb-spacer"></div>
  <div class="sb-user">
    <button class="user-card" onclick="showPage('profile',null)" style="width:100%;text-align:left;cursor:pointer;background:var(--glass);border:1px solid transparent;border-radius:9px;padding:8px 10px;transition:all .15s;font-family:inherit;color:inherit;display:flex;align-items:center;gap:9px" onmouseover="this.style.background='var(--green-glow)';this.style.borderColor='rgba(74,222,128,.12)'" onmouseout="this.style.background='var(--glass)';this.style.borderColor='transparent'">
      <div class="user-av">
        @if (!string.IsNullOrEmpty(avatarPath))
        {
          <img src="@avatarPath" alt="@initials.ToUpper()" />
        }
        else
        {
          @initials.ToUpper()
        }
      </div>
      <div>
        <div class="user-name">@displayName</div>
        <div class="user-role">Administrator</div>
      </div>
    </button>
    <div class="signout" onclick="window.location.href='@Url.Action("Logout", "Home")'">
      <svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Sign Out
    </div>
  </div>
</aside>

<div class="main">

  <!-- DASHBOARD PAGE -->
  <div class="page active" id="page-dashboard">
    <div class="page-hdr">
      <div>
        <div class="page-title">Dashboard</div>
        <div class="page-sub">Welcome back, @firstName</div>
      </div>
      <div style="position:absolute;right:0;top:50%;transform:translateY(-50%);font-size:11.5px;color:var(--text-m);background:rgba(39,167,68,.1);border:1px solid rgba(39,167,68,.2);padding:6px 13px;border-radius:8px;display:flex;align-items:center;gap:6px">
        <span style="width:6px;height:6px;border-radius:50%;background:#4ade80;box-shadow:0 0 6px #4ade80;display:inline-block"></span>
        System Online
      </div>
    </div>

    @{
        var ci          = System.Globalization.CultureInfo.InvariantCulture;
        var nStud       = Model.Students?.Count ?? 0;
        var nProf       = Model.Professors?.Count ?? 0;
        var nTreas      = Model.Treasurers?.Count ?? 0;
        var nAdmin      = Model.Admins?.Count ?? 0;
        var nPending    = Model.RequestedAccounts?.Count ?? 0;
        var distTotal   = nStud + nProf + nTreas + nAdmin;
        var maxRole     = Math.Max(1, Math.Max(Math.Max(nStud, nProf), Math.Max(nTreas, nAdmin)));
        Func<int, string> distPct = n => (distTotal > 0 ? n * 100.0 / distTotal : 0).ToString("0.##", ci);
        Func<int, string> barPct  = n => (n * 100.0 / maxRole).ToString("0.##", ci);
    }
    <div class="acct-overview">
      <div class="acct-cards">
        <div class="acct-card" onclick="showPage('students',document.getElementById('nav-students'))" style="cursor:pointer">
          <div class="acct-card-top">
            <div class="acct-card-ic" style="background:rgba(190,242,100,.14)">
              <svg viewBox="0 0 24 24" fill="none"><path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="#bef264" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 12v5c0 1.657 2.686 3 6 3s6-1.343 6-3v-5" stroke="#bef264" stroke-width="1.8" stroke-linecap="round"/></svg>
            </div>
            <div><div class="acct-card-name">Students</div><div class="acct-card-role">Enrolled</div></div>
          </div>
          <div class="acct-card-bot">
            <div class="acct-card-num" id="dash-students">@nStud</div>
            <div class="acct-card-track"><div class="acct-card-fill" style="width:@(barPct(nStud))%;background:linear-gradient(90deg,#a3e635,#bef264)"></div></div>
          </div>
        </div>

        <div class="acct-card" onclick="showPage('professors',document.getElementById('nav-professors'))" style="cursor:pointer">
          <div class="acct-card-top">
            <div class="acct-card-ic" style="background:rgba(103,232,249,.12)">
              <svg viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="#67e8f9" stroke-width="1.8" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="#67e8f9" stroke-width="1.8"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="#67e8f9" stroke-width="1.8" stroke-linecap="round"/></svg>
            </div>
            <div><div class="acct-card-name">Professors</div><div class="acct-card-role">Faculty</div></div>
          </div>
          <div class="acct-card-bot">
            <div class="acct-card-num" id="dash-professors">@nProf</div>
            <div class="acct-card-track"><div class="acct-card-fill" style="width:@(barPct(nProf))%;background:linear-gradient(90deg,#22d3ee,#67e8f9)"></div></div>
          </div>
        </div>

        <div class="acct-card">
          <div class="acct-card-top">
            <div class="acct-card-ic" style="background:rgba(52,211,153,.14)">
              <svg viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="#4ade80" stroke-width="1.8"/><path d="M2 7l10 6 10-6" stroke="#4ade80" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div><div class="acct-card-name">Treasurers</div><div class="acct-card-role">Finance</div></div>
          </div>
          <div class="acct-card-bot">
            <div class="acct-card-num" id="dash-treasurers">@nTreas</div>
            <div class="acct-card-track"><div class="acct-card-fill" style="width:@(barPct(nTreas))%;background:linear-gradient(90deg,#34d399,#4ade80)"></div></div>
          </div>
        </div>

        <div class="acct-card">
          <div class="acct-card-top">
            <div class="acct-card-ic" style="background:rgba(245,158,11,.14)">
              <svg viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#fbbf24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div><div class="acct-card-name">Admins</div><div class="acct-card-role">Full access</div></div>
          </div>
          <div class="acct-card-bot">
            <div class="acct-card-num" id="dash-admins">@nAdmin</div>
            <div class="acct-card-track"><div class="acct-card-fill" style="width:@(barPct(nAdmin))%;background:linear-gradient(90deg,#f59e0b,#fbbf24)"></div></div>
          </div>
        </div>
      </div>
    </div>

    <div class="content-card">
      <div class="cc-hdr">
        <div class="cc-title">Account Requests</div>
        <span class="badge by" id="req-count-badge">@(Model.RequestedAccounts?.Count ?? 0) pending</span>
      </div>
      <div class="tbl-wrap tbl-scroll">
        <table>
          <thead>
            <tr><th>#</th><th>CTU ID</th><th>Photo</th><th>Name</th><th>Course.Year.Section</th><th>Role</th><th>Date</th><th>Action</th></tr>
          </thead>
          <tbody id="req-tbody">
            <tr class="empty-row"><td colspan="8">Loading…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>


  <!-- STUDENTS PAGE -->
  <div class="page" id="page-students">
    <div class="page-hdr">
      <div>
        <div class="page-title">Students</div>
        <div class="page-sub">@(Model.Students?.Count ?? 0) approved students</div>
      </div>
    </div>
    <div class="content-card">
      <div class="toolbar">
        <div class="search-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="8" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke-width="1.8" stroke-linecap="round"/></svg>
          <input type="text" id="students-search" placeholder="Search by name, CTU ID, course…" oninput="filterStudentsPage(this.value)" />
        </div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
          <select class="filter-select" id="students-filter-status" onchange="applyStudentsPageFilters()">
            <option value="">All Payment Status</option>
            <option value="Paid">Paid</option>
            <option value="Partial">Partial</option>
            <option value="Unpaid">Unpaid</option>
          </select>
          <select class="filter-select" id="students-filter-course" onchange="applyStudentsPageFilters()">
            <option value="">All Courses</option>
          </select>
          <select class="filter-select" id="students-filter-year" onchange="applyStudentsPageFilters()">
            <option value="">All Year Levels</option>
            <option value="1">1st Year</option>
            <option value="2">2nd Year</option>
            <option value="3">3rd Year</option>
            <option value="4">4th Year</option>
            <option value="5">Graduated</option>
          </select>
          <select class="filter-select" id="students-filter-sy" onchange="applyStudentsPageFilters()">
            <option value="">All School Years</option>
          </select>
          <button class="btn-outline" onclick="resetStudentsPageFilters()" title="Reset filters and sort to default" style="padding:7px 14px">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L3 8"/></svg>
            Default
          </button>
        </div>
      </div>
      <div class="tbl-wrap tbl-scroll">
        <table><thead><tr>
          <th>#</th>
          <th>CTU ID</th>
          <th>Photo</th>
          <th>Name</th>
          <th>Course.Year.Section</th>
          <th><span id="adm-th-sem1-label">Org Fee Balance – 1st Semester</span></th>
          <th><span id="adm-th-sem2-label">Org Fee Balance – 2nd Semester</span></th>
          <th style="text-align:center">Action</th>
        </tr></thead>
        <tbody id="students-tb">
          <tr class="empty-row"><td colspan="8">Loading students…</td></tr>
        </tbody></table>
      </div>
    </div>
  </div>

  
  <!-- PROFESSORS PAGE -->
  <div class="page" id="page-professors">
    <div class="page-hdr">
      <div>
        <div class="page-title">Professors</div>
        <div class="page-sub">@(Model.Professors?.Count ?? 0) approved professors</div>
      </div>
    </div>
    <div class="content-card">
      <div class="toolbar">
        <div class="search-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="8" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke-width="1.8" stroke-linecap="round"/></svg>
          <input type="text" placeholder="Search professors…" oninput="filterTable(this,'profs-tb')" />
        </div>
      </div>
      <div class="tbl-wrap tbl-scroll">
        <table><thead><tr><th>#</th><th>CTU ID</th><th>Name</th><th>Email</th><th></th></tr></thead>
        <tbody id="profs-tb">
          @if (Model.Professors != null && Model.Professors.Any())
          {
              int i = 1;
              @foreach (var p in Model.Professors)
              {
                  <tr>
                      <td class="td-mono td-m">@(i++)</td>
                      <td class="td-mono td-m">@p.SchoolId</td>
                      <td>
    <strong>@p.FullName</strong>
    @if (p.Role == "Admin") {
        <span style="font-size:10px;font-weight:600;background:rgba(39,167,68,.15);color:#5fdd8e;border:1px solid rgba(39,167,68,.25);border-radius:5px;padding:1px 7px;margin-left:8px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle;">Admin</span>
    }
</td>
                      <td class="td-m">@p.Email</td>
                  <td style="width:40px;text-align:right">
    <div class="dropdown-wrap">
        <button class="dot-btn" onclick="toggleDropdown(this)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
        </button>
        <div class="dropdown-menu">
            <div class="dropdown-item" onclick="editProfessor(@p.AccountId)">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                Edit
            </div>
            <div class="dropdown-item has-submenu" onclick="showProfRoleSubmenu(this, @p.AccountId)">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                Change Role
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" style="margin-left:auto"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                <!-- submenu -->
                <div class="dropdown-menu" id="prof-role-submenu-@p.AccountId" style="display:none;position:absolute;left:-140px;top:0;min-width:130px">
                    <div class="dropdown-item" onclick="changeProfRole(@p.AccountId, 'Professor'); event.stopPropagation()">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 14l9-5-9-5-9 5 9 5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Professor
                    </div>
                    <div class="dropdown-item" onclick="changeProfRole(@p.AccountId, 'Admin'); event.stopPropagation()">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Admin
                    </div>
                </div>
            </div>
            <div class="dropdown-item danger" onclick="deleteProfessor(@p.AccountId)">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Delete Account
            </div>
        </div>
    </div>
</td>
                  </tr>
              }
          }
          else
          {
              <tr class="empty-row"><td colspan="5">No professors found.</td></tr>
          }
        </tbody></table>
      </div>
    </div>
  </div>

  
  <!-- PROFILE PAGE -->
  <div class="page" id="page-profile">
    <div class="page-hdr">
      <div><div class="page-title">My Profile</div><div class="page-sub">Your account information</div></div>
    </div>
    <div class="content-card">
      <div class="profile-hero">
        <div class="profile-avatar-wrap">
          <div class="profile-avatar" id="profileAvatarCircle">
            @if (!string.IsNullOrEmpty(avatarPath))
            {
              <img src="@avatarPath" alt="@displayName" id="profileAvatarImg" />
            }
            else
            {
              <span id="profileAvatarInitials">@initials.ToUpper()</span>
            }
          </div>
          <button class="avatar-edit-badge" onclick="triggerAvatarUpload()"
            title="@(string.IsNullOrEmpty(avatarPath) ? "Add photo" : "Change photo")"
            aria-label="@(string.IsNullOrEmpty(avatarPath) ? "Add photo" : "Change photo")">
            <svg viewBox="0 0 24 24" fill="none" style="width:14px;height:14px;color:#fff"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="1.8"/></svg>
          </button>
          <input type="file" id="avatarFileInput" accept="image/jpeg,image/png,image/webp" style="display:none" onchange="handleAvatarChange(this)" />
        </div>
        <div class="profile-hero-name">@displayName</div>
        <div class="profile-hero-role">Administrator</div>
      </div>
      <div class="profile-fields">
        <div class="profile-field">
          <label>CTU ID</label>
          <span style="font-family:'DM Mono',monospace;font-size:12px">@(schoolId.Length > 0 ? schoolId : "—")</span>
        </div>
        <div class="profile-field">
          <label>Email</label>
          <span>@(email.Length > 0 ? email : "—")</span>
        </div>
      </div>
    </div>
    <div class="notice" style="background:rgba(59,130,246,.06);border-color:rgba(59,130,246,.18)">
      <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#93c5fd" stroke-width="1.8"/><path d="M12 8v4M12 16h.01" stroke="#93c5fd" stroke-width="1.8" stroke-linecap="round"/></svg>
      <p class="notice-text">To update your personal information, please contact the system owner.</p>
    </div>
  </div>

  <!-- SETTINGS PAGE -->
  <div class="page" id="page-settings">
    <div class="page-hdr">
      <div>
        <div class="page-title">Settings</div>
        <div class="page-sub">System configuration</div>
      </div>
    </div>

    <!-- Settings Tabs -->
    <div style="display:flex;gap:2px;margin-bottom:20px;border-bottom:1px solid rgba(255,255,255,.06)">
      <button class="settings-tab active" onclick="switchSettingsTab('sy',this)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        School Year & Semester
      </button>
      <button class="settings-tab" onclick="switchSettingsTab('courses',this)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        Manage Courses
      </button>
      <button class="settings-tab" onclick="switchSettingsTab('fees',this)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M12 6v2m0 8v2M9 9.5A3 3 0 0112 8a3 3 0 010 6 3 3 0 00-3 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        Set Fee Amount
      </button>
      <button class="settings-tab" onclick="switchSettingsTab('password',this)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M12 2a5 5 0 00-5 5v4H6a2 2 0 00-2 2v7a2 2 0 002 2h12a2 2 0 002-2v-7a2 2 0 00-2-2h-1V7a5 5 0 00-5-5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 12a3 3 0 016 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        Change Password
      </button>
    </div>

    <!-- SCHOOL YEAR & SEMESTER -->
    <div class="settings-panel active" id="settings-sy">
      <div class="content-card" style="margin-bottom:14px">
        <div class="cc-hdr"><div class="cc-title">Add School Year</div></div>
        <div style="padding:20px 24px">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
              <label class="settings-label">Year Start</label>
              <input id="sy-yearStart" type="number" class="settings-input" placeholder="e.g. 2025" />
            </div>
            <div>
              <label class="settings-label">Year End</label>
              <input id="sy-yearEnd" type="number" class="settings-input" placeholder="e.g. 2026" />
            </div>
          </div>
          <div style="margin-bottom:16px;padding:14px 16px;background:rgba(39,167,68,.05);border:1px solid rgba(39,167,68,.12);border-radius:10px">
            <div style="font-size:11px;font-weight:700;color:#5fdd8e;letter-spacing:.06em;text-transform:uppercase;margin-bottom:12px">First Semester</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
              <div>
                <label class="settings-label">Semester Starts</label>
                <input id="sy-first-start" type="date" class="settings-input" />
              </div>
              <div>
                <label class="settings-label">Semester Ends</label>
                <input id="sy-first-end" type="date" class="settings-input" />
              </div>
            </div>
          </div>
          <div style="margin-bottom:16px;padding:14px 16px;background:rgba(251,191,36,.04);border:1px solid rgba(251,191,36,.12);border-radius:10px">
            <div style="font-size:11px;font-weight:700;color:#fbbf24;letter-spacing:.06em;text-transform:uppercase;margin-bottom:12px">Second Semester</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
              <div>
                <label class="settings-label">Semester Starts</label>
                <input id="sy-second-start" type="date" class="settings-input" />
              </div>
              <div>
                <label class="settings-label">Semester Ends</label>
                <input id="sy-second-end" type="date" class="settings-input" />
              </div>
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end">
            <button class="btn-ap" onclick="addSchoolYear()">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
              Add School Year
            </button>
          </div>
        </div>
      </div>

      <div class="content-card">
        <div class="cc-hdr"><div class="cc-title">School Years</div><span class="badge by" id="sy-count-badge">0 total</span></div>
        <div class="tbl-wrap tbl-scroll">
          <table>
            <thead><tr><th>#</th><th>School Year</th><th>Semesters</th><th>Status</th><th></th></tr></thead>
            <tbody id="sy-tbody">
              <tr class="empty-row"><td colspan="4">No school years found.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- MANAGE COURSES -->
    <div class="settings-panel" id="settings-courses">
      <div class="content-card" style="margin-bottom:14px">
        <div class="cc-hdr"><div class="cc-title">Add Course</div></div>
        <div style="padding:20px 24px">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
              <label class="settings-label">Course Code</label>
              <input id="course-code" type="text" class="settings-input" placeholder="e.g. BSIT" />
            </div>
            <div>
              <label class="settings-label">Course Name</label>
              <input id="course-name" type="text" class="settings-input" placeholder="e.g. BS Information Technology" />
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end">
            <button class="btn-ap" onclick="addCourse()">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
              Add Course
            </button>
          </div>
        </div>
      </div>

      <div class="content-card">
        <div class="cc-hdr"><div class="cc-title">Courses</div><span class="badge by" id="courses-count-badge">0 total</span></div>
        <div class="tbl-wrap tbl-scroll">
          <table>
            <thead><tr><th>#</th><th>Code</th><th>Course Name</th><th></th></tr></thead>
            <tbody id="courses-tbody">
              <tr class="empty-row"><td colspan="4">No courses found.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- SET FEE AMOUNT -->
    <div class="settings-panel" id="settings-fees">
      <div class="content-card" style="margin-bottom:14px">
        <div class="cc-hdr"><div class="cc-title">Set Organization Fee</div></div>
        <div style="padding:20px 24px">
          <div style="display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:16px">
            <div>
              <label class="settings-label">School Year & Semester</label>
              <select id="fee-sy-sem" class="settings-input" onchange="onFeeDropdownChange()" style="appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23fff%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 10px center;background-size:20px;background-color:#0a1f10;cursor:pointer">
                <option value="">Select school year & semester</option>
              </select>
            </div>
            <div>
              <label class="settings-label">Amount (₱)</label>
              <input id="fee-amount" type="number" step="0.01" class="settings-input" placeholder="e.g. 150.00" />
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end">
            <button class="btn-ap" onclick="setFeeAmount()">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
              Set Fee Amount
            </button>
          </div>
        </div>
      </div>

      <div class="content-card">
        <div class="cc-hdr"><div class="cc-title">Organization Fees</div></div>
        <div class="tbl-wrap tbl-scroll">
          <table>
            <thead><tr><th>School Year</th><th>Semester</th><th>Amount</th><th>Status</th><th></th></tr></thead>
            <tbody id="fees-tbody">
              <tr class="empty-row"><td colspan="5">No fee records found.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- CHANGE PASSWORD -->
    <div class="settings-panel" id="settings-password">
      <div class="content-card" style="margin-bottom:14px">
        <div class="cc-hdr"><div class="cc-title">Change Password</div></div>
        <div style="padding:20px 24px">
          <div style="display:grid;gap:12px;margin-bottom:16px;max-width:480px">
            <div>
              <label class="settings-label">Current Password</label>
              <input id="pwd-current" type="password" class="settings-input" placeholder="Enter current password" />
            </div>
            <div>
              <label class="settings-label">New Password</label>
              <input id="pwd-new" type="password" class="settings-input" placeholder="Enter new password" oninput="checkPasswordMatch()" />
            </div>
            <div>
              <label class="settings-label">Confirm New Password</label>
              <input id="pwd-confirm" type="password" class="settings-input" placeholder="Confirm new password" oninput="checkPasswordMatch()" />
            </div>
            <div id="pwd-match-message" style="font-size:12px;color:var(--text-m);min-height:18px"></div>
          </div>
          <div style="display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;max-width:480px">
            <button class="btn-ap" onclick="changeAdminPassword()">Change Password</button>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>
</div>

@Html.AntiForgeryToken()

<!-- EDIT STUDENT MODAL -->
<div id="editModal" style="display:none;position:fixed;inset:0;z-index:500;display:none;align-items:center;justify-content:center;">
  <!-- backdrop -->
  <div onclick="closeEditModal()" style="position:absolute;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(4px)"></div>
  <!-- modal box -->
  <div style="position:relative;z-index:1;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:28px 32px;width:100%;max-width:480px;box-shadow:0 24px 60px rgba(0,0,0,.5)">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:22px">
      <div>
        <div style="font-size:16px;font-weight:700;color:#fff">Edit Student</div>
        <div style="font-size:11.5px;color:var(--text-m);margin-top:2px">Changes will be saved to the database</div>
      </div>
      <button onclick="closeEditModal()" style="background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:30px;height:30px;border-radius:8px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center">✕</button>
    </div>

    <input type="hidden" id="edit-accountId" />

    <!-- Name fields -->
    <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-d);margin-bottom:10px">Personal Information</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
      <div>
        <label style="font-size:11px;color:var(--text-m);display:block;margin-bottom:4px">First Name</label>
        <input id="edit-firstName" type="text" style="width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none" />
      </div>
      <div>
        <label style="font-size:11px;color:var(--text-m);display:block;margin-bottom:4px">Last Name</label>
        <input id="edit-lastName" type="text" style="width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none" />
      </div>
    </div>
    <div style="margin-bottom:18px">
      <label style="font-size:11px;color:var(--text-m);display:block;margin-bottom:4px">Middle Name</label>
      <input id="edit-middleName" type="text" style="width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none" />
    </div>
    <div style="margin-bottom:18px">
      <label style="font-size:11px;color:var(--text-m);display:block;margin-bottom:4px">Email</label>
      <input type="email" placeholder="e.g. student@email.com"
             id="edit-email"
             oninput="checkEmailAvailability(this.value)"
             style="width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none;transition:border-color .2s" />
      <div id="email-feedback" style="font-size:11px;margin-top:5px;min-height:16px"></div>
    </div>

    <!-- Academic fields -->
    <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-d);margin-bottom:10px">Academic Information</div>
    <div style="margin-bottom:10px">
      <label style="font-size:11px;color:var(--text-m);display:block;margin-bottom:4px">Course</label>
      <select id="edit-courseId" style="width:100%;background:#0a1f10;border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none;cursor:pointer;appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23fff%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 10px center;background-size:20px">
        <option value="">Loading courses…</option>
      </select>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:24px">
      <div>
        <label style="font-size:11px;color:var(--text-m);display:block;margin-bottom:4px">Year Level</label>
        <select id="edit-yearLevel" style="width:100%;background:#0a1f10;border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none;cursor:pointer;appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23fff%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 10px center;background-size:20px">
          <option value="1">1st Year</option>
          <option value="2">2nd Year</option>
          <option value="3">3rd Year</option>
          <option value="4">4th Year</option>
          <option value="5">Graduated</option>
        </select>
      </div>
      <div>
        <label style="font-size:11px;color:var(--text-m);display:block;margin-bottom:4px">Section</label>
        <input id="edit-section" type="text" placeholder="e.g. A" style="width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;font-family:inherit;outline:none" />
      </div>
    </div>

    <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-d);margin-bottom:10px">Academic Status</div>
    <div style="margin-bottom:24px">
      <label style="font-size:11px;color:var(--text-m);display:block;margin-bottom:4px">Status</label>
