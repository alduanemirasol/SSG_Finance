function autoMiddlePeriod(input) {
    var val = input.value.replace(/\./g, '').toUpperCase(); // remove existing periods, uppercase
    if (val.length > 0) {
        input.value = val + '.';
    } else {
        input.value = '';
    }
}

// Settings functionality
async function switchSettingsTab(name, btn) {
    document.querySelectorAll('.settings-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.settings-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('settings-' + name).classList.add('active');
    btn.classList.add('active');

    if (name === 'sy')       await refreshSchoolYears();
    if (name === 'courses')  await refreshCourses();
    if (name === 'fees')     await refreshFees();
    if (name === 'password') { /* nothing to load */ }
}

function togglePwdVisibility(fieldId) {
    const field = document.getElementById(fieldId);
    if (!field) return;
    field.type = field.type === 'password' ? 'text' : 'password';
}

function checkPasswordMatch() {
    const newPassword = document.getElementById('pwd-new')?.value || '';
    const confirmPassword = document.getElementById('pwd-confirm')?.value || '';
    const message = document.getElementById('pwd-match-message');
    if (!message) return;
    if (!newPassword && !confirmPassword) {
        message.textContent = '';
        return;
    }

    if (newPassword === confirmPassword) {
        message.textContent = 'Passwords match';
        message.style.color = '#5fdd8e';
    } else {
        message.textContent = 'Passwords do not match';
        message.style.color = '#ff6b6b';
    }
}

async function changeAdminPassword() {
    const currentPassword = document.getElementById('pwd-current')?.value.trim() || '';
    const newPassword     = document.getElementById('pwd-new')?.value.trim() || '';
    const confirmPassword = document.getElementById('pwd-confirm')?.value.trim() || '';

    if (!currentPassword || !newPassword || !confirmPassword) {
        showToast('Please fill in all password fields.', 'fail');
        return;
    }

    if (newPassword !== confirmPassword) {
        showToast('New password and confirmation do not match.', 'fail');
        return;
    }

    if (newPassword.length < 8) {
        showToast('Password must be at least 8 characters long.', 'fail');
        return;
    }

    try {
        const response = await fetch('/Home/ChangeAdminPassword', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ currentPassword, newPassword, confirmPassword })
        });

        const result = await response.json();
        if (!result.success) {
            showToast(result.message || 'Unable to update password.', 'fail');
            return;
        }

        document.getElementById('pwd-current').value = '';
        document.getElementById('pwd-new').value = '';
        document.getElementById('pwd-confirm').value = '';
        document.getElementById('pwd-match-message').textContent = '';

        showToast(result.message || 'Password updated successfully.', 'success');
    }
    catch (ex) {
        showToast('An error occurred while updating the password.', 'fail');
    }
}

async function addSchoolYear() {
    const yearStart = parseInt(document.getElementById('sy-yearStart').value);
    const yearEnd   = parseInt(document.getElementById('sy-yearEnd').value);

    if (!yearStart || !yearEnd)          { showToast('Both year start and end are required.', 'fail'); return; }
    if (yearEnd !== yearStart + 1)       { showToast('Year end must be exactly year start + 1.', 'fail'); return; }

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    try {
        const res  = await fetch('/Home/AddSchoolYear', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
            body:    JSON.stringify({ yearStart, yearEnd })
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById('sy-yearStart').value = '';
            document.getElementById('sy-yearEnd').value   = '';
            showToast(data.message, 'ok');
            refreshSchoolYears();
        } else {
            showToast(data.message, 'fail');
        }
    } catch { showToast('Request failed.', 'fail'); }
}

async function addCourse() {
    const courseCode = document.getElementById('course-code').value.trim().toUpperCase();
    const courseName = document.getElementById('course-name').value.trim();

    if (!courseCode) { showToast('Course code is required.', 'fail'); return; }

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    try {
        const res  = await fetch('/Home/AddCourse', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
            body:    JSON.stringify({ courseCode, courseName })
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById('course-code').value = '';
            document.getElementById('course-name').value = '';
            showToast(data.message, 'ok');
            refreshCourses();
        } else {
            showToast(data.message, 'fail');
