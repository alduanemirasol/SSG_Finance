function toggleRecentRows() {
    var rows = document.querySelectorAll('.recent-row');
    var btn = document.getElementById('view-all-btn');
    var isExpanded = btn.getAttribute('data-expanded') === 'true';
    
    rows.forEach(function(row, i) {
        if (i >= 5) {
            row.style.display = isExpanded ? 'none' : '';
        }
    });
    
    btn.setAttribute('data-expanded', isExpanded ? 'false' : 'true');
    var total = btn.getAttribute('data-total');
    btn.textContent = isExpanded ? 'View All (' + total + ')' : 'Show Less';
}
function toggleDropdown(btn) {
    // close all other open dropdowns first
    document.querySelectorAll('.dropdown-menu.open').forEach(function(m) {
        if (m !== btn.nextElementSibling) m.classList.remove('open');
    });
    btn.nextElementSibling.classList.toggle('open');
}

// close dropdown when clicking outside
document.addEventListener('click', function(e) {
    if (!e.target.closest('.dropdown-wrap')) {
        document.querySelectorAll('.dropdown-menu.open').forEach(function(m) {
            m.classList.remove('open');
        });
    }
});

// holds courses list so we only fetch once
let coursesCache = [];

let emailCheckTimer = null;
let emailIsTaken = false;

function checkEmailAvailability(value) {
    const feedback = document.getElementById('email-feedback');
    const input = document.getElementById('edit-email');
    const accountId = parseInt(document.getElementById('edit-accountId').value);

    clearTimeout(emailCheckTimer);

    if (!value || !value.includes('@@')) {
        feedback.textContent = '';
        input.style.borderColor = 'rgba(255,255,255,0.12)';
        return;
    }

    emailCheckTimer = setTimeout(async () => {
        try {
            const res = await fetch('/Home/CheckEmail?email=' + encodeURIComponent(value) + '&excludeAccountId=' + accountId);
            const data = await res.json();

            if (data.taken) {
                emailIsTaken = true;
                feedback.textContent = 'This email is already used by ' + data.usedBy;
                feedback.style.color = '#f87171';
                input.style.borderColor = 'rgba(239,68,68,0.5)';
            } else {
                emailIsTaken = false;
                feedback.textContent = 'Email is available';
                feedback.style.color = '#5fdd8e';
                input.style.borderColor = 'rgba(39,167,68,0.5)';
            }
        } catch {
            feedback.textContent = '';
        }
    }, 500); // debounce — waits 500ms after user stops typing
}

async function loadCoursesIntoSelect() {
    if (coursesCache.length > 0) return; // already loaded
    try {
        const res  = await fetch('/Home/GetCourses');
        const data = await res.json();
        if (data.success) {
            coursesCache = data.courses;
            const sel = document.getElementById('edit-courseId');
            sel.innerHTML = '<option value="">Select course</option>';
            data.courses.forEach(c => {
                const opt = document.createElement('option');
                opt.value       = c.courseId;
                opt.textContent = c.courseCode;
                sel.appendChild(opt);
            });
        }
    } catch { showToast('Failed to load courses.', 'fail'); }
}

async function editStudent(accountId) {
    document.getElementById('editModal').style.display = 'flex';
    document.getElementById('edit-accountId').value = accountId;

    // load courses first
    await loadCoursesIntoSelect();

    // fetch current student data
    try {
        const res  = await fetch(`/Home/GetStudent?accountId=${accountId}`);
        const data = await res.json();
        if (data.success) {
            document.getElementById('edit-firstName').value  = data.firstName  ?? '';
            document.getElementById('edit-lastName').value   = data.lastName   ?? '';
            document.getElementById('edit-middleName').value = data.middleName ?? '';
            document.getElementById('edit-email').value     = data.email     ?? '';
            document.getElementById('edit-courseId').value   = data.courseId   ?? '';
            document.getElementById('edit-yearLevel').value  = data.yearLevel  ?? '1';
            document.getElementById('edit-section').value    = data.section    ?? '';
            document.getElementById('edit-academicStatus').value = data.academicStatus ?? 'Enrolled';
        } else {
            showToast(data.message, 'fail');
            closeEditModal();
        }
    } catch { showToast('Failed to load student.', 'fail'); closeEditModal(); }
}

function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
    emailIsTaken = false;
    document.getElementById('email-feedback').textContent = '';
}

async function saveStudent() {
    const accountId  = parseInt(document.getElementById('edit-accountId').value);
    const firstName  = document.getElementById('edit-firstName').value.trim();
    const lastName   = document.getElementById('edit-lastName').value.trim();
    const middleName = document.getElementById('edit-middleName').value.trim();
    const email      = document.getElementById('edit-email').value.trim();
    const courseId   = parseInt(document.getElementById('edit-courseId').value);
    const yearLevel  = parseInt(document.getElementById('edit-yearLevel').value);
    const section    = document.getElementById('edit-section').value.trim();
    const academicStatus = document.getElementById('edit-academicStatus').value;

    if (!firstName || !lastName) { showToast('First and last name are required.', 'fail'); return; }
    if (!courseId)                { showToast('Please select a course.', 'fail'); return; }

    if (emailIsTaken) {
        showToast('Please use a different email address.', 'fail');
        return;
    }

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    try {
        const res  = await fetch('/Home/UpdateStudent', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
            body:    JSON.stringify({ accountId, firstName, lastName, middleName, email, courseId, yearLevel, section, academicStatus })
        });
        const data = await res.json();

        if (data.success) {
            // update the row in the DOM without reload
            const row       = document.querySelector(`[data-account="${accountId}"]`);
            const nameCell  = row?.querySelector('td:nth-child(2)');
            const courseCell = row?.querySelector('td:nth-child(3)');
            const yearCell  = row?.querySelector('td:nth-child(4)');

            if (nameCell) {
                const isActive = row.getAttribute('data-active') === 'true';
                const fullName = `${lastName.toUpperCase()}, ${firstName.toUpperCase()}`;
                nameCell.innerHTML = isActive
                    ? `<strong>${fullName}</strong>` 
                    : `<strong style="color:#f87171">${fullName}</strong>
                       <span class="deactivated-badge" style="font-size:10px;font-weight:600;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25);border-radius:5px;padding:1px 7px;margin-left:8px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle;">Deactivated</span>`;
            }
            if (courseCell) {
                const courseName = coursesCache.find(c => c.courseId === courseId)?.courseCode ?? '';
                courseCell.innerHTML = `<span class="badge bg">${courseName}</span>`;
            }
            if (yearCell) {
                yearCell.textContent = `${yearLevel}-${section}`;
            }

            closeEditModal();
            showToast(data.message, 'ok');
        } else {
            showToast(data.message, 'fail');
        }
    } catch { showToast('Save failed. Please try again.', 'fail'); }
}
async function deleteStudent(accountId) {
    if (!confirm('Are you sure you want to PERMANENTLY delete this account? This cannot be undone.')) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    try {
