    async function saveStudent() {
        const accountId  = parseInt(document.getElementById('edit-accountId').value);
        const firstName  = document.getElementById('edit-firstName').value.trim();
        const lastName   = document.getElementById('edit-lastName').value.trim();
        const middleName = document.getElementById('edit-middleName').value.trim();
        const email      = document.getElementById('edit-email').value.trim();
        const courseId   = parseInt(document.getElementById('edit-courseId').value);
        const yearLevel  = parseInt(document.getElementById('edit-yearLevel').value);
        const section    = document.getElementById('edit-section').value.trim();
        const academicStatus = document.getElementById('edit-academicStatus').value;

        if (!firstName || !lastName) { showToast('First and last name are required.', 'fail'); return; }
        if (!courseId)                { showToast('Please select a course.', 'fail'); return; }

        if (emailIsTaken) {
            showToast('Please use a different email address.', 'fail');
            return;
        }

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        try {
