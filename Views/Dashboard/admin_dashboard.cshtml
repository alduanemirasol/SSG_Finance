async function saveNewProfessor() {
    const firstName  = document.getElementById('prof-firstName')?.value.trim();
    const lastName   = document.getElementById('prof-lastName')?.value.trim();
    const middleName = document.getElementById('prof-middleName')?.value.trim();
    const schoolId   = document.getElementById('prof-schoolId')?.value.trim();
    const email      = document.getElementById('prof-email')?.value.trim();
    const password   = document.getElementById('prof-password')?.value.trim();

    if (!firstName || !lastName)  { showToast('First and last name are required.', 'fail'); return; }
    if (!schoolId)                { showToast('School ID is required.', 'fail'); return; }
    if (!password || password.length < 6) { showToast('Password must be at least 6 characters.', 'fail'); return; }

