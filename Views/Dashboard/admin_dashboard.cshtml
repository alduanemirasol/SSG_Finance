<div id="toast"></div>

<script>
    // Formats the "Year Level - Section" cell. A year level of 5 means the student
    // has completed the 4-year program, so it shows "4 Completed" with no section.
    function fmtYearLevel(yearLevel, section) {
        if (yearLevel === null || yearLevel === undefined || yearLevel === '' || yearLevel === '—')
            return '—' + '-' + (section ?? '—');
        if (Number(yearLevel) === 5)
            return '4 Completed';
        return yearLevel + '-' + (section ?? '—');
    }

    // Formats a pre-joined "5-A" style year-section string. Year level 5 means the
    // student has completed the 4-year program, so it shows "4 Completed".
    function fmtYearSection(yearSection) {
        const ys = String(yearSection ?? '').trim();
        const yearPart = ys.split('-')[0].trim();
        return yearPart === '5' ? 'Graduate' : ys;
    }

    async function showPage(name, navEl) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
        var page = document.getElementById('page-' + name);
        if (page) page.classList.add('active');
        if (navEl) navEl.classList.add('active');
        else { var n = document.getElementById('nav-' + name); if (n) n.classList.add('active'); }

        // refresh the tab data
        if (name === 'dashboard')   { refreshDashboard(); refreshRequests(); }
        if (name === 'students')    refreshStudents();
        if (name === 'professors')  refreshProfessors();
        if (name === 'settings')    await refreshSchoolYears();
    }
    async function updateStatus(accountId, status) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        if (!confirm(`Are you sure you want to ${status.toLowerCase()} this account?`)) return;
        try {
            const res  = await fetch('/Home/UpdateAccountStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ?? '' },
                body: JSON.stringify({ accountId, status })
            });
            const data = await res.json();
            if (data.success) {
                const row = document.getElementById(`req-row-${accountId}`);
                if (row) { row.style.opacity = '0'; row.style.transition = 'opacity .3s'; setTimeout(() => row.remove(), 300); }
                const badge = document.getElementById('req-count-badge');
                if (badge) { const count = parseInt(badge.textContent) - 1; badge.textContent = `${Math.max(0, count)} pending`; }
                showToast(data.message, 'ok');
            } else {
                showToast(data.message, 'fail');
            }
        } catch {
            showToast('Request failed. Please try again.', 'fail');
        }
    }

    async function rejectAndDelete(accountId) {
        if (!confirm('Are you sure you want to reject and permanently delete this account? This cannot be undone.')) return;

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        try {
            const res = await fetch('/Home/DeleteAccount', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ accountId: accountId })
            });
            const data = await res.json();

            if (data.success) {
                const row = document.getElementById(`req-row-${accountId}`);
                if (row) {
                    row.style.opacity = '0';
                    row.style.transition = 'opacity .3s';
                    setTimeout(() => row.remove(), 300);
                }

                const badge = document.getElementById('req-count-badge');
                if (badge) { const count = parseInt(badge.textContent) - 1; badge.textContent = `${Math.max(0, count)} pending`; }

                showToast('Account rejected and deleted successfully.', 'ok');
            } else {
                showToast(data.message, 'fail');
            }
        } catch {
            showToast('Request failed. Please try again.', 'fail');
        }
    }

    function filterTable(input,tbodyId){
    var q=input.value.toLowerCase();
    document.querySelectorAll('#'+tbodyId+' tr').forEach(function(row){
        row.style.display=row.textContent.toLowerCase().includes(q)?'':'none';
    });
    }
    function showToast(msg,type){
    var t=document.getElementById('toast');
    t.textContent=msg;t.className='show '+type;
    clearTimeout(t._t);t._t=setTimeout(()=>t.className='',3000);
    }

    function triggerAvatarUpload() {
      const proceed = confirm(
        'Photo Guidelines\n\n' +
        'Please upload a formal photo that meets the following requirements:\n' +
        '• Format: 1×1 (square)\n' +
        '• Attire: your official school uniform or a plain white shirt\n' +
        '• Background: a plain white background\n\n' +
        'Click OK to choose your photo.'
      );
      if (!proceed) return;
      document.getElementById('avatarFileInput').click();
    }
    async function handleAvatarChange(input) {
      const file = input.files[0];
      if (!file) return;
      const allowed = ['image/jpeg','image/png','image/webp'];
      if (!allowed.includes(file.type)) { showToast('Only JPG, PNG, or WEBP allowed.','fail'); input.value=''; return; }
      if (file.size > 2*1024*1024) { showToast('Image must be 2 MB or smaller.','fail'); input.value=''; return; }
      const fd = new FormData();
      fd.append('accountId', '@accountId');
      fd.append('avatar', file);
      showToast('Uploading photo…','ok');
      try {
        const res  = await fetch('/Home/UploadAvatar', { method:'POST', body:fd });
        const data = await res.json();
        if (!data.success) { showToast(data.message||'Upload failed.','fail'); return; }
        const newSrc = data.avatarPath;
        const circle = document.getElementById('profileAvatarCircle');
        const initEl = document.getElementById('profileAvatarInitials');
        let imgEl = document.getElementById('profileAvatarImg');
        if (initEl) initEl.remove();
        if (!imgEl) { imgEl = document.createElement('img'); imgEl.id='profileAvatarImg'; Object.assign(imgEl.style,{width:'100%',height:'100%',objectFit:'cover',display:'block'}); circle.appendChild(imgEl); }
        imgEl.src = newSrc;
        const sideAv = document.querySelector('.user-av');
        if (sideAv) sideAv.innerHTML = `<img src="${newSrc}" style="width:100%;height:100%;object-fit:cover;border-radius:8px">`;
        showToast('Photo updated.','ok');
      } catch { showToast('Upload failed. Try again.','fail'); }
      input.value = '';
    }

    function resetDropdownPos(menu) {
        menu.style.position = '';
        menu.style.top = '';
        menu.style.left = '';
        menu.style.right = '';
        menu.style.bottom = '';
    }
    function closeAllDropdowns() {
        // only top-level menus carry the fixed-position overrides
        document.querySelectorAll('.dropdown-wrap > .dropdown-menu.open').forEach(function(m) {
            m.classList.remove('open');
            resetDropdownPos(m);
        });
        // hide any open role submenus (their inline position must be preserved)
        document.querySelectorAll('[id^="role-submenu-"],[id^="prof-role-submenu-"]').forEach(function(s) {
            s.style.display = 'none';
            s.classList.remove('open');
        });
    }
    function toggleDropdown(btn) {
        var menu = btn.nextElementSibling;
        var willOpen = !menu.classList.contains('open');
        closeAllDropdowns();
        if (!willOpen) return;
        menu.classList.add('open');

        // Position as fixed so the menu can escape the scrollable table container.
        // NOTE: an ancestor with backdrop-filter/filter/transform (e.g. .content-card
        // uses backdrop-filter) becomes the containing block for position:fixed, so
        // raw viewport coords would be offset. We measure where fixed (0,0) actually
        // lands and subtract that offset, which is correct for any containing block.
        var r = btn.getBoundingClientRect();
        menu.style.position = 'fixed';
        menu.style.right  = 'auto';
        menu.style.bottom = 'auto';
        menu.style.left = '0px';
        menu.style.top  = '0px';
        var base = menu.getBoundingClientRect();   // containing block's origin in viewport coords
        var offX = base.left, offY = base.top;
        var mw = menu.offsetWidth  || 180;
        var mh = menu.offsetHeight || 200;

        // Right-align the menu's right edge with the button's right edge.
        menu.style.left = (r.right - mw - offX) + 'px';
        // Open downward, or upward if there isn't room below.
        if (r.bottom + mh + 8 > window.innerHeight) {
            menu.style.top = (r.top - 4 - mh - offY) + 'px';
        } else {
            menu.style.top = (r.bottom + 4 - offY) + 'px';
        }
    }

    // close dropdown when clicking outside
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.dropdown-wrap')) closeAllDropdowns();
    });
    // close dropdowns on any scroll so the fixed menus don't detach from their row
    document.addEventListener('scroll', closeAllDropdowns, true);

    // holds courses list so we only fetch once
    let coursesCache = [];

    let emailCheckTimer = null;
    let emailIsTaken = false;

    function checkEmailAvailability(value) {
        const feedback = document.getElementById('email-feedback');
        const input = document.getElementById('edit-email');
        const accountId = parseInt(document.getElementById('edit-accountId').value);

        clearTimeout(emailCheckTimer);

        if (!value || !value.includes('@@')) {
            feedback.textContent = '';
            input.style.borderColor = 'rgba(255,255,255,0.12)';
            return;
        }

        emailCheckTimer = setTimeout(async () => {
            try {
                const res = await fetch('/Home/CheckEmail?email=' + encodeURIComponent(value) + '&excludeAccountId=' + accountId);
                const data = await res.json();

                if (data.taken) {
                    emailIsTaken = true;
                    feedback.textContent = 'This email is already used by ' + data.usedBy;
                    feedback.style.color = '#f87171';
                    input.style.borderColor = 'rgba(239,68,68,0.5)';
                } else {
                    emailIsTaken = false;
                    feedback.textContent = 'Email is available';
                    feedback.style.color = '#5fdd8e';
                    input.style.borderColor = 'rgba(39,167,68,0.5)';
                }
            } catch {
                feedback.textContent = '';
            }
        }, 500); // debounce — waits 500ms after user stops typing
    }

    async function loadCoursesIntoSelect() {
        if (coursesCache.length > 0) return; // already loaded
        try {
            const res  = await fetch('/Home/GetCourses');
            const data = await res.json();
            if (data.success) {
                coursesCache = data.courses;
                const sel = document.getElementById('edit-courseId');
                sel.innerHTML = '<option value="">Select course</option>';
                data.courses.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value       = c.courseId;
                    opt.textContent = c.courseCode;
                    sel.appendChild(opt);
                });
            }
        } catch { showToast('Failed to load courses.', 'fail'); }
    }

    async function editStudent(accountId) {
        document.getElementById('editModal').style.display = 'flex';
        document.getElementById('edit-accountId').value = accountId;

        // load courses first
        await loadCoursesIntoSelect();

        // fetch current student data
        try {
            const res  = await fetch(`/Home/GetStudent?accountId=${accountId}`);
            const data = await res.json();
            if (data.success) {
                document.getElementById('edit-firstName').value  = data.firstName  ?? '';
                document.getElementById('edit-lastName').value   = data.lastName   ?? '';
                document.getElementById('edit-middleName').value = data.middleName ?? '';
                document.getElementById('edit-email').value     = data.email     ?? '';
                document.getElementById('edit-courseId').value   = data.courseId   ?? '';
                document.getElementById('edit-yearLevel').value  = data.yearLevel  ?? '1';
                document.getElementById('edit-section').value    = data.section    ?? '';
                document.getElementById('edit-academicStatus').value = data.academicStatus ?? 'Enrolled';
            } else {
                showToast(data.message, 'fail');
                closeEditModal();
            }
        } catch { showToast('Failed to load student.', 'fail'); closeEditModal(); }
    }

    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
        emailIsTaken = false;
        document.getElementById('email-feedback').textContent = '';
    }

    // ── RETURN FROM LEAVE ───────────────────────────────────────────────────
    // School years ordered ascending by start year; each expands into two
    // semester "slots" so we can range over a leave window the same way the
    // server does in HomeController.ReturnFromLeave.
    let RL_SCHOOL_YEARS = [];

    function rlSemLabel(sem) { return sem === 'First' ? '1st Sem' : '2nd Sem'; }

    function rlBuildSlots() {
        const slots = [];
        for (const sy of RL_SCHOOL_YEARS) {
            slots.push({ schoolYearId: sy.schoolYearId, semester: 'First',  label: `${sy.yearLabel} ${rlSemLabel('First')}` });
            slots.push({ schoolYearId: sy.schoolYearId, semester: 'Second', label: `${sy.yearLabel} ${rlSemLabel('Second')}` });
        }
        return slots;
    }

    function rlSlotIndex(slots, schoolYearId, semester) {
        return slots.findIndex(s => s.schoolYearId === schoolYearId && s.semester === semester);
    }

    // The fixed "returns at" end, resolved from the server's current term.
    let RL_CURRENT_IDX = -1;

    async function openReturnFromLeaveModal(userId) {
        try {
            const res  = await fetch(`/Home/GetReturnFromLeaveInfo?userId=${userId}`);
            if (!res.ok) { showToast(`Failed to load (HTTP ${res.status}).`, 'fail'); return; }
            const data = await res.json();
            if (!data.success) { showToast(data.message || 'Failed to load.', 'fail'); return; }
            if (!data.schoolYears || !data.schoolYears.length) {
                showToast('No school years configured yet.', 'fail'); return;
            }

            RL_SCHOOL_YEARS = data.schoolYears; // ascending by YearStart
            document.getElementById('rl-userid').value = userId;

            const stu = ALL_STUDENTS_PAGE.find(s => s.userId === userId);
            document.getElementById('rl-sub').textContent = stu ? `${stu.name} · ${stu.schoolId || ''}`.trim() : '';

            const slots   = rlBuildSlots();
            const lastSel = document.getElementById('rl-last');
            const returns = document.getElementById('rl-returns');
            const confirm = document.getElementById('rl-confirm');

            RL_CURRENT_IDX = data.currentTerm
                ? rlSlotIndex(slots, data.currentTerm.schoolYearId, data.currentTerm.semester)
                : -1;

            // Can't build a leave window when there's no current term, or when the
            // current term is the very first semester on record (nothing before it
            // to exempt). Open the modal anyway with an explanation, Confirm off.
            if (!data.currentTerm || RL_CURRENT_IDX <= 0) {
                lastSel.innerHTML = '';
                returns.textContent = data.currentTerm
                    ? data.currentTerm.yearLabel + ' ' + rlSemLabel(data.currentTerm.semester)
                    : '— not set —';
                document.getElementById('rl-preview').innerHTML = !data.currentTerm
                    ? '<span style="color:#f87171">No current term is set, so the leave window can\'t be computed. Set the current term first.</span>'
                    : '<span style="color:#f87171">There are no semesters before the current term, so there is nothing to exempt. Re-enrol this student via Edit → Status = Enrolled.</span>';
                confirm.disabled = true;
                confirm.style.opacity = '.5';
                confirm.style.cursor = 'not-allowed';
                document.getElementById('returnLeaveModal').style.display = 'flex';
                return;
            }

            returns.textContent = data.currentTerm.yearLabel + ' ' + rlSemLabel(data.currentTerm.semester);

            // "Last attended" options: every slot before the current term.
            lastSel.innerHTML = slots.slice(0, RL_CURRENT_IDX)
                .map(s => `<option value="${s.schoolYearId}|${s.semester}">${escapeHtml(s.label)}</option>`)
                .join('');

            // Default to the detected last-attended slot, clamped to before the current term.
            let defaultIdx = data.lastAttended
                ? rlSlotIndex(slots, data.lastAttended.schoolYearId, data.lastAttended.semester)
                : RL_CURRENT_IDX - 1;
            if (defaultIdx < 0 || defaultIdx >= RL_CURRENT_IDX) defaultIdx = RL_CURRENT_IDX - 1;
            lastSel.value = `${slots[defaultIdx].schoolYearId}|${slots[defaultIdx].semester}`;

            updateReturnPreview();
            document.getElementById('returnLeaveModal').style.display = 'flex';
        } catch (err) {
            console.error('Return from Leave load error:', err);
            showToast('Failed to load: ' + (err && err.message ? err.message : err), 'fail');
        }
    }

    function updateReturnPreview() {
        const slots   = rlBuildSlots();
        const preview = document.getElementById('rl-preview');
        const confirm = document.getElementById('rl-confirm');
        const val     = document.getElementById('rl-last').value;
        if (!val || RL_CURRENT_IDX < 0) return;

        const [syId, sem] = val.split('|');
        const lastIdx = rlSlotIndex(slots, parseInt(syId), sem);

        // Gap = semesters strictly between last attended and the current term.
        const gap = slots.slice(lastIdx + 1, RL_CURRENT_IDX);
        if (gap.length === 0) {
            preview.innerHTML = 'No gap — the student will simply be re-enrolled, with no exemptions.';
        } else {
            preview.innerHTML = `Will re-enrol and exempt <strong>${gap.length}</strong> semester(s): `
                + gap.map(s => escapeHtml(s.label)).join(', ');
        }
        confirm.disabled = false;
        confirm.style.opacity = '1';
        confirm.style.cursor = 'pointer';
    }

