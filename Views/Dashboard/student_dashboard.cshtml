@model MyMvcApp.Models.DashboardViewModel
@{
    ViewData["Title"] = "Student Dashboard";
    var firstName     = Context.Session.GetString("FirstName") ?? "Student";
    var lastName      = Context.Session.GetString("LastName") ?? "";
    var middleName    = Context.Session.GetString("MiddleName") ?? "";
    var schoolId      = Context.Session.GetString("SchoolId") ?? "";
    var studentId     = schoolId;
    var courseCode    = Context.Session.GetString("CourseCode") ?? "";
    var courseName    = Context.Session.GetString("CourseName") ?? "";
    var yearLevel     = Context.Session.GetString("YearLevel") ?? "";
    var section       = Context.Session.GetString("Section") ?? "";
    var email         = Context.Session.GetString("Email") ?? "";
    var accountId     = Context.Session.GetString("AccountId") ?? "";
    var initials      = (firstName.Length > 0 ? firstName[0].ToString() : "") + (lastName.Length > 0 ? lastName[0].ToString() : "");
    var avatarPath    = Context.Session.GetString("AvatarPath") ?? "";
    var middleInitial = middleName.Length > 0 ? middleName[0].ToString().ToUpper() + "." : "";
    var displayName   = (firstName + (middleInitial.Length > 0 ? " " + middleInitial : "") + (lastName.Length > 0 ? " " + lastName : "")).Trim();
    var yearDisplay   = yearLevel == "5" ? "4 Completed" : (yearLevel.Length > 0 ? yearLevel : "—");
    var courseDisplay = (courseCode.Length > 0 ? courseCode : "") +
                        (yearDisplay != "—" ? " — " + yearDisplay + (section.Length > 0 && yearLevel != "5" ? section : "") : "");

    // Shorten a semester label ("First"/"Second"/…) to "1st" / "2nd".
    string SemShort(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return "-";
        var t = s.Trim().ToLowerInvariant();
        if (t.StartsWith("first")  || t.StartsWith("1")) return "1st";
        if (t.StartsWith("second") || t.StartsWith("2")) return "2nd";
        return s;
    }
  }

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="/js/csrf.js"></script>
  <title>SSG Finance - Student Dashboard</title>
  <link rel="icon" type="image/png" href="~/images/favicon.png" />
  <style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=DM+Mono:wght@400;500&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap');

    *{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#071a0c;
      --bg2:#0c2413;
      --sidebar:#081509;
      --green:#27a744;
      --green-d:#1a7a4a;
      --green-glow:rgba(39,167,68,.18);
      --green-glow2:rgba(39,167,68,.08);
      --glass:rgba(255,255,255,.045);
      --glass-b:rgba(255,255,255,.09);
      --text:#e8f5ec;
      --text-m:rgba(232,245,236,.6);
      --text-d:rgba(232,245,236,.35);
      --card:#0f2918;
      --card-b:rgba(255,255,255,.07);
      --green-badge:rgba(39,167,68,.18);
      --green-badge-t:#5fdd8e;
      --yellow-badge:rgba(251,191,36,.14);
      --yellow-badge-t:#fbbf24;
      --red-badge:rgba(239,68,68,.14);
      --red-badge-t:#f87171;
    }

    body{font-family:'DM Sans',sans-serif;background:var(--bg);display:flex;min-height:100vh;color:var(--text);font-size:14px;width:100%;overflow-x:hidden}

    /* ── SIDEBAR ── */
    .sidebar{width:210px;background:var(--sidebar);border-right:1px solid rgba(255,255,255,.05);display:flex;flex-direction:column;flex-shrink:0;transition:transform 0.3s ease;z-index:100;position:fixed;height:100vh;height:100dvh;left:0;top:0}
    .sidebar.collapsed{transform:translateX(-100%)}
    .mobile-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99}
    .mobile-overlay.active{display:block;left:210px}
    .mobile-menu-btn{display:none;position:fixed;top:20px;left:20px;z-index:101;background:var(--card);border:1px solid var(--card-b);border-radius:8px;padding:8px;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.2)}
    .sb-close-btn{display:none;position:absolute;top:12px;right:12px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;font-size:14px;align-items:center;justify-content:center;font-family:inherit;z-index:1}
    .sb-close-btn:hover{background:rgba(239,68,68,.12);color:#f87171}
    .mobile-menu-btn svg{width:20px;height:20px;color:var(--text)}
    .sb-brand{display:flex;align-items:center;gap:10px;padding:20px 16px 18px;border-bottom:1px solid rgba(255,255,255,.05)}
    .sb-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 14px rgba(39,167,68,.3)}
    .sb-logo svg{width:18px;height:18px}
    .sb-logo img{width:100%;height:100%;object-fit:cover;border-radius:10px}
    .sb-brand-name{font-size:13.5px;font-weight:700;color:#fff;letter-spacing:-.01em}
    .sb-brand-sub{font-size:10px;color:rgba(39,167,68,.85);letter-spacing:.1em;text-transform:uppercase;margin-top:1px}
    .sb-label{font-size:9.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--text-d);padding:16px 16px 5px}
    .nav-item{display:flex;align-items:center;gap:9px;padding:8px 12px;margin:1px 8px;border-radius:8px;font-size:13px;font-weight:500;color:var(--text-m);cursor:pointer;transition:all .15s;text-decoration:none;position:relative}
    .nav-item:hover{background:var(--glass);color:var(--text)}
    .nav-item.active{background:var(--green-glow);color:#5fdd8e;border:1px solid rgba(74,222,128,.12)}
    .nav-item svg{width:15px;height:15px;flex-shrink:0;opacity:.85}
    .sb-spacer{flex:1}
    .sb-user{padding:10px 8px 10px;border-top:1px solid rgba(255,255,255,.05)}
    .user-card{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;background:var(--glass)}
    .user-av{width:36px;min-width:36px;height:36px;border-radius:8px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden}
    .user-av img{width:100%;height:100%;object-fit:cover;display:block;border-radius:8px;pointer-events:none}
    .user-name{font-size:12px;font-weight:600;color:#fff}
    .user-role{font-size:10.5px;color:var(--text-d)}
    .signout{display:flex;align-items:center;gap:7px;padding:7px 10px;margin-top:3px;border-radius:8px;font-size:12.5px;font-weight:500;color:var(--text-d);cursor:pointer;transition:all .15s;text-decoration:none}
    .signout:hover{background:rgba(239,68,68,.08);color:#f87171}
    .signout svg{width:14px;height:14px}

    /* ── MAIN ── */
    .main{flex:1;min-width:0;padding:36px 36px 60px;background:var(--bg);overflow-y:auto;overflow-x:hidden;position:relative;height:100vh;margin-left:210px;transition:margin-left 0.3s ease}
    .main.sidebar-collapsed{margin-left:0}
    .main::before{content:'';position:absolute;top:-80px;right:-80px;width:380px;height:380px;background:radial-gradient(circle,rgba(39,167,68,.06) 0%,transparent 70%);pointer-events:none;border-radius:50%}

    .page{display:none;max-width:1200px;margin-left:auto;margin-right:auto}.page.active{display:block}

    .page-hdr{display:flex;align-items:center;justify-content:center;text-align:center;margin-bottom:22px;position:relative}
    .page-title{font-size:22px;font-weight:800;color:#fff;letter-spacing:-.03em}
    .page-sub{font-size:12px;color:var(--text-m);margin-top:2px}

    /* ── STAT CARDS ── */
    .stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px;width:100%}
    .stat-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;padding:18px 20px;display:flex;flex-direction:column;gap:8px;position:relative;overflow:hidden;backdrop-filter:blur(8px)}
    .stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(39,167,68,.25),transparent)}
    .stat-lbl{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d)}
    .stat-row{display:flex;align-items:center;justify-content:space-between}
    .stat-val{font-size:28px;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em}
    .stat-val.amount{font-size:22px}
    .stat-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center}
    .stat-icon.g{background:rgba(39,167,68,.15)}
    .stat-icon.y{background:rgba(251,191,36,.12)}
    .stat-icon.r{background:rgba(239,68,68,.12)}
    .stat-icon svg{width:15px;height:15px}
    .stat-trend{font-size:11px;font-weight:500;color:var(--green)}
    .stat-trend.warn{color:#fbbf24}
    .stat-trend.ok{color:#5fdd8e}

    /* ── CONTENT CARDS ── */
    .content-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;overflow:visible;margin-bottom:16px;backdrop-filter:blur(8px);position:relative;width:100%;isolation:isolate}
    .content-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(39,167,68,.2),transparent);z-index:1}
    .cc-hdr{display:flex;align-items:center;justify-content:space-between;padding:15px 20px 13px;border-bottom:1px solid rgba(255,255,255,.05)}
    .cc-title{font-size:13.5px;font-weight:700;color:#fff;letter-spacing:-.01em}

    /* ── TABLES ── */
    .tbl-wrap{overflow-x:auto}
    /* Scrollable table viewport: vertical + horizontal scrollbars, sticky header */
    .tbl-scroll{max-height:min(540px,62vh);overflow:auto;scrollbar-width:thin;scrollbar-color:rgba(39,167,68,.45) rgba(255,255,255,.04)}
    .tbl-scroll thead th{position:sticky;top:0;z-index:4;background:#142d1d}
    .tbl-scroll::-webkit-scrollbar{width:10px;height:10px}
    .tbl-scroll::-webkit-scrollbar-track{background:rgba(255,255,255,.03)}
    .tbl-scroll::-webkit-scrollbar-thumb{background:rgba(39,167,68,.4);border-radius:6px;border:2px solid transparent;background-clip:padding-box}
    .tbl-scroll::-webkit-scrollbar-thumb:hover{background:rgba(39,167,68,.6);background-clip:padding-box}
    .tbl-scroll::-webkit-scrollbar-corner{background:transparent}
    table{width:100%;border-collapse:collapse;font-size:12.5px}
    thead th{padding:10px 15px;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);border-bottom:1px solid rgba(255,255,255,.05);text-align:left;white-space:nowrap;background:rgba(255,255,255,.02)}
    tbody tr{border-bottom:1px solid rgba(255,255,255,.04);transition:background .1s}
    tbody tr:last-child{border-bottom:none}
    tbody tr:hover{background:rgba(39,167,68,.05)}
    td{padding:11px 15px;color:var(--text);vertical-align:middle}
    .td-m{color:var(--text-m)}
    .td-mono{font-family:'DM Mono',monospace;font-size:11.5px}

    /* ── BADGES ── */
    .badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:10.5px;font-weight:600;letter-spacing:.02em}
    .bg{background:var(--green-badge);color:var(--green-badge-t)}
    .by{background:var(--yellow-badge);color:var(--yellow-badge-t)}
    .br{background:var(--red-badge);color:var(--red-badge-t)}

    /* ── STATUS PILLS ── */
    .status-pill{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:20px;font-size:10.5px;font-weight:600}
    .status-pill .dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
    .status-paid{background:var(--green-badge);color:var(--green-badge-t)}.status-paid .dot{background:#5fdd8e}
    .status-pending{background:var(--yellow-badge);color:var(--yellow-badge-t)}.status-pending .dot{background:#fbbf24}
    .status-overdue{background:var(--red-badge);color:var(--red-badge-t)}.status-overdue .dot{background:#f87171}
    .status-partial{background:rgba(139,92,246,.14);color:#c4b5fd}.status-partial .dot{background:#c4b5fd}

    /* ── PAY BUTTON ── */
    .btn-pay{display:inline-flex;align-items:center;gap:5px;padding:5px 14px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid rgba(39,167,68,.25);background:var(--green-badge);color:var(--green-badge-t);transition:all .15s;font-family:inherit}
    .btn-pay:hover{background:rgba(39,167,68,.28);transform:translateY(-1px)}
    .btn-pay:disabled{opacity:.4;cursor:not-allowed;transform:none}

    /* ── DOWNLOAD BUTTON ── */
    .btn-download{display:flex;align-items:center;gap:8px;padding:9px 20px;border-radius:8px;font-size:12.5px;font-weight:600;cursor:pointer;border:1px solid rgba(255,255,255,.12);background:transparent;color:var(--text-m);transition:all .15s;font-family:inherit;margin:14px 20px}
    .btn-download:hover{border-color:var(--green);color:var(--green);background:var(--green-glow2)}

    /* ── NOTICE ── */
    .notice{display:flex;align-items:flex-start;gap:10px;padding:13px 16px;border-radius:10px;background:rgba(251,191,36,.06);border:1px solid rgba(251,191,36,.15);margin-bottom:16px}
    .notice svg{width:16px;height:16px;flex-shrink:0;margin-top:1px}
    .notice-text{font-size:12px;color:var(--text-m);line-height:1.6}

    /* ── MODAL (DARK) ── */
    .modal{display:none;position:fixed;inset:0;z-index:500;align-items:center;justify-content:center}
    .modal.open{display:flex}
    .modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(4px)}
    .modal-box{position:relative;z-index:1;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:28px 32px;width:100%;max-width:560px;box-shadow:0 24px 60px rgba(0,0,0,.5);max-height:80vh;overflow-y:auto}
    .modal-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
    .modal-title{font-size:16px;font-weight:700;color:#fff}
    .modal-close{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:30px;height:30px;border-radius:8px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;font-family:inherit}

    /* ── RECEIPT MODAL ── */
    .receipt-modal{display:none;position:fixed;inset:0;z-index:600;align-items:center;justify-content:center}
    .receipt-modal.open{display:flex}
    .receipt-modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(6px)}
    .receipt-modal-inner{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:12px;max-height:95vh;overflow-y:auto;padding:16px}

    /* receipt controls bar */
    .receipt-controls{display:flex;align-items:center;gap:10px;background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:8px 14px;width:100%;max-width:620px}
    .receipt-ctrl-title{flex:1;font-size:12.5px;font-weight:600;color:var(--text-m)}
    .btn-receipt-close{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;font-family:inherit;flex-shrink:0}
    .btn-receipt-close:hover{background:rgba(239,68,68,.12);color:#f87171}
    .btn-pdf{display:inline-flex;align-items:center;gap:6px;padding:6px 16px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:1px solid rgba(39,167,68,.3);background:rgba(39,167,68,.15);color:#5fdd8e;transition:all .15s;font-family:inherit;flex-shrink:0}
    .btn-pdf:hover{background:rgba(39,167,68,.25);transform:translateY(-1px)}

    /* ── THE ACTUAL RECEIPT (white paper) ── */
    /* Long bond paper: 8.5in × 13in → at 96dpi = 816 × 1248px, scaled down to ~620px wide */
    .receipt-paper{
      width:620px;
      min-height:auto;
      background:#ffffff;
      border:1px solid #ccc;
      box-shadow:0 8px 40px rgba(0,0,0,.45);
      padding:24px 56px 28px;
      font-family:Arial, Helvetica, sans-serif;
      color:#111;
      position:relative;
      flex-shrink:0;
    }

    .rp-header{text-align:center;margin-bottom:12px;position:relative;z-index:1}
    .rp-org{font-size:12px;font-weight:700;letter-spacing:.01em;margin-bottom:1px}
    .rp-campus{font-size:11px;font-weight:400}
    .rp-divider{border:none;border-top:1px solid #555;margin:8px 0 6px}
    .rp-type{font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin-top:6px}
    .rp-copy{font-size:11px;font-style:italic;color:#111;margin-top:1px}

    .rp-meta{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;position:relative;z-index:1}
    .rp-meta-label{font-size:11px;font-weight:400}
    .rp-meta-value{font-size:12px;font-weight:700;color:#111;border-bottom:1px solid #888;min-width:140px;display:inline-block;padding-bottom:2px;text-align:center}
    .rp-meta-value.date-val{color:#111}

    .rp-section-title{text-align:center;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px;position:relative;z-index:1}

    .rp-field{display:flex;align-items:baseline;margin-bottom:6px;position:relative;z-index:1}
    .rp-field-label{font-size:12px;font-weight:400;min-width:150px;flex-shrink:0}
    .rp-field-value{flex:1;font-size:12px;font-weight:700;border-bottom:1px solid #888;padding-bottom:2px;min-height:18px;padding-left:6px;font-family:Arial,Helvetica,sans-serif}
    .rp-field-value.handwritten{font-family:Arial,Helvetica,sans-serif;font-style:none;font-size:12px;letter-spacing:.01em}

    /* status badge on receipt */
    .rp-status-badge{display:inline-block;padding:1px 10px;border:none;font-size:12px;font-weight:700;font-style:none;background:transparent;color:#111}
    .rp-status-badge.paid{color:#111}
    .rp-status-badge.partial{color:#111}
    .rp-status-badge.pending{color:#111}

    /* signature section */
    .rp-signature-section{margin-top:24px;display:flex;justify-content:flex-end;position:relative;z-index:1}
    .rp-sig-block{text-align:center;min-width:220px}
    .rp-sig-label{font-size:11px;margin-bottom:6px}
    .rp-sig-line{display:none}
    .rp-sig-name-label{font-size:11px;color:#111}

    /* watermark "COPY" */
    .rp-watermark{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-35deg);font-size:90px;font-weight:700;color:rgba(0,0,0,.04);pointer-events:none;letter-spacing:.2em;z-index:0;font-family:'Libre Baskerville',serif;text-transform:uppercase}

    /* ── TOAST ── */
    #toast{position:fixed;bottom:20px;right:20px;padding:10px 18px;border-radius:9px;font-size:12.5px;font-weight:500;background:#1f2937;color:#fff;opacity:0;transform:translateY(8px);transition:opacity .25s,transform .25s;z-index:999;pointer-events:none;display:flex;align-items:center;gap:7px;box-shadow:0 8px 24px rgba(0,0,0,.4)}
    #toast.show{opacity:1;transform:translateY(0)}
    #toast.ok{background:#052e16;border:1px solid rgba(39,167,68,.3)}
    #toast.fail{background:#450a0a;border:1px solid rgba(239,68,68,.3)}

    .top-accent{height:2px;background:linear-gradient(90deg,transparent,var(--green),transparent);position:absolute;top:0;left:0;right:0;z-index:10}
    .empty-row td{text-align:center;padding:40px;color:var(--text-d);font-size:12.5px}

    /* ── PROFILE INFO CARD ── */
    .profile-info-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
    .info-field{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:12px 16px}
    .info-field label{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);display:block;margin-bottom:4px}
    .info-field span{font-size:13px;font-weight:500;color:var(--text)}

    /* ── PROFILE HERO ── */
    .profile-hero{display:flex;flex-direction:column;align-items:center;padding:32px 20px 24px;border-bottom:1px solid rgba(255,255,255,.05)}
    .profile-avatar-wrap{position:relative;width:88px;height:88px;margin-bottom:14px;flex-shrink:0}
    .profile-avatar{width:88px;height:88px;border-radius:50%;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:700;color:#fff;overflow:hidden;border:2px solid rgba(39,167,68,.3);box-shadow:0 0 18px rgba(39,167,68,.18)}
    .profile-avatar img{width:100%;height:100%;object-fit:cover;display:block}
    .avatar-edit-badge{position:absolute;bottom:0;right:0;width:28px;height:28px;border-radius:50%;background:#27a744;border:2px solid var(--card);display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;z-index:3;transition:background .15s,transform .15s;box-shadow:0 2px 6px rgba(0,0,0,.35)}
        .avatar-edit-badge:hover{background:#2fbf52;transform:scale(1.08)}
    .profile-hero-name{font-size:16px;font-weight:700;color:#fff;text-align:center;letter-spacing:-.01em;line-height:1.3}
    .profile-hero-role{font-size:11.5px;color:var(--text-d);margin-top:3px}
    .profile-fields{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:20px}
    .profile-field{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:12px 16px}
    .profile-field label{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);display:block;margin-bottom:4px}
    .profile-field span{font-size:13px;font-weight:500;color:var(--text);word-break:break-word}
    .profile-field.full{grid-column:1/-1}

    /* ── PRINT STYLES ── */
    @@media print {
      /* Collapse ALL page layout so nothing pushes the receipt down */
      body > * { display: none !important; }

      html, body {
        background: #fff !important;
        margin: 0 !important; padding: 0 !important;
        display: block !important;
        overflow: visible !important;
        height: auto !important; min-height: 0 !important;
      }

      /* Show only the receipt modal */
      #receiptModal {
        display: block !important;
        position: static !important;
        background: #fff !important;
        padding: 0 !important; margin: 0 !important;
      }

      /* Hide backdrop and controls bar */
      #receiptModal .receipt-modal-backdrop,
      #receiptModal .receipt-controls { display: none !important; }

      /* Reset modal inner */
      #receiptModal .receipt-modal-inner {
        display: block !important;
        position: static !important;
        padding: 0 !important; margin: 0 !important;
        max-height: none !important;
        overflow: visible !important;
        background: #fff !important;
      }

      /* Receipt paper */
      .receipt-paper {
        display: block !important;
        position: static !important;
        transform: none !important;
        margin: 0 auto !important;
        box-shadow: none !important;
        border: none !important;
        background: #fff !important;
        page-break-inside: avoid;
      }
      .receipt-paper::before { display: none !important; }
      .receipt-paper, .receipt-paper * {
        visibility: visible !important;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }

      @@page { margin: 12mm; size: auto; }
    }

    /* ── MOBILE RESPONSIVE ── */
    @@media (max-width: 768px) {
      .mobile-menu-btn{display:flex;align-items:center;justify-content:center}
      .sb-close-btn{display:flex}
      .sidebar{transform:translateX(-100%)}
      .sidebar.mobile-open{transform:translateX(0)}
      .main{margin-left:0;padding:20px 16px 60px}
      /* Left-align title so it clears the hamburger button */
      .page-hdr{padding-left:48px;justify-content:flex-start}
      /* Hide the date badge — it overlaps the title on small screens */
      .page-date-badge{display:none}
      .stat-grid{grid-template-columns:1fr;gap:10px}
      .stat-val{font-size:24px}
      .page-title{font-size:20px}
      .profile-info-row{grid-template-columns:1fr}
      /* Fix profile fields: stay 2-col → drop to 1-col */
      .profile-fields{grid-template-columns:1fr}
      .modal-box{max-width:95%;margin:20px;padding:20px}
      .tbl-wrap{border-radius:8px}
      table{font-size:11.5px}
      thead th{padding:8px 10px;font-size:9px}
      td{padding:8px 10px}
      .nav-item{padding:10px 12px;font-size:14px}
      .sb-brand{padding:16px 12px}
      .notice{padding:12px 14px}
      .notice-text{font-size:11px}
      /* Receipt: scroll horizontally instead of fragile scale+margin hack */
      .receipt-modal-inner{padding:8px;overflow-x:auto;align-items:flex-start}
      .receipt-controls{max-width:95vw}
      .receipt-paper{transform:none;margin-bottom:0}
      /* Hide # and Semester columns in Payment History — too many cols on mobile */
      #page-history thead th:nth-child(1),
      #page-history td:nth-child(1),
      #page-history thead th:nth-child(3),
      #page-history td:nth-child(3){display:none}
    }

    @@media (max-width: 480px) {
      .main{padding:16px 12px 60px}
      .page-hdr{flex-direction:column;align-items:flex-start;gap:8px}
      .stat-card{padding:14px 16px}
      .stat-val{font-size:20px}
      .stat-val.amount{font-size:18px}
      .page-title{font-size:18px}
      .content-card{border-radius:12px}
      .cc-hdr{padding:12px 16px}
      .cc-title{font-size:12px}
      .badge{font-size:9.5px;padding:2px 7px}
      table{font-size:10.5px}
      thead th{padding:6px 8px;font-size:8.5px}
      td{padding:6px 8px}
      .btn-pay{font-size:10px;padding:4px 10px}
      .btn-download{font-size:11px;padding:8px 16px;margin:12px 16px}
    }
  </style>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
</head>
<body>

<div class="top-accent"></div>
<div style="display:flex;min-height:100vh;width:100%;position:relative">

<!-- ── MOBILE MENU BUTTON ── -->
<button class="mobile-menu-btn" onclick="toggleMobileMenu()" aria-label="Toggle navigation" aria-expanded="false">
  <svg viewBox="0 0 24 24" fill="none"><path d="M3 12h18M3 6h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
</button>

<!-- ── MOBILE OVERLAY ── -->
<div class="mobile-overlay" onclick="closeMobileMenu()"></div>

<!-- ── SIDEBAR ── -->
<aside class="sidebar">
  <button class="sb-close-btn" onclick="closeMobileMenu()" aria-label="Close navigation">✕</button>
  <div class="sb-brand">
    <div class="sb-logo">
      <img src="~/logo.png" alt="SSG Finance Logo" />
    </div>
    <div>
      <div class="sb-brand-name">SSG Finance</div>
      <div class="sb-brand-sub">Student Portal</div>
    </div>
  </div>

  <div class="sb-label">Main</div>
  <a class="nav-item active" id="nav-overview" onclick="showPage('overview',this)">
    <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
    Overview
  </a>
  <a class="nav-item" id="nav-fees" onclick="showPage('fees',this)">
    <svg viewBox="0 0 24 24" fill="none"><rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M16 11a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M2 10V7a2 2 0 012-2h16a2 2 0 012 2v3" stroke="currentColor" stroke-width="1.8"/></svg>
    Current Fees
  </a>
  <a class="nav-item" id="nav-history" onclick="showPage('history',this)">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 8v4l3 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/></svg>
    Payment History
  </a>

  <div class="sb-spacer"></div>
  <div class="sb-user">
    <button class="user-card" onclick="showPage('profile', null)" style="width:100%;text-align:left;cursor:pointer;background:var(--glass);border:1px solid transparent;border-radius:9px;padding:8px 10px;transition:all .15s;font-family:inherit;color:inherit;display:flex;align-items:center;gap:9px" onmouseover="this.style.background='var(--green-glow)';this.style.borderColor='rgba(74,222,128,.12)'" onmouseout="this.style.background='var(--glass)';this.style.borderColor='transparent'">
      <div class="user-av">
        @if (!string.IsNullOrEmpty(avatarPath))
        {
          <img src="@avatarPath" alt="@initials.ToUpper()" />
        }
        else
        {
          @initials.ToUpper()
        }
      </div>
      <div>
        <div class="user-name">@firstName @lastName</div>
        <div class="user-role">Student</div>
      </div>
    </button>
    <a class="signout" href="/Home/Logout">
      <svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Sign Out
    </a>
  </div>
</aside>

<!-- ── MAIN CONTENT ── -->
<div class="main">

  <!-- ══ OVERVIEW PAGE ══ -->
  <div class="page active" id="page-overview">
    <div class="page-hdr">
      <div>
        <div class="page-title">Overview</div>
        <div class="page-sub">Welcome back, @firstName</div>
      </div>
      <div class="page-date-badge" style="position:absolute;right:0;top:50%;transform:translateY(-50%);font-size:11.5px;color:var(--text-m);background:rgba(39,167,68,.1);border:1px solid rgba(39,167,68,.2);padding:6px 13px;border-radius:8px;display:flex;align-items:center;gap:6px">
        <span style="width:6px;height:6px;border-radius:50%;background:#4ade80;box-shadow:0 0 6px #4ade80;display:inline-block"></span>
        @DateTime.Now.ToString("MMMM dd, yyyy")
      </div>
    </div>

    @{
      var totalBalance = Model.PaymentHistory.Sum(h =>
        h.Payments.Where(p => p.Status == "Total").Sum(p => p.Amount) -
        h.Payments.Where(p => p.Status != "Total").Sum(p => p.Amount));
      var totalPaid    = Model.PaymentHistory.SelectMany(h => h.Payments).Where(p => p.Status != "Total").Sum(p => p.Amount);
      var pendingCount = Model.PaymentHistory.Count(h => h.OverallStatus != "Paid");
    }
    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-lbl">Org Fee Balance</div>
        <div class="stat-row">
          <div class="stat-val amount">₱@totalBalance.ToString("N2")</div>
          <div class="stat-icon r">
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6" stroke="#f87171" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
        </div>
        <div class="stat-trend @(totalBalance > 0 ? "warn" : "ok")">@(totalBalance > 0 ? "Amount due" : "Fully settled")</div>
      </div>
      <div class="stat-card">
        <div class="stat-lbl">Total Paid Amount</div>
        <div class="stat-row">
          <div class="stat-val amount">₱@totalPaid.ToString("N2")</div>
          <div class="stat-icon g">
            <svg viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#27a744" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </div>
        <div class="stat-trend ok">All confirmed payments</div>
      </div>
      <div class="stat-card">
        <div class="stat-lbl">Pending Semesters</div>
        <div class="stat-row">
          <div class="stat-val">@pendingCount</div>
          <div class="stat-icon y">
            <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#fbbf24" stroke-width="1.8"/><path d="M12 8v4l3 3" stroke="#fbbf24" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
        </div>
        <div class="stat-trend @(pendingCount > 0 ? "warn" : "ok")">@(pendingCount > 0 ? "Semesters not yet fully paid" : "All semesters paid")</div>
      </div>
    </div>

    <div class="notice">
      <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#fbbf24" stroke-width="1.8"/><path d="M12 8v4M12 16h.01" stroke="#fbbf24" stroke-width="1.8" stroke-linecap="round"/></svg>
      <p class="notice-text">This dashboard is <strong>view-only</strong>. Contact your SSG office to update payment records or dispute a balance.</p>
    </div>
  </div>

  <!-- ══ CURRENT FEES PAGE ══ -->
  <div class="page" id="page-fees">
    <div class="page-hdr">
      <div>
        <div class="page-title">Current Fees</div>
        <div class="page-sub">Your active fee obligations</div>
      </div>
    </div>
    <div class="content-card">
      <div class="cc-hdr">
        <div class="cc-title">Fee Breakdown</div>
        <span class="badge by">@((Model.PaymentHistory?.Count(ph => ph.OverallStatus != "Paid") ?? 0)) pending</span>
      </div>
      <div class="tbl-wrap tbl-scroll">
        <table>
          <thead>
            <tr><th>#</th><th>Semester</th><th>School Year</th><th>Org Fee Balance</th><th>Paid Amount</th><th>Status</th><th>To Pay</th></tr>
          </thead>
          <tbody>
            @if (Model.PaymentHistory != null && Model.PaymentHistory.Any())
            {
              int feeIdx = 1;
              @foreach (var h in Model.PaymentHistory.Where(ph => ph.OverallStatus != "Paid"))
              {
                var total = h.Payments.Where(p => p.Status == "Total").Sum(p => p.Amount);
                var paid  = h.Payments.Where(p => p.Status != "Total").Sum(p => p.Amount);
                var bal   = total - paid;
                string sc;
                switch (h.OverallStatus.ToLower())
                {
                  case "paid":    sc = "bg"; break;
                  case "pending": sc = "by"; break;
                  case "overdue": sc = "br"; break;
                  default:        sc = "by"; break;
                }
                <tr>
                  <td class="td-mono td-m">@(feeIdx++)</td>
                  <td class="td-m"><strong>@SemShort(h.Semester)</strong></td>
                  <td class="td-mono td-m">@h.Term</td>
                  <td class="td-mono" style="color:@(bal > 0 ? "#f87171" : "#5fdd8e")">₱@bal.ToString("N2")</td>
                  <td class="td-mono">₱@paid.ToString("N2")</td>
                  <td><span class="badge @sc">@h.OverallStatus</span></td>
                  <td>
                    <button class="btn-pay" onclick="showPayModal('@h.Term', @bal)" title="How to pay" style="display:inline-flex;align-items:center;justify-content:center;padding:5px 9px">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M9.6 9.2a2.4 2.4 0 014.6.8c0 1.6-2.2 2.2-2.2 2.2M12 17h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                  </td>
                </tr>
              }
            }
            else
            {
              <tr class="empty-row"><td colspan="7">No fee records found.</td></tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══ PAYMENT HISTORY PAGE ══ -->
  <div class="page" id="page-history">
    <div class="page-hdr">
      <div>
        <div class="page-title">Payment History</div>
        @{ var txRecordCount = Model.PaymentHistory?.SelectMany(ph => ph.Payments).Count(p => p.Status != "Total") ?? 0; }
        <div class="page-sub">@txRecordCount payment record@(txRecordCount == 1 ? "" : "s")</div>
      </div>
    </div>
    <div class="content-card">
      <div class="cc-hdr">
        <div class="cc-title">All Transactions</div>
        <span class="badge bg">@txRecordCount record@(txRecordCount == 1 ? "" : "s")</span>
      </div>
      <div class="tbl-wrap tbl-scroll">
        <table>
          <thead>
            <tr><th>#</th><th>Semester</th><th>School Year</th><th>Paid Amount</th><th>Status</th><th>Received By</th><th>Date of Payment</th><th>Receipt</th></tr>
          </thead>
          <tbody>
            @{
              var sourceHistory = Model.PaymentHistory ?? new List<MyMvcApp.Models.StudentPaymentHistoryViewModel>();
              var transactionRows = sourceHistory
                    .SelectMany((h, historyIndex) => h.Payments
                      .Where(p => p.Status != "Total")
                      .Select((p, paymentIndex) => new { History = h, Payment = p, HistoryIndex = historyIndex, PaymentIndex = paymentIndex }))
                    .OrderByDescending(x => x.Payment.PaymentDate ?? DateTime.MinValue)
                    .ThenByDescending(x => x.Payment.PaymentId)
                    .ToList();
            }
            @if (transactionRows.Any())
            {
              int idx = 1;
              @foreach (var item in transactionRows.Select((row, i) => new { Row = row, Index = i }))
              {
                var h       = item.Row.History;
                var payment = item.Row.Payment;
                var required = h.Payments.Where(p => p.Status == "Total").Sum(p => p.Amount);
                var total   = payment.Amount;
                var paid    = h.Payments.Where(p => p.Status != "Total").Sum(p => p.Amount);
                var balance = required - paid;
                string sc;
                switch (payment.Status.ToLower())
                {
                  case "paid":    sc = "bg"; break;
                  case "partial": sc = "by"; break;
                  case "pending": sc = "by"; break;
                  case "overdue": sc = "br"; break;
                  default:        sc = "by"; break;
                }
                <tr>
                  <td class="td-mono td-m">@(idx++)</td>
                  <td class="td-m"><strong>@SemShort(!string.IsNullOrWhiteSpace(payment.Semester) ? payment.Semester : h.Semester)</strong></td>
                  <td class="td-mono td-m">@h.Term</td>
                  <td>₱@total.ToString("N2")</td>
                  <td><span class="badge @sc">@payment.Status</span></td>
                  <td class="td-m">@(!string.IsNullOrWhiteSpace(payment.TreasurerName) ? payment.TreasurerName : "—")</td>
                  <td class="td-mono td-m">
                    @{
                      var paymentDate = payment.PaymentDate;
                      @((paymentDate.HasValue ? paymentDate.Value.ToString("MMM dd, yyyy") : "—"))
                    }
                  </td>
                  <td>
                    <button
                      title="View receipt"
                      style="display:inline-flex;align-items:center;justify-content:center;background:transparent;border:1px solid rgba(255,255,255,.12);color:var(--text-m);padding:5px 8px;border-radius:6px;cursor:pointer;font-family:inherit;transition:all .15s"
                      onmouseover="this.style.borderColor='#fbbf24';this.style.color='#fbbf24'"
                      onmouseout="this.style.borderColor='rgba(255,255,255,.12)';this.style.color='var(--text-m)'"
                      onclick="printReceipt(@(item.Index))">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="1.8"/><polyline points="14 2 14 8 20 8" stroke="currentColor" stroke-width="1.8"/><line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="1.8"/><line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="1.8"/><polyline points="10 9 9 9 8 9" stroke="currentColor" stroke-width="1.8"/></svg>
                    </button>
                  </td>
                </tr>
              }
            }
            else
            {
              <tr class="empty-row"><td colspan="8">No payment history available.</td></tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══ PROFILE PAGE ══ -->
  <div class="page" id="page-profile">
    <div class="page-hdr">
      <div>
        <div class="page-title">My Profile</div>
        <div class="page-sub">Your account information</div>
      </div>
    </div>
    <div class="content-card">
      <!-- Hero -->
      <div class="profile-hero">
        <div class="profile-avatar-wrap">
          <div class="profile-avatar" id="profileAvatarCircle">
            @if (!string.IsNullOrEmpty(avatarPath))
            {
              <img src="@avatarPath" alt="@displayName" id="profileAvatarImg" />
            }
            else
            {
              <span id="profileAvatarInitials">@initials.ToUpper()</span>
            }
          </div>
          <button class="avatar-edit-badge" onclick="triggerAvatarUpload()"
            title="@(string.IsNullOrEmpty(avatarPath) ? "Add photo" : "Change photo")"
            aria-label="@(string.IsNullOrEmpty(avatarPath) ? "Add photo" : "Change photo")">
            <svg viewBox="0 0 24 24" fill="none" style="width:14px;height:14px;color:#fff"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="1.8"/></svg>
          </button>
          <input type="file" id="avatarFileInput" accept="image/jpeg,image/png,image/webp" style="display:none" onchange="handleAvatarChange(this)" />
        </div>
        <div class="profile-hero-name">@displayName</div>
        <div class="profile-hero-role">Student</div>
      </div>

      <!-- Info fields -->
      <div class="profile-fields">
        <div class="profile-field">
          <label>CTU ID</label>
          <span style="font-family:'DM Mono',monospace;font-size:12px">@(studentId.Length > 0 ? studentId : "—")</span>
        </div>
        <div class="profile-field">
          <label>Email</label>
          <span>@(email.Length > 0 ? email : "—")</span>
        </div>
        <div class="profile-field">
          <label>Course</label>
          <span>@(courseDisplay.Length > 0 ? courseDisplay.TrimStart(' ', '—').Trim() : "—")</span>
        </div>
        <div class="profile-field">
          <label>Course Name</label>
          <span>@(courseName.Length > 0 ? courseName : "—")</span>
        </div>
      </div>
    </div>
    <div class="notice">
      <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#fbbf24" stroke-width="1.8"/><path d="M12 8v4M12 16h.01" stroke="#fbbf24" stroke-width="1.8" stroke-linecap="round"/></svg>
      <p class="notice-text">To update your personal information, please contact your SSG office or registrar.</p>
    </div>
  </div>

</div><!-- /main -->
</div>

<!-- ══ PAY MODAL ══ -->
<div id="payModal" class="modal" onclick="handlePayModalClick(event)">
  <div class="modal-backdrop"></div>
  <div class="modal-box" style="max-width:400px">
    <div class="modal-hdr">
      <div>
        <div class="modal-title">Pay Fee</div>
        <div style="font-size:11.5px;color:var(--text-m);margin-top:2px" id="payModalSub"></div>
      </div>
      <button class="modal-close" onclick="closePayModal()">✕</button>
    </div>
    <div style="background:rgba(39,167,68,.08);border:1px solid rgba(39,167,68,.2);border-radius:10px;padding:16px 20px;margin-bottom:20px">
      <div style="font-size:10.5px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);margin-bottom:4px">Org Fee Balance</div>
      <div style="font-size:26px;font-weight:800;color:#fff;letter-spacing:-.03em" id="payModalAmount"></div>
    </div>
    <div style="font-size:12px;color:var(--text-m);line-height:1.6;margin-bottom:20px">
      To process your payment, please proceed to SSG Finance office with this information. Online payment integration is coming soon.
    </div>
    <div style="display:flex;gap:10px;justify-content:flex-end">
      <button onclick="closePayModal()" style="padding:9px 20px;background:transparent;border:1px solid rgba(255,255,255,.15);border-radius:8px;color:var(--text-m);font-size:13px;font-weight:600;cursor:pointer;font-family:inherit">Close</button>
    </div>
  </div>
</div>

<!-- ══ RECEIPT MODAL ══ -->
<div id="receiptModal" class="receipt-modal" onclick="handleReceiptBackdropClick(event)">
  <div class="receipt-modal-backdrop"></div>
  <div class="receipt-modal-inner">
    <!-- Controls bar -->
    <div class="receipt-controls">
      <span class="receipt-ctrl-title" id="receiptCtrlTitle">Official Receipt</span>
      <button class="btn-pdf" onclick="downloadReceiptPDF()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Save PDF
      </button>
      <button class="btn-receipt-close" onclick="closeReceipt()">✕</button>
    </div>

    <!-- Paper receipt -->
    <div class="receipt-paper" id="receiptPaper" style="padding-top:10px">

      <!-- Header -->
      <div class="rp-header">
        <div class="rp-org">SUPREME STUDENT GOVERNMENT</div>
        <div class="rp-campus">Cebu Technological University - Ginatilan Campus</div>
        <hr class="rp-divider">
        <div class="rp-type">Organization Fee</div>
        <div class="rp-copy">(Owner's Copy)</div>
      </div>

      <!-- Receipt No / Date -->
      <div class="rp-meta">
        <div><span class="rp-meta-label">Receipt No. </span><span class="rp-meta-value" id="rp-receipt-no" style="color:#c00">—</span></div>
        <div><span class="rp-meta-label">Date </span><span class="rp-meta-value date-val" id="rp-date">—</span></div>
      </div>

      <div class="rp-section-title">Acknowledgement Receipt</div>

      <div class="rp-field"><span class="rp-field-label">Name:</span><span class="rp-field-value handwritten" id="rp-name">—</span></div>
      <div class="rp-field"><span class="rp-field-label">ID Number:</span><span class="rp-field-value handwritten" id="rp-id">—</span></div>
      <div class="rp-field"><span class="rp-field-label">Course/Year/Section:</span><span class="rp-field-value handwritten" id="rp-course">—</span></div>
      <div class="rp-field"><span class="rp-field-label">S.Y.-Semester:</span><span class="rp-field-value" id="rp-term">—</span></div>
      <div class="rp-field"><span class="rp-field-label">Amount Paid:</span><span class="rp-field-value handwritten" id="rp-amount">—</span></div>
      <div class="rp-field"><span class="rp-field-label">Amount in words:</span><span class="rp-field-value handwritten" id="rp-amount-words">—</span></div>
      <div class="rp-field"><span class="rp-field-label">Status:</span><span class="rp-field-value"><span class="rp-status-badge" id="rp-status">—</span></span></div>

      <!-- Signature -->
      <div class="rp-signature-section">
        <div class="rp-sig-block">
          <div class="rp-sig-label">Received by:</div>

          <div style="position:relative;width:220px;height:48px">

            <!-- Name sits just above the line -->
            <div id="rp-received-by"
                 style="font-size:12px;font-weight:700;color:#111;text-align:center;
                        position:absolute;bottom:8px;left:0;right:0;z-index:1">
              &nbsp;
            </div>

            <!-- Line at the bottom -->
            <div style="border-top:1px solid #555;width:100%;position:absolute;bottom:0;left:0;z-index:1"></div>

            <!-- Signature overlaid on top of the name, filtered to appear red -->
            <img id="rp-sig-image" src="" alt="Treasurer signature"
                 style="display:none;
                        position:absolute;
                        bottom:-14px;
                        left:50%;
                        transform:translateX(-50%);
                        max-height:52px;
                        max-width:180px;
                        object-fit:contain;
                        z-index:2;
                        filter:invert(12%) sepia(100%) saturate(5000%) hue-rotate(345deg) brightness(80%) contrast(119%)"/>

          </div>

          <div class="rp-sig-name-label" style="text-align:center">(Signature over Printed Name)</div>
        </div>
      </div>
    </div><!-- /receipt-paper -->
  </div>
</div>

<div id="toast"></div>


  <script>
    const paymentHistoryRaw = @Html.Raw(Json.Serialize(Model.PaymentHistory));
    const receiptsRaw = @Html.Raw(Json.Serialize(Model.Receipts));
    const paymentHistory = (paymentHistoryRaw || []).map(history => ({
      Term: history.Term ?? history.term ?? '',
      OverallStatus: history.OverallStatus ?? history.overallStatus ?? '',
      Payments: (history.Payments ?? history.payments ?? []).map(payment => ({
        PaymentId: payment.PaymentId ?? payment.paymentId ?? 0,
        Semester: payment.Semester ?? payment.semester ?? '',
        Course: payment.Course ?? payment.course ?? '',
        Amount: Number(payment.Amount ?? payment.amount ?? 0),
        Status: payment.Status ?? payment.status ?? '',
        PaymentDate: payment.PaymentDate ?? payment.paymentDate ?? null,
        TreasurerName: payment.TreasurerName ?? payment.treasurerName ?? '',
        ReceiptNumber: payment.ReceiptNumber ?? payment.receiptNumber ?? '',
        ReceiptIssueDate: payment.ReceiptIssueDate ?? payment.receiptIssueDate ?? null,
        ReceiptIssuedBy: payment.ReceiptIssuedBy ?? payment.receiptIssuedBy ?? '',
        ReceiptIssuedByAccountId: payment.ReceiptIssuedByAccountId ?? payment.receiptIssuedByAccountId ?? 0
      }))
    }));
    const receipts = (receiptsRaw || []).map(receipt => ({
      ReceiptId: receipt.ReceiptId ?? receipt.receiptId ?? 0,
      ReceiptNumber: receipt.ReceiptNumber ?? receipt.receiptNumber ?? '',
      PaymentId: receipt.PaymentId ?? receipt.paymentId ?? 0,
      IssueDate: receipt.IssueDate ?? receipt.issueDate ?? null,
      IssuedByAccountId: receipt.IssuedByAccountId ?? receipt.issuedByAccountId ?? 0,
      IssuedByName: receipt.IssuedByName ?? receipt.issuedByName ?? '',
      Amount: Number(receipt.Amount ?? receipt.amount ?? 0),
      Status: receipt.Status ?? receipt.status ?? ''
    }));
    const transactionRows = (paymentHistory || [])
          .flatMap((history, historyIndex) => (history.Payments || [])
            .filter(payment => payment.Status !== 'Total')
            .map((payment, paymentIndex) => ({ History: history, Payment: payment, HistoryIndex: historyIndex, PaymentIndex: paymentIndex })))
          .sort((a, b) => {
            const bDate = b.Payment.PaymentDate ? new Date(b.Payment.PaymentDate).getTime() : 0;
            const aDate = a.Payment.PaymentDate ? new Date(a.Payment.PaymentDate).getTime() : 0;
            return (bDate - aDate) || ((b.Payment.PaymentId || 0) - (a.Payment.PaymentId || 0));
          });
    const studentName    = '@(firstName + " " + lastName)'.trim().toUpperCase();
    const studentIdVal   = '@studentId';
    const studentCourse  = '@courseCode';
    const studentYear    = '@yearLevel';
    const studentSection = '@(section)';

    // For display: a year level of 5 means the 4-year program is completed.
    // Show "4 Completed" (with no section) instead of "5" + section.
    const studentYearSectionDisplay = (studentYear === '5')
        ? '4 Completed'
        : (studentYear + studentSection);

    /* ── HELPERS ── */
    function amountToWords(amount) {
      if (amount === 0) return 'Zero Pesos Only';
      const ones = ['','One','Two','Three','Four','Five','Six','Seven','Eight','Nine',
                    'Ten','Eleven','Twelve','Thirteen','Fourteen','Fifteen','Sixteen',
                    'Seventeen','Eighteen','Nineteen'];
      const tens = ['','','Twenty','Thirty','Forty','Fifty','Sixty','Seventy','Eighty','Ninety'];
      function say(n) {
        if (n < 20) return ones[n];
        if (n < 100) return tens[Math.floor(n/10)] + (n % 10 ? ' ' + ones[n%10] : '');
        return ones[Math.floor(n/100)] + ' Hundred' + (n % 100 ? ' ' + say(n%100) : '');
      }
      const pesos = Math.floor(amount);
      const cents = Math.round((amount - pesos) * 100);
      let result = say(pesos) + ' Peso' + (pesos !== 1 ? 's' : '');
      if (cents > 0) result += ' and ' + say(cents) + ' Centavo' + (cents !== 1 ? 's' : '');
      return result + ' Only';
    }

    function generateReceiptNo(term, idx) {
      // Format: SY-SEMESTER-NNNN based on term string
      const parts = term.replace(/[–—]/g, '-').split(/[-\s]+/);
      const yr = parts[0] ? parts[0].slice(-2) : '00';
      const sem = term.toLowerCase().includes('second') ? '02' : '01';
      const num = String(idx + 1).padStart(4, '0');
      return yr + '-' + sem + '-' + num;
    }

    function formatDate(dateStr) {
      if (!dateStr) return new Date().toLocaleDateString('en-PH');
      return new Date(dateStr).toLocaleDateString('en-PH');
    }

    /* ── RECEIPT MODAL ── */
    function openReceipt(idx) {
      console.log('Opening receipt for index:', idx);
      const filteredItem = transactionRows[idx];
      if (!filteredItem) {
        console.log('No item found at index:', idx);
        return;
      }
      
      const history = filteredItem.History;
      const actualPayment = filteredItem.Payment;
      const originalIdx = filteredItem.HistoryIndex;
      console.log('Found payment data:', history);

      // Find the corresponding receipt from receipts array
      const receipt = receipts.find(r => Number(r.PaymentId) === Number(actualPayment.PaymentId))
        || receipts.find(r => actualPayment.ReceiptNumber && r.ReceiptNumber === actualPayment.ReceiptNumber);
      
      console.log('Found receipt:', receipt);
      
      // Find the actual payment record
      console.log('Found paid payment:', actualPayment);
      
      // Use receipt data if available, otherwise fall back to payment data
      const term = history.Term || '';
      const paid = Number(actualPayment ? actualPayment.Amount : 0);
      const status = actualPayment.Status || (receipt ? receipt.Status : '') || history.OverallStatus || 'Partial';
      const paymentDate = receipt ? receipt.IssueDate : (actualPayment ? actualPayment.PaymentDate : null);
      const treasurerName = receipt ? receipt.IssuedByName : (actualPayment ? (actualPayment.TreasurerName || '—') : '—');
      const receiptNumber = receipt ? receipt.ReceiptNumber : (actualPayment ? actualPayment.ReceiptNumber : '');
      const receiptIssueDate = receipt ? receipt.IssueDate : (actualPayment ? actualPayment.ReceiptIssueDate : null);
      const receiptIssuedBy = receipt ? receipt.IssuedByName : (actualPayment ? (actualPayment.ReceiptIssuedBy || treasurerName) : treasurerName);
      const issuedByAccountId = receipt ? receipt.IssuedByAccountId : (actualPayment ? actualPayment.ReceiptIssuedByAccountId : 0);
      
      const receivedByName = receiptIssuedBy || (actualPayment ? (actualPayment.ReceiptIssuedBy || actualPayment.TreasurerName) : '') || '\u2014';
      console.log('Receipt data - Amount:', paid, 'Status:', status, 'Receipt #:', receiptNumber, 'Issue Date:', receiptIssueDate, 'Issued By:', receivedByName);

      document.getElementById('receiptCtrlTitle').textContent  = 'Receipt — ' + term;
      
      // Use actual receipt number from database
      const receiptNo = receiptNumber || '—';
      document.getElementById('rp-receipt-no').textContent     = receiptNo;
      
      // Use receipt issue date if available, otherwise payment date
      const dateToUse = receiptIssueDate ? new Date(receiptIssueDate) : (paymentDate ? new Date(paymentDate) : new Date());
      const formattedDate = dateToUse.toLocaleDateString('en-PH', { month: '2-digit', day: '2-digit', year: '2-digit' });
      document.getElementById('rp-date').textContent           = formattedDate;
      
      console.log('Final receipt data - Receipt #:', receiptNo, 'Date:', formattedDate, 'Issued By:', receivedByName);
      
      document.getElementById('rp-name').textContent           = studentName || '—';
      document.getElementById('rp-id').textContent             = studentIdVal || '—';
      // Use the year level/section captured at the time of this payment so the receipt
      // never changes as the student advances. Fall back to current session values only
      // for old receipts that have no snapshot. Year level 5 means "4 Completed".
      let receiptYearSection;
      if (receipt && receipt.YearLevelAtPayment !== null && receipt.YearLevelAtPayment !== undefined) {
        const yl = String(receipt.YearLevelAtPayment);
        const sec = receipt.SectionAtPayment || '';
        receiptYearSection = (yl === '5') ? '4 Completed' : (yl + sec);
      } else {
        receiptYearSection = studentYearSectionDisplay;
      }
      document.getElementById('rp-course').textContent         = (studentCourse + ' ' + receiptYearSection).trim() || '—';
      const termEl = document.getElementById('rp-term');
      if (termEl) termEl.textContent = term || '—';
      document.getElementById('rp-amount').textContent         = '₱ ' + paid.toFixed(2);
      document.getElementById('rp-amount-words').textContent   = amountToWords(paid);
      document.getElementById('rp-received-by').textContent   = receivedByName;

      const sigImg = document.getElementById('rp-sig-image');
      if (sigImg) {
        sigImg.removeAttribute('src');
        sigImg.style.display = 'none';

        if (issuedByAccountId) {
          fetch('/Home/GetSignatureByAccountId?accountId=' + encodeURIComponent(issuedByAccountId))
            .then(r => r.json())
            .then(data => {
              if (data.success && data.signatureData) {
                sigImg.src = data.signatureData;
                sigImg.style.display = 'block';
              }
            })
            .catch(() => {
              sigImg.style.display = 'none';
            });
        }
      }

      const statusEl = document.getElementById('rp-status');
      statusEl.textContent = status;
      statusEl.className   = 'rp-status-badge ' + status.toLowerCase();

      document.getElementById('receiptModal').classList.add('open');
    }

    function closeReceipt() {
      document.getElementById('receiptModal').classList.remove('open');
    }

    function printReceipt(idx) {
      openReceipt(idx);
      // Immediately hide the modal on screen — print CSS will still reveal it during print
      const modal = document.getElementById('receiptModal');
      if (modal) modal.classList.remove('open');

      setTimeout(() => {
        const originalTitle = document.title;
        const studentName = (document.getElementById('rp-name')?.textContent || '').trim().replace(/\s+/g, '_');
        const receiptNo   = (document.getElementById('rp-receipt-no')?.textContent || 'receipt').trim();
        document.title = studentName && receiptNo ? `${studentName}_${receiptNo}` : receiptNo || ' ';
        window.print();
        document.title = originalTitle;
      }, 400);
    }

    
    function handleReceiptBackdropClick(e) {
      if (e.target === document.getElementById('receiptModal') || e.target.classList.contains('receipt-modal-backdrop')) {
        closeReceipt();
      }
    }

    async function downloadReceiptPDF() {
      const receiptEl = document.getElementById('receiptPaper');
      const receiptNo = (document.getElementById('rp-receipt-no')?.textContent || 'receipt')
        .replace(/[^\w-]+/g, '-')
        .replace(/^-+|-+$/g, '');

      // Hide watermark temporarily for a clean PDF
      const watermark = receiptEl.querySelector('.rp-watermark');
      const originalDisplay = watermark ? watermark.style.display : '';
      if (watermark) watermark.style.display = 'none';

      showToast('Generating PDF...', 'ok');

      try {
        const canvas = await html2canvas(receiptEl, {
          scale: 2,
          useCORS: true,
          backgroundColor: '#f9f8f5',
          logging: false
        });

        const imgData = canvas.toDataURL('image/png');

        const { jsPDF } = window.jspdf;
        // Long bond paper: 216mm x 330mm
        const pdf = new jsPDF({
          orientation: 'portrait',
          unit: 'mm',
          format: [216, 330]
        });

        const pageWidth  = pdf.internal.pageSize.getWidth();
        const pageHeight = pdf.internal.pageSize.getHeight();

        const margin    = 8;
        const imgWidth  = pageWidth - margin * 2;
        const imgHeight = (canvas.height * imgWidth) / canvas.width;

        pdf.addImage(imgData, 'PNG', margin, margin, imgWidth, Math.min(imgHeight, pageHeight - margin * 2));
        pdf.save(`SSG-Receipt-${receiptNo}.pdf`);

        showToast('PDF downloaded successfully.', 'ok');
      } catch (err) {
        console.error('PDF generation failed:', err);
        showToast('Failed to generate PDF. Please try again.', 'fail');
      } finally {
        if (watermark) watermark.style.display = originalDisplay;
      }
    }

    /* ── PAGES ── */
    function showPage(name, navEl) {
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
      const page = document.getElementById('page-' + name);
      if (page) page.classList.add('active');
      if (navEl) navEl.classList.add('active');
      closeMobileMenu();
    }

    /* ── PAY MODAL ── */
    function toggleMobileMenu() {
      const sidebar = document.querySelector('.sidebar');
      const overlay = document.querySelector('.mobile-overlay');
      const button = document.querySelector('.mobile-menu-btn');
      const isOpen = sidebar?.classList.toggle('mobile-open') ?? false;
      overlay?.classList.toggle('active', isOpen);
      button?.setAttribute('aria-expanded', String(isOpen));
      if (button) button.style.display = isOpen ? 'none' : 'flex';
    }

    function closeMobileMenu() {
      document.querySelector('.sidebar')?.classList.remove('mobile-open');
      document.querySelector('.mobile-overlay')?.classList.remove('active');
      const button = document.querySelector('.mobile-menu-btn');
      if (button) { button.setAttribute('aria-expanded', 'false'); button.style.display = ''; }
    }

    function showPayModal(term, amount) {
      document.getElementById('payModalSub').textContent    = term;
      document.getElementById('payModalAmount').textContent = '₱' + amount.toFixed(2);
      document.getElementById('payModal').classList.add('open');
    }
    function closePayModal() { document.getElementById('payModal').classList.remove('open'); }
    function handlePayModalClick(e) {
      if (e.target === document.getElementById('payModal') || e.target.classList.contains('modal-backdrop')) closePayModal();
    }

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') { closeReceipt(); closePayModal(); closeMobileMenu(); }
    });

    /* ── TOAST ── */
    function showToast(msg, type) {
      const t = document.getElementById('toast');
      t.textContent = msg; t.className = 'show ' + type;
      clearTimeout(t._t); t._t = setTimeout(() => t.className = '', 3000);
    }

    /* ── AVATAR UPLOAD ── */
    function triggerAvatarUpload() {
      const proceed = confirm(
        'Photo Guidelines\n\n' +
        'Please upload a formal photo that meets the following requirements:\n' +
        '• Format: 1×1 (square)\n' +
        '• Attire: your official school uniform or a plain white shirt\n' +
        '• Background: a plain white background\n\n' +
        'Click OK to choose your photo.'
      );
      if (!proceed) return;
      document.getElementById('avatarFileInput').click();
    }

    async function handleAvatarChange(input) {
      const file = input.files[0];
      if (!file) return;

      const allowed = ['image/jpeg', 'image/png', 'image/webp'];
      if (!allowed.includes(file.type)) {
        showToast('Only JPG, PNG, or WEBP images are allowed.', 'fail');
        input.value = '';
        return;
      }
      if (file.size > 2 * 1024 * 1024) {
        showToast('Image must be 2 MB or smaller.', 'fail');
        input.value = '';
        return;
      }

      const accountId = '@accountId';
      const fd = new FormData();
      fd.append('accountId', accountId);
      fd.append('avatar', file);

      showToast('Uploading photo…', 'ok');
      try {
        const res  = await fetch('/Home/UploadAvatar', { method: 'POST', body: fd });
        const data = await res.json();
        if (!data.success) { showToast(data.message || 'Upload failed.', 'fail'); return; }

        const newSrc = data.avatarPath;

        // Update profile page avatar
        const circle = document.getElementById('profileAvatarCircle');
        const initEl = document.getElementById('profileAvatarInitials');
        let imgEl = document.getElementById('profileAvatarImg');
        if (initEl) initEl.remove();
        if (!imgEl) {
          imgEl = document.createElement('img');
          imgEl.id = 'profileAvatarImg';
          Object.assign(imgEl.style, { width:'100%', height:'100%', objectFit:'cover', display:'block' });
          circle.appendChild(imgEl);
        }
        imgEl.src = newSrc;

        // Update sidebar avatar
        const sideAv = document.querySelector('.user-av');
        if (sideAv) {
          sideAv.innerHTML = `<img src="${newSrc}" style="width:100%;height:100%;object-fit:cover;border-radius:8px" />`;
        }

        showToast('Photo updated successfully.', 'ok');
      } catch {
        showToast('Upload failed. Please try again.', 'fail');
      }
      input.value = '';
    }

    // ================================================================
    // AUTO-REFRESH POLLING
    // Refreshes student payment data every 30 seconds
    // Students don't need fast refresh — 30s is fine
    // ================================================================
    const STUDENT_REFRESH_INTERVAL = 30000; // 30 seconds

    async function refreshStudentData() {
      // Don't refresh if a modal is open — would be jarring
      const payModalOpen     = document.getElementById('payModal')?.classList.contains('open');
      const receiptModalOpen = document.getElementById('receiptModal')?.classList.contains('open');
      if (payModalOpen || receiptModalOpen) return;

      try {
        const res  = await fetch('/Home/GetStudentDashboardData');
        const data = await res.json();
        if (!data.success) return;

        // Update stat cards on Overview page
        const balanceEls = document.querySelectorAll('#page-overview .stat-val.amount');
        const balanceEl  = balanceEls?.[0];
        const paidEl     = balanceEls?.[1];
        const pendingEl  = document.querySelector('#page-overview .stat-val:not(.amount)');

        if (balanceEl) balanceEl.textContent = '₱' + Number(data.outstandingBalance).toFixed(2);
        if (paidEl)    paidEl.textContent    = '₱' + Number(data.totalPaid).toFixed(2);
        if (pendingEl) pendingEl.textContent = data.pendingCount;

        // Update pending badge on Current Fees tab
        const feesBadge = document.querySelector('#page-fees .badge.by');
        if (feesBadge) feesBadge.textContent = data.pendingCount + ' pending';

        // Update history record count
        const historyBadge = document.querySelector('#page-history .badge.bg');
        if (historyBadge) historyBadge.textContent = data.paymentCount + ' records';
      } catch { /* silent fail — don't disturb student */ }
    }

    // ── SERVER-SENT EVENTS ───────────────────────────────────────────
    (function() {
        function connect() {
            const sse = new EventSource('/Home/Events');
            sse.addEventListener('fees-changed',     () => refreshStudentData());
            sse.addEventListener('payments-changed',  () => refreshStudentData());
            sse.onerror = () => { sse.close(); setTimeout(connect, 5000); };
        }
        connect();
    })();
  </script>
</body>
</html>

