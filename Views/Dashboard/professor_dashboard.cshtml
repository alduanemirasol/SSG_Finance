@{
    ViewData["Title"] = "Professor Dashboard";
    Layout = null;
    var firstName     = Context.Session.GetString("FirstName") ?? "Professor";
    var lastName      = Context.Session.GetString("LastName") ?? "";
    var middleName    = Context.Session.GetString("MiddleName") ?? "";
    var schoolId      = Context.Session.GetString("SchoolId") ?? "";
    var email         = Context.Session.GetString("Email") ?? "";
    var accountId     = Context.Session.GetString("AccountId") ?? "";
    var initials      = (firstName.Length > 0 ? firstName[0].ToString() : "") + (lastName.Length > 0 ? lastName[0].ToString() : "");
    var avatarPath    = Context.Session.GetString("AvatarPath") ?? "";
    var middleInitial = middleName.Length > 0 ? middleName[0].ToString().ToUpper() + "." : "";
    var displayName   = (firstName + (middleInitial.Length > 0 ? " " + middleInitial : "") + (lastName.Length > 0 ? " " + lastName : "")).Trim();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="/js/csrf.js"></script>
    <title>SSG Finance - Professor</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <style>
        /* ── RESET & ROOT ── */
        *{box-sizing:border-box;margin:0;padding:0}
        :root{
          --bg:#071a0c;--sidebar:#081509;
          --green:#27a744;--green-d:#1a7a4a;
          --green-glow:rgba(39,167,68,.18);--green-glow2:rgba(39,167,68,.08);
          --glass:rgba(255,255,255,.045);
          --text:#e8f5ec;--text-m:rgba(232,245,236,.6);--text-d:rgba(232,245,236,.35);
          --card:#0f2918;--card-b:rgba(255,255,255,.07);
          --green-badge:rgba(39,167,68,.18);--green-badge-t:#5fdd8e;
          --yellow-badge:rgba(251,191,36,.14);--yellow-badge-t:#fbbf24;
          --red-badge:rgba(239,68,68,.14);--red-badge-t:#f87171;
          --blue-badge:rgba(59,130,246,.14);--blue-badge-t:#93c5fd;
        }
        body{font-family:'DM Sans',sans-serif;background:var(--bg);display:flex;min-height:100vh;color:var(--text);font-size:14px;overflow:hidden}

        /* ── SIDEBAR ── */
        .sidebar{width:218px;background:var(--sidebar);border-right:1px solid rgba(255,255,255,.05);display:flex;flex-direction:column;flex-shrink:0}
        .sb-brand{display:flex;align-items:center;gap:10px;padding:20px 16px 18px;border-bottom:1px solid rgba(255,255,255,.05)}
        .sb-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 14px rgba(39,167,68,.3)}
        .sb-logo svg{width:18px;height:18px}
        .sb-logo img{width:100%;height:100%;object-fit:cover;border-radius:10px}
        .sb-brand-name{font-size:13.5px;font-weight:700;color:#fff;letter-spacing:-.01em}
        .sb-brand-sub{font-size:10px;color:rgba(39,167,68,.85);letter-spacing:.1em;text-transform:uppercase;margin-top:1px}
        .sb-label{font-size:9.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--text-d);padding:16px 16px 5px}
        .nav-item{display:flex;align-items:center;gap:9px;padding:8px 12px;margin:1px 8px;border-radius:8px;font-size:13px;font-weight:500;color:var(--text-m);cursor:pointer;transition:all .15s;border:1px solid transparent;user-select:none}
        .nav-item:hover{background:var(--glass);color:var(--text)}
        .nav-item.active{background:var(--green-glow);color:#5fdd8e;border-color:rgba(74,222,128,.12)}
        .nav-item svg{width:15px;height:15px;flex-shrink:0;opacity:.85}
        .sb-spacer{flex:1}
        .sb-user{padding:10px 8px;border-top:1px solid rgba(255,255,255,.05)}
        .user-card{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;background:var(--glass)}
        .user-av{width:36px;min-width:36px;height:36px;border-radius:8px;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden}
        .user-av img{width:100%;height:100%;object-fit:cover;display:block;border-radius:8px;pointer-events:none}
        .user-name{font-size:12px;font-weight:600;color:#fff}
        .user-role{font-size:10.5px;color:var(--text-d)}
        .signout{display:flex;align-items:center;gap:7px;padding:7px 10px;margin-top:3px;border-radius:8px;font-size:12.5px;font-weight:500;color:var(--text-d);cursor:pointer;transition:all .15s}
        .signout:hover{background:rgba(239,68,68,.08);color:#f87171}
        .signout svg{width:14px;height:14px}

        /* ── MAIN ── */
        .main{flex:1;min-width:0;padding:32px 32px 60px;background:var(--bg);overflow-y:auto;height:100vh;position:relative}
        .main::before{content:'';position:absolute;top:-80px;right:-80px;width:380px;height:380px;background:radial-gradient(circle,rgba(39,167,68,.06) 0%,transparent 70%);pointer-events:none;border-radius:50%}
        .top-accent{height:2px;background:linear-gradient(90deg,transparent,var(--green),transparent);position:fixed;top:0;left:0;right:0;z-index:10}

        /* ── PAGES ── */
        .page{display:none;max-width:1200px;margin-left:auto;margin-right:auto}.page.active{display:block}
        .page-hdr{display:flex;align-items:center;justify-content:center;text-align:center;margin-bottom:22px;position:relative}
        .page-title{font-size:22px;font-weight:800;color:#fff;letter-spacing:-.03em}
        .page-sub{font-size:12px;color:var(--text-m);margin-top:2px}

        /* ── STAT CARDS ── */
        .stat-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px}
        .stat-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;padding:18px 20px;position:relative;overflow:hidden}
        .stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px}
        .stat-card.green::before{background:linear-gradient(90deg,transparent,rgba(39,167,68,.35),transparent)}
        .stat-card.red::before{background:linear-gradient(90deg,transparent,rgba(239,68,68,.35),transparent)}
        .stat-card.blue::before{background:linear-gradient(90deg,transparent,rgba(59,130,246,.35),transparent)}
        .stat-card.yellow::before{background:linear-gradient(90deg,transparent,rgba(251,191,36,.35),transparent)}
        .stat-lbl{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:8px}
        .stat-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
        .stat-val{font-size:28px;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em}
        .stat-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center}
        .stat-icon svg{width:15px;height:15px}
        .stat-icon.g{background:rgba(39,167,68,.15)}
        .stat-icon.r{background:rgba(239,68,68,.12)}
        .stat-icon.b{background:rgba(59,130,246,.12)}
        .stat-icon.y{background:rgba(251,191,36,.12)}
        .stat-sub{font-size:10.5px;color:var(--text-d);padding-top:6px;border-top:1px solid rgba(255,255,255,.05)}

        /* ── CONTENT CARDS ── */
        .content-card{background:var(--card);border:1px solid var(--card-b);border-radius:14px;margin-bottom:14px;position:relative;overflow:visible}
        .content-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;border-radius:14px 14px 0 0;background:linear-gradient(90deg,transparent,rgba(39,167,68,.2),transparent)}
        .cc-hdr{display:flex;align-items:center;justify-content:space-between;padding:14px 20px 12px;border-bottom:1px solid rgba(255,255,255,.05)}
        .cc-title{font-size:13.5px;font-weight:700;color:#fff}

        /* ── TABLES ── */
        .toolbar{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;border-bottom:1px solid rgba(255,255,255,.05);gap:10px;flex-wrap:wrap}
        .search-box{display:flex;align-items:center;gap:7px;border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:7px 12px;background:rgba(255,255,255,.04);min-width:210px;transition:all .15s}
        .search-box:focus-within{border-color:var(--green);background:rgba(39,167,68,.06)}
        .search-box input{border:none;outline:none;font-family:inherit;font-size:12.5px;color:var(--text);width:100%;background:transparent}
        .search-box input::placeholder{color:var(--text-d)}
        .search-box svg{width:14px;height:14px;color:var(--text-d);flex-shrink:0}
        .filter-select{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:7px 28px 7px 11px;font-size:12px;color:var(--text-m);font-family:inherit;cursor:pointer;outline:none;appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><path fill=%22%23e8f5ec%22 d=%22M7 10l5 5 5-5z%22/></svg>');background-repeat:no-repeat;background-position:right 6px center;background-size:18px}
        .filter-select option{background:#0a1f10}
        table{width:100%;border-collapse:collapse;font-size:12.5px}
        thead th{padding:10px 16px;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);border-bottom:1px solid rgba(255,255,255,.05);text-align:left;white-space:nowrap;background:rgba(255,255,255,.02)}
        /* Scrollable table viewport: vertical + horizontal scrollbars, sticky header */
        .tbl-scroll{max-height:min(540px,62vh);overflow:auto;scrollbar-width:thin;scrollbar-color:rgba(39,167,68,.45) rgba(255,255,255,.04)}
        .tbl-scroll thead th{position:sticky;top:0;z-index:4;background:#142d1d}
        .tbl-scroll::-webkit-scrollbar{width:10px;height:10px}
        .tbl-scroll::-webkit-scrollbar-track{background:rgba(255,255,255,.03)}
        .tbl-scroll::-webkit-scrollbar-thumb{background:rgba(39,167,68,.4);border-radius:6px;border:2px solid transparent;background-clip:padding-box}
        .tbl-scroll::-webkit-scrollbar-thumb:hover{background:rgba(39,167,68,.6);background-clip:padding-box}
        .tbl-scroll::-webkit-scrollbar-corner{background:transparent}
        tbody tr{border-bottom:1px solid rgba(255,255,255,.04);transition:background .1s}
        tbody tr:last-child{border-bottom:none}
        tbody tr:hover{background:rgba(39,167,68,.04)}
        td{padding:11px 16px;color:var(--text);vertical-align:middle}
        .td-m{color:var(--text-m)}.td-mono{font-family:'DM Mono',monospace;font-size:11.5px}
        .empty-row td{text-align:center;padding:40px;color:var(--text-d);font-size:12.5px}

        /* ── BADGES ── */
        .badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:10.5px;font-weight:600}
        .bg{background:var(--green-badge);color:var(--green-badge-t)}
        .by{background:var(--yellow-badge);color:var(--yellow-badge-t)}
        .br{background:var(--red-badge);color:var(--red-badge-t)}
        .bb{background:var(--blue-badge);color:var(--blue-badge-t)}

        /* ── STATUS PILLS ── */
        .status-pill{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:20px;font-size:10.5px;font-weight:600}
        .status-pill .dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
        .status-paid{background:var(--green-badge);color:var(--green-badge-t)}.status-paid .dot{background:#5fdd8e}
        .status-pending{background:var(--yellow-badge);color:var(--yellow-badge-t)}.status-pending .dot{background:#fbbf24}
        .status-overdue{background:var(--red-badge);color:var(--red-badge-t)}.status-overdue .dot{background:#f87171}
        .status-partial{background:rgba(139,92,246,.14);color:#c4b5fd}.status-partial .dot{background:#c4b5fd}

        /* ── BUTTONS ── */
        .btn-primary{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:12.5px;font-weight:600;cursor:pointer;border:none;font-family:inherit;transition:all .15s;background:var(--green);color:#fff}
        .btn-primary:hover{background:#22963d;transform:translateY(-1px)}
        .btn-outline{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;background:transparent;border:1px solid rgba(255,255,255,.12);color:var(--text-m)}
        .btn-outline:hover{border-color:var(--green);color:#5fdd8e;background:var(--green-glow2)}

        /* ── CHARTS ── */
        .charts-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:14px;margin-bottom:14px}
        .chart-wrap{padding:16px;height:210px;position:relative}
        .donut-wrap{padding:16px;display:flex;flex-direction:column;align-items:center;gap:10px}
        .donut-canvas{width:150px;height:150px}
        .donut-legend{width:100%;display:flex;flex-direction:column;gap:5px}
        .dl-row{display:flex;align-items:center;justify-content:space-between;font-size:11.5px}
        .dl-dot{width:9px;height:9px;border-radius:2px;margin-right:7px;flex-shrink:0}
        .dl-lbl{display:flex;align-items:center;color:var(--text-m)}
        .dl-val{font-family:'DM Mono',monospace;font-weight:500;font-size:11.5px}

        /* ── NOTICE ── */
        .notice{display:flex;align-items:flex-start;gap:10px;padding:13px 16px;border-radius:10px;background:rgba(59,130,246,.06);border:1px solid rgba(59,130,246,.18);margin-bottom:16px}
        .notice svg{width:16px;height:16px;flex-shrink:0;margin-top:1px}
        .notice-text{font-size:12px;color:var(--text-m);line-height:1.6}

        /* ── PROFILE HERO ── */
        .profile-hero{display:flex;flex-direction:column;align-items:center;padding:32px 20px 24px;border-bottom:1px solid rgba(255,255,255,.05)}
        .profile-avatar-wrap{position:relative;width:88px;height:88px;margin-bottom:14px;flex-shrink:0}
        .profile-avatar{width:88px;height:88px;border-radius:50%;background:linear-gradient(135deg,#1a7a4a,#27a744);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:700;color:#fff;overflow:hidden;border:2px solid rgba(39,167,68,.3);box-shadow:0 0 18px rgba(39,167,68,.18)}
        .profile-avatar img{width:100%;height:100%;object-fit:cover;display:block}
        .avatar-edit-badge{position:absolute;bottom:0;right:0;width:28px;height:28px;border-radius:50%;background:#27a744;border:2px solid var(--card);display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;z-index:3;transition:background .15s,transform .15s;box-shadow:0 2px 6px rgba(0,0,0,.35)}
        .avatar-edit-badge:hover{background:#2fbf52;transform:scale(1.08)}
        .profile-hero-name{font-size:16px;font-weight:700;color:#fff;text-align:center;letter-spacing:-.01em;line-height:1.3}
        .profile-hero-role{font-size:11.5px;color:var(--text-d);margin-top:3px}
        .profile-fields{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:20px}
        .profile-field{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:12px 16px}
        .profile-field label{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text-d);display:block;margin-bottom:4px}
        .profile-field span{font-size:13px;font-weight:500;color:var(--text);word-break:break-word}
        .profile-field.full{grid-column:1/-1}

        /* ── PROGRESS BAR ── */
        .progress-wrap{margin-top:6px}
        .progress-bar{height:5px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden}
        .progress-fill{height:100%;border-radius:3px;transition:width .5s ease}
        .progress-label{display:flex;justify-content:space-between;font-size:10px;color:var(--text-d);margin-top:4px}

        /* ── TOAST ── */
        #toast{position:fixed;bottom:20px;right:20px;padding:10px 18px;border-radius:9px;font-size:12.5px;font-weight:500;background:#1f2937;color:#fff;opacity:0;transform:translateY(8px);transition:opacity .25s,transform .25s;z-index:999;pointer-events:none;box-shadow:0 8px 24px rgba(0,0,0,.4)}
        #toast.show{opacity:1;transform:translateY(0)}
        #toast.ok{background:#052e16;border:1px solid rgba(39,167,68,.3)}
        #toast.fail{background:#450a0a;border:1px solid rgba(239,68,68,.3)}

        /* ── DROPDOWN ── */
        .dropdown-wrap{position:relative;display:inline-block}
        .dot-btn{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;display:flex;align-items:center;justify-content:center}
        .dot-btn:hover{background:rgba(255,255,255,.1);color:var(--text)}
        .dropdown-menu{display:none;position:absolute;right:0;bottom:34px;top:auto;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:10px;min-width:160px;z-index:9999;box-shadow:0 8px 24px rgba(0,0,0,.4);overflow:hidden}
        .dropdown-menu.open{display:block}
        .dropdown-item{display:flex;align-items:center;gap:8px;padding:9px 14px;font-size:12.5px;color:var(--text-m);cursor:pointer;transition:background .1s}
        .dropdown-item:hover{background:rgba(39,167,68,.08);color:var(--text)}
        /* ── ORG FEE MODAL (added) ── */
        .modal-overlay{display:none;position:fixed;inset:0;z-index:500;align-items:center;justify-content:center}
        .modal-overlay.open{display:flex}
        .modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(4px)}
        .modal-box{position:relative;z-index:1;background:#0f2918;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:28px 30px;width:100%;max-width:500px;box-shadow:0 24px 60px rgba(0,0,0,.5);max-height:90vh;overflow-y:auto}
        .modal-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px}
        .modal-title{font-size:16px;font-weight:700;color:#fff}
        .modal-sub{font-size:11.5px;color:var(--text-m);margin-top:2px}
        .modal-close{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);color:var(--text-m);width:28px;height:28px;border-radius:7px;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .modal-footer{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,.06)}
        .btn-outline{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;background:transparent;border:1px solid rgba(255,255,255,.12);color:var(--text-m)}
        .btn-outline:hover{border-color:var(--green);color:#5fdd8e;background:var(--green-glow2)}
    </style>
</head>
<body>

<div class="top-accent"></div>

<!-- ── SIDEBAR ── -->
<aside class="sidebar">
    <div class="sb-brand">
        <div class="sb-logo">
            <img src="~/logo.png" alt="SSG Finance Logo" />
        </div>
        <div>
            <div class="sb-brand-name">SSG Finance</div>
            <div class="sb-brand-sub">Professor</div>
        </div>
    </div>

    <div class="sb-label">Menu</div>
    <div class="nav-item active" onclick="showPage('students',this)">
        <svg viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        Students
    </div>

    <div class="sb-spacer"></div>
    <div class="sb-user">
        <button class="user-card" onclick="showPage('profile',null)" style="width:100%;text-align:left;cursor:pointer;background:var(--glass);border:1px solid transparent;border-radius:9px;padding:8px 10px;transition:all .15s;font-family:inherit;color:inherit;display:flex;align-items:center;gap:9px" onmouseover="this.style.background='var(--green-glow)';this.style.borderColor='rgba(74,222,128,.12)'" onmouseout="this.style.background='var(--glass)';this.style.borderColor='transparent'">
            <div class="user-av">
              @if (!string.IsNullOrEmpty(avatarPath))
              {
                <img src="@avatarPath" alt="@initials.ToUpper()" />
              }
              else
              {
                @initials.ToUpper()
              }
            </div>
            <div>
                <div class="user-name">@firstName @lastName</div>
                <div class="user-role">Professor</div>
            </div>
        </button>
        <div class="signout" onclick="window.location.href='@Url.Action("Logout", "Home")'">
            <svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Sign Out
        </div>
    </div>
</aside>

<!-- ── MAIN ── -->
<div class="main">

    <!-- ══ STUDENTS ══ -->
    <div class="page active" id="page-students">
        <div class="page-hdr">
            <div>
                <div class="page-title">Students</div>
                <div class="page-sub" id="students-page-sub">All students in your class</div>
            </div>
        </div>
        <div class="content-card">
            <div class="toolbar">
                <div class="search-box">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="8" stroke-width="1.8"/><path d="M21 21l-4.35-4.35" stroke-width="1.8" stroke-linecap="round"/></svg>
                    <input type="text" id="students-search" placeholder="Search by name, ID, course…" oninput="filterStudentsPage(this.value)"/>
                </div>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                    <select class="filter-select" id="students-filter-status" onchange="applyStudentsPageFilters()">
                        <option value="">All Payment Status</option>
                        <option value="Paid">Paid</option>
                        <option value="Partial">Partial</option>
                        <option value="Unpaid">Unpaid</option>
                    </select>
                    <select class="filter-select" id="students-filter-course" onchange="applyStudentsPageFilters()">
                        <option value="">All Courses</option>
                    </select>
                    <select class="filter-select" id="students-filter-year" onchange="applyStudentsPageFilters()">
                        <option value="">All Year Levels</option>
                        <option value="1">1st Year</option>
                        <option value="2">2nd Year</option>
                        <option value="3">3rd Year</option>
                        <option value="4">4th Year</option>
                    </select>
                    <select class="filter-select" id="students-filter-sy" onchange="applyStudentsPageFilters()">
                        <option value="">All School Years</option>
                    </select>
                    <button class="btn-outline" onclick="resetStudentsPageFilters()" title="Reset filters to default" style="padding:7px 14px">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L3 8"/></svg>
                        Default
                    </button>
                </div>
            </div>
            <div class="tbl-scroll">
            <table>
                <thead><tr><th>#</th><th>CTU ID</th><th>Name</th><th>Course · Year &amp; Section</th><th>Org Fee Bal(1st Sem<span id="th-sem1-badge"></span></th><th>Org Fee Bal(2nd Sem)<span id="th-sem2-badge"></span></th><th>Ledger</th></tr></thead>
                <tbody id="students-page-tbody">
                    <tr class="empty-row"><td colspan="7">Loading students…</td></tr>
                </tbody>
            </table>
            </div>
        </div>
    </div>

    <!-- ══ PROFILE ══ -->
    <div class="page" id="page-profile">
        <div class="page-hdr">
            <div><div class="page-title">My Profile</div><div class="page-sub">Your account information</div></div>
        </div>
        <div class="content-card">
            <div class="profile-hero">
                <div class="profile-avatar-wrap">
                    <div class="profile-avatar" id="profileAvatarCircle">
                        @if (!string.IsNullOrEmpty(avatarPath))
                        {
                            <img src="@avatarPath" alt="@displayName" id="profileAvatarImg" />
                        }
                        else
                        {
                            <span id="profileAvatarInitials">@initials.ToUpper()</span>
                        }
                    </div>
                    <button class="avatar-edit-badge" onclick="triggerAvatarUpload()"
                        title="@(string.IsNullOrEmpty(avatarPath) ? "Add photo" : "Change photo")"
                        aria-label="@(string.IsNullOrEmpty(avatarPath) ? "Add photo" : "Change photo")">
                        <svg viewBox="0 0 24 24" fill="none" style="width:14px;height:14px;color:#fff"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="1.8"/></svg>
                    </button>
                    <input type="file" id="avatarFileInput" accept="image/jpeg,image/png,image/webp" style="display:none" onchange="handleAvatarChange(this)" />
                </div>
                <div class="profile-hero-name">@displayName</div>
                <div class="profile-hero-role">Professor</div>
            </div>
            <div class="profile-fields">
                <div class="profile-field">
                    <label>CTU ID</label>
                    <span style="font-family:'DM Mono',monospace;font-size:12px">@(schoolId.Length > 0 ? schoolId : "—")</span>
                </div>
                <div class="profile-field">
                    <label>Email</label>
                    <span>@(email.Length > 0 ? email : "—")</span>
                </div>
            </div>
        </div>
        <div class="notice">
            <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#93c5fd" stroke-width="1.8"/><path d="M12 8v4M12 16h.01" stroke="#93c5fd" stroke-width="1.8" stroke-linecap="round"/></svg>
            <p class="notice-text">To update your personal information, please contact the SSG administrator.</p>
        </div>
    </div>

</div><!-- /main -->

<div id="toast"></div>

<script>
// ── State ─────────────────────────────────────────────────────────
let allStudents = [];
let barChart, donutChart;

// ── Page Navigation ───────────────────────────────────────────────
function showPage(name, navEl) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    const page = document.getElementById('page-' + name);
    if (page) page.classList.add('active');
    if (navEl) navEl.classList.add('active');
    else if (name === 'students') {
        // Profile opens from the user card; keep the Students nav highlighted otherwise.
        const nav = document.querySelector('.nav-item');
        if (nav) nav.classList.add('active');
    }
}

// ── Helpers ───────────────────────────────────────────────────────
function p(n) { return '₱' + Number(n).toLocaleString('en-PH', { minimumFractionDigits: 2 }); }
function fd(d) {
    if (!d) return '—';
    return new Date(d.split('T')[0] + 'T00:00').toLocaleDateString('en-PH', { month: 'short', day: 'numeric', year: 'numeric' });
}
function showToast(msg, type) {
    const t = document.getElementById('toast');
    t.textContent = msg; t.className = 'show ' + type;
    clearTimeout(t._t); t._t = setTimeout(() => t.className = '', 3000);
}

function triggerAvatarUpload() {
    const proceed = confirm(
        'Photo Guidelines\n\n' +
        'Please upload a formal photo that meets the following requirements:\n' +
        '• Format: 1×1 (square)\n' +
        '• Attire: your official school uniform or a plain white shirt\n' +
        '• Background: a plain white background\n\n' +
        'Click OK to choose your photo.'
    );
    if (!proceed) return;
    document.getElementById('avatarFileInput').click();
}
async function handleAvatarChange(input) {
    const file = input.files[0];
    if (!file) return;
    const allowed = ['image/jpeg','image/png','image/webp'];
    if (!allowed.includes(file.type)) { showToast('Only JPG, PNG, or WEBP allowed.','fail'); input.value=''; return; }
    if (file.size > 2*1024*1024) { showToast('Image must be 2 MB or smaller.','fail'); input.value=''; return; }
    const fd = new FormData();
    fd.append('accountId', '@accountId');
    fd.append('avatar', file);
    showToast('Uploading photo…','ok');
    try {
        const res  = await fetch('/Home/UploadAvatar', { method:'POST', body:fd });
        const data = await res.json();
        if (!data.success) { showToast(data.message||'Upload failed.','fail'); return; }
        const newSrc = data.avatarPath;
        const circle = document.getElementById('profileAvatarCircle');
        const initEl = document.getElementById('profileAvatarInitials');
        let imgEl = document.getElementById('profileAvatarImg');
        if (initEl) initEl.remove();
        if (!imgEl) { imgEl = document.createElement('img'); imgEl.id='profileAvatarImg'; Object.assign(imgEl.style,{width:'100%',height:'100%',objectFit:'cover',display:'block'}); circle.appendChild(imgEl); }
        imgEl.src = newSrc;
        const sideAv = document.querySelector('.user-av');
        if (sideAv) sideAv.innerHTML = `<img src="${newSrc}" style="width:100%;height:100%;object-fit:cover;border-radius:8px">`;
        showToast('Photo updated.','ok');
    } catch { showToast('Upload failed. Try again.','fail'); }
    input.value = '';
}

function statusBadge(status) {
    if (!status) status = 'Unpaid';
    const sl = status.toLowerCase();
    if (sl === 'paid') return `<span class="status-pill status-paid"><span class="dot"></span>Paid</span>`;
    if (sl === 'partial') return `<span class="status-pill status-partial"><span class="dot"></span>Partial</span>`;
    if (sl === 'pending' || sl === 'unpaid') return `<span class="status-pill status-overdue"><span class="dot"></span>Unpaid</span>`;
    return `<span class="badge by">${status}</span>`;
}

// ── Load Students from API ────────────────────────────────────────
async function loadStudents() {
    try {
        const res  = await fetch('/Home/GetProfessorStudentPayments');
        const data = await res.json();
        if (!data.success) {
            showToast('Failed to load students.', 'fail');
            return;
        }

        allStudents = data.students.map(s => ({
            userId:          s.userId,
            schoolId:        s.schoolId,
            name:            s.name,
            courseCode:      s.courseCode,
            yearSection:     s.yearSection,
            totalPaid:       s.totalPaid,
            requiredAmount:  s.requiredAmount,
            status:          s.status,
            hasPaid:         s.hasPaid,
            lastPaymentDate: s.lastPaymentDate
        }));

        updateDashboardStats();
        renderStudentsTable();
        renderPaymentTable();
        renderCharts();
    } catch (err) {
        console.error('Failed to load students:', err);
        showToast('Failed to load students.', 'fail');
    }
}

// ── Dashboard Stats ───────────────────────────────────────────────
function updateDashboardStats() {
    const total   = allStudents.length;
    const paid    = allStudents.filter(s => s.status === 'Paid').length;
    const partial = allStudents.filter(s => s.status === 'Partial').length;
    const unpaid  = allStudents.filter(s => s.status === 'Unpaid').length;
    const pending = partial + unpaid;

    document.getElementById('s-total').textContent   = total;
    document.getElementById('s-paid').textContent    = paid;
    document.getElementById('s-pending').textContent = pending;
    document.getElementById('s-total-sub').textContent   = `${total} student${total !== 1 ? 's' : ''} enrolled`;
    document.getElementById('s-paid-sub').textContent    = `${total > 0 ? Math.round(paid/total*100) : 0}% collection rate`;
    document.getElementById('s-pending-sub').textContent = `${pending} student${pending !== 1 ? 's' : ''} yet to fully pay`;

    // Payment status page
    document.getElementById('ps-paid').textContent    = paid;
    document.getElementById('ps-partial').textContent = partial;
    document.getElementById('ps-unpaid').textContent  = unpaid;

    const pct = total > 0 ? Math.round(paid / total * 100) : 0;
    document.getElementById('ps-pct-badge').textContent  = pct + '%';
    document.getElementById('ps-progress').style.width   = pct + '%';
    document.getElementById('ps-prog-left').textContent  = `${paid} student${paid !== 1 ? 's' : ''} fully paid`;
    document.getElementById('ps-prog-right').textContent = `${pending} remaining`;
}

// ── Students Table ────────────────────────────────────────────────
function renderStudentsTable(filtered) {
    // The old "My Students" table was replaced by the treasurer-style Org Fee list.
    // Kept as a safe no-op so existing callers (loadStudents) don't break.
    const tbody = document.getElementById('students-tbody');
    if (!tbody) return;
    const data = filtered ?? allStudents;
    const sub = document.getElementById('students-sub');
    if (sub) sub.textContent = `${data.length} student${data.length !== 1 ? 's' : ''} in your class`;
    if (!data.length) {
        tbody.innerHTML = '<tr class="empty-row"><td colspan="6">No students found.</td></tr>';
        return;
    }
    tbody.innerHTML = data.map((s, i) => `
        <tr>
            <td class="td-mono td-m">${i + 1}</td>
            <td><strong>${s.name}</strong></td>
            <td class="td-mono td-m">${s.schoolId}</td>
            <td><span class="badge bg">${s.courseCode}</span></td>
            <td class="td-m">${s.yearSection}</td>
            <td>${statusBadge(s.status)}</td>
        </tr>
    `).join('');
}

function filterStudentsTable(q) {
    const filterEl = document.getElementById('students-status-filter');
    if (!filterEl) return;
    const statusFilter = filterEl.value.toLowerCase();
    const query = (q || '').toLowerCase().trim();
    const filtered = allStudents.filter(s => {
        const matchQ = !query
            || s.name.toLowerCase().includes(query)
            || s.schoolId.toLowerCase().includes(query)
            || s.courseCode.toLowerCase().includes(query)
            || s.yearSection.toLowerCase().includes(query);
        const matchStatus = !statusFilter || s.status.toLowerCase() === statusFilter;
        return matchQ && matchStatus;
    });
    renderStudentsTable(filtered);
}

// ── Payment Table ─────────────────────────────────────────────────
function renderPaymentTable(filtered) {
    const data  = filtered ?? allStudents;
    const tbody = document.getElementById('payment-tbody');
    if (!data.length) {
        tbody.innerHTML = '<tr class="empty-row"><td colspan="6">No records found.</td></tr>';
        return;
    }
    tbody.innerHTML = data.map((s, i) => `
        <tr>
            <td class="td-mono td-m">${i + 1}</td>
            <td><strong>${s.name}</strong></td>
            <td class="td-mono td-m">${s.schoolId}</td>
            <td class="td-m">${s.courseCode} ${s.yearSection}</td>
            <td class="td-mono" style="color:${s.totalPaid > 0 ? '#5fdd8e' : '#f87171'}">
                ₱${Number(s.totalPaid).toLocaleString('en-PH', { minimumFractionDigits: 2 })}
                ${s.requiredAmount > 0 ? `<span style="color:var(--text-d);font-size:10px"> / ₱${Number(s.requiredAmount).toLocaleString('en-PH', { minimumFractionDigits: 2 })}</span>` : ''}
            </td>
            <td>${statusBadge(s.status)}</td>
        </tr>
    `).join('');
}

function filterPaymentTable(q) {
    const query = (q || '').toLowerCase().trim();
    const filtered = allStudents.filter(s =>
        !query
        || s.name.toLowerCase().includes(query)
        || s.schoolId.toLowerCase().includes(query)
    );
    renderPaymentTable(filtered);
}

// ── Recent Activity ───────────────────────────────────────────────
async function renderRecentActivity() {
    const badge = document.getElementById('recent-badge');
    const tbody = document.getElementById('recent-tbody');

    try {
        const res  = await fetch('/Home/GetRecentPayments');
        const data = await res.json();

        console.log('GetRecentPayments response:', data);

        if (!data.success || !Array.isArray(data.payments) || !data.payments.length) {
            badge.textContent = '0 recent';
            tbody.innerHTML = '<tr class="empty-row"><td colspan="5">No recent payments found.</td></tr>';
            return;
        }

        badge.textContent = data.payments.length + ' recent';
        tbody.innerHTML = data.payments.map(p => `
            <tr>
                <td><strong>${p.studentName}</strong></td>
                <td class="td-mono td-m">${p.schoolId}</td>
                <td class="td-m">${p.courseCode} ${p.yearSection}</td>
                <td class="td-mono" style="color:#5fdd8e">+₱${Number(p.amount).toLocaleString('en-PH', { minimumFractionDigits: 2 })}</td>
                <td>${statusBadge(p.paymentStatus)}</td>
            </tr>
        `).join('');
    } catch (err) {
        console.error('Failed to load recent payments:', err);
        badge.textContent = 'Error';
        tbody.innerHTML = '<tr class="empty-row"><td colspan="5">Failed to load recent activity.</td></tr>';
    }
}

// ── Charts ────────────────────────────────────────────────────────
function renderCharts() {
    const paid    = allStudents.filter(s => s.status === 'Paid').length;
    const partial = allStudents.filter(s => s.status === 'Partial').length;
    const unpaid  = allStudents.filter(s => s.status === 'Unpaid').length;

    // Bar chart — group by section
    const sections = [...new Set(allStudents.map(s => s.yearSection))].sort();
    const sectionFilter = document.getElementById('chart-section-filter');
    const currentSections = Array.from(sectionFilter.options).map(o => o.value);
    sections.forEach(sec => {
        if (!currentSections.includes(sec)) {
            const opt = document.createElement('option');
            opt.value = sec; opt.textContent = sec;
            sectionFilter.appendChild(opt);
        }
    });
    updateBarChart();

    // Donut chart
    const dLabels  = ['Paid', 'Partial', 'Unpaid'];
    const dData    = [paid, partial, unpaid];
    const dColors  = ['rgba(39,167,68,.8)', 'rgba(139,92,246,.8)', 'rgba(239,68,68,.7)'];
    const valColors = ['#5fdd8e', '#c4b5fd', '#f87171'];

    if (donutChart) donutChart.destroy();
    donutChart = new Chart(document.getElementById('donutChart'), {
        type: 'doughnut',
        data: { labels: dLabels, datasets: [{ data: dData, backgroundColor: dColors, borderWidth: 0, hoverOffset: 4 }] },
        options: { responsive: true, cutout: '68%', plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ` ${ctx.parsed} students` } } } }
    });

    const total = paid + partial + unpaid;
    document.getElementById('donut-legend').innerHTML = dLabels.map((l, i) => `
        <div class="dl-row">
            <div class="dl-lbl"><div class="dl-dot" style="background:${dColors[i]}"></div>${l}</div>
            <div class="dl-val" style="color:${valColors[i]}">${total > 0 ? Math.round(dData[i]/total*100) : 0}% · ${dData[i]} students</div>
        </div>
    `).join('');
}

function updateBarChart() {
    const sectionVal = document.getElementById('chart-section-filter')?.value || 'all';
    const filtered = sectionVal === 'all' ? allStudents : allStudents.filter(s => s.yearSection === sectionVal);

    const sections = sectionVal === 'all'
        ? [...new Set(allStudents.map(s => s.yearSection))].sort()
        : [sectionVal];

    const paidData   = sections.map(sec => allStudents.filter(s => s.yearSection === sec && s.hasPaid).length);
    const unpaidData = sections.map(sec => allStudents.filter(s => s.yearSection === sec && !s.hasPaid).length);

    if (barChart) barChart.destroy();
    barChart = new Chart(document.getElementById('barChart'), {
        type: 'bar',
        data: {
            labels: sections.length ? sections : ['No Data'],
            datasets: [
                { label: 'Paid',    data: paidData,   backgroundColor: 'rgba(39,167,68,.75)',  borderRadius: 4, borderSkipped: false },
                { label: 'Pending', data: unpaidData,  backgroundColor: 'rgba(239,68,68,.65)', borderRadius: 4, borderSkipped: false }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { display: true, labels: { color: 'rgba(232,245,236,.5)', font: { size: 11 }, boxWidth: 10, padding: 12 } },
                tooltip: { callbacks: { label: ctx => ` ${ctx.parsed.y} students` } }
            },
            scales: {
                x: { grid: { display: false }, ticks: { color: 'rgba(232,245,236,.4)', font: { size: 10 } } },
                y: { grid: { color: 'rgba(255,255,255,.05)' }, ticks: { color: 'rgba(232,245,236,.4)', font: { size: 10 }, stepSize: 1 } }
            }
        }
    });
}

// ── Init ──────────────────────────────────────────────────────────
async function init() {
    await loadStudentsPage();
}

init();

// ================================================================
// AUTO-REFRESH POLLING
// Refreshes data every 10 seconds so professor sees live updates
// ================================================================

const PROF_REFRESH_INTERVAL = 10000; // 10 seconds

async function refreshCurrentProfPage() {
    const activePage = document.querySelector('.page.active');
    if (!activePage) return;
    const pageId = activePage.id.replace('page-', '');
    if (pageId === 'students') {
        await loadStudentsPage(document.getElementById('students-filter-sy')?.value || null);
    }
    // profile: nothing dynamic to refresh
}

setInterval(async () => {
    await refreshCurrentProfPage();
}, PROF_REFRESH_INTERVAL);

// ════════════════════════════════════════════════════════════════
// ORG FEE STUDENT LIST (shared treasurer-style module)
// ════════════════════════════════════════════════════════════════
let ALL_STUDENTS_PAGE = [];
let studentsPageQ = '';
let studentsPageCourse = '';
let _currentSem = null; // 'first' | 'second' | null (past school year)

// Resolve the live semester for the loaded school year from the API's
// per-fee flags (all rows share the same value, so the first row is enough).
function computeProfSemContext() {
  const s = ALL_STUDENTS_PAGE[0];
  _currentSem = s && s.firstSemIsCurrent ? 'first'
              : s && s.secondSemIsCurrent ? 'second'
              : null;
}

// Put a "Current" badge on whichever semester column is the live one. Only the
// real current semester gets the badge — past school years show none.
function updateSemHeaderIndicators() {
  const badge = '<span style="font-size:9px;font-weight:700;background:var(--green-glow);color:#5fdd8e;border:1px solid rgba(74,222,128,.3);border-radius:5px;padding:1px 6px;margin-left:6px;letter-spacing:.04em;text-transform:uppercase;vertical-align:middle">Current</span>';
  const b1 = document.getElementById('th-sem1-badge');
  const b2 = document.getElementById('th-sem2-badge');
  if (b1) b1.innerHTML = _currentSem === 'first'  ? badge : '';
  if (b2) b2.innerHTML = _currentSem === 'second' ? badge : '';
}

function escapeHtml(value) {
  return String(value ?? '').replace(/[&<>"']/g, ch => ({
    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
  }[ch]));
}

function feeStatusBadge(status) {
  const s = (status || 'Unpaid').toLowerCase();
  if (s === 'paid') return '<span class="badge bg">Paid</span>';
  if (s === 'partial') return '<span class="badge by">Partial</span>';
  if (s === 'n/a') return '<span class="badge" style="background:rgba(255,255,255,.06);color:var(--text-d)">N/A</span>';
  return '<span class="badge br">Unpaid</span>';
}

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function renderReceiptCell(paymentId, receiptNumber, hasReceipt) {
  if (!hasReceipt || !receiptNumber || receiptNumber === '—') {
    return '<span style="color:var(--text-d)">—</span>';
  }
  return `<span style="font-family:'DM Mono',monospace;font-size:10.5px;color:var(--text-m)">${escapeHtml(receiptNumber)}</span>`;
}

function renderCurrentFeesTable(currentSchoolYear, fees) {
  const list = Array.isArray(fees) ? fees : [];
  const rowsHtml = list.length
    ? list.map(f => {
        const semLabel = f.semester === 'First' ? '1st Semester'
                       : f.semester === 'Second' ? '2nd Semester'
                       : (f.semester || '—');
        const balColor = f.balance > 0 ? '#f87171' : '#5fdd8e';
        return `<tr>
          <td style="padding:9px 12px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text-m)">${escapeHtml(f.schoolYear || 'N/A')}</td>
          <td style="padding:9px 12px;color:var(--text)">${semLabel}</td>
          <td style="padding:9px 12px;font-family:'DM Mono',monospace;color:${balColor}">${p(f.balance)}</td>
          <td style="padding:9px 12px;font-family:'DM Mono',monospace;color:var(--text)">${p(f.requiredAmount)}</td>
          <td style="padding:9px 12px">${feeStatusBadge(f.feeStatus)}</td>
        </tr>`;
      }).join('')
    : `<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-d)">No applicable fees found.</td></tr>`;

  return `
    <div style="font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-d);margin-bottom:10px">Current Fees${currentSchoolYear ? ' · A.Y. ' + escapeHtml(currentSchoolYear) : ''}</div>
    <div style="border:1px solid rgba(255,255,255,.08);border-radius:10px;overflow:hidden">
      <table style="width:100%;border-collapse:collapse;font-size:12px">
        <thead>
          <tr style="background:rgba(255,255,255,.04)">
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">School Year</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Semester</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Balance</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Amount</th>
            <th style="padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-d);font-weight:600">Status</th>
          </tr>
        </thead>
        <tbody>${rowsHtml}</tbody>
      </table>
    </div>`;
}

async function loadStudentsPage(schoolYear = null) {
  const tbody = document.getElementById('students-page-tbody');
  if (tbody) tbody.innerHTML = '<tr class="empty-row"><td colspan="7">Loading students…</td></tr>';
  const sySel = document.getElementById('students-filter-sy');
  await initStudentsPageFilters();
  const selectedSY = schoolYear || sySel?.value || '';
  try {
    const url = selectedSY
      ? `/Home/GetTreasurerStudentsWithFees?schoolYear=${encodeURIComponent(selectedSY)}`
      : '/Home/GetTreasurerStudentsWithFees';
    const res = await fetch(url);
    const data = await res.json();
    if (!data.success) {
      if (tbody) tbody.innerHTML = `<tr class="empty-row"><td colspan="7">${escapeHtml(data.message || 'Failed to load students.')}</td></tr>`;
      return;
    }
    ALL_STUDENTS_PAGE = data.students || [];
    const sub = document.getElementById('students-page-sub');
    if (sub) sub.textContent = `${ALL_STUDENTS_PAGE.length} student${ALL_STUDENTS_PAGE.length !== 1 ? 's' : ''} · A.Y. ${data.schoolYear}`;
    computeProfSemContext();
    updateSemHeaderIndicators();
    populateStudentsPageFilters();
    applyStudentsPageFilters();
  } catch (err) {
    console.error('Failed to load students page:', err);
    if (tbody) tbody.innerHTML = '<tr class="empty-row"><td colspan="7">Failed to load students.</td></tr>';
  }
}

function renderStudentsPage(filtered) {
  const data = (filtered ?? ALL_STUDENTS_PAGE).slice()
    .sort((a, b) => String(a.name || '').localeCompare(String(b.name || ''), undefined, { sensitivity: 'base' }));
  const tbody = document.getElementById('students-page-tbody');
  if (!tbody) return;
  if (!data.length) {
    tbody.innerHTML = '<tr class="empty-row"><td colspan="7">No students found.</td></tr>';
    return;
  }
  // Read-only semester cell, matching the treasurer's clean single-line style:
  // "₱0.00 (paid)" when settled, otherwise the amount due. Professors cannot
  // record payments, so there is no Pay button.
  const profSemCell = (required, paid, status) => {
    const sl = (status || '').toLowerCase();
    if (sl === 'n/a' || ((required || 0) <= 0 && (paid || 0) <= 0))
      return '<span style="color:var(--text-d);font-size:11px">—</span>';
    if (sl === 'paid')
      return '<span style="font-family:\'DM Mono\',monospace;font-size:12px;color:#5fdd8e">₱0.00 <span style="color:var(--text-d)">(paid)</span></span>';
    const bal = Math.max(0, (required || 0) - (paid || 0));
    return `<span style="font-family:'DM Mono',monospace;font-size:12px;color:#f87171">₱${bal.toFixed(2)}</span>`;
  };

  tbody.innerHTML = data.map((s, i) => {
    const courseYr = `${escapeHtml(s.courseCode)} ${escapeHtml(s.yearSection)}`;
    const roleTag = s.role === 'Treasurer'
      ? ' <span style="font-size:10px;font-weight:600;background:rgba(249,115,22,.15);color:#fdba74;border:1px solid rgba(249,115,22,.25);border-radius:5px;padding:1px 7px;margin-left:6px;letter-spacing:.05em;text-transform:uppercase;vertical-align:middle">Treasurer</span>'
      : '';
    return `<tr>
      <td class="td-mono td-m">${i + 1}</td>
      <td class="td-mono td-m">${escapeHtml(s.schoolId)}</td>
      <td><strong>${escapeHtml(s.name)}</strong>${roleTag}</td>
      <td class="td-m">${courseYr}</td>
      <td>${profSemCell(s.firstSemRequired,  s.firstSemPaid,  s.firstSemStatus)}</td>
      <td>${profSemCell(s.secondSemRequired, s.secondSemPaid, s.secondSemStatus)}</td>
      <td>
        <button class="btn-outline" title="Ledger" aria-label="Ledger" style="padding:5px 7px;display:inline-flex;align-items:center;justify-content:center" onclick="openStudentOrgFeeModal(${s.userId})">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
      </td>
    </tr>`;
  }).join('');
}

function filterStudentsPage(q) {
  studentsPageQ = (q || '').toLowerCase().trim();
  applyStudentsPageFilters();
}

async function initStudentsPageFilters() {
  const sySel = document.getElementById('students-filter-sy');
  if (!sySel || sySel.dataset.listenerAttached) return;
  try {
    const res = await fetch('/Home/GetSchoolYears');
    const data = await res.json();
    if (!data.success) return;
    const currentSY = data.schoolYears.find(sy => sy.yearStatus === 'Current');
    sySel.innerHTML = data.schoolYears.map(sy =>
      `<option value="${sy.yearStart}–${sy.yearEnd}">${sy.yearStart}–${sy.yearEnd}</option>`
    ).join('') + '<option value="">All School Years</option>';
    if (currentSY) sySel.value = `${currentSY.yearStart}–${currentSY.yearEnd}`;
    sySel.dataset.currentSy = sySel.value;   // remember default SY for the Default button
    sySel.dataset.listenerAttached = 'true';
    sySel.addEventListener('change', () => loadStudentsPage(sySel.value));
  } catch {}
}

function populateStudentsPageFilters() {
  const courseSel = document.getElementById('students-filter-course');
  if (!courseSel) return;
  const courses = [...new Set(ALL_STUDENTS_PAGE.map(s => (s.courseCode || '').trim()).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: 'base' }));
  const prevCourse = courseSel.value;
  courseSel.innerHTML = '<option value="">All Courses</option>' +
    courses.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('');
  if (prevCourse) courseSel.value = prevCourse;
}

function applyStudentsPageFilters() {
  studentsPageCourse = document.getElementById('students-filter-course')?.value || '';
  const yearFilter   = document.getElementById('students-filter-year')?.value || '';
  const statusFilter = document.getElementById('students-filter-status')?.value || '';
  const filtered = ALL_STUDENTS_PAGE.filter(s => {
    const name = (s.name || '').toLowerCase();
    const schoolId = (s.schoolId || '').toLowerCase();
    const course = (s.courseCode || '').toLowerCase();
    const yearSection = (s.yearSection || '').toLowerCase();
    const matchesQ = !studentsPageQ
      || name.includes(studentsPageQ) || schoolId.includes(studentsPageQ)
      || course.includes(studentsPageQ) || yearSection.includes(studentsPageQ);
    const matchesCourse = !studentsPageCourse || (s.courseCode || '') === studentsPageCourse;
    // yearSection looks like "3-A" → the year level is the part before the dash.
    const studentYear = (s.yearSection || '').split('-')[0].trim();
    const matchesYear = !yearFilter || studentYear === yearFilter;
    // "Paid" requires BOTH semesters paid; "Partial"/"Unpaid" matches EITHER semester.
    let matchesStatus = true;
    if (statusFilter) {
      const s1 = (s.firstSemStatus || '').toLowerCase();
      const s2 = (s.secondSemStatus || '').toLowerCase();
      const f  = statusFilter.toLowerCase();
      matchesStatus = (f === 'paid') ? (s1 === 'paid' && s2 === 'paid') : (s1 === f || s2 === f);
    }
    return matchesQ && matchesCourse && matchesYear && matchesStatus;
  });
  renderStudentsPage(filtered);
}

// "Default" button: clear search + status + course + year, reset to the current
// school year, and reload the list.
function resetStudentsPageFilters() {
  studentsPageQ = '';
  const search = document.getElementById('students-search');
  if (search) search.value = '';
  ['students-filter-status', 'students-filter-course', 'students-filter-year'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  const sySel = document.getElementById('students-filter-sy');
  if (sySel && sySel.dataset.currentSy) sySel.value = sySel.dataset.currentSy;
  loadStudentsPage(sySel ? sySel.value : null);
}

async function openStudentOrgFeeModal(userId) {
  const nameEl = document.getElementById('student-orgfee-name');
  const subEl = document.getElementById('student-orgfee-sub');
  const tbody = document.getElementById('student-orgfee-tbody');

  nameEl.textContent = 'Ledger';
  subEl.textContent = 'Loading…';
  tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:24px;color:var(--text-d)">Loading…</td></tr>';
  openModal('modal-student-orgfee');

  try {
    const res = await fetch('/Home/GetStudentOrgFeeDetails?userId=' + encodeURIComponent(userId));
    const data = await res.json();
    if (!data.success) {
      subEl.textContent = data.message || 'Unable to load org fee details.';
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:24px;color:var(--text-d)">No data available.</td></tr>';
      return;
    }
    const s = data.student;
    nameEl.textContent = s.name;
    subEl.textContent = `${s.schoolId} · ${s.courseCode} ${s.yearSection}${s.role === 'Treasurer' ? ' · Treasurer' : ''}${data.schoolYear ? ' · A.Y. ' + data.schoolYear : ''}`;

    const fees = data.fees || [];
    const txs  = data.transactions || [];
    if (!fees.length && !txs.length) {
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:24px;color:var(--text-d)">No org fee records.</td></tr>';
      return;
    }

    // Group by (schoolYear, semester) from both fees and payments, so a current
    // semester with no payments still appears, and a paid prior semester shows too.
    const groupKey = (sy, sem) => `${sy || ''}|${sem || ''}`;
    const groups = new Map();
    fees.forEach(f => {
      const k = groupKey(f.schoolYear, f.semester);
      if (!groups.has(k)) groups.set(k, { schoolYear: f.schoolYear, semester: f.semester, fee: null, payments: [] });
      groups.get(k).fee = f;
    });
    txs.forEach(t => {
      const k = groupKey(t.schoolYear, t.semester);
      if (!groups.has(k)) groups.set(k, { schoolYear: t.schoolYear, semester: t.semester, fee: null, payments: [] });
    });
    groups.forEach(g => { g.payments = []; });
    txs.forEach(t => { groups.get(groupKey(t.schoolYear, t.semester)).payments.push(t); });

    // Current semester floats to the top, then newest year first (2nd sem before 1st).
    const sorted = [...groups.values()].sort((a, b) => {
      const aCur = a.fee && a.fee.isCurrent ? 1 : 0;
      const bCur = b.fee && b.fee.isCurrent ? 1 : 0;
      if (aCur !== bCur) return bCur - aCur;
      const sa = parseInt((a.schoolYear || '').split('–')[0], 10) || 0;
      const sb = parseInt((b.schoolYear || '').split('–')[0], 10) || 0;
      if (sa !== sb) return sb - sa;
      const semOrder = { 'First': 1, 'Second': 2 };
      return (semOrder[b.semester] || 0) - (semOrder[a.semester] || 0);
    });

    tbody.innerHTML = sorted.map((g, idx) => {
      const semLabel  = g.semester === 'First' ? '1st Semester' : g.semester === 'Second' ? '2nd Semester' : (g.semester || '—');
      const totalPaid = g.payments.reduce((sum, pay) => sum + (pay.amount || 0), 0);
      const required  = g.fee?.requiredAmount ?? null;
      const balance   = g.fee ? g.fee.balance : (required != null ? Math.max(0, required - totalPaid) : 0);
      let status;
      if (required != null && required <= 0) status = 'N/A';
      else if (totalPaid <= 0)               status = 'Unpaid';
      else if (balance <= 0)                 status = 'Paid';
      else                                   status = 'Partial';
      const dates = g.payments.map(pay => pay.date).filter(Boolean).sort();
      const latestDate = dates.length ? fd(dates[dates.length - 1]) : '—';
      return `<tr style="border-bottom:1px solid rgba(255,255,255,.04)">
        <td style="padding:10px 12px;color:var(--text-m);font-size:11px">${idx + 1}</td>
        <td style="padding:10px 12px;color:var(--text);font-weight:600">${semLabel}</td>
        <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text-m)">${escapeHtml(g.schoolYear || '—')}</td>
        <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:12px;color:${balance > 0 ? '#f87171' : '#5fdd8e'}">${p(balance)}</td>
        <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:12px;color:var(--text)">${p(totalPaid)}</td>
        <td style="padding:10px 12px">${feeStatusBadge(status)}</td>
        <td style="padding:10px 12px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text-m)">${latestDate}</td>
      </tr>`;
    }).join('');
  } catch (err) {
    console.error('Failed to load student org fee details:', err);
    subEl.textContent = 'Failed to load org fee details.';
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:24px;color:var(--text-d)">Request failed.</td></tr>';
  }
}

// Load the org-fee student list whenever the Students page is shown.
(function () {
  const origShowPage = window.showPage;
  window.showPage = function (name, navEl) {
    origShowPage(name, navEl);
    if (name === 'students') loadStudentsPage();
  };
})();

// ── SERVER-SENT EVENTS ───────────────────────────────────────────────
(function() {
    function connect() {
        const sse = new EventSource('/Home/Events');
        sse.addEventListener('accounts-changed',  () => {
            const p = document.querySelector('.page.active')?.id?.replace('page-','');
            if (p === 'students') loadStudentsPage();
        });
        sse.addEventListener('payments-changed', () => {
            const p = document.querySelector('.page.active')?.id?.replace('page-','');
            if (p === 'students') loadStudentsPage();
        });
        sse.onerror = () => { sse.close(); setTimeout(connect, 5000); };
    }
    connect();
})();
</script>

